# Production Dockerfile for UAR
FROM python:3.11-slim

# Set environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Create non-root user for security
RUN groupadd -r uar && useradd -r -g uar uar

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set work directory
WORKDIR /app

# Copy requirements first for better caching
COPY pyproject.toml ./
RUN python -m pip install --upgrade pip && \
    python -m pip install -e .

# Copy entrypoint script first
COPY scripts/docker-entrypoint.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Copy application code
COPY . .

# Create necessary directories
RUN mkdir -p /var/lib/uar/runs /var/log/uar && \
    chown -R uar:uar /var/lib/uar /var/log/uar /app

# Switch to non-root user
USER uar

# Health check (uses API_PORT env var, defaults to 8000)
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f "http://localhost:${API_PORT:-8000}/api/health" || exit 1

# Expose port
EXPOSE 8000

# Use entrypoint for validation
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# Start the application
CMD ["python", "-m", "uvicorn", "uar.api.server:app", "--host", "0.0.0.0", "--port", "8000"]
