# UAR Minimal Configuration
# Copy this file to .env for a quick start
# Only the essentials needed to run UAR

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Security - IMPORTANT: Change this in production!
SECRET_KEY=dev-secret-key-change-in-production

# API Keys (comma-separated, format: key:user:tier,key2:user2:tier2)
API_KEYS=dev_key:dev:admin

# Paths
PROJECT_ROOT=.

# SaaS Integrations (optional)
# CONVEX_URL=https://your-deployment.convex.cloud
# CONVEX_DEPLOYMENT=your-deployment
# GREPTILE_API_KEY=your-greptile-key
# GREPTILE_REPO=owner/repo

# Vercel (optional, for CLI deployments)
# VERCEL_TOKEN=your-vercel-token

# UOR Ecosystem (optional)
# UOR_FOUNDATION_API_URL=https://api.uor.foundation/v1
# HOLOGRAM_API_KEY=your-key
# MOLTBOOK_API_KEY=your-key

# That's it! Everything else has sensible defaults.
# For advanced options, see .env.example
