<https://uor.foundation/op/SD_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_6" ;
  rdfs:comment "SetType d_Δ invariant under element permutation, D_{2n} symmetry." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_SD_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_SD_6_rhs> ;
