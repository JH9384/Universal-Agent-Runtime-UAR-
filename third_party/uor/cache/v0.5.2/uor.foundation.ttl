  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_WLS_6_base" ;
  rdfs:comment "Base case for QLS_6 at Q0: the psi-pipeline produces a valid ChainComplex for 8-bit WittLifts by direct construction." ;
