<https://uor.foundation/op/psi_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "psi_3" ;
  rdfs:comment "ψ_3: ChainComplex → HomologyGroups (homology functor). Computes homology groups from a chain complex." ;
