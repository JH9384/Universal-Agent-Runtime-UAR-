<https://uor.foundation/op/NV_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "NV_4" ;
  rdfs:comment "Constraint accumulation monotonicity: β_k non-increasing under SR_1. Derives from SR_1." ;
