  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GO_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GO_1" ;
  rdfs:comment "GluingObstruction feedback: given a GluingObstruction class in H^1(N(C)), the killing RefinementSuggestion adds a constraint whose pinned sites contain the intersection of the cycle-generating pair." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GO_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GO_1_rhs> ;
