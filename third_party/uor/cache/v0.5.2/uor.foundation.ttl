<https://uor.foundation/op/SD_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_3" ;
  rdfs:comment "SequenceType = free monoid on element type with backbone constraint." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_SD_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_SD_3_rhs> ;
