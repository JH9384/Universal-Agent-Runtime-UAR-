  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/GR_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_3" ;
  rdfs:comment "Session convergence: a Session S converges iff there exists i such that freeRank(B_i) = 0." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GR_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/GR_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_4" ;
  rdfs:comment "Context reset isolation: bindings in C_fresh are independent of bindings in C_prior after a SessionBoundary." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GR_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/GR_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_5" ;
  rdfs:comment "Contradiction detection: ContradictionBoundary fires iff there exist bindings b, b' with the same address, different datum, under the same constraint." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GR_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/TS_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_1" ;
  rdfs:comment "Nerve realisability: for any target (χ*, β₀* = 1, β_k* = 0 for k ≥ 1) with χ* ≤ n, there exists a ConstrainedType T over R_n whose constraint nerve realises the target." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_2" ;
  rdfs:comment "Minimal basis bound: for the IT_7d target (χ* = n, all β* = 0), the MinimalConstraintBasis has size exactly n (one constraint per site position). No redundant constraints exist in the minimal basis." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_3" ;
  rdfs:comment "Synthesis monotonicity: adding a constraint to a synthesis candidate never decreases the Euler characteristic of the resulting nerve (χ is monotone non-decreasing under constraint addition)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_4" ;
  rdfs:comment "Synthesis convergence: the TypeSynthesisResolver terminates for any realisable target in at most n constraint additions (for n-site types)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_5" ;
  rdfs:comment "Synthesis–certification duality: a SynthesizedType T achieves the IT_7d target if and only if the CompletenessResolver certifies T as a CompleteType. The forward ψ-pipeline and the inverse TypeSynthesisResolver are dual computations." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_6" ;
  rdfs:comment "Jacobian-guided synthesis efficiency: using the Jacobian (DC_10) to select the next constraint reduces the expected number of synthesis steps from O(n²) (uninformed) to O(n log n) (Jacobian-guided)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/TS_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_7" ;
  rdfs:comment "Unreachable signatures: a Betti profile with β₀ = 0 is unreachable by any non-empty ConstrainedType — the nerve of a non-empty constraint set is always connected (β₀ ≥ 1)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/WLS_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_1" ;
  rdfs:comment "Lift unobstructedness criterion: WittLift T' is a CompleteType iff the spectral sequence E_r^{p,q} collapses at E_2 (d_2 = 0 and all higher differentials zero)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WLS_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_2" ;
  rdfs:comment "Obstruction localisation: a non-trivial LiftObstruction is localised to a specific site at bit position n+1. The obstruction class lives in H²(N(C(T))) and is killed by adding one constraint involving the new site." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WLS_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_3" ;
  rdfs:comment "Monotone lifting for trivially obstructed types: if T is a CompleteType at Q_n and its constraint set is closed under the Q_{n+1} extension map, then T' is a CompleteType at Q_{n+1} with basisSize(T') = basisSize(T) + 1." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WLS_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_4" ;
  rdfs:comment "Spectral sequence convergence bound: for constraint configurations of homological depth d (H_k(N(C(T))) = 0 for k > d), the spectral sequence converges by page E_{d+2}." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WLS_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_5" ;
  rdfs:comment "Universal identity preservation: every op:universallyValid identity holds in ℤ/(2^{n+1})ℤ with the lifted constraint set. The lift does not invalidate any certified universal identity." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WLS_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WLS_6" ;
  rdfs:comment "ψ-pipeline universality for quantum lifts: the ψ-pipeline produces a valid ChainComplex for any WittLift T' — the chain complex of T' restricts to the chain complex of T on the base nerve, and the extension is well-formed by construction." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WLS_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WLS_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WLS_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MN_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_1" ;
  rdfs:comment "Holonomy group containment: HolonomyGroup(T) ≤ D_{2^n} for all ConstrainedTypes T over R_n. The holonomy group is always a subgroup of the full dihedral group." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_2" ;
  rdfs:comment "Additive flatness (extends OB_H1): if all constraints in T are additive (ResidueConstraint or DepthConstraint type), then HolonomyGroup(T) = {id} — T is a FlatType." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_3" ;
  rdfs:comment "Dihedral generation: if T contains both a neg-related and a bnot-related constraint in a common closed path, then HolonomyGroup(T) = D_{2^n} — T has full dihedral holonomy." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_4" ;
  rdfs:comment "Holonomy-Betti implication: HolonomyGroup(T) ≠ {id} ⟹ β₁(N(C(T))) ≥ 1. Non-trivial monodromy requires a topological loop. (Converse is false: β₁ ≥ 1 does not imply non-trivial holonomy.)" ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_5" ;
  rdfs:comment "CompleteType holonomy: a CompleteType (IT_7d: χ = n, all β = 0) has trivial holonomy. IT_7d implies FlatType because IT_7d requires β₁ = 0, which by MN_4 implies trivial monodromy." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_6" ;
  rdfs:comment "Monodromy composition: if p₁ and p₂ are closed constraint paths, then monodromy(p₁ · p₂) = monodromy(p₁) · monodromy(p₂) in D_{2^n} (group homomorphism from loops to dihedral elements)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/MN_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MN_7" ;
  rdfs:comment "TwistedType obstruction class: the monodromy of a TwistedType contributes a non-zero class to H²(N(C(T')); ℤ/2ℤ) where T' is any WittLift of T. TwistedTypes always have non-trivial lift obstructions." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MN_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MN_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MN_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/PT_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PT_1" ;
  rdfs:comment "Product type site additivity: siteBudget(A × B) = siteBudget(A) + siteBudget(B)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PT_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PT_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/PT_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PT_2" ;
  rdfs:comment "Product type partition product: partition(A × B) = partition(A) ⊗ partition(B). v0.2.2 T1.3: grounds cert:PartitionCertificate — every PartitionCertificate attests the PartitionComponent classification (Irreducible / Reducible / Units / Exterior) derived from this partition-map identity." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PT_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PT_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/PT_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PT_3" ;
  rdfs:comment "Product type Euler additivity: χ(N(C(A × B))) = χ(N(C(A))) + χ(N(C(B)))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PT_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PT_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/PT_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PT_4" ;
  rdfs:comment "Product type entropy additivity: S(A × B) = S(A) + S(B)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PT_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PT_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Thermodynamic> .

<https://uor.foundation/op/ST_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_1" ;
  rdfs:comment "Sum type site budget: siteBudget(A + B) = max(siteBudget(A), siteBudget(B))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/ST_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_2" ;
  rdfs:comment "Sum type entropy: S(A + B) = ln 2 + max(S(A), S(B))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Thermodynamic> .

<https://uor.foundation/op/GS_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GS_1" ;
  rdfs:comment "Context temperature: T_ctx(C) = freeRank(C) × ln 2 / n." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GS_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GS_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GS_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Thermodynamic> .

<https://uor.foundation/op/GS_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GS_2" ;
  rdfs:comment "Grounding degree: σ(C) = (n − freeRank(C)) / n." ;
