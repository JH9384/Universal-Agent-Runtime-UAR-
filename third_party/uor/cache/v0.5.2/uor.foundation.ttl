  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_2" ;
  rdfs:comment "Per-lease binding monotonicity: within a leased sub-domain, freeRank decreases monotonically (SR_1 restricted to lease)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_3" ;
  rdfs:comment "General composition freeRank via inclusion-exclusion." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_4" ;
  rdfs:comment "Disjoint-lease composition is additive: the intersection term vanishes when leases are site-disjoint (SR_9)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_5" ;
  rdfs:comment "Policy-invariant final binding set: different execution policies produce identical SiteBinding records." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_6" ;
  rdfs:comment "Full lease coverage implies composed saturation: k sessions on disjoint covering leases, each locally converged, produce a GroundedContext via composition." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_7" ;
  rdfs:comment "Distributed O(1) resolution: a query against a composed GroundedContext resolves in zero steps." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/MC_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_8" ;
  rdfs:comment "Parallelism bound: per-session resolution work is bounded by lease size, not by total site count n." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_MC_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_1" ;
  rdfs:comment "Witt coordinate identification: the bit coordinates (x_0, …, x_[n−1]) of x ∈ Z/(2ⁿ)Z are exactly its Witt coordinates under the canonical isomorphism W_n(F_2) ≅ Z/(2ⁿ)Z." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_2" ;
  rdfs:comment "Witt sum correction equals carry: the k-th Witt addition polynomial correction term S_k − x_k − y_k (mod 2) is exactly the carry c_k(x,y)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_3" ;
  rdfs:comment "Carry recurrence is the Witt polynomial recurrence: CA_2 implements the ghost equation for S_[k+1] at p=2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_4" ;
  rdfs:comment "The δ-correction at level k equals the single-level carry c_[k+1](x,y). Each application of δ divides by 2, consuming one unit of 2-adic valuation." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_5" ;
  rdfs:comment "LiftObstruction is equivalent to δ-nonvanishing: a nontrivial LiftObstruction at Q_[k+1] means δ_k ≠ 0 for some element pair." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_6" ;
  rdfs:comment "Metric discrepancy equals Witt defect: d_Δ(x,y) > 0 iff the ghost map correction (carry) is nonzero." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_7" ;
  rdfs:comment "D_1 is the Witt truncation order relation: succ^[2ⁿ](x) = x is the group relation r^[2ⁿ] = 1 in the Witt-Burnside ring of D_[2∞]." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_8" ;
  rdfs:comment "D_3 is the Witt-Burnside conjugation relation: neg(succ(neg(x))) = pred(x) is srs = r⁻¹ in the pro-dihedral group." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_9>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_9" ;
  rdfs:comment "D_4 is a Witt-Burnside reflection composition: bnot(neg(x)) = pred(x) is the product of two reflections yielding inverse rotation." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_9_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_9_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_9_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_10>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_10" ;
  rdfs:comment "The δ-ring Frobenius lift on W_n(F_2) is the identity map because F_2 is a perfect field of characteristic 2 (a² = a for a ∈ F_2)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_10_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_10_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_10_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_11>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_11" ;
  rdfs:comment "The Verschiebung on W_n(F_2) is multiplication by 2: V(x) = 2x = add(x,x). This is a coordinate shift with zero Witt defect." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_11_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_11_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_11_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WC_12>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WC_12" ;
  rdfs:comment "The δ-operator on W_n(F_2) is the squaring defect divided by 2: δ(x) = (x − mul(x,x)) / 2. Expressible entirely in existing op/ primitives (sub, mul, arithmetic right shift)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WC_12_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WC_12_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WC_12_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/OA_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "OA_1" ;
  rdfs:comment "Ostrowski product formula at p=2: |2|_2 · |2|_∞ = 1. The 2-adic and Archimedean absolute values of 2 are multiplicative inverses." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_OA_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_OA_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_OA_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/ArithmeticValuation> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/OA_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "OA_2" ;
  rdfs:comment "Crossing cost equals ln 2: the Archimedean image of one unit of 2-adic valuation, under the product formula, is ln 2 nats." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_OA_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_OA_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_OA_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/ArithmeticValuation> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/OA_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "OA_3" ;
  rdfs:comment "QM_1 grounding: the Landauer cost β* = ln 2 is the crossing cost from OA_2, derived from the prime p=2 that structures the Witt tower." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_OA_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_OA_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_OA_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/ArithmeticValuation> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/OA_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "OA_4" ;
  rdfs:comment "Born rule bridge (conditional on amplitude rationality): P(outcome k) = |α_k|_∞², where |·|_∞ is the Archimedean image of the 2-adic amplitude via the product formula." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_OA_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_OA_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_OA_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/ArithmeticValuation> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/OA_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "OA_5" ;
  rdfs:comment "Entropy per delta-level equals the crossing cost: each application of the delta-operator (division by 2) costs ln 2 nats in the Archimedean completion, which is the per-bit Landauer cost. v0.2.2 Phase C.4: grounds MultiplicationCertificate." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_OA_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_OA_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_OA_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/ArithmeticValuation> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/HT_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "HT_1" ;
  rdfs:comment "KanComplex(N(C)) — the constraint nerve satisfies the Kan extension condition for all horns of dimension ≤ d where d is the maximum simplex dimension of N(C)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_HT_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_HT_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_HT_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/HT_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "HT_2" ;
  rdfs:comment "Path components of nerve recover β₀: π₀(N(C)) ≅ Z^{β₀} counts the connected components of the constraint configuration." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_HT_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_HT_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_HT_2_forAll> ;
