<https://uor.foundation/op/GR_10>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_10" ;
  rdfs:comment "ExecutionPolicy confluence: different execution policies on the same pending query set produce the same final resolved state (Church-Rosser for session resolution)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_10_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_10_rhs> ;
