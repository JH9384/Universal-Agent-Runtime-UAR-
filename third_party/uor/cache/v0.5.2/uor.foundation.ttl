  rdfs:comment "Every boundary effect touches at least one site." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_IO_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_IO_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_IO_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/IH_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "IH_1" ;
  rdfs:comment "Inhabitance soundness (bidirectional). For any type:ConstrainedType T, cert:InhabitanceCertificate(T) .verified is true iff the carrier of T is non-empty. Discharge: the verdict reified by cert:InhabitanceCertificate agrees with the denotational carrier-non-emptiness predicate, by direct unfolding of cert:verified against the predicate semantics." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_IH_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_IH_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_IH_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/IH_2a>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "IH_2a" ;
  rdfs:comment "Inhabitance cost (2-SAT restriction). For instances T satisfying predicate:Is2SatShape, the cost of resolver:TwoSatDecider on T is inherited from the classical 2-SAT decision procedure: O(n+m) where n is the variable count and m the clause count. Unrestricted IH_2 would be equivalent to P = NP and is not adopted." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_IH_2a_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_IH_2a_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_IH_2a_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/IH_2b>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "IH_2b" ;
  rdfs:comment "Inhabitance cost (Horn-SAT restriction). For instances T satisfying predicate:IsHornShape, the cost of resolver:HornSatDecider on T is inherited from the classical Horn-SAT decision procedure via unit propagation: O(n+m)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_IH_2b_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_IH_2b_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_IH_2b_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/IH_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "IH_3" ;
  rdfs:comment "Carrier preservation under basis reduction. The constraint-nerve reduction performed during inhabitance search preserves the carrier of the input ConstrainedType. Discharged against resolver:JacobianGuidedResolver and resolver:guidingJacobian vocabulary." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_IH_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_IH_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_IH_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

# Namespace: query
<https://uor.foundation/query/>
  a owl:Ontology ;
  rdfs:label "UOR Queries" ;
  rdfs:comment "Information extraction queries. Users initiate queries; the kernel resolves them against the ring substrate." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/u/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/state/> ;
.

<https://uor.foundation/query/Query>
  a owl:Class ;
  rdfs:label "Query" ;
  rdfs:comment "A request for information from the UOR kernel. The root abstraction for all query types." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/query/CoordinateQuery>
  a owl:Class ;
  rdfs:label "CoordinateQuery" ;
  rdfs:comment "A query for the ring-coordinate position of a datum: its stratum, spectrum, and address within the ring geometry." ;
  rdfs:subClassOf <https://uor.foundation/query/Query> ;
.

<https://uor.foundation/query/MetricQuery>
  a owl:Class ;
  rdfs:label "MetricQuery" ;
  rdfs:comment "A query for a metric value between two datums: ring distance, Hamming distance, or their divergence (curvature)." ;
  rdfs:subClassOf <https://uor.foundation/query/Query> ;
.

<https://uor.foundation/query/RepresentationQuery>
  a owl:Class ;
  rdfs:label "RepresentationQuery" ;
  rdfs:comment "A query for the canonical representation of a datum or term: its normal form under the active resolver strategy." ;
  rdfs:subClassOf <https://uor.foundation/query/Query> ;
.

<https://uor.foundation/query/RelationQuery>
  a owl:Class ;
  rdfs:label "RelationQuery" ;
  rdfs:comment "A Query with a known source address, a typed relation constraint, and an open target partition:FreeRank. Represents any question of the form: given this source symbol and relation type, what is the target? The relation type is read from the observable coordinate triple (d_R, d_H, d_I) — not externally supplied. Applies across NLP, ARC-AGI grids, music, images, sensor streams, and logical formulae." ;
  rdfs:subClassOf <https://uor.foundation/query/Query> ;
.

<https://uor.foundation/query/TriadProjection>
  a owl:Class ;
  rdfs:label "TriadProjection" ;
  rdfs:comment "A classification of coordinate types that a CoordinateQuery can extract. Each TriadProjection individual names a specific coordinate system (stratum, spectrum, address) replacing the string-valued query:coordinate property." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/query/SessionQuery>
  a owl:Class ;
  rdfs:label "SessionQuery" ;
  rdfs:comment "A RelationQuery that explicitly declares its session membership, allowing the conformance suite to validate session-scoped site reduction across multi-turn Prism deployments." ;
  rdfs:subClassOf <https://uor.foundation/query/RelationQuery> ;
.

<https://uor.foundation/query/inputType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inputType" ;
  rdfs:comment "The type of input the query accepts." ;
  rdfs:domain <https://uor.foundation/query/Query> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/query/outputType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "outputType" ;
  rdfs:comment "The type of output the query produces." ;
  rdfs:domain <https://uor.foundation/query/Query> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/query/hasTriadProjection>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "hasTriadProjection" ;
  rdfs:comment "The typed coordinate kind this query extracts. Replaces the string-valued query:coordinate property with a typed reference to a TriadProjection individual." ;
  rdfs:domain <https://uor.foundation/query/CoordinateQuery> ;
  rdfs:range <https://uor.foundation/query/TriadProjection> .

<https://uor.foundation/query/sourceAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceAddress" ;
  rdfs:comment "The ring address of the grounded source symbol." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/query/relationType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "relationType" ;
  rdfs:comment "The transformation type, expressed as a type:Conjunction composed from the primitive BoundConstraint basis. At inference time this is the output of an observable coordinate read on example pairs — computed from (d_R, d_H, d_I). Not an externally supplied input; read from the representation space." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/query/targetSite>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetSite" ;
  rdfs:comment "The open site budget for the unknown target. Begins fully free; closes to isClosed = true upon resolution." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/query/groundingMap>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingMap" ;
  rdfs:comment "The GroundingMap that resolved the source symbol to its ring address." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/morphism/GroundingMap> .

<https://uor.foundation/query/projectionMap>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "projectionMap" ;
  rdfs:comment "The ProjectionMap that will render the resolved address neighbourhood back to surface symbols." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/morphism/ProjectionMap> .

<https://uor.foundation/query/sessionContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sessionContext" ;
  rdfs:comment "Accumulated session state carrying all state:Binding instances produced by prior queries. Each binding records a resolved address, its datum, and the type under which it was resolved. Prior bindings monotonically reduce the free site space for subsequent queries." ;
  rdfs:domain <https://uor.foundation/query/RelationQuery> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/query/sessionMembership>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sessionMembership" ;
  rdfs:comment "The session this query belongs to." ;
  rdfs:domain <https://uor.foundation/query/SessionQuery> ;
  rdfs:range <https://uor.foundation/state/Session> .

<https://uor.foundation/query/TwoAdicValuation>
  a owl:NamedIndividual , <https://uor.foundation/query/TriadProjection> ;
  rdfs:label "TwoAdicValuation" ;
  rdfs:comment "The stratum coordinate: the layer position of a datum within the ring's stratification." .

<https://uor.foundation/query/WalshHadamardImage>
  a owl:NamedIndividual , <https://uor.foundation/query/TriadProjection> ;
  rdfs:label "WalshHadamardImage" ;
  rdfs:comment "The spectrum coordinate: the spectral decomposition of a datum under the ring's Fourier analysis." .

<https://uor.foundation/query/Address>
  a owl:NamedIndividual , <https://uor.foundation/query/TriadProjection> ;
  rdfs:label "Address" ;
  rdfs:comment "The address coordinate: the content-addressable position of a datum in the Braille glyph encoding. Renamed from RingElement in v0.2.2 W8 to unify vocabulary with the schema:Triad bundling properties." .

# Namespace: resolver
<https://uor.foundation/resolver/>
  a owl:Ontology ;
  rdfs:label "UOR Resolvers" ;
  rdfs:comment "Type resolution strategies implementing the partition map Π : T_n → Part(R_n). Resolvers transform type declarations into ring partitions." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/query/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/predicate/> ;
.

<https://uor.foundation/resolver/Resolver>
  a owl:Class ;
  rdfs:label "Resolver" ;
  rdfs:comment "A strategy for resolving a type declaration into a partition of the ring. The kernel dispatches to a specific resolver based on the type's structure." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/resolver/ResolutionState> ;
  owl:disjointWith <https://uor.foundation/resolver/RefinementSuggestion> ;
.

<https://uor.foundation/resolver/DihedralFactorizationResolver>
  a owl:Class ;
  rdfs:label "DihedralFactorizationResolver" ;
  rdfs:comment "Resolves types by factoring the ring under dihedral group action. Identifies orbits under D_{2^n} to determine irreducibility boundaries." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/CanonicalFormResolver>
  a owl:Class ;
  rdfs:label "CanonicalFormResolver" ;
  rdfs:comment "Resolves types by computing canonical forms via term rewriting. Applies the critical identity and normalization rules to reduce terms to unique canonical representatives." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/EvaluationResolver>
  a owl:Class ;
  rdfs:label "EvaluationResolver" ;
  rdfs:comment "Resolves types by direct evaluation: applies operations to enumerate ring elements and classify them as irreducible, reducible, unit, or exterior." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/ResolutionState>
  a owl:Class ;
  rdfs:label "ResolutionState" ;
  rdfs:comment "The current state of an iterative resolution: tracks how many iterations have been performed, whether the resolution is complete, and the current site deficit." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/resolver/Resolver> ;
  owl:disjointWith <https://uor.foundation/resolver/RefinementSuggestion> ;
.

<https://uor.foundation/resolver/RefinementSuggestion>
  a owl:Class ;
  rdfs:label "RefinementSuggestion" ;
  rdfs:comment "A suggestion from the resolver for how to refine an incomplete resolution: which metric axis to explore, which class to narrow to, and which sites to target." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/resolver/Resolver> ;
  owl:disjointWith <https://uor.foundation/resolver/ResolutionState> ;
.

<https://uor.foundation/resolver/ComplexityClass>
  a owl:Class ;
  rdfs:label "ComplexityClass" ;
  rdfs:comment "A computational complexity classification for resolvers. Each resolver's asymptotic runtime is typed as a named ComplexityClass individual rather than a free string." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/resolver/CechNerve>
  a owl:Class ;
  rdfs:label "CechNerve" ;
  rdfs:comment "The simplicial complex whose vertices are constraints and where a k-simplex exists iff the corresponding k+1 constraints have nonempty intersection. The nerve's topology governs resolution convergence: trivial homology ↔ smooth convergence, non-trivial homology ↔ potential stalls." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  rdfs:subClassOf <https://uor.foundation/homology/SimplicialComplex> ;
  rdfs:subClassOf <https://uor.foundation/homology/KanComplex> ;
.

<https://uor.foundation/resolver/CompletenessResolver>
  a owl:Class ;
  rdfs:label "CompletenessResolver" ;
  rdfs:comment "A specialisation of Resolver driving the completeness certification loop. Accepts a CompletenessCandidate, runs the ψ-pipeline (reading nerveEulerCharacteristic from ResolutionState), and either issues a CompletenessCertificate or produces a RefinementSuggestion." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/WittLevelResolver>
  a owl:Class ;
  rdfs:label "WittLevelResolver" ;
  rdfs:comment "A Resolver parameterised by quantum level. The same resolver strategy runs at any quantum level n ≥ 1 by substituting the appropriate R_n ring." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/SessionResolver>
  a owl:Class ;
  rdfs:label "SessionResolver" ;
  rdfs:comment "A Resolver that maintains a BindingAccumulator across multiple RelationQuery evaluations. The top-level resolver for multi-turn Prism deployments." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/TypeSynthesisResolver>
  a owl:Class ;
  rdfs:label "TypeSynthesisResolver" ;
  rdfs:comment "A Resolver that runs the ψ-pipeline in inverse mode. Accepts a TypeSynthesisGoal and returns a TypeSynthesisResult. Internally maintains a ConstraintSearchState tracking which constraint combinations have been explored and which Betti profiles they realise." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/ConstraintSearchState>
  a owl:Class ;
  rdfs:label "ConstraintSearchState" ;
  rdfs:comment "Internal resolver state tracking the boundary of explored constraint combinations during synthesis. Carries exploredCount, currentCandidate, and a link to the best SynthesisSignature achieved so far." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/resolver/IncrementalCompletenessResolver>
  a owl:Class ;
  rdfs:label "IncrementalCompletenessResolver" ;
  rdfs:comment "A Resolver that determines whether a CompleteType T at Q_n lifts to a CompleteType at Q_{n+1} without re-running the full ψ-pipeline from scratch. It computes the SpectralSequencePage sequence, reads the LiftObstruction, and either confirms the lift or returns a LiftRefinementSuggestion." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/LiftRefinementSuggestion>
  a owl:Class ;
  rdfs:label "LiftRefinementSuggestion" ;
  rdfs:comment "A RefinementSuggestion produced when a WittLift has a non-trivial LiftObstruction. Specialises RefinementSuggestion with liftSitePosition (the new bit position n+1) and obstructionClass." ;
  rdfs:subClassOf <https://uor.foundation/resolver/RefinementSuggestion> ;
.

<https://uor.foundation/resolver/MonodromyResolver>
  a owl:Class ;
  rdfs:label "MonodromyResolver" ;
  rdfs:comment "A Resolver that computes the HolonomyGroup of a ConstrainedType by enumerating closed paths in the constraint nerve and accumulating DihedralElement values. Outputs a MonodromyClass and classifies the type as FlatType or TwistedType." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/JacobianGuidedResolver>
  a owl:Class ;
  rdfs:label "JacobianGuidedResolver" ;
  rdfs:comment "A resolver that uses the Jacobian matrix to guide constraint selection, implementing DC_10: select the constraint that maximises total curvature reduction." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/SuperpositionResolver>
  a owl:Class ;
  rdfs:label "SuperpositionResolver" ;
  rdfs:comment "A resolver that handles superposed site states, computing amplitudes and determining when superposition collapses to a classical site assignment (Amendment 32)." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/GroundingAwareResolver>
  a owl:Class ;
  rdfs:label "GroundingAwareResolver" ;
  rdfs:comment "A resolver that exploits accumulated session bindings at full saturation (σ = 1) to provide O(1) resolution via direct coordinate reads (SC_5)." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/GeodesicValidator>
  a owl:Class ;
  rdfs:label "GeodesicValidator" ;
  rdfs:comment "A resolver that validates whether a ComputationTrace satisfies the dual geodesic condition (AR_1-ordered and DC_10-selected). Produces GeodesicViolation individuals on failure." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/MeasurementResolver>
  a owl:Class ;
  rdfs:label "MeasurementResolver" ;
  rdfs:comment "A resolver that handles projective collapse of SuperposedSiteState components. Issues MeasurementCertificate upon successful collapse with QM_1 verification." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/TowerCompletenessResolver>
  a owl:Class ;
  rdfs:label "TowerCompletenessResolver" ;
  rdfs:comment "A Resolver that constructs a LiftChain from liftSourceLevel to an arbitrary liftTargetLevel Q_k by iterating IncrementalCompletenessResolver step by step." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/InhabitanceResolver>
  a owl:Class ;
  rdfs:label "InhabitanceResolver" ;
  rdfs:comment "A Resolver whose dispatch is governed by a new predicate:InhabitanceDispatchTable. Returns either a cert:InhabitanceCertificate (verified true with witness) or a proof:InhabitanceImpossibilityWitness (verified false with contradiction proof). Inherits the dual-output termination discipline from resolver:TypeSynthesisResolver." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/TwoSatDecider>
  a owl:Class ;
  rdfs:label "TwoSatDecider" ;
  rdfs:comment "A Resolver target that decides carrier non-emptiness on ConstrainedType instances whose constraint nerve contains only disjunctions of width ≤ 2, via classical 2-SAT in O(n+m). Dispatch rule 1 of the InhabitanceDispatchTable." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/HornSatDecider>
  a owl:Class ;
  rdfs:label "HornSatDecider" ;
  rdfs:comment "A Resolver target that decides carrier non-emptiness on ConstrainedType instances whose disjunctions each contain at most one positive literal, via classical Horn-SAT unit propagation in O(n+m). Dispatch rule 2 of the InhabitanceDispatchTable." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/ResidualVerdictResolver>
  a owl:Class ;
  rdfs:label "ResidualVerdictResolver" ;
  rdfs:comment "A Resolver target for the catch-all default dispatch rule. Returns the residual-hard verdict without promising a polynomial bound; the verdict is well-formed but the cost identity is unbounded. Dispatch rule 3 of the InhabitanceDispatchTable ensuring total coverage (reduction:DispatchMiss is unreachable for this table)." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/MultiplicationResolver>
  a owl:Class ;
  rdfs:label "MultiplicationResolver" ;
  rdfs:comment "A Resolver target that decides the cost-optimal Toom-Cook splitting factor R for a Datum<L> × Datum<L> multiplication at a given call-site context (stack budget linear:stackBudgetBytes, const-eval regime). The decision procedure is a pure derivation over a closed-form Landauer cost function grounded in op:OA_5: for each admissible R, the cost is (2R - 1) · (N/R)² · 64 · ln 2 nats (R > 1) or N² · 64 · ln 2 nats (R = 1). The resolver picks the cost-minimum R subject to stack-budget and const-eval constraints and returns a cert:MultiplicationCertificate recording the choice." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/CertifyMapping>
  a owl:Class ;
  rdfs:label "CertifyMapping" ;
  rdfs:comment "An ontology fact recording that a resolver:Resolver subclass produces a specific cert:Certificate subclass on success and a specific proof:ImpossibilityWitness subclass on failure. The v0.2.1 Rust codegen reads CertifyMapping individuals to emit foundation::Certify trait impls for each resolver class, keeping the mapping data-driven rather than hand-tabulated in source." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/resolver/ExecutionPolicy>
  a owl:Class ;
  rdfs:label "ExecutionPolicy" ;
  rdfs:comment "A strategy class that defines how a SessionResolver orders pending RelationQuery instances for dispatch. The policy reads the targetSite.freeRank of each pending query and applies an ordering function." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/resolver/Resolver> ;
  owl:disjointWith <https://uor.foundation/resolver/ResolutionState> ;
  owl:disjointWith <https://uor.foundation/resolver/RefinementSuggestion> ;
.

<https://uor.foundation/resolver/ExecutionPolicyKind>
  a owl:Class ;
  rdfs:label "ExecutionPolicyKind" ;
  rdfs:comment "A typed controlled vocabulary for ExecutionPolicy individuals. Follows the SessionBoundaryType pattern: a single class with named individuals rather than a subclass hierarchy." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/resolver/HomotopyResolver>
  a owl:Class ;
  rdfs:label "HomotopyResolver" ;
  rdfs:comment "A resolver that runs the extended ψ-pipeline (ψ_7–ψ_9) to compute the full homotopy type of a CechNerve. Returns HomotopyGroup observables and PostnikovTruncation records." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/ModuliResolver>
  a owl:Class ;
  rdfs:label "ModuliResolver" ;
  rdfs:comment "A resolver that computes the local structure of the moduli space at a given CompleteType: constructs the DeformationComplex, determines the HolonomyStratum, and computes tangent/obstruction dimensions." ;
  rdfs:subClassOf <https://uor.foundation/resolver/Resolver> ;
.

<https://uor.foundation/resolver/inputType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inputType" ;
  rdfs:comment "The type of input this resolver accepts." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/resolver/outputType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "outputType" ;
  rdfs:comment "The type of output this resolver produces. For all UOR resolvers, the output is a partition:Partition." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/resolver/strategy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "strategy" ;
  rdfs:comment "A human-readable description of the resolution strategy this resolver implements." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/resolver/resolutionState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "resolutionState" ;
  rdfs:comment "The current resolution state of this resolver." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/resolver/ResolutionState> .

<https://uor.foundation/resolver/isComplete>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isComplete" ;
  rdfs:comment "Whether this resolution is complete: all sites are pinned and the partition is fully determined." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/resolver/iterationCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "iterationCount" ;
  rdfs:comment "The number of refinement iterations performed so far." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/resolver/siteDeficit>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "siteDeficit" ;
  rdfs:comment "The site budget showing the remaining unpinned sites. When all sites are pinned, the deficit is zero and resolution is complete." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/resolver/suggestion>
  a owl:ObjectProperty ;
  rdfs:label "suggestion" ;
  rdfs:comment "A refinement suggestion for advancing this resolution." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/resolver/RefinementSuggestion> .

<https://uor.foundation/resolver/suggestedAxis>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "suggestedAxis" ;
  rdfs:comment "The metric axis this suggestion recommends exploring." ;
  rdfs:domain <https://uor.foundation/resolver/RefinementSuggestion> ;
  rdfs:range <https://uor.foundation/type/MetricAxis> .

<https://uor.foundation/resolver/suggestedClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "suggestedClass" ;
  rdfs:comment "The constraint class this suggestion recommends applying." ;
  rdfs:domain <https://uor.foundation/resolver/RefinementSuggestion> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/resolver/targetSites>
  a owl:ObjectProperty ;
  rdfs:label "targetSites" ;
  rdfs:comment "The site coordinates this suggestion targets for pinning." ;
  rdfs:domain <https://uor.foundation/resolver/RefinementSuggestion> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/resolver/convergenceRate>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "convergenceRate" ;
  rdfs:comment "The rate at which sites are being pinned per iteration. A higher rate indicates faster convergence toward a complete resolution." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/resolver/hasComplexityClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "hasComplexityClass" ;
  rdfs:comment "The computational complexity class of this resolver. Replaces the string-valued resolver:complexity property." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/resolver/ComplexityClass> .

<https://uor.foundation/resolver/cechNerve>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "cechNerve" ;
  rdfs:comment "The constraint nerve associated with this resolution state." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/resolver/CechNerve> .

<https://uor.foundation/resolver/residualEntropy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "residualEntropy" ;
  rdfs:comment "The residual Shannon entropy of the resolution state: S = freeRank × ln 2. Measures remaining uncertainty." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/resolver/topologicallyComplete>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "topologicallyComplete" ;
  rdfs:comment "Whether all Betti numbers of the constraint nerve are zero, indicating no topological obstructions to resolution." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/resolver/nerveEulerCharacteristic>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "nerveEulerCharacteristic" ;
  rdfs:comment "The Euler characteristic χ(N(C)) of the active constraint nerve at this resolution state. IT_7d requires this value to equal n (the quantum level) for resolution to be complete. Cached here to avoid recomputing the full ψ pipeline on each iteration check." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/resolver/completenessTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "completenessTarget" ;
  rdfs:comment "The CompletenessCandidate this resolver is certifying." ;
  rdfs:domain <https://uor.foundation/resolver/CompletenessResolver> ;
  rdfs:range <https://uor.foundation/type/CompletenessCandidate> .

<https://uor.foundation/resolver/quantumLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "quantumLevel" ;
  rdfs:comment "The quantum level this resolver instance is configured for." ;
  rdfs:domain <https://uor.foundation/resolver/WittLevelResolver> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/resolver/sessionAccumulator>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sessionAccumulator" ;
  rdfs:comment "The BindingAccumulator this session resolver maintains across multiple RelationQuery evaluations." ;
  rdfs:domain <https://uor.foundation/resolver/SessionResolver> ;
  rdfs:range <https://uor.foundation/state/BindingAccumulator> .

<https://uor.foundation/resolver/synthesisGoal>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "synthesisGoal" ;
  rdfs:comment "The goal this type synthesis resolver is working to achieve." ;
  rdfs:domain <https://uor.foundation/resolver/TypeSynthesisResolver> ;
  rdfs:range <https://uor.foundation/type/TypeSynthesisGoal> .

<https://uor.foundation/resolver/exploredCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "exploredCount" ;
  rdfs:comment "Number of constraint combinations evaluated so far during synthesis." ;
  rdfs:domain <https://uor.foundation/resolver/ConstraintSearchState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/resolver/currentCandidate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "currentCandidate" ;
  rdfs:comment "The type candidate currently being evaluated during synthesis." ;
  rdfs:domain <https://uor.foundation/resolver/ConstraintSearchState> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/resolver/liftTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftTarget" ;
  rdfs:comment "The WittLift this incremental completeness resolver is evaluating." ;
  rdfs:domain <https://uor.foundation/resolver/IncrementalCompletenessResolver> ;
  rdfs:range <https://uor.foundation/type/WittLift> .

<https://uor.foundation/resolver/liftSitePosition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftSitePosition" ;
  rdfs:comment "The new site position at Q_{n+1} that the lift refinement suggestion targets." ;
  rdfs:domain <https://uor.foundation/resolver/LiftRefinementSuggestion> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/resolver/obstructionClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionClass" ;
  rdfs:comment "The obstruction class this lift refinement suggestion is designed to kill." ;
  rdfs:domain <https://uor.foundation/resolver/LiftRefinementSuggestion> ;
  rdfs:range <https://uor.foundation/observable/LiftObstructionClass> .

<https://uor.foundation/resolver/monodromyTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "monodromyTarget" ;
  rdfs:comment "The type whose holonomy this monodromy resolver is computing." ;
  rdfs:domain <https://uor.foundation/resolver/MonodromyResolver> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/resolver/holonomyResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "holonomyResult" ;
  rdfs:comment "The HolonomyGroup produced by this monodromy resolver run." ;
  rdfs:domain <https://uor.foundation/resolver/MonodromyResolver> ;
  rdfs:range <https://uor.foundation/observable/HolonomyGroup> .

<https://uor.foundation/resolver/guidingJacobian>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "guidingJacobian" ;
  rdfs:comment "The Jacobian observable guiding constraint selection at this resolution state (DC_10)." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/observable/Jacobian> .

<https://uor.foundation/resolver/usedGrounding>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "usedGrounding" ;
  rdfs:comment "Whether this resolver used the saturation shortcut (SC_5) to bypass the ψ-pipeline and return a direct coordinate read." ;
  rdfs:domain <https://uor.foundation/resolver/GroundingAwareResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/resolver/validateGeodesic>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "validateGeodesic" ;
  rdfs:comment "The GeodesicTrace being validated by this GeodesicValidator." ;
  rdfs:domain <https://uor.foundation/resolver/GeodesicValidator> ;
  rdfs:range <https://uor.foundation/trace/GeodesicTrace> .

<https://uor.foundation/resolver/collapseAmplitude>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "collapseAmplitude" ;
  rdfs:comment "The amplitude of the SuperposedSiteState prior to projective collapse by this MeasurementResolver." ;
  rdfs:domain <https://uor.foundation/resolver/MeasurementResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/resolver/collapsedSite>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "collapsedSite" ;
  rdfs:comment "The site index that was collapsed (pinned to a classical value) by the projective measurement." ;
  rdfs:domain <https://uor.foundation/resolver/MeasurementResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/resolver/measurementOutcome>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "measurementOutcome" ;
  rdfs:comment "The classical value obtained from the projective collapse. Either 0 or 1 for a single-site measurement." ;
  rdfs:domain <https://uor.foundation/resolver/MeasurementResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/resolver/amplitudeVector>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "amplitudeVector" ;
  rdfs:comment "The amplitude vector of all branches maintained by this SuperpositionResolver during ψ-pipeline traversal. Encoded as a comma-separated list of decimal amplitudes. Must satisfy Σ|αᵢ|² = 1 (QM_5) after normalization." ;
  rdfs:domain <https://uor.foundation/resolver/SuperpositionResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/resolver/priorAmplitudeVector>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "priorAmplitudeVector" ;
  rdfs:comment "The full vector of all branch amplitudes before projective collapse. Recorded by the MeasurementResolver to enable Born rule verification (QM_5): P(outcome k) = |α_k|²." ;
  rdfs:domain <https://uor.foundation/resolver/MeasurementResolver> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/resolver/towerSourceLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "towerSourceLevel" ;
  rdfs:comment "The level at which the tower starts." ;
  rdfs:domain <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/resolver/towerTargetLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "towerTargetLevel" ;
  rdfs:comment "The level to which the tower is being built." ;
  rdfs:domain <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/resolver/currentChain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "currentChain" ;
  rdfs:comment "The LiftChain under construction." ;
  rdfs:domain <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  rdfs:range <https://uor.foundation/type/LiftChain> .

<https://uor.foundation/resolver/towerStepResolver>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "towerStepResolver" ;
  rdfs:comment "The IncrementalCompletenessResolver used for each single-step lift." ;
  rdfs:domain <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  rdfs:range <https://uor.foundation/resolver/IncrementalCompletenessResolver> .

<https://uor.foundation/resolver/executionPolicy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "executionPolicy" ;
  rdfs:comment "The ordering strategy this resolver applies to pending queries. Defaults to FifoPolicy if unset." ;
  rdfs:domain <https://uor.foundation/resolver/SessionResolver> ;
  rdfs:range <https://uor.foundation/resolver/ExecutionPolicy> .

<https://uor.foundation/resolver/homotopyTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "homotopyTarget" ;
  rdfs:comment "The CechNerve whose homotopy type this resolver computes." ;
  rdfs:domain <https://uor.foundation/resolver/HomotopyResolver> ;
  rdfs:range <https://uor.foundation/resolver/CechNerve> .

<https://uor.foundation/resolver/homotopyResult>
  a owl:ObjectProperty ;
  rdfs:label "homotopyResult" ;
  rdfs:comment "A HomotopyGroup observable produced by this resolver." ;
  rdfs:domain <https://uor.foundation/resolver/HomotopyResolver> ;
  rdfs:range <https://uor.foundation/observable/HomotopyGroup> .

<https://uor.foundation/resolver/moduliTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "moduliTarget" ;
  rdfs:comment "The CompleteType whose local moduli structure this resolver computes." ;
  rdfs:domain <https://uor.foundation/resolver/ModuliResolver> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/resolver/moduliDeformation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "moduliDeformation" ;
  rdfs:comment "The DeformationComplex constructed by this resolver." ;
  rdfs:domain <https://uor.foundation/resolver/ModuliResolver> ;
  rdfs:range <https://uor.foundation/homology/DeformationComplex> .

<https://uor.foundation/resolver/dispatchTable>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchTable" ;
  rdfs:comment "The dispatch table governing resolver selection for this resolver class." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/predicate/DispatchTable> .

<https://uor.foundation/resolver/resolverPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "resolverPredicate" ;
  rdfs:comment "The predicate that selects this specific resolver. When the predicate evaluates to true on an input type, this resolver is chosen." ;
  rdfs:domain <https://uor.foundation/resolver/Resolver> ;
  rdfs:range <https://uor.foundation/predicate/TypePredicate> .

<https://uor.foundation/resolver/forResolver>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "forResolver" ;
  rdfs:comment "The resolver:Resolver subclass this CertifyMapping describes." ;
  rdfs:domain <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/resolver/producesCertificate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "producesCertificate" ;
  rdfs:comment "The cert:Certificate (or proof:ComputationCertificate) subclass this resolver produces on success." ;
  rdfs:domain <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/resolver/producesWitness>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "producesWitness" ;
  rdfs:comment "The proof:ImpossibilityWitness subclass this resolver produces on failure." ;
  rdfs:domain <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/resolver/ConstantTime>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ComplexityClass> ;
  rdfs:label "ConstantTime" ;
  rdfs:comment "O(1) complexity — the resolver runs in constant time regardless of ring size." .

<https://uor.foundation/resolver/LogarithmicTime>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ComplexityClass> ;
  rdfs:label "LogarithmicTime" ;
  rdfs:comment "O(log n) complexity — the resolver runs in logarithmic time in the quantum level." .

<https://uor.foundation/resolver/LinearTime>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ComplexityClass> ;
  rdfs:label "LinearTime" ;
  rdfs:comment "O(n) complexity — the resolver runs in time linear in the quantum level." .

<https://uor.foundation/resolver/ExponentialTime>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ComplexityClass> ;
  rdfs:label "ExponentialTime" ;
  rdfs:comment "O(2^n) complexity — the resolver runs in time exponential in the quantum level." .

<https://uor.foundation/resolver/FifoPolicy>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ExecutionPolicyKind> ;
  rdfs:label "FifoPolicy" ;
  rdfs:comment "Process queries in arrival order. The implicit pre-Amendment 48 behavior." .

<https://uor.foundation/resolver/MinFreeCountFirst>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ExecutionPolicyKind> ;
  rdfs:label "MinFreeCountFirst" ;
  rdfs:comment "Process the query with the smallest targetSite.freeRank first. Favors cheapest resolutions, accelerating early grounding gain." .

<https://uor.foundation/resolver/MaxFreeCountFirst>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ExecutionPolicyKind> ;
  rdfs:label "MaxFreeCountFirst" ;
  rdfs:comment "Process the query with the largest targetSite.freeRank first. Favors hardest resolutions, maximizing information gain per step." .

<https://uor.foundation/resolver/DisjointFirst>
  a owl:NamedIndividual , <https://uor.foundation/resolver/ExecutionPolicyKind> ;
  rdfs:label "DisjointFirst" ;
  rdfs:comment "Process queries whose targetSite is disjoint from all other pending queries' site sets first. Minimizes contention when operating against a SharedContext." .

<https://uor.foundation/resolver/towerCertifyMapping>
  a owl:NamedIndividual , <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:label "towerCertifyMapping" ;
  rdfs:comment "TowerCompletenessResolver produces LiftChainCertificate on success and ImpossibilityWitness on failure." ;
  <https://uor.foundation/resolver/forResolver> <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  <https://uor.foundation/resolver/producesCertificate> <https://uor.foundation/cert/LiftChainCertificate> ;
  <https://uor.foundation/resolver/producesWitness> <https://uor.foundation/proof/ImpossibilityWitness> .

<https://uor.foundation/resolver/incrementalCertifyMapping>
  a owl:NamedIndividual , <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:label "incrementalCertifyMapping" ;
  rdfs:comment "IncrementalCompletenessResolver produces LiftChainCertificate (single-step) on success and ImpossibilityWitness on failure." ;
  <https://uor.foundation/resolver/forResolver> <https://uor.foundation/resolver/IncrementalCompletenessResolver> ;
  <https://uor.foundation/resolver/producesCertificate> <https://uor.foundation/cert/LiftChainCertificate> ;
  <https://uor.foundation/resolver/producesWitness> <https://uor.foundation/proof/ImpossibilityWitness> .

<https://uor.foundation/resolver/groundingAwareCertifyMapping>
  a owl:NamedIndividual , <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:label "groundingAwareCertifyMapping" ;
  rdfs:comment "GroundingAwareResolver produces GroundingCertificate on success and ImpossibilityWitness on failure." ;
  <https://uor.foundation/resolver/forResolver> <https://uor.foundation/resolver/GroundingAwareResolver> ;
  <https://uor.foundation/resolver/producesCertificate> <https://uor.foundation/cert/GroundingCertificate> ;
  <https://uor.foundation/resolver/producesWitness> <https://uor.foundation/proof/ImpossibilityWitness> .

<https://uor.foundation/resolver/inhabitanceCertifyMapping>
  a owl:NamedIndividual , <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:label "inhabitanceCertifyMapping" ;
  rdfs:comment "InhabitanceResolver produces InhabitanceCertificate on success and InhabitanceImpossibilityWitness on failure." ;
  <https://uor.foundation/resolver/forResolver> <https://uor.foundation/resolver/InhabitanceResolver> ;
  <https://uor.foundation/resolver/producesCertificate> <https://uor.foundation/cert/InhabitanceCertificate> ;
  <https://uor.foundation/resolver/producesWitness> <https://uor.foundation/proof/InhabitanceImpossibilityWitness> .

<https://uor.foundation/resolver/multiplicationCertifyMapping>
  a owl:NamedIndividual , <https://uor.foundation/resolver/CertifyMapping> ;
  rdfs:label "multiplicationCertifyMapping" ;
  rdfs:comment "MultiplicationResolver produces MultiplicationCertificate on success and ImpossibilityWitness on failure. The resolver is total over admissible call-site contexts (stack_budget_bytes > 0), so failure is unreachable for well-formed inputs." ;
  <https://uor.foundation/resolver/forResolver> <https://uor.foundation/resolver/MultiplicationResolver> ;
  <https://uor.foundation/resolver/producesCertificate> <https://uor.foundation/cert/MultiplicationCertificate> ;
  <https://uor.foundation/resolver/producesWitness> <https://uor.foundation/proof/ImpossibilityWitness> .

# Namespace: type
<https://uor.foundation/type/>
  a owl:Ontology ;
  rdfs:label "UOR Type System" ;
  rdfs:comment "Runtime type declarations that parameterize the resolution pipeline. Types are declared by Prism applications and resolved to partitions of the ring." ;
  uor:space "user" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/u/> ;
  owl:imports <https://uor.foundation/op/> ;
.

<https://uor.foundation/type/TypeDefinition>
  a owl:Class ;
  rdfs:label "TypeDefinition" ;
  rdfs:comment "A runtime type declaration. The root class for all UOR types. Each TypeDefinition, when resolved, produces a partition of the ring at the specified quantum level." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/type/Constraint> ;
  owl:disjointWith <https://uor.foundation/type/MetricAxis> ;
.

<https://uor.foundation/type/PrimitiveType>
  a owl:Class ;
  rdfs:label "PrimitiveType" ;
  rdfs:comment "A primitive type defined by a fixed bit width. The carrier is the entire ring Z/(2^n)Z at the specified quantum level." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/ProductType>
  a owl:Class ;
  rdfs:label "ProductType" ;
  rdfs:comment "A product (Cartesian) type formed from multiple component types. The carrier is the product of the component carriers." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/SumType>
  a owl:Class ;
  rdfs:label "SumType" ;
  rdfs:comment "A sum (disjoint union) type formed from multiple variant types. The carrier is the disjoint union of the variant carriers." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/ConstrainedType>
  a owl:Class ;
  rdfs:label "ConstrainedType" ;
  rdfs:comment "A type formed by constraining a base type with a predicate. The carrier is the subset of the base carrier satisfying the constraint." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/Constraint>
  a owl:Class ;
  rdfs:label "Constraint" ;
  rdfs:comment "A composable predicate that refines a type by pinning one or more site coordinates. Constraints are the parameterization mechanism for ConstrainedType." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/type/TypeDefinition> ;
  owl:disjointWith <https://uor.foundation/type/MetricAxis> ;
.

<https://uor.foundation/type/MetricAxis>
  a owl:Class ;
  rdfs:label "MetricAxis" ;
  rdfs:comment "A classification axis for constraints by their geometric effect. The three axes — vertical (ring/additive), horizontal (Hamming/bitwise), diagonal (incompatibility) — form the tri-metric coordinate system of UOR." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/type/TypeDefinition> ;
  owl:disjointWith <https://uor.foundation/type/Constraint> ;
.

<https://uor.foundation/type/CompleteType>
  a owl:Class ;
  rdfs:label "CompleteType" ;
  rdfs:comment "A TypeDefinition certified to satisfy the UOR completeness criterion (IT_7d): its constraint nerve N(C) has Euler characteristic χ = n and all Betti numbers β_k = 0. A CompleteType guarantees that resolution closes the site budget in O(1) — no iterative refinement is required. Completeness is attested by a cert:CompletenessCertificate linked via cert:certifiedType. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/CompletenessCandidate>
  a owl:Class ;
  rdfs:label "CompletenessCandidate" ;
  rdfs:comment "A ConstrainedType actively undergoing the completeness certification pipeline. Links to the resolver:ResolutionState tracking the current iteration and to the resolver:CechNerve being computed. Disjoint from CompleteType (which is already certified). This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/ConstrainedType> ;
  owl:disjointWith <https://uor.foundation/type/CompleteType> ;
.

<https://uor.foundation/type/CompletenessWitness>
  a owl:Class ;
  rdfs:label "CompletenessWitness" ;
  rdfs:comment "A record of a single site-closing event: one constraint application that reduced the FreeRank deficit. Carries the applied constraint and the sitesClosed count. Forms the ordered audit trail between ConstrainedType and CompleteType." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/TypeSynthesisGoal>
  a owl:Class ;
  rdfs:label "TypeSynthesisGoal" ;
  rdfs:comment "A specification of the desired topological properties of a type to be synthesised. Carries a target Euler characteristic (targetEulerCharacteristic) and a target Betti profile (zero or more targetBettiNumber assertions). The minimal goal for O(1) resolution is: targetEulerCharacteristic = n and all targetBettiNumber = 0 — the IT_7d profile." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/TypeSynthesisResult>
  a owl:Class ;
  rdfs:label "TypeSynthesisResult" ;
  rdfs:comment "The output of a TypeSynthesisResolver run. Contains the SynthesizedType, the realised topological signature (as a SynthesisSignature), and the SynthesisTrace recording the construction steps." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/SynthesizedType>
  a owl:Class ;
  rdfs:label "SynthesizedType" ;
  rdfs:comment "A ConstrainedType produced by the TypeSynthesisResolver. Distinguished from a hand-authored ConstrainedType by the presence of a type:synthesisResult link. May or may not be a CompleteType, depending on the synthesis goal. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/ConstrainedType> ;
.

<https://uor.foundation/type/MinimalConstraintBasis>
  a owl:Class ;
  rdfs:label "MinimalConstraintBasis" ;
  rdfs:comment "The minimal set of constraints in the SynthesizedType's constraint set that is sufficient to realise the target topological signature. The minimality criterion is that removing any single member changes the realised signature." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/WittLift>
  a owl:Class ;
  rdfs:label "WittLift" ;
  rdfs:comment "A ConstrainedType T' over R_{n+1} obtained by extending a ConstrainedType T over R_n. Carries a link to the base type (liftBase), the quantum level it lifts to (liftTargetLevel), and the LiftObstruction (if the lift fails to transfer completeness). A WittLift is a CompleteType iff its LiftObstruction is trivial." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/LiftObstruction>
  a owl:Class ;
  rdfs:label "LiftObstruction" ;
  rdfs:comment "The algebraic obstruction to a WittLift inheriting the completeness of its base type. Computed as the image of the spectral sequence differential d_2. If trivial (zero), the base type's completeness lifts. If non-trivial, at least one additional constraint is needed at the new quantum level." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/TwistedType>
  a owl:Class ;
  rdfs:label "TwistedType" ;
  rdfs:comment "A ConstrainedType whose HolonomyGroup is non-trivial — at least one closed constraint path produces a non-identity dihedral element. A TwistedType may still be a CompleteType (IT_7d is a homological, not holonomic, criterion), but its resolution paths require tracking dihedral accumulation. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/ConstrainedType> ;
  owl:disjointWith <https://uor.foundation/type/FlatType> ;
.

<https://uor.foundation/type/FlatType>
  a owl:Class ;
  rdfs:label "FlatType" ;
  rdfs:comment "A ConstrainedType whose HolonomyGroup is trivial — all closed constraint paths have identity monodromy. The constraint configuration is topologically flat: resolution is path-independent. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/ConstrainedType> ;
  owl:disjointWith <https://uor.foundation/type/TwistedType> ;
.

<https://uor.foundation/type/SuperposedSiteState>
  a owl:Class ;
  rdfs:label "SuperposedSiteState" ;
  rdfs:comment "A type representing a superposition of site states where sites carry complex amplitudes rather than binary pinned/free assignments. Ontological realisation of RC_5 (Amendment 32). This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver." ;
  rdfs:subClassOf <https://uor.foundation/type/TypeDefinition> ;
.

<https://uor.foundation/type/ForbiddenSignature>
  a owl:Class ;
  rdfs:label "ForbiddenSignature" ;
  rdfs:comment "A topological signature (χ, β_k) that is formally impossible to achieve for any ConstrainedType. Witnessed by an ImpossibilityWitness in proof/." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/CollapsedSiteState>
  a owl:Class ;
  rdfs:label "CollapsedSiteState" ;
  rdfs:comment "A site state that has undergone projective collapse from a SuperposedSiteState to a definitive classical value. Topologically equivalent to a classically pinned site (QM_2)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/LiftChain>
  a owl:Class ;
  rdfs:label "LiftChain" ;
  rdfs:comment "An ordered composition of WittLift steps from liftSourceLevel (Q_j) to liftTargetLevel (Q_k) for any j < k. The canonical object certifying type completeness at arbitrary Q_k." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/ObstructionChain>
  a owl:Class ;
  rdfs:label "ObstructionChain" ;
  rdfs:comment "The complete ordered sequence of LiftObstruction records encountered and resolved along a LiftChain. An empty ObstructionChain means the tower is flat." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/ModuliSpace>
  a owl:Class ;
  rdfs:label "ModuliSpace" ;
  rdfs:comment "The space of all CompleteTypes over R_n at a given quantum level." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/HolonomyStratum>
  a owl:Class ;
  rdfs:label "HolonomyStratum" ;
  rdfs:comment "A stratum indexed by a conjugacy class of subgroups of D_{2^n}." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/DeformationFamily>
  a owl:Class ;
  rdfs:label "DeformationFamily" ;
  rdfs:comment "A one-parameter family of constraint configurations parameterizing a path." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/VersalDeformation>
  a owl:Class ;
  rdfs:label "VersalDeformation" ;
  rdfs:comment "The versal deformation of a CompleteType T." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/ModuliTowerMap>
  a owl:Class ;
  rdfs:label "ModuliTowerMap" ;
  rdfs:comment "The map induced by WittLift from one moduli space to the next." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/GaloisConnection>
  a owl:Class ;
  rdfs:label "GaloisConnection" ;
  rdfs:comment "The adjunction between the type lattice and the site lattice. The upper adjoint is type closure; the lower adjoint is site interior. σ = lower adjoint evaluation; r = complement of upper adjoint image." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/TypeInclusion>
  a owl:Class ;
  rdfs:label "TypeInclusion" ;
  rdfs:comment "A morphism T₁ → T₂ witnessing that T₁ is a subtype of T₂: the constraint set of T₁ is a superset of the constraint set of T₂." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
.

<https://uor.foundation/type/VarianceAnnotation>
  a owl:Class ;
  rdfs:label "VarianceAnnotation" ;
  rdfs:comment "The variance of a structural type position under operad composition. One of Covariant, Contravariant, Invariant, or Bivariant." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/SubtypingLattice>
  a owl:Class ;
  rdfs:label "SubtypingLattice" ;
  rdfs:comment "The partial order on types induced by TypeInclusion. The top element is PrimitiveType (no constraints); the bottom elements are CompleteTypes (all sites pinned)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/ConstraintDefaults>
  a owl:Class ;
  rdfs:label "ConstraintDefaults" ;
  rdfs:comment "Declarative defaults for type:Constraint subclasses, consumed by #[derive(ConstrainedType)] at macro-crate build time." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/BoundConstraint>
  a owl:Class ;
  rdfs:label "BoundConstraint" ;
  rdfs:comment "Parametric constraint carrier consumed by the codegen to emit `BoundConstraint<O: Observable, B: BoundShape>` in the Rust foundation. The (observable, bound_shape) pair picks the predicate form; the typed datatype properties (modulus, residue, hammingBound, ...) carry the parameters for that specific kind. Replaces the seven v0.2.1 enumerated Constraint subclasses with a parametric form; the legacy names survive as Rust type aliases (ResidueConstraint, HammingConstraint, ...)." ;
  rdfs:subClassOf <https://uor.foundation/type/Constraint> ;
.

<https://uor.foundation/type/BoundShape>
  a owl:Class ;
  rdfs:label "BoundShape" ;
  rdfs:comment "The predicate form a BoundConstraint imposes on its bound observable. Closed enumeration with exactly six named individuals (EqualBound, LessEqBound, GreaterEqBound, RangeContainBound, ResidueClassBound, AffineEqualBound). Adding a new bound shape is an ontology+grammar+codegen edit on the same protocol as adding a Witt level." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/type/Conjunction>
  a owl:Class ;
  rdfs:label "Conjunction" ;
  rdfs:comment "A conjunction of BoundConstraint instances. The conjuncts property is ordered. Replaces the v0.2.1 CompositeConstraint enumeration; the legacy name survives as a Rust type alias (CompositeConstraint<const N: usize> = Conjunction<N>)." ;
  rdfs:subClassOf <https://uor.foundation/type/Constraint> ;
.

<https://uor.foundation/type/bitWidth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bitWidth" ;
  rdfs:comment "The bit width of a primitive type (the quantum level n). The carrier is Z/(2^n)Z." ;
  rdfs:domain <https://uor.foundation/type/PrimitiveType> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/type/component>
  a owl:ObjectProperty ;
  rdfs:label "component" ;
  rdfs:comment "A component type in a product type." ;
  rdfs:domain <https://uor.foundation/type/ProductType> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/type/variant>
  a owl:ObjectProperty ;
  rdfs:label "variant" ;
  rdfs:comment "A variant type in a sum type. Ordering contract: variants are returned in canonical content-fingerprint order (ascending), matching the canonicalization used by coproduct_shape! and the content-address hashing pipeline, so introspection via variant() and the algebra_id derived from the same type agree on which variant is 'left' and which is 'right'. Author-order is not preserved." ;
  rdfs:domain <https://uor.foundation/type/SumType> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/type/tagSite>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "tagSite" ;
  rdfs:comment "The tag site distinguishing variants of this sum type at runtime (ST_6). Stored at the physical layout position max(SITE_COUNT(A), SITE_COUNT(B)) so the tag cannot collide with any inherited bookkeeping site when either operand is itself a coproduct." ;
  rdfs:domain <https://uor.foundation/type/SumType> ;
  rdfs:range <https://uor.foundation/partition/TagSite> .

<https://uor.foundation/type/baseType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "baseType" ;
  rdfs:comment "The base type that a constrained type restricts." ;
  rdfs:domain <https://uor.foundation/type/ConstrainedType> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/type/contentAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "contentAddress" ;
  rdfs:comment "The content-derived address of this type definition, uniquely identifying the type in the UOR address space." ;
  rdfs:domain <https://uor.foundation/type/TypeDefinition> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/type/hasConstraint>
  a owl:ObjectProperty ;
  rdfs:label "hasConstraint" ;
  rdfs:comment "A typed constraint object applied to this constrained type. Replaces the deprecated string-based type:constraint property." ;
  rdfs:domain <https://uor.foundation/type/ConstrainedType> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/type/modulus>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "modulus" ;
  rdfs:comment "The modulus m of a residue constraint: x ≡ r (mod m)." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/type/residue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "residue" ;
  rdfs:comment "The residue value r of a residue constraint: x ≡ r (mod m)." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/carryPattern>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "carryPattern" ;
  rdfs:comment "The carry propagation pattern of a carry constraint, expressed as a Datum at the appropriate quantum level." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/type/minDepth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "minDepth" ;
  rdfs:comment "The minimum factorization depth required by a depth constraint." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/maxDepth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxDepth" ;
  rdfs:comment "The maximum factorization depth allowed by a depth constraint." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/composedFrom>
  a owl:ObjectProperty ;
  rdfs:label "composedFrom" ;
  rdfs:comment "A component constraint of this composite constraint." ;
  rdfs:domain <https://uor.foundation/type/Conjunction> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/type/hammingBound>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hammingBound" ;
  rdfs:comment "Upper bound on the Hamming weight of the Datum." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/siteIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "siteIndex" ;
  rdfs:comment "Zero-based index of the pinned site coordinate." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/siteValue>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "siteValue" ;
  rdfs:comment "The value the pinned site coordinate must equal (a Datum in the set {0, 1})." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/type/affineOffset>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "affineOffset" ;
  rdfs:comment "Constant offset defining the affine subspace." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/type/affineGenerator>
  a owl:ObjectProperty ;
  rdfs:label "affineGenerator" ;
  rdfs:comment "A generator of the affine subspace. Non-functional: multiple generators span the subspace." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/type/metricAxis>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricAxis" ;
  rdfs:comment "The metric axis along which this constraint operates: vertical (ring), horizontal (Hamming), or diagonal (incompatibility)." ;
  rdfs:domain <https://uor.foundation/type/Constraint> ;
  rdfs:range <https://uor.foundation/type/MetricAxis> .

<https://uor.foundation/type/pinsSites>
  a owl:ObjectProperty ;
  rdfs:label "pinsSites" ;
  rdfs:comment "A site coordinate that this constraint pins when applied." ;
  rdfs:domain <https://uor.foundation/type/Constraint> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/type/affectsAxis>
  a owl:ObjectProperty ;
  rdfs:label "affectsAxis" ;
  rdfs:comment "The metric axis that this operation affects. Replaces the string-valued type:axisSignature property with a typed reference to MetricAxis individuals. Non-functional: an operation may affect multiple axes." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <https://uor.foundation/type/MetricAxis> .

<https://uor.foundation/type/crossingCost>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "crossingCost" ;
  rdfs:comment "The cost of applying this constraint in terms of axis crossings: the number of metric boundaries that must be traversed." ;
  rdfs:domain <https://uor.foundation/type/Constraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/completenessCandidate>
  a owl:ObjectProperty ;
  rdfs:label "completenessCandidate" ;
  rdfs:comment "The ConstrainedType being evaluated for completeness by this CompletenessCandidate." ;
  rdfs:domain <https://uor.foundation/type/CompletenessCandidate> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/type/candidateNerve>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "candidateNerve" ;
  rdfs:comment "The constraint nerve being computed for this candidate. The CompletenessResolver reads χ(N(C)) from this nerve at each iteration via resolver:nerveEulerCharacteristic." ;
  rdfs:domain <https://uor.foundation/type/CompletenessCandidate> ;
  rdfs:range <https://uor.foundation/resolver/CechNerve> .

<https://uor.foundation/type/witnessConstraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "witnessConstraint" ;
  rdfs:comment "The constraint applied in this witness step." ;
  rdfs:domain <https://uor.foundation/type/CompletenessWitness> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/type/sitesClosed>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitesClosed" ;
  rdfs:comment "Number of sites closed by this witness step." ;
  rdfs:domain <https://uor.foundation/type/CompletenessWitness> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/targetEulerCharacteristic>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetEulerCharacteristic" ;
  rdfs:comment "The target χ(N(C)) value. For O(1) resolution: set equal to n (the quantum level)." ;
  rdfs:domain <https://uor.foundation/type/TypeSynthesisGoal> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/type/targetBettiNumber>
  a owl:DatatypeProperty ;
  rdfs:label "targetBettiNumber" ;
  rdfs:comment "Non-functional. Each assertion specifies a target Betti number value for a given homological degree. Multiple assertions permitted, one per degree." ;
  rdfs:domain <https://uor.foundation/type/TypeSynthesisGoal> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/synthesisResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "synthesisResult" ;
  rdfs:comment "Links a SynthesizedType back to the synthesis run that produced it." ;
  rdfs:domain <https://uor.foundation/type/SynthesizedType> ;
  rdfs:range <https://uor.foundation/type/TypeSynthesisResult> .

<https://uor.foundation/type/basisConstraint>
  a owl:ObjectProperty ;
  rdfs:label "basisConstraint" ;
  rdfs:comment "Non-functional. One assertion per constraint in the minimal basis." ;
  rdfs:domain <https://uor.foundation/type/MinimalConstraintBasis> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/type/basisSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "basisSize" ;
  rdfs:comment "The cardinality of the minimal basis. The theoretical lower bound is n (one constraint per site)." ;
  rdfs:domain <https://uor.foundation/type/MinimalConstraintBasis> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/liftBase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftBase" ;
  rdfs:comment "The base type being lifted to the next quantum level." ;
  rdfs:domain <https://uor.foundation/type/WittLift> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/type/liftTargetLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftTargetLevel" ;
  rdfs:comment "The quantum level this lift targets." ;
  rdfs:domain <https://uor.foundation/type/WittLift> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/type/liftObstruction>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftObstruction" ;
  rdfs:comment "The LiftObstruction for this lift. Trivial (zero class) iff the lift inherits completeness." ;
  rdfs:domain <https://uor.foundation/type/WittLift> ;
  rdfs:range <https://uor.foundation/type/LiftObstruction> .

<https://uor.foundation/type/obstructionTrivial>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionTrivial" ;
  rdfs:comment "True iff the obstruction class is zero — the base type's completeness transfers to the lifted quantum level without additional constraints." ;
  rdfs:domain <https://uor.foundation/type/LiftObstruction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/obstructionSite>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionSite" ;
  rdfs:comment "The site at the new quantum level where the obstruction is located. Ranges over the new bit position introduced at Q_{n+1}." ;
  rdfs:domain <https://uor.foundation/type/LiftObstruction> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/type/holonomyGroup>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "holonomyGroup" ;
  rdfs:comment "The HolonomyGroup of this type. Computed by the MonodromyResolver." ;
  rdfs:domain <https://uor.foundation/type/ConstrainedType> ;
  rdfs:range <https://uor.foundation/observable/HolonomyGroup> .

<https://uor.foundation/type/monodromyClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "monodromyClass" ;
  rdfs:comment "The MonodromyClass classifying this type as flat or twisted." ;
  rdfs:domain <https://uor.foundation/type/ConstrainedType> ;
  rdfs:range <https://uor.foundation/observable/MonodromyClass> .

<https://uor.foundation/type/amplitude>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "amplitude" ;
  rdfs:comment "The amplitude coefficient for this superposed site state." ;
  rdfs:domain <https://uor.foundation/type/SuperposedSiteState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/type/targetForbidden>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetForbidden" ;
  rdfs:comment "Whether the target signature of this TypeSynthesisGoal is a ForbiddenSignature. If true, synthesis is provably impossible." ;
  rdfs:domain <https://uor.foundation/type/TypeSynthesisGoal> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/collapsedFrom>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "collapsedFrom" ;
  rdfs:comment "The SuperposedSiteState from which this CollapsedSiteState was produced by projective measurement." ;
  rdfs:domain <https://uor.foundation/type/CollapsedSiteState> ;
  rdfs:range <https://uor.foundation/type/SuperposedSiteState> .

<https://uor.foundation/type/survivingAmplitude>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "survivingAmplitude" ;
  rdfs:comment "The amplitude of the surviving branch after projective collapse. |α|² is the probability of this outcome under the Born rule." ;
  rdfs:domain <https://uor.foundation/type/CollapsedSiteState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/type/normalizationVerified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "normalizationVerified" ;
  rdfs:comment "Whether the amplitude vector of this SuperposedSiteState satisfies the normalization condition Σ|αᵢ|² = 1 (QM_5). Set by the SuperpositionResolver after verification." ;
  rdfs:domain <https://uor.foundation/type/SuperposedSiteState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/holonomyClassified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "holonomyClassified" ;
  rdfs:comment "Whether this ConstrainedType has been classified as FlatType or TwistedType by the MonodromyResolver. The MN_8 identity guarantees this is a bivalent classification: holonomyClassified(T) iff isFlatType(T) xor isTwistedType(T)." ;
  rdfs:domain <https://uor.foundation/type/ConstrainedType> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/liftSourceLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "liftSourceLevel" ;
  rdfs:comment "The quantum level at the base of the chain." ;
  rdfs:domain <https://uor.foundation/type/LiftChain> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/type/chainLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "chainLength" ;
  rdfs:comment "The number of WittLift steps in the chain (k - j)." ;
  rdfs:domain <https://uor.foundation/type/LiftChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/chainStep>
  a owl:ObjectProperty ;
  rdfs:label "chainStep" ;
  rdfs:comment "A WittLift step in this chain. Non-functional: one per step." ;
  rdfs:domain <https://uor.foundation/type/LiftChain> ;
  rdfs:range <https://uor.foundation/type/WittLift> .

<https://uor.foundation/type/chainObstructionProfile>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "chainObstructionProfile" ;
  rdfs:comment "The full obstruction history of this chain." ;
  rdfs:domain <https://uor.foundation/type/LiftChain> ;
  rdfs:range <https://uor.foundation/type/ObstructionChain> .

<https://uor.foundation/type/resolvedBasisSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "resolvedBasisSize" ;
  rdfs:comment "The basis size of the CompleteType at the chain target level." ;
  rdfs:domain <https://uor.foundation/type/LiftChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/obstructionAt>
  a owl:ObjectProperty ;
  rdfs:label "obstructionAt" ;
  rdfs:comment "A non-trivial LiftObstruction in this chain. Non-functional." ;
  rdfs:domain <https://uor.foundation/type/ObstructionChain> ;
  rdfs:range <https://uor.foundation/type/LiftObstruction> .

<https://uor.foundation/type/obstructionCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionCount" ;
  rdfs:comment "Total number of non-trivial LiftObstruction records." ;
  rdfs:domain <https://uor.foundation/type/ObstructionChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/isFlat>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isFlat" ;
  rdfs:comment "True iff obstructionCount = 0 (flat tower)." ;
  rdfs:domain <https://uor.foundation/type/ObstructionChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/moduliWittLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "moduliWittLevel" ;
  rdfs:comment "The quantum level at which this moduli space is defined." ;
  rdfs:domain <https://uor.foundation/type/ModuliSpace> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/type/moduliPoint>
  a owl:ObjectProperty ;
  rdfs:label "moduliPoint" ;
  rdfs:comment "A CompleteType that is a point of this moduli space." ;
  rdfs:domain <https://uor.foundation/type/ModuliSpace> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/type/moduliDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "moduliDimension" ;
  rdfs:comment "The dimension of this moduli space." ;
  rdfs:domain <https://uor.foundation/type/ModuliSpace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/stratumHolonomyClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stratumHolonomyClass" ;
  rdfs:comment "The MonodromyClass indexing this stratum." ;
  rdfs:domain <https://uor.foundation/type/HolonomyStratum> ;
  rdfs:range <https://uor.foundation/observable/MonodromyClass> .

<https://uor.foundation/type/stratumCodimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stratumCodimension" ;
  rdfs:comment "The codimension of this stratum within the moduli space." ;
  rdfs:domain <https://uor.foundation/type/HolonomyStratum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/stratumModuli>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stratumModuli" ;
  rdfs:comment "The moduli space containing this stratum." ;
  rdfs:domain <https://uor.foundation/type/HolonomyStratum> ;
  rdfs:range <https://uor.foundation/type/ModuliSpace> .

<https://uor.foundation/type/familyParameter>
  a owl:ObjectProperty ;
  rdfs:label "familyParameter" ;
  rdfs:comment "A CompleteType along the deformation path." ;
  rdfs:domain <https://uor.foundation/type/DeformationFamily> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/type/familyPreservesCompleteness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "familyPreservesCompleteness" ;
  rdfs:comment "Whether every member of this deformation family remains a CompleteType." ;
  rdfs:domain <https://uor.foundation/type/DeformationFamily> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/versalBase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "versalBase" ;
  rdfs:comment "The CompleteType at the base of this versal deformation." ;
  rdfs:domain <https://uor.foundation/type/VersalDeformation> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/type/versalDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "versalDimension" ;
  rdfs:comment "The dimension of the versal deformation space." ;
  rdfs:domain <https://uor.foundation/type/VersalDeformation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/towerMapSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "towerMapSource" ;
  rdfs:comment "The source moduli space of this tower map." ;
  rdfs:domain <https://uor.foundation/type/ModuliTowerMap> ;
  rdfs:range <https://uor.foundation/type/ModuliSpace> .

<https://uor.foundation/type/upperAdjoint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "upperAdjoint" ;
  rdfs:comment "The upper adjoint (type closure) of the Galois connection, expressed as a symbolic formula string." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/lowerAdjoint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "lowerAdjoint" ;
  rdfs:comment "The lower adjoint (site interior) of the Galois connection, expressed as a symbolic formula string." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/fixpointCondition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "fixpointCondition" ;
  rdfs:comment "The fixpoint condition for the Galois connection: when upper(lower(T)) = T, the type is complete." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/refinementDirection>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "refinementDirection" ;
  rdfs:comment "Description of the refinement direction: ascending in type lattice corresponds to descending in site freedom." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/structuralSiteCount>
  a owl:AnnotationProperty ;
  rdfs:label "structuralSiteCount" ;
  rdfs:comment "Formula or description of the site count for a structural type individual." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/type/structuralGrounding>
  a owl:AnnotationProperty ;
  rdfs:label "structuralGrounding" ;
  rdfs:comment "Description of the grounding rule that maps values of this structural type onto the UOR ring." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/type/structuralConstraint>
  a owl:AnnotationProperty ;
  rdfs:label "structuralConstraint" ;
  rdfs:comment "Description of the constraint characterizing this structural type, if applicable." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/type/galoisClosureProperty>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "galoisClosureProperty" ;
  rdfs:comment "The closure property of a Galois connection." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/galoisInteriorProperty>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "galoisInteriorProperty" ;
  rdfs:comment "The interior property of a Galois connection." ;
  rdfs:domain <https://uor.foundation/type/GaloisConnection> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/groundingMapRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingMapRef" ;
  rdfs:comment "Reference to the grounding map used for this type." ;
  rdfs:range <https://uor.foundation/morphism/GroundingMap> .

<https://uor.foundation/type/compositionLaw>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionLaw" ;
  rdfs:comment "The algebraic composition law governing this type." ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/siteOrderingConstraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "siteOrderingConstraint" ;
  rdfs:comment "Constraint on the ordering of sites for this type." ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/backboneThreshold>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "backboneThreshold" ;
  rdfs:comment "The threshold for backbone inclusion in the type lattice." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/permutationGroup>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "permutationGroup" ;
  rdfs:comment "The permutation group acting on sites of this type." ;
  rdfs:range <https://uor.foundation/op/Group> .

<https://uor.foundation/type/acyclicityWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "acyclicityWitness" ;
  rdfs:comment "Witness certifying acyclicity of the type dependency graph." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/connectivityWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "connectivityWitness" ;
  rdfs:comment "Witness certifying connectivity of the type graph." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/schemaConstraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "schemaConstraint" ;
  rdfs:comment "Constraint imposed by the schema on this type." ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/alphabetSize>
  a owl:AnnotationProperty ;
  rdfs:label "alphabetSize" ;
  rdfs:comment "The size of the alphabet for symbol-based types." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/quantizationRange>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "quantizationRange" ;
  rdfs:comment "The range specification for quantized types." ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/type/elementTypeRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "elementTypeRef" ;
  rdfs:comment "Reference to the element type within a composite type." ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/type/inclusionSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inclusionSource" ;
  rdfs:comment "The subtype (more constraints)." ;
  rdfs:domain <https://uor.foundation/type/TypeInclusion> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/type/inclusionTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inclusionTarget" ;
  rdfs:comment "The supertype (fewer constraints)." ;
  rdfs:domain <https://uor.foundation/type/TypeInclusion> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/type/positionVariance>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "positionVariance" ;
  rdfs:comment "The variance of each operand position." ;
  rdfs:domain <https://uor.foundation/operad/StructuralOperad> ;
  rdfs:range <https://uor.foundation/type/VarianceAnnotation> .

<https://uor.foundation/type/inclusionWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "inclusionWitness" ;
  rdfs:comment "True iff constraints(source) ⊇ constraints(target). Computed, not asserted." ;
  rdfs:domain <https://uor.foundation/type/TypeInclusion> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/type/latticeDepth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "latticeDepth" ;
  rdfs:comment "Maximum chain length from PrimitiveType (top) to any CompleteType (bottom). Equals the site budget n at quantum level Q_k." ;
  rdfs:domain <https://uor.foundation/type/SubtypingLattice> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/type/defaultValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "defaultValue" ;
  rdfs:comment "Default integer value for the named constraint default." ;
  rdfs:domain <https://uor.foundation/type/ConstraintDefaults> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/type/boundObservable>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundObservable" ;
  rdfs:comment "The observable:Observable whose values this BoundConstraint bounds. Picks which datum projection is being constrained." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/observable/Observable> .

<https://uor.foundation/type/boundShape>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundShape" ;
  rdfs:comment "The predicate form this BoundConstraint imposes on its bound observable. Closed enumeration with exactly six named individuals (EqualBound, LessEqBound, GreaterEqBound, RangeContainBound, ResidueClassBound, AffineEqualBound)." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <https://uor.foundation/type/BoundShape> .

<https://uor.foundation/type/boundArguments>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "boundArguments" ;
  rdfs:comment "The BoundConstraint's parameters in canonical string form (e.g., 'modulus=256;residue=255' for a residue class bound). Non-functional — the string-form encoding is the canonical serialization; typed accessors on the Rust side unpack it via the per-type-alias constructors." ;
  rdfs:domain <https://uor.foundation/type/BoundConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/type/conjuncts>
  a owl:ObjectProperty ;
  rdfs:label "conjuncts" ;
  rdfs:comment "An ordered list of BoundConstraint individuals that this Conjunction composes. Non-functional — multiple conjuncts span the conjunction." ;
  rdfs:domain <https://uor.foundation/type/Conjunction> ;
  rdfs:range <https://uor.foundation/type/BoundConstraint> .

<https://uor.foundation/type/verticalAxis>
  a owl:NamedIndividual , <https://uor.foundation/type/MetricAxis> ;
  rdfs:label "verticalAxis" ;
  rdfs:comment "The vertical (ring/additive) metric axis. Constraints on this axis operate through ring arithmetic: residue classes, divisibility, and additive structure." .

<https://uor.foundation/type/horizontalAxis>
  a owl:NamedIndividual , <https://uor.foundation/type/MetricAxis> ;
  rdfs:label "horizontalAxis" ;
  rdfs:comment "The horizontal (Hamming/bitwise) metric axis. Constraints on this axis operate through bitwise structure: carry patterns, bit positions, and Hamming distance." .

<https://uor.foundation/type/diagonalAxis>
  a owl:NamedIndividual , <https://uor.foundation/type/MetricAxis> ;
  rdfs:label "diagonalAxis" ;
  rdfs:comment "The diagonal (incompatibility) metric axis. Constraints on this axis measure the gap between ring and Hamming metrics — the curvature of UOR geometry." .

<https://uor.foundation/type/ScalarType>
  a owl:NamedIndividual , <https://uor.foundation/type/PrimitiveType> ;
  rdfs:label "ScalarType" ;
  rdfs:comment "A single value from an ordered domain. siteCount = n (quantization bits)." ;
  <https://uor.foundation/type/structuralSiteCount> "n (quantization bits)" ;
  <https://uor.foundation/type/structuralGrounding> "quantize(value, range, bits) produces ring element where d_R reflects value proximity" .

<https://uor.foundation/type/SymbolType>
  a owl:NamedIndividual , <https://uor.foundation/type/PrimitiveType> ;
  rdfs:label "SymbolType" ;
  rdfs:comment "A value from a finite unordered set. siteCount = ceil(log2(|alphabet|))." ;
  <https://uor.foundation/type/structuralSiteCount> "ceil(log2(|alphabet|))" ;
  <https://uor.foundation/type/structuralGrounding> "argmin_{encoding} sum d_delta over observed pairs (CY_5)" .

<https://uor.foundation/type/SequenceType>
  a owl:NamedIndividual , <https://uor.foundation/type/ProductType> ;
  rdfs:label "SequenceType" ;
  rdfs:comment "An ordered list of elements with backbone constraint. The free monoid on the element type." ;
  <https://uor.foundation/type/structuralSiteCount> "sum of element site counts" ;
  <https://uor.foundation/type/structuralGrounding> "free monoid on element type, backbone constraint" ;
  <https://uor.foundation/type/structuralConstraint> "backbone ordering: elements indexed by position" .

<https://uor.foundation/type/TupleType>
  a owl:NamedIndividual , <https://uor.foundation/type/ProductType> ;
  rdfs:label "TupleType" ;
  rdfs:comment "A fixed collection of named fields." ;
  <https://uor.foundation/type/structuralSiteCount> "sum of field site counts" ;
  <https://uor.foundation/type/structuralGrounding> "site ordering follows CY_6 (optimal site ordering)" .

<https://uor.foundation/type/GraphType>
  a owl:NamedIndividual , <https://uor.foundation/type/ConstrainedType> ;
  rdfs:label "GraphType" ;
  rdfs:comment "Nodes with edge constraints. Constraint nerve = graph topology." ;
  <https://uor.foundation/type/structuralSiteCount> "sum of node site counts + edge overhead" ;
  <https://uor.foundation/type/structuralGrounding> "constraint nerve = graph nerve, beta_k equality" ;
  <https://uor.foundation/type/structuralConstraint> "edge constraints: adjacency preserved under grounding" .

<https://uor.foundation/type/SetType>
  a owl:NamedIndividual , <https://uor.foundation/type/ConstrainedType> ;
  rdfs:label "SetType" ;
  rdfs:comment "Unordered collection. d_delta is permutation-invariant." ;
  <https://uor.foundation/type/structuralSiteCount> "sum of element site counts" ;
  <https://uor.foundation/type/structuralGrounding> "d_delta invariant under element permutation, D_{2n} symmetry" ;
  <https://uor.foundation/type/structuralConstraint> "permutation invariance: encoding is order-independent" .

<https://uor.foundation/type/TreeType>
  a owl:NamedIndividual , <https://uor.foundation/type/ConstrainedType> ;
  rdfs:label "TreeType" ;
  rdfs:comment "Hierarchical structure. beta_1=0 (acyclic), beta_0=1 (connected)." ;
  <https://uor.foundation/type/structuralSiteCount> "sum of node site counts" ;
  <https://uor.foundation/type/structuralGrounding> "parent-child encoding with acyclicity constraint" ;
  <https://uor.foundation/type/structuralConstraint> "beta_1=0 (acyclic), beta_0=1 (connected)" .

<https://uor.foundation/type/TableType>
  a owl:NamedIndividual , <https://uor.foundation/type/ProductType> ;
  rdfs:label "TableType" ;
  rdfs:comment "Collection of tuples sharing a schema = Sequence(Tuple(S)). Functorial decomposition." ;
  <https://uor.foundation/type/structuralSiteCount> "row_count * tuple_site_count" ;
  <https://uor.foundation/type/structuralGrounding> "Sequence(Tuple(S)), functorial decomposition" ;
  <https://uor.foundation/type/structuralConstraint> "shared schema: all rows conform to tuple type S" .

<https://uor.foundation/type/Covariant>
  a owl:NamedIndividual , <https://uor.foundation/type/VarianceAnnotation> ;
  rdfs:label "Covariant" ;
  rdfs:comment "The structural position preserves TypeInclusion: if T₁ ≤ T₂, then F(T₁) ≤ F(T₂)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/type/Covariant> .

<https://uor.foundation/type/Contravariant>
  a owl:NamedIndividual , <https://uor.foundation/type/VarianceAnnotation> ;
  rdfs:label "Contravariant" ;
  rdfs:comment "The structural position reverses TypeInclusion: if T₁ ≤ T₂, then F(T₂) ≤ F(T₁)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/type/Contravariant> .

<https://uor.foundation/type/Invariant>
  a owl:NamedIndividual , <https://uor.foundation/type/VarianceAnnotation> ;
  rdfs:label "Invariant" ;
  rdfs:comment "The structural position requires exact type equality: F(T₁) ≤ F(T₂) only if T₁ = T₂." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/type/Invariant> .

<https://uor.foundation/type/Bivariant>
  a owl:NamedIndividual , <https://uor.foundation/type/VarianceAnnotation> ;
  rdfs:label "Bivariant" ;
  rdfs:comment "The structural position ignores the type parameter: F(T₁) ≤ F(T₂) for all T₁, T₂." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/type/Bivariant> .

<https://uor.foundation/type/EitherType>
  a owl:NamedIndividual , <https://uor.foundation/type/SumType> ;
  rdfs:label "EitherType" ;
  rdfs:comment "The canonical binary disjoint union type whose carrier is L + R." .

<https://uor.foundation/type/OptionType>
  a owl:NamedIndividual , <https://uor.foundation/type/SumType> ;
  rdfs:label "OptionType" ;
  rdfs:comment "The canonical A + Unit idiom for optional values." .

<https://uor.foundation/type/ResidueDefaultModulus>
  a owl:NamedIndividual , <https://uor.foundation/type/ConstraintDefaults> ;
  rdfs:label "ResidueDefaultModulus" ;
  rdfs:comment "Default modulus for ResidueConstraint when the #[uor(residue = X)] attribute omits the explicit modulus. 256 matches the v0.2.1 reference ring Z/(2^8)Z." ;
  <https://uor.foundation/type/defaultValue> "256"^^xsd:integer .

<https://uor.foundation/type/EqualBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "EqualBound" ;
  rdfs:comment "Predicate form: `observable(datum) == target`. Used by BoundConstraint instances asserting strict equality of a datum's observable projection to a target value." .

<https://uor.foundation/type/LessEqBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "LessEqBound" ;
  rdfs:comment "Predicate form: `observable(datum) <= bound`. Used by hamming, depth, carry, and site-rank bound constraints." .

<https://uor.foundation/type/GreaterEqBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "GreaterEqBound" ;
  rdfs:comment "Predicate form: `observable(datum) >= bound`." .

<https://uor.foundation/type/RangeContainBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "RangeContainBound" ;
  rdfs:comment "Predicate form: `lo <= observable(datum) <= hi`. The datum's observable projection must lie within the inclusive range `[lo, hi]`." .

<https://uor.foundation/type/ResidueClassBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "ResidueClassBound" ;
  rdfs:comment "Predicate form: `observable(datum) ≡ residue (mod modulus)`. Used by BoundConstraint instances asserting residue-class membership." .

<https://uor.foundation/type/AffineEqualBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "AffineEqualBound" ;
  rdfs:comment "Predicate form: `observable(datum) == offset + Σ αᵢ·generatorᵢ`. The datum's observable projection must equal an affine combination of the BoundConstraint's affine generators." .

<https://uor.foundation/type/LexicographicLessEqBound>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundShape> ;
  rdfs:label "LexicographicLessEqBound" ;
  rdfs:comment "Predicate form: `observable(datum) <= bound` over byte-sequence-valued observables under canonical big-endian unsigned ordering. Fixed-length: lexicographic byte-wise comparison. Variable-length: lexicographic with shorter-prefix-rule (the shorter sequence is less than the longer when bytes match through the shorter's length). Wiki ADR-040 + ADR-038: this is the BoundShape primitive for byte-sequence-valued AxisProjectionObservable instances (e.g. axis-realized hash projections) — LessEqBound is the integer-valued primitive (HammingMetric, DerivationDepthObservable, etc.)." .

<https://uor.foundation/type/residueConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "residueConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 ResidueConstraint class: (observable:ValueModObservable, type:ResidueClassBound). The Rust foundation exposes this kind via the `ResidueConstraint` type alias with `pub const fn new(modulus, residue)`." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/observable/ValueModObservable> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/ResidueClassBound> ;
  <https://uor.foundation/type/boundArguments> "modulus=256;residue=0" .

<https://uor.foundation/type/hammingConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "hammingConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 HammingConstraint class: (observable:HammingMetric, type:LessEqBound). The Rust foundation exposes this kind via the `HammingConstraint` type alias with `pub const fn new(bound)`." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/observable/HammingMetric> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/LessEqBound> ;
  <https://uor.foundation/type/boundArguments> "bound=0" .

<https://uor.foundation/type/depthConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "depthConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 DepthConstraint class: (derivation:DerivationDepthObservable, type:LessEqBound)." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/derivation/DerivationDepthObservable> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/LessEqBound> ;
  <https://uor.foundation/type/boundArguments> "min_depth=0;max_depth=0" .

<https://uor.foundation/type/carryConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "carryConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 CarryConstraint class: (carry:CarryDepthObservable, type:LessEqBound)." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/carry/CarryDepthObservable> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/LessEqBound> ;
  <https://uor.foundation/type/boundArguments> "bound=0" .

<https://uor.foundation/type/siteConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "siteConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 SiteConstraint class: (partition:FreeRankObservable, type:LessEqBound)." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/partition/FreeRankObservable> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/LessEqBound> ;
  <https://uor.foundation/type/boundArguments> "site_index=0" .

<https://uor.foundation/type/affineConstraintKind>
  a owl:NamedIndividual , <https://uor.foundation/type/BoundConstraint> ;
  rdfs:label "affineConstraintKind" ;
  rdfs:comment "Parametric replacement for the v0.2.1 AffineConstraint class: (observable:ValueModObservable, type:AffineEqualBound)." ;
  <https://uor.foundation/type/boundObservable> <https://uor.foundation/observable/ValueModObservable> ;
  <https://uor.foundation/type/boundShape> <https://uor.foundation/type/AffineEqualBound> ;
  <https://uor.foundation/type/boundArguments> "offset=0" .

# Namespace: partition
<https://uor.foundation/partition/>
  a owl:Ontology ;
  rdfs:label "UOR Partitions" ;
  rdfs:comment "Irreducibility partitions produced by type resolution. A partition divides the ring into four disjoint components: Irreducible, Reducible, Units, and Exterior." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
.

<https://uor.foundation/partition/Partition>
  a owl:Class ;
  rdfs:label "Partition" ;
  rdfs:comment "A four-component partition of R_n produced by resolving a type declaration. The four components — Irreducible, Reducible, Units, Exterior — are mutually disjoint and exhaustive over the carrier." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/partition/Component>
  a owl:Class ;
  rdfs:label "Component" ;
  rdfs:comment "A single component of a partition: a set of datum values belonging to one of the four categories." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/SiteIndex> ;
  owl:disjointWith <https://uor.foundation/partition/FreeRank> ;
.

<https://uor.foundation/partition/IrreducibleSet>
  a owl:Class ;
  rdfs:label "IrreducibleSet" ;
  rdfs:comment "The set of irreducible elements under the active type: elements whose only factorizations involve units or themselves. Analogous to prime elements in a ring." ;
  rdfs:subClassOf <https://uor.foundation/partition/Component> ;
  owl:disjointWith <https://uor.foundation/partition/ReducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/UnitGroup> ;
  owl:disjointWith <https://uor.foundation/partition/Complement> ;
.

<https://uor.foundation/partition/ReducibleSet>
  a owl:Class ;
  rdfs:label "ReducibleSet" ;
  rdfs:comment "The set of reducible non-unit elements: elements that can be expressed as a product of two or more non-unit elements." ;
  rdfs:subClassOf <https://uor.foundation/partition/Component> ;
  owl:disjointWith <https://uor.foundation/partition/IrreducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/UnitGroup> ;
  owl:disjointWith <https://uor.foundation/partition/Complement> ;
.

<https://uor.foundation/partition/UnitGroup>
  a owl:Class ;
  rdfs:label "UnitGroup" ;
  rdfs:comment "The set of invertible elements (units) in the carrier: elements with a multiplicative inverse. In Z/(2^n)Z, the units are the odd integers." ;
  rdfs:subClassOf <https://uor.foundation/partition/Component> ;
  owl:disjointWith <https://uor.foundation/partition/IrreducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/ReducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/Complement> ;
.

<https://uor.foundation/partition/Complement>
  a owl:Class ;
  rdfs:label "Complement" ;
  rdfs:comment "Elements of R_n that fall outside the active carrier — i.e., outside the type's domain. These are ring elements that do not participate in the current type resolution." ;
  rdfs:subClassOf <https://uor.foundation/partition/Component> ;
  owl:disjointWith <https://uor.foundation/partition/IrreducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/ReducibleSet> ;
  owl:disjointWith <https://uor.foundation/partition/UnitGroup> ;
.

<https://uor.foundation/partition/SiteIndex>
  a owl:Class ;
  rdfs:label "SiteIndex" ;
  rdfs:comment "A single site coordinate in the iterated Z/2Z fibration. Each site represents one binary degree of freedom in the ring's structure. The total number of sites equals the quantum level n." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/FreeRank> ;
  owl:disjointWith <https://uor.foundation/partition/Component> ;
.

<https://uor.foundation/partition/FreeRank>
  a owl:Class ;
  rdfs:label "FreeRank" ;
  rdfs:comment "The site budget for a partition: an accounting of how many sites are pinned (determined by constraints) versus free (still available for further refinement). A closed budget means all sites are pinned and the type is fully resolved." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/SiteIndex> ;
  owl:disjointWith <https://uor.foundation/partition/Component> ;
.

<https://uor.foundation/partition/SiteBinding>
  a owl:Class ;
  rdfs:label "SiteBinding" ;
  rdfs:comment "A record of a single site being pinned by a constraint. Links a specific site coordinate to the constraint that determined its value." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/partition/PartitionProduct>
  a owl:Class ;
  rdfs:label "PartitionProduct" ;
  rdfs:comment "The tensor product of two partitions: partition(A × B) = partition(A) ⊗ partition(B). The four-component structure combines component-wise under the product type construction (PT_2a). Carries leftFactor and rightFactor links to the operand partitions." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/PartitionCoproduct> ;
  owl:disjointWith <https://uor.foundation/partition/CartesianPartitionProduct> ;
.

<https://uor.foundation/partition/PartitionCoproduct>
  a owl:Class ;
  rdfs:label "PartitionCoproduct" ;
  rdfs:comment "The coproduct (disjoint union) of two partitions: partition(A + B) = partition(A) ⊕ partition(B). The four-component structure combines via disjoint union under the sum type construction (PT_2b). Carries leftSummand and rightSummand links to the operand partitions." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/PartitionProduct> ;
  owl:disjointWith <https://uor.foundation/partition/CartesianPartitionProduct> ;
.

<https://uor.foundation/partition/CartesianPartitionProduct>
  a owl:Class ;
  rdfs:label "CartesianPartitionProduct" ;
  rdfs:comment "The Cartesian product of partitions. Classifies the nerve topology of A ⊠ B as a simplicial product (χ multiplicative per CPT_3, Betti by Künneth per CPT_4) rather than a site-disjoint union (χ additive — PartitionProduct). Site budget is |S_A| + |S_B| per CPT_1 — the bit width of the product state space. Partition-ness is asserted via leftCartesianFactor / rightCartesianFactor (both ranged at Partition), matching the sibling pattern for PartitionProduct and PartitionCoproduct. Satisfies CPT_1–CPT_6 per this amendment." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/partition/PartitionProduct> ;
  owl:disjointWith <https://uor.foundation/partition/PartitionCoproduct> ;
.

<https://uor.foundation/partition/TagSite>
  a owl:Class ;
  rdfs:label "TagSite" ;
  rdfs:comment "The distinguishing site in a PartitionCoproduct whose value (0 or 1) selects the variant. Logically, the tag is not a data site of either operand (ST_6) and carries exactly the ln 2 entropy quantum (ST_2). Its physical placement in a flat constraint layout follows the foundation layout convention: layoutTagSite = max(SITE_COUNT(A), SITE_COUNT(B)), so the tag does not collide with any inherited bookkeeping sites when operands are themselves coproducts." ;
  rdfs:subClassOf <https://uor.foundation/partition/SiteIndex> ;
.

<https://uor.foundation/partition/FreeRankObservable>
  a owl:Class ;
  rdfs:label "FreeRankObservable" ;
  rdfs:comment "Observes the free-rank of the partition associated with a Datum's site context, recording the count of unbound sites at the moment of observation. Used as the bound observable for the siteConstraintKind BoundConstraint." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/partition/PartitionComponent>
  a owl:Class ;
  rdfs:label "PartitionComponent" ;
  rdfs:comment "Closed enumeration of partition component kinds: Irreducible (non-factorizable), Reducible (factorizable into non-trivial parts), Units (invertible), Exterior (outside the factorization domain). Codegen treats this as an enum class with exactly 4 individuals." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/partition/irreducibles>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "irreducibles" ;
  rdfs:comment "The irreducible component of this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/IrreducibleSet> .

<https://uor.foundation/partition/reducibles>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "reducibles" ;
  rdfs:comment "The reducible component of this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/ReducibleSet> .

<https://uor.foundation/partition/units>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "units" ;
  rdfs:comment "The units component of this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/UnitGroup> .

<https://uor.foundation/partition/exterior>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "exterior" ;
  rdfs:comment "The exterior component of this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/Complement> .

<https://uor.foundation/partition/member>
  a owl:ObjectProperty ;
  rdfs:label "member" ;
  rdfs:comment "A datum value belonging to this partition component." ;
  rdfs:domain <https://uor.foundation/partition/Component> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/partition/cardinality>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cardinality" ;
  rdfs:comment "The number of elements in this partition component. The cardinalities of the four components must sum to 2^n." ;
  rdfs:domain <https://uor.foundation/partition/Component> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/density>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "density" ;
  rdfs:comment "The irreducible density of this partition: |Irr| / |A|, where A is the active carrier." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/partition/sourceType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceType" ;
  rdfs:comment "The type declaration that was resolved to produce this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/partition/wittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "wittLength" ;
  rdfs:comment "The Witt level n at which this partition was computed. The ring has 2^n elements at this level." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/partition/sitePosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitePosition" ;
  rdfs:comment "The zero-based position of this site coordinate within the iterated fibration. Position 0 is the least significant bit; position n-1 is the most significant." ;
  rdfs:domain <https://uor.foundation/partition/SiteIndex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/siteState>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "siteState" ;
  rdfs:comment "The current state of this site coordinate: 'pinned' if determined by a constraint, 'free' if still available for refinement." ;
  rdfs:domain <https://uor.foundation/partition/SiteIndex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/siteBudget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "siteBudget" ;
  rdfs:comment "The site budget associated with this partition." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/partition/totalSites>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "totalSites" ;
  rdfs:comment "The total number of site coordinates in this budget, equal to the quantum level n." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/pinnedCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pinnedCount" ;
  rdfs:comment "The number of site coordinates currently pinned by constraints." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/freeRank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "freeRank" ;
  rdfs:comment "The number of site coordinates still free (not yet pinned). Equals totalSites - pinnedCount." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/partition/isClosed>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isClosed" ;
  rdfs:comment "Whether all sites in this budget are pinned. A closed budget means the type is fully resolved and the partition is complete." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/partition/hasSite>
  a owl:ObjectProperty ;
  rdfs:label "hasSite" ;
  rdfs:comment "A site coordinate belonging to this budget." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/partition/pinnedBy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "pinnedBy" ;
  rdfs:comment "The constraint that pins this site coordinate." ;
  rdfs:domain <https://uor.foundation/partition/SiteBinding> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/partition/pinsCoordinate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "pinsCoordinate" ;
  rdfs:comment "The site coordinate that this pinning determines." ;
  rdfs:domain <https://uor.foundation/partition/SiteBinding> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/partition/hasBinding>
  a owl:ObjectProperty ;
  rdfs:label "hasBinding" ;
  rdfs:comment "A site pinning record in this budget." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <https://uor.foundation/partition/SiteBinding> .

<https://uor.foundation/partition/ancillaSite>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "ancillaSite" ;
  rdfs:comment "An ancilla site coordinate paired with this site for reversible computation (RC_1–RC_4 ancilla model)." ;
  rdfs:domain <https://uor.foundation/partition/SiteIndex> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/partition/reversibleStrategy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "reversibleStrategy" ;
  rdfs:comment "True when this site budget uses a reversible computation strategy preserving information through ancilla sites." ;
  rdfs:domain <https://uor.foundation/partition/FreeRank> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/partition/exteriorCriteria>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "exteriorCriteria" ;
  rdfs:comment "The formal membership criterion for this Complement: x ∈ Ext(T) iff x ∉ carrier(T). The Complement is context-dependent on the active type T (FPM_9)." ;
  rdfs:domain <https://uor.foundation/partition/Complement> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/partition/isExhaustive>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isExhaustive" ;
  rdfs:comment "Whether the four components of this partition are exhaustive over R_n: |Irr| + |Red| + |Unit| + |Ext| = 2^n (FPM_8). Set by the kernel after verification." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/partition/leftFactor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftFactor" ;
  rdfs:comment "The left operand partition of this tensor product." ;
  rdfs:domain <https://uor.foundation/partition/PartitionProduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/rightFactor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightFactor" ;
  rdfs:comment "The right operand partition of this tensor product." ;
  rdfs:domain <https://uor.foundation/partition/PartitionProduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/leftSummand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftSummand" ;
  rdfs:comment "The left operand partition of this coproduct." ;
  rdfs:domain <https://uor.foundation/partition/PartitionCoproduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/rightSummand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightSummand" ;
  rdfs:comment "The right operand partition of this coproduct." ;
  rdfs:domain <https://uor.foundation/partition/PartitionCoproduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/leftCartesianFactor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftCartesianFactor" ;
  rdfs:comment "The left operand partition of this Cartesian partition product." ;
  rdfs:domain <https://uor.foundation/partition/CartesianPartitionProduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/rightCartesianFactor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightCartesianFactor" ;
  rdfs:comment "The right operand partition of this Cartesian partition product." ;
  rdfs:domain <https://uor.foundation/partition/CartesianPartitionProduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/partition/tagSiteOf>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "tagSiteOf" ;
  rdfs:comment "The tag site distinguishing the variants of a PartitionCoproduct. Logically distinct from every data site of either operand (ST_6) and carries the ln 2 entropy quantum of ST_2." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <https://uor.foundation/partition/TagSite> .

<https://uor.foundation/partition/tagValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "tagValue" ;
  rdfs:comment "The boolean value (false = 0, true = 1) assigned to a tag site. false selects the left variant of the PartitionCoproduct; true selects the right variant." ;
  rdfs:domain <https://uor.foundation/partition/TagSite> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/partition/productCategoryLevel>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "productCategoryLevel" ;
  rdfs:comment "The categorical level at which this construction is a product / coproduct. Values: 'partition_classification' (PartitionProduct, PartitionCoproduct), or 'nerve_topology' (CartesianPartitionProduct). Prevents misreading the product vs coproduct distinction across levels." ;
  rdfs:domain <https://uor.foundation/partition/Partition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/partition/Irreducible>
  a owl:NamedIndividual , <https://uor.foundation/partition/PartitionComponent> ;
  rdfs:label "Irreducible" ;
  rdfs:comment "The irreducible component: elements that admit no non-trivial factorization within the ring." .

<https://uor.foundation/partition/Reducible>
  a owl:NamedIndividual , <https://uor.foundation/partition/PartitionComponent> ;
  rdfs:label "Reducible" ;
  rdfs:comment "The reducible component: elements that factor into non-trivial parts." .

<https://uor.foundation/partition/Units>
  a owl:NamedIndividual , <https://uor.foundation/partition/PartitionComponent> ;
  rdfs:label "Units" ;
  rdfs:comment "The unit component: invertible elements of the ring." .

<https://uor.foundation/partition/Exterior>
  a owl:NamedIndividual , <https://uor.foundation/partition/PartitionComponent> ;
  rdfs:label "Exterior" ;
  rdfs:comment "The exterior component: elements outside the factorization domain (e.g., zero or ring-boundary values)." .

# Namespace: foundation
<https://uor.foundation/foundation/>
  a owl:Ontology ;
  rdfs:label "UOR Foundation Layout Invariants" ;
  rdfs:comment "Foundation-level layout invariants complementing op-namespace theorems. Quantifies over foundation-defined SITE_COUNT arithmetic and ConstraintRef byte patterns, not over ontology-level siteBudget." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/type/> ;
.

<https://uor.foundation/foundation/LayoutInvariant>
  a owl:Class ;
  rdfs:label "LayoutInvariant" ;
  rdfs:comment "A foundation-level layout invariant. Each instance describes an arithmetic or encoding identity that the foundation's mint primitives and validate_const() pass enforce at compile time, distinct from the ontology-level theorem individuals carried by the op namespace. Violations produce GenericImpossibilityWitness citations against the specific LayoutInvariant IRI, letting consumers distinguish a layout-level failure from a theorem-level failure." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/foundation/layoutRule>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "layoutRule" ;
  rdfs:comment "The arithmetic or encoding identity this LayoutInvariant asserts, expressed as a human-readable string for inspection in documentation and debugging output." ;
  rdfs:domain <https://uor.foundation/foundation/LayoutInvariant> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/foundation/ProductLayoutWidth>
  a owl:NamedIndividual , <https://uor.foundation/foundation/LayoutInvariant> ;
  rdfs:label "ProductLayoutWidth" ;
  rdfs:comment "PartitionProduct layout-width invariant: products introduce no bookkeeping of their own, so layout widths add. Cited by primitive_partition_product when the caller-supplied combined SITE_COUNT differs from the sum of operand SITE_COUNTs." ;
  <https://uor.foundation/foundation/layoutRule> "SITE_COUNT(A × B) = SITE_COUNT(A) + SITE_COUNT(B)" .

<https://uor.foundation/foundation/CartesianLayoutWidth>
  a owl:NamedIndividual , <https://uor.foundation/foundation/LayoutInvariant> ;
  rdfs:label "CartesianLayoutWidth" ;
  rdfs:comment "CartesianPartitionProduct layout-width invariant: cartesian products introduce no bookkeeping either, so layout widths add the same way PartitionProduct does. The distinction between these two constructions lives at the nerve-topology level (χ multiplicative vs additive), not the layout level." ;
  <https://uor.foundation/foundation/layoutRule> "SITE_COUNT(A ⊠ B) = SITE_COUNT(A) + SITE_COUNT(B)" .

<https://uor.foundation/foundation/CoproductLayoutWidth>
  a owl:NamedIndividual , <https://uor.foundation/foundation/LayoutInvariant> ;
  rdfs:label "CoproductLayoutWidth" ;
  rdfs:comment "PartitionCoproduct layout-width invariant: coproducts add exactly one tag site beyond the widest operand's full layout. Uses SITE_COUNT (not siteBudget) so nested coproducts whose operands carry inherited bookkeeping do not collide their outer tag with an inner tag site." ;
  <https://uor.foundation/foundation/layoutRule> "SITE_COUNT(A + B) = max(SITE_COUNT(A), SITE_COUNT(B)) + 1" .

<https://uor.foundation/foundation/CoproductTagEncoding>
  a owl:NamedIndividual , <https://uor.foundation/foundation/LayoutInvariant> ;
  rdfs:label "CoproductTagEncoding" ;
  rdfs:comment "PartitionCoproduct canonical tag-pinner encoding: each variant's tag-pinning constraint is the canonical Affine form with all-zero coefficients except a single 1 at tag_site, with bias 0 for the left variant and bias −1 for the right. Semantically equivalent but non-normalized encodings (coefficient ≠ 1, or alternative biases, etc.) are rejected at mint time because content-addressing depends on the normalized byte pattern, not the semantic equivalence class." ;
  <https://uor.foundation/foundation/layoutRule> "Affine { coefficients: [0,…,0, 1 at tag_site], bias: 0 (left) | −1 (right) }" .

# Namespace: observable
<https://uor.foundation/observable/>
  a owl:Ontology ;
  rdfs:label "UOR Observables" ;
  rdfs:comment "Observable quantities and metrics computed by the UOR kernel. Includes ring-metric, Hamming-metric, curvature, holonomy, and catastrophe-theoretic observables." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/type/> ;
.

<https://uor.foundation/observable/Observable>
  a owl:Class ;
  rdfs:label "Observable" ;
  rdfs:comment "A measurable quantity in the UOR Framework. All observables are kernel-computed and user-consumed." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/StratumObservable>
  a owl:Class ;
  rdfs:label "StratumObservable" ;
  rdfs:comment "An observable measuring stratum-level properties: position within the ring's layer structure." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/MetricObservable>
  a owl:Class ;
  rdfs:label "MetricObservable" ;
  rdfs:comment "An observable measuring geometric distance between ring elements under a specific metric." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/PathObservable>
  a owl:Class ;
  rdfs:label "PathObservable" ;
  rdfs:comment "An observable measuring properties of paths through the ring: path length, total variation, winding number." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/ReductionObservable>
  a owl:Class ;
  rdfs:label "ReductionObservable" ;
  rdfs:comment "An observable measuring reduction properties: the length and count of operation sequences." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/CatastropheObservable>
  a owl:Class ;
  rdfs:label "CatastropheObservable" ;
  rdfs:comment "An observable measuring catastrophe-theoretic properties: thresholds at which qualitative changes occur in the partition." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/CurvatureObservable>
  a owl:Class ;
  rdfs:label "CurvatureObservable" ;
  rdfs:comment "An observable measuring the curvature of the UOR geometry: the gap between ring-isometry and Hamming-isometry for a given transform." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/HolonomyObservable>
  a owl:Class ;
  rdfs:label "HolonomyObservable" ;
  rdfs:comment "An observable measuring holonomy: the accumulated transformation when traversing a closed path in the ring." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/SpectralObservable>
  a owl:Class ;
  rdfs:label "SpectralObservable" ;
  rdfs:comment "ADR-049: an observable whose value is a structural reading of a digest's frequency-domain spectrum. Distinct from the seven internally-derived Observable categories (Stratum / Metric / Path / Reduction / Catastrophe / Curvature / Holonomy) — its values are Walsh–Hadamard parities at specific frequencies, not derivable from the framework's internal algebraic/topological structure. Foundation's typed observable `WalshHadamardParity` per ADR-049 falls under this subclass; predicates over its values enter the typed-commitment surface per ADR-048 as `SingletonCommitment<WalshHadamardParity>` operands." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/ValueThresholdObservable>
  a owl:Class ;
  rdfs:label "ValueThresholdObservable" ;
  rdfs:comment "ADR-040 + ADR-049: an observable whose value is a byte-sequence threshold comparison reading of a digest. Distinct from the seven internally-derived Observable categories (Stratum / Metric / Path / Reduction / Catastrophe / Curvature / Holonomy) and from SpectralObservable / AxisProjectionObservable — its values carry from `(digest as big-endian unsigned integer) <= (target as big-endian unsigned integer)`, the predicate form ADR-040 named when it committed `type:LexicographicLessEqBound`. Foundation's typed observable `LexicographicLessEqThreshold` per ADR-049 falls under this subclass; the canonical search-cost commitment alias `TargetCommitment = SingletonCommitment<LexicographicLessEqThreshold>` per ADR-048 consumes it. The ConstraintRef::Bound.args_repr canonical-string-form encoding for ValueThresholdObservable arguments carries the target byte sequence as the bound's argument directly." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/AxisProjectionObservable>
  a owl:Class ;
  rdfs:label "AxisProjectionObservable" ;
  rdfs:comment "ADR-038: an observable whose value is the axis-realized projection of typed sites through an application-declared AxisTuple kernel per ADR-030. Distinct from the seven internally-derived Observable categories (Stratum, Metric, Path, Reduction, Catastrophe, Curvature, Holonomy) — its values carry from the substrate-extension surface (axis kernels), not from the framework's internal algebraic / topological structure. The closed-catalog discipline holds: foundation owns the subclass; applications consume catalog variants through canonical-string-form `args_repr` on `ConstraintRef::Bound`. The args_repr encoding (per ADR-038) is `axis_address=<hex>;kernel=<symbolic>;sites=<site-list>[;target=<target-spec>]` — axis identification by content-address (AXIS_ADDRESS per ADR-030), not by tuple position, so the encoding is application-invariant." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/RingMetric>
  a owl:Class ;
  rdfs:label "RingMetric" ;
  rdfs:comment "Distance between two ring elements under the ring metric: d_R(x, y) = |x - y| mod 2^n." ;
  rdfs:subClassOf <https://uor.foundation/observable/MetricObservable> ;
.

<https://uor.foundation/observable/HammingMetric>
  a owl:Class ;
  rdfs:label "HammingMetric" ;
  rdfs:comment "Distance between two ring elements under the Hamming metric: the number of bit positions where they differ." ;
  rdfs:subClassOf <https://uor.foundation/observable/MetricObservable> ;
.

<https://uor.foundation/observable/IncompatibilityMetric>
  a owl:Class ;
  rdfs:label "IncompatibilityMetric" ;
  rdfs:comment "The metric incompatibility between two ring elements: the divergence between their ring-metric and Hamming-metric distances, measuring geometric curvature." ;
  rdfs:subClassOf <https://uor.foundation/observable/MetricObservable> ;
.

<https://uor.foundation/observable/ValueModObservable>
  a owl:Class ;
  rdfs:label "ValueModObservable" ;
  rdfs:comment "Observes a Datum's value modulo a configurable modulus. Used as the bound observable for BoundConstraint instances representing residue and affine constraint kinds (residueConstraintKind, affineConstraintKind)." ;
  rdfs:subClassOf <https://uor.foundation/observable/MetricObservable> ;
.

<https://uor.foundation/observable/GroundingSigma>
  a owl:Class ;
  rdfs:label "GroundingSigma" ;
  rdfs:comment "Observes the grounding completion ratio σ ∈ [0, 1] of a context, where σ = 1 indicates the ground state (state:GroundedContext). Backs the sigma_metric BaseMetric accessor on Grounded<T>." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/JacobianObservable>
  a owl:Class ;
  rdfs:label "JacobianObservable" ;
  rdfs:comment "Observes the per-site Jacobian row of a Datum at a particular WittLevel, computed as the sequence of partial derivatives of the ring operation with respect to each site coordinate. Backs the jacobian_metric BaseMetric accessor on Grounded<T>; the Rust-side JacobianMetric<L> is parametric over the level marker." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/StratumValue>
  a owl:Class ;
  rdfs:label "StratumValue" ;
  rdfs:comment "The stratum index of a ring element." ;
  rdfs:subClassOf <https://uor.foundation/observable/StratumObservable> ;
.

<https://uor.foundation/observable/StratumDelta>
  a owl:Class ;
  rdfs:label "StratumDelta" ;
  rdfs:comment "The difference in stratum between two ring elements." ;
  rdfs:subClassOf <https://uor.foundation/observable/StratumObservable> ;
.

<https://uor.foundation/observable/StratumTrajectory>
  a owl:Class ;
  rdfs:label "StratumTrajectory" ;
  rdfs:comment "The sequence of strata traversed by a path through the ring." ;
  rdfs:subClassOf <https://uor.foundation/observable/StratumObservable> ;
.

<https://uor.foundation/observable/PathLength>
  a owl:Class ;
  rdfs:label "PathLength" ;
  rdfs:comment "The length of a path through the ring, measured in operation steps." ;
  rdfs:subClassOf <https://uor.foundation/observable/PathObservable> ;
.

<https://uor.foundation/observable/TotalVariation>
  a owl:Class ;
  rdfs:label "TotalVariation" ;
  rdfs:comment "The total variation of a path: the sum of metric distances between consecutive elements." ;
  rdfs:subClassOf <https://uor.foundation/observable/PathObservable> ;
.

<https://uor.foundation/observable/WindingNumber>
  a owl:Class ;
  rdfs:label "WindingNumber" ;
  rdfs:comment "The winding number of a closed path: the number of times the path wraps around the ring." ;
  rdfs:subClassOf <https://uor.foundation/observable/PathObservable> ;
.

<https://uor.foundation/observable/ReductionLength>
  a owl:Class ;
  rdfs:label "ReductionLength" ;
  rdfs:comment "The number of operation applications in a reduction sequence." ;
  rdfs:subClassOf <https://uor.foundation/observable/ReductionObservable> ;
.

<https://uor.foundation/observable/ReductionCount>
  a owl:Class ;
  rdfs:label "ReductionCount" ;
  rdfs:comment "The number of distinct reduction sequences in a computation." ;
  rdfs:subClassOf <https://uor.foundation/observable/ReductionObservable> ;
.

<https://uor.foundation/observable/CatastropheThreshold>
  a owl:Class ;
  rdfs:label "CatastropheThreshold" ;
  rdfs:comment "A critical value at which a qualitative change occurs in the partition structure." ;
  rdfs:subClassOf <https://uor.foundation/observable/CatastropheObservable> ;
.

<https://uor.foundation/observable/CatastropheCount>
  a owl:Class ;
  rdfs:label "CatastropheCount" ;
  rdfs:comment "The number of catastrophe events (qualitative partition changes) in a computation." ;
  rdfs:subClassOf <https://uor.foundation/observable/CatastropheObservable> ;
.

<https://uor.foundation/observable/Commutator>
  a owl:Class ;
  rdfs:label "Commutator" ;
  rdfs:comment "The commutator [f, g](x) = f(g(x)) - g(f(x)) of two operations, measuring their non-commutativity." ;
  rdfs:subClassOf <https://uor.foundation/observable/CurvatureObservable> ;
.

<https://uor.foundation/observable/CurvatureFlux>
  a owl:Class ;
  rdfs:label "CurvatureFlux" ;
  rdfs:comment "The integrated curvature over a region of type space: the total metric incompatibility accumulated." ;
  rdfs:subClassOf <https://uor.foundation/observable/CurvatureObservable> ;
.

<https://uor.foundation/observable/Monodromy>
  a owl:Class ;
  rdfs:label "Monodromy" ;
  rdfs:comment "The monodromy of a closed path: the net transformation accumulated when traversing a loop in the type space." ;
  rdfs:subClassOf <https://uor.foundation/observable/HolonomyObservable> ;
.

<https://uor.foundation/observable/ParallelTransport>
  a owl:Class ;
  rdfs:label "ParallelTransport" ;
  rdfs:comment "The parallel transport of a vector along a path: the canonical lift of the path to the tangent bundle of the ring." ;
  rdfs:subClassOf <https://uor.foundation/observable/HolonomyObservable> ;
.

<https://uor.foundation/observable/DihedralElement>
  a owl:Class ;
  rdfs:label "DihedralElement" ;
  rdfs:comment "An element of the dihedral group D_{2^n} acting on the type space. Each dihedral element induces an isometry of 𝒯_n." ;
  rdfs:subClassOf <https://uor.foundation/observable/HolonomyObservable> ;
.

<https://uor.foundation/observable/MeasurementUnit>
  a owl:Class ;
  rdfs:label "MeasurementUnit" ;
  rdfs:comment "A unit of measurement for observable quantities. Each MeasurementUnit individual names a specific unit (bits, ring steps, dimensionless) replacing the string-valued observable:unit property." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/Jacobian>
  a owl:Class ;
  rdfs:label "Jacobian" ;
  rdfs:comment "Site-by-site curvature decomposition. J_k measures the discrete derivative of the incompatibility metric at site position k: J_k = |d_R(x, succ(x)) - d_H(x, succ(x))| restricted to position k." ;
  rdfs:subClassOf <https://uor.foundation/observable/CurvatureObservable> ;
.

<https://uor.foundation/observable/TopologicalObservable>
  a owl:Class ;
  rdfs:label "TopologicalObservable" ;
  rdfs:comment "An observable measuring a topological invariant of the resolution space. Topological observables are invariant under continuous deformations of the constraint configuration." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/BettiNumber>
  a owl:Class ;
  rdfs:label "BettiNumber" ;
  rdfs:comment "The rank of a homology group of the constraint nerve. β_k = rank(H_k(N(C))) counts the k-dimensional holes in the constraint configuration." ;
  rdfs:subClassOf <https://uor.foundation/observable/TopologicalObservable> ;
.

<https://uor.foundation/observable/SpectralGap>
  a owl:Class ;
  rdfs:label "SpectralGap" ;
  rdfs:comment "The smallest positive eigenvalue of the constraint nerve Laplacian. Controls the convergence rate of iterative resolution: larger gap = faster convergence." ;
  rdfs:subClassOf <https://uor.foundation/observable/TopologicalObservable> ;
.

<https://uor.foundation/observable/ThermoObservable>
  a owl:Class ;
  rdfs:label "ThermoObservable" ;
  rdfs:comment "An observable measuring thermodynamic properties of the resolution process: residual entropy, Landauer cost, and reduction distribution statistics." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/ResidualEntropy>
  a owl:Class ;
  rdfs:label "ResidualEntropy" ;
  rdfs:comment "S_residual: the residual Shannon entropy of the site distribution after partial resolution. Computed as S = (Σ κ_k − χ(N(C))) × ln 2 (IT_7b). Unit: Nats." ;
  rdfs:subClassOf <https://uor.foundation/observable/ThermoObservable> ;
.

<https://uor.foundation/observable/LandauerCost>
  a owl:Class ;
  rdfs:label "LandauerCost" ;
  rdfs:comment "The minimum thermodynamic cost (in units of k_B T ln 2) of erasing one bit of site uncertainty. The UOR ring operates at β* = ln 2 — the Landauer temperature." ;
  rdfs:subClassOf <https://uor.foundation/observable/ThermoObservable> ;
.

<https://uor.foundation/observable/LandauerBudget>
  a owl:Class ;
  rdfs:label "LandauerBudget" ;
  rdfs:comment "A sealed observable carrier for accumulated Landauer cost in nats. Monotonic within a single pipeline invocation. The UOR ring operates at the Landauer temperature (β* = ln 2), so this observable is a direct measure of irreversible bit-erasure performed by the computation up to the witness it accompanies." ;
  rdfs:subClassOf <https://uor.foundation/observable/ThermoObservable> ;
.

<https://uor.foundation/observable/ReductionEntropy>
  a owl:Class ;
  rdfs:label "ReductionEntropy" ;
  rdfs:comment "The Shannon entropy of the reduction distribution P(j) = 2^{−j}. At the Landauer temperature, this equals ln 2 per reduction step — each step erases exactly one bit of site uncertainty." ;
  rdfs:subClassOf <https://uor.foundation/observable/ThermoObservable> ;
.

<https://uor.foundation/observable/SynthesisSignature>
  a owl:Class ;
  rdfs:label "SynthesisSignature" ;
  rdfs:comment "A named topological signature: a pair (realised Euler characteristic, realised Betti profile). Linked from TypeSynthesisResult. Allows comparison between the goal signature and the actually achieved signature." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/SpectralSequencePage>
  a owl:Class ;
  rdfs:label "SpectralSequencePage" ;
  rdfs:comment "A single page E_r of the quantum level spectral sequence. Carries the page index r and the differential d_r. The sequence converges when all differentials vanish — typically by E_3 for simple constraint configurations." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/LiftObstructionClass>
  a owl:Class ;
  rdfs:label "LiftObstructionClass" ;
  rdfs:comment "The cohomology class in H^2(N(C(T))) representing the LiftObstruction for a specific WittLift. The class is zero iff the obstruction is trivial. When non-zero, it indexes the specific site pair at Q_{n+1} that cannot be closed by the lifted constraint set alone." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/MonodromyClass>
  a owl:Class ;
  rdfs:label "MonodromyClass" ;
  rdfs:comment "A classification of a type's holonomy: the subgroup of D_{2^n} generated by all Monodromy observables computed over closed paths in the type's constraint nerve. Trivial iff every closed constraint path returns to its starting site assignment without net dihedral transformation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/HolonomyGroup>
  a owl:Class ;
  rdfs:label "HolonomyGroup" ;
  rdfs:comment "The holonomy group of a ConstrainedType: the group of all Monodromy elements achievable by closed paths in the constraint nerve. Always a subgroup of D_{2^n}. Trivial iff the type has trivial monodromy everywhere; equals D_{2^n} iff paths involving both neg and bnot involutions are present." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/ClosedConstraintPath>
  a owl:Class ;
  rdfs:label "ClosedConstraintPath" ;
  rdfs:comment "A sequence of constraint applications forming a closed loop in the constraint nerve — beginning and ending at the same site assignment. The Monodromy of the loop is the net DihedralElement accumulated when traversing it." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/PhaseBoundaryType>
  a owl:Class ;
  rdfs:label "PhaseBoundaryType" ;
  rdfs:comment "A classification of phase boundary in the catastrophe diagram: period boundary (g divides 2^n − 1) or power-of-two boundary (g = 2^k)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/AchievabilityStatus>
  a owl:Class ;
  rdfs:label "AchievabilityStatus" ;
  rdfs:comment "The achievability classification of a topological signature in the morphospace. Either Achievable or Forbidden (witnessed by ImpossibilityWitness)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/HomotopyGroup>
  a owl:Class ;
  rdfs:label "HomotopyGroup" ;
  rdfs:comment "The k-th homotopy group πk(N(C), v) of the constraint nerve based at vertex v." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/HigherMonodromy>
  a owl:Class ;
  rdfs:label "HigherMonodromy" ;
  rdfs:comment "The image of πk(N(C)) → Aut(sitek) for k > 1. Generalises the MN_6 monodromy homomorphism." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/WhiteheadProduct>
  a owl:Class ;
  rdfs:label "WhiteheadProduct" ;
  rdfs:comment "The Whitehead product [α, β] ∈ πp+q−1 for α ∈ πp, β ∈ πq." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/StratificationRecord>
  a owl:Class ;
  rdfs:label "StratificationRecord" ;
  rdfs:comment "A record of the holonomy stratification of the moduli space at a given quantum level: the list of HolonomyStrata, their codimensions, and their relationship to the MorphospaceBoundary." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/observable/BaseMetric>
  a owl:Class ;
  rdfs:label "BaseMetric" ;
  rdfs:comment "Superclass for the six universal measurements. Every computation on the ring produces these six quantities: d_Δ, σ, J_k, β_k, χ, r." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/GroundingObservable>
  a owl:Class ;
  rdfs:label "GroundingObservable" ;
  rdfs:comment "The grounding metric σ = pinned sites / total sites. Ranges from 0 (no sites pinned) to 1 (fully grounded)." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/EulerCharacteristicObservable>
  a owl:Class ;
  rdfs:label "EulerCharacteristicObservable" ;
  rdfs:comment "The Euler characteristic χ = Σ(−1)^k β_k of the constraint nerve. An integer-valued topological invariant." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/observable/value>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "value" ;
  rdfs:comment "The numeric value of an observable measurement." ;
  rdfs:domain <https://uor.foundation/observable/Observable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/observable/source>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "source" ;
  rdfs:comment "The source object of this measurement (datum, partition, or path start point)." ;
  rdfs:domain <https://uor.foundation/observable/Observable> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/observable/target>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "target" ;
  rdfs:comment "The target object of this measurement (for metrics and path-end measurements)." ;
  rdfs:domain <https://uor.foundation/observable/Observable> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/observable/hasUnit>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "hasUnit" ;
  rdfs:comment "The measurement unit of this observable. Replaces the string-valued observable:unit property with a typed reference to a MeasurementUnit individual." ;
  rdfs:domain <https://uor.foundation/observable/Observable> ;
  rdfs:range <https://uor.foundation/observable/MeasurementUnit> .

<https://uor.foundation/observable/sitePosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitePosition" ;
  rdfs:comment "The site position k at which this Jacobian entry is measured." ;
  rdfs:domain <https://uor.foundation/observable/Jacobian> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/derivativeValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "derivativeValue" ;
  rdfs:comment "The discrete derivative value at this site position." ;
  rdfs:domain <https://uor.foundation/observable/Jacobian> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/observable/dimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "dimension" ;
  rdfs:comment "The dimension k of the topological observable (e.g., the degree of the Betti number or the dimension of the spectral gap)." ;
  rdfs:domain <https://uor.foundation/observable/TopologicalObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/realisedEuler>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "realisedEuler" ;
  rdfs:comment "The Euler characteristic actually achieved by this synthesis signature." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/observable/realisedBetti>
  a owl:DatatypeProperty ;
  rdfs:label "realisedBetti" ;
  rdfs:comment "Non-functional. Realised Betti number values, one assertion per homological degree." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/pageIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pageIndex" ;
  rdfs:comment "The page r of this spectral sequence page. r=1 is the initial page; convergence is declared when all d_r are zero." ;
  rdfs:domain <https://uor.foundation/observable/SpectralSequencePage> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/differentialIsZero>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "differentialIsZero" ;
  rdfs:comment "True iff d_r = 0 on this page — no further corrections to the lifted homology." ;
  rdfs:domain <https://uor.foundation/observable/SpectralSequencePage> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/convergedAt>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "convergedAt" ;
  rdfs:comment "The page index r at which the spectral sequence converged (all subsequent differentials zero)." ;
  rdfs:domain <https://uor.foundation/observable/SpectralSequencePage> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/obstructionClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionClass" ;
  rdfs:comment "The cohomology class in H^2(N(C(T))) representing this obstruction." ;
  rdfs:domain <https://uor.foundation/observable/LiftObstructionClass> ;
  rdfs:range <https://uor.foundation/cohomology/CohomologyGroup> .

<https://uor.foundation/observable/monodromyLoop>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "monodromyLoop" ;
  rdfs:comment "The closed path that generates this monodromy value." ;
  rdfs:domain <https://uor.foundation/observable/Monodromy> ;
  rdfs:range <https://uor.foundation/observable/ClosedConstraintPath> .

<https://uor.foundation/observable/monodromyElement>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "monodromyElement" ;
  rdfs:comment "The dihedral element g in D_{2^n} accumulated when traversing the loop. The monodromy is trivial iff this element is the group identity." ;
  rdfs:domain <https://uor.foundation/observable/Monodromy> ;
  rdfs:range <https://uor.foundation/observable/DihedralElement> .

<https://uor.foundation/observable/isTrivialMonodromy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isTrivialMonodromy" ;
  rdfs:comment "True iff the monodromyElement is the identity in D_{2^n}." ;
  rdfs:domain <https://uor.foundation/observable/Monodromy> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/holonomyGroup>
  a owl:ObjectProperty ;
  rdfs:label "holonomyGroup" ;
  rdfs:comment "Non-functional. The generators of the holonomy group: one DihedralElement per generating monodromy." ;
  rdfs:domain <https://uor.foundation/observable/HolonomyGroup> ;
  rdfs:range <https://uor.foundation/observable/DihedralElement> .

<https://uor.foundation/observable/holonomyGroupOrder>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "holonomyGroupOrder" ;
  rdfs:comment "The order of the holonomy group as a subgroup of D_{2^n}. For a FlatType: 1. For full dihedral holonomy: 2^{n+1}." ;
  rdfs:domain <https://uor.foundation/observable/HolonomyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/observable/pathLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pathLength" ;
  rdfs:comment "The number of constraint application steps in this closed path." ;
  rdfs:domain <https://uor.foundation/observable/ClosedConstraintPath> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/pathConstraints>
  a owl:ObjectProperty ;
  rdfs:label "pathConstraints" ;
  rdfs:comment "Non-functional. The ordered sequence of constraints traversed. One assertion per step." ;
  rdfs:domain <https://uor.foundation/observable/ClosedConstraintPath> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/observable/dihedralElementValue>
  a owl:ObjectProperty ;
  rdfs:label "dihedralElementValue" ;
  rdfs:comment "Non-functional. One assertion per generator in the normal form of the element — the sequence of neg and/or bnot operations that realises this dihedral element when composed." ;
  rdfs:domain <https://uor.foundation/observable/DihedralElement> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/observable/isIdentityElement>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isIdentityElement" ;
  rdfs:comment "True iff this element is the group identity (the trivial monodromy value)." ;
  rdfs:domain <https://uor.foundation/observable/DihedralElement> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/elementOrder>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "elementOrder" ;
  rdfs:comment "The order of this element in D_{2^n}: the smallest k >= 1 such that g^k = id. For neg and bnot: order 2." ;
  rdfs:domain <https://uor.foundation/observable/DihedralElement> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/observable/hardnessEstimate>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hardnessEstimate" ;
  rdfs:comment "An estimated computational hardness for a ThermoObservable, connecting thermodynamic cost to complexity (TH_9 realisation)." ;
  rdfs:domain <https://uor.foundation/observable/ThermoObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/observable/phaseN>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "phaseN" ;
  rdfs:comment "The ring dimension coordinate n in the (n, g) catastrophe phase diagram (PD_1 n-coordinate)." ;
  rdfs:domain <https://uor.foundation/observable/CatastropheObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/observable/phaseG>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "phaseG" ;
  rdfs:comment "The group-order coordinate g in the (n, g) catastrophe phase diagram (PD_1 g-coordinate)." ;
  rdfs:domain <https://uor.foundation/observable/CatastropheObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/observable/onResonanceLine>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "onResonanceLine" ;
  rdfs:comment "True when g divides 2^n − 1, placing this observable on a resonance line in the phase diagram (PD_4)." ;
  rdfs:domain <https://uor.foundation/observable/CatastropheObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/phaseBoundaryType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "phaseBoundaryType" ;
  rdfs:comment "The type of phase boundary at this point in the catastrophe diagram: PeriodBoundary or PowerOfTwoBoundary (PD_2)." ;
  rdfs:domain <https://uor.foundation/observable/CatastropheObservable> ;
  rdfs:range <https://uor.foundation/observable/PhaseBoundaryType> .

<https://uor.foundation/observable/achievabilityStatus>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "achievabilityStatus" ;
  rdfs:comment "The achievability classification of this observable's topological signature in the morphospace." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <https://uor.foundation/observable/AchievabilityStatus> .

<https://uor.foundation/observable/isAchievable>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isAchievable" ;
  rdfs:comment "Whether this signature has been empirically verified as achievable at some quantum level." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/isForbidden>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isForbidden" ;
  rdfs:comment "Whether this signature has been formally proven impossible by an ImpossibilityWitness." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/achievabilityWitness>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "achievabilityWitness" ;
  rdfs:comment "The proof individual (ImpossibilityWitness or AxiomaticDerivation) that grounds this signature's achievability classification." ;
  rdfs:domain <https://uor.foundation/observable/SynthesisSignature> ;
  rdfs:range <https://uor.foundation/proof/Proof> .

<https://uor.foundation/observable/rotationExponent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "rotationExponent" ;
  rdfs:comment "The rotation exponent k ∈ \\[0, 2^n) of this dihedral element in the standard representation r^k s^s. Together with reflectionBit, uniquely identifies the element within D_\\{2^n\\}." ;
  rdfs:domain <https://uor.foundation/observable/DihedralElement> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/reflectionBit>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "reflectionBit" ;
  rdfs:comment "The reflection flag s ∈ \\{0,1\\} of this dihedral element. False = pure rotation (r^k), true = reflection (r^k·s). D_7 defines composition: (r^a s^p)(r^b s^q) = r^(a + (-1)^p b) s^(p XOR q)." ;
  rdfs:domain <https://uor.foundation/observable/DihedralElement> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/homotopyDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "homotopyDimension" ;
  rdfs:comment "The dimension k of this homotopy group πk." ;
  rdfs:domain <https://uor.foundation/observable/HomotopyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/homotopyRank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "homotopyRank" ;
  rdfs:comment "The rank of this homotopy group (number of free generators)." ;
  rdfs:domain <https://uor.foundation/observable/HomotopyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/homotopyBasepoint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "homotopyBasepoint" ;
  rdfs:comment "The basepoint vertex v at which this homotopy group is computed." ;
  rdfs:domain <https://uor.foundation/observable/HomotopyGroup> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/observable/higherMonodromyDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "higherMonodromyDimension" ;
  rdfs:comment "The dimension k > 1 at which this higher monodromy acts." ;
  rdfs:domain <https://uor.foundation/observable/HigherMonodromy> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/whiteheadTrivial>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "whiteheadTrivial" ;
  rdfs:comment "True iff this Whitehead product is trivial (zero in πp+q−1)." ;
  rdfs:domain <https://uor.foundation/observable/WhiteheadProduct> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/observable/postnikovTruncation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "postnikovTruncation" ;
  rdfs:comment "The Postnikov truncation associated with this spectral sequence page." ;
  rdfs:domain <https://uor.foundation/observable/SpectralSequencePage> ;
  rdfs:range <https://uor.foundation/homology/PostnikovTruncation> .

<https://uor.foundation/observable/stratificationLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stratificationLevel" ;
  rdfs:comment "The quantum level at which this stratification is computed." ;
  rdfs:domain <https://uor.foundation/observable/StratificationRecord> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/observable/stratificationStratum>
  a owl:ObjectProperty ;
  rdfs:label "stratificationStratum" ;
  rdfs:comment "A HolonomyStratum in this stratification record." ;
  rdfs:domain <https://uor.foundation/observable/StratificationRecord> ;
  rdfs:range <https://uor.foundation/type/HolonomyStratum> .

<https://uor.foundation/observable/metricDomain>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "metricDomain" ;
  rdfs:comment "The mathematical domain of this base metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/observable/metricRange>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "metricRange" ;
  rdfs:comment "The mathematical range (codomain) of this base metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/observable/metricComposition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricComposition" ;
  rdfs:comment "How this metric composes with others in the measurement tower." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/referencesClass>
  a owl:AnnotationProperty ;
  rdfs:label "referencesClass" ;
  rdfs:comment "IRI of the existing observable class that this base metric references. Annotation-valued (not ObjectProperty) because the assertion is a class-level reference, not an instance-level one: the metric describes a class of Observable phenomena, not a specific individual." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/observable/referencesIdentity>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "referencesIdentity" ;
  rdfs:comment "The existing identity that defines this base metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/observable/saturationNumerator>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "saturationNumerator" ;
  rdfs:comment "The count of pinned sites (numerator of σ)." ;
  rdfs:domain <https://uor.foundation/observable/GroundingObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/saturationDenominator>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "saturationDenominator" ;
  rdfs:comment "The total site count (denominator of σ)." ;
  rdfs:domain <https://uor.foundation/observable/GroundingObservable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/observable/alternatingSum>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "alternatingSum" ;
  rdfs:comment "The alternating sum formula for Euler characteristic." ;
  rdfs:domain <https://uor.foundation/observable/EulerCharacteristicObservable> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/metricUnit>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricUnit" ;
  rdfs:comment "The unit of measurement for this base metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/observable/MeasurementUnit> .

<https://uor.foundation/observable/metricPrecision>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "metricPrecision" ;
  rdfs:comment "The precision or resolution of this base metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/metricMonotonicity>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricMonotonicity" ;
  rdfs:comment "Monotonicity property of this metric (e.g., non-decreasing)." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/metricDecomposition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricDecomposition" ;
  rdfs:comment "The decomposition rule for this metric into sub-metrics." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/metricTowerPosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "metricTowerPosition" ;
  rdfs:comment "The position of this metric in the metric tower." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/observable/metricComputationCost>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricComputationCost" ;
  rdfs:comment "The computational cost of evaluating this metric." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/metricBound>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "metricBound" ;
  rdfs:comment "Upper or lower bound on the metric value." ;
  rdfs:domain <https://uor.foundation/observable/BaseMetric> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/observable/landauerNats>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "landauerNats" ;
  rdfs:comment "The accumulated Landauer cost carried by a LandauerBudget instance, measured in nats. Monotonic within a pipeline invocation. The unit is observable:Nats — every increment corresponds to a number of irreversible bit-erasures times ln 2 (op:OA_5)." ;
  rdfs:domain <https://uor.foundation/observable/LandauerBudget> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/observable/Bits>
  a owl:NamedIndividual , <https://uor.foundation/observable/MeasurementUnit> ;
  rdfs:label "Bits" ;
  rdfs:comment "Information-theoretic unit: the measurement is in bits (e.g., Hamming weight, entropy)." .

<https://uor.foundation/observable/RingSteps>
  a owl:NamedIndividual , <https://uor.foundation/observable/MeasurementUnit> ;
  rdfs:label "RingSteps" ;
  rdfs:comment "Ring-arithmetic unit: the measurement is in ring distance steps (|x - y| mod 2^n)." .

<https://uor.foundation/observable/Dimensionless>
  a owl:NamedIndividual , <https://uor.foundation/observable/MeasurementUnit> ;
  rdfs:label "Dimensionless" ;
  rdfs:comment "Dimensionless unit: the measurement is a pure number (e.g., winding number, Betti number, spectral gap)." .

<https://uor.foundation/observable/Nats>
  a owl:NamedIndividual , <https://uor.foundation/observable/MeasurementUnit> ;
  rdfs:label "Nats" ;
  rdfs:comment "Natural information unit: entropy measured in nats (using natural logarithm). S_residual is expressed in nats when computed as (Σ κ_k − χ) × ln 2." .

<https://uor.foundation/observable/PeriodBoundary>
  a owl:NamedIndividual , <https://uor.foundation/observable/PhaseBoundaryType> ;
  rdfs:label "PeriodBoundary" ;
  rdfs:comment "A phase boundary where g divides 2^n − 1, meaning g is a period of the multiplicative structure of R_n." .

<https://uor.foundation/observable/PowerOfTwoBoundary>
  a owl:NamedIndividual , <https://uor.foundation/observable/PhaseBoundaryType> ;
  rdfs:label "PowerOfTwoBoundary" ;
  rdfs:comment "A phase boundary where g = 2^k, meaning g aligns with the binary stratification of R_n." .

<https://uor.foundation/observable/Achievable>
  a owl:NamedIndividual , <https://uor.foundation/observable/AchievabilityStatus> ;
  rdfs:label "Achievable" ;
  rdfs:comment "The signature has been verified as achievable at some quantum level by an AxiomaticDerivation proof." .

<https://uor.foundation/observable/Forbidden>
  a owl:NamedIndividual , <https://uor.foundation/observable/AchievabilityStatus> ;
  rdfs:label "Forbidden" ;
  rdfs:comment "The signature has been formally proven impossible by an ImpossibilityWitness deriving from MS_1, MS_2, or other impossibility theorems." .

<https://uor.foundation/observable/d_delta_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "d_delta_metric" ;
  rdfs:comment "d_Δ: the incompatibility metric |d_R − d_H| per site pair." ;
  <https://uor.foundation/observable/metricDomain> "pair of ring elements" ;
  <https://uor.foundation/observable/metricRange> "non-negative integer" ;
  <https://uor.foundation/observable/referencesClass> <https://uor.foundation/observable/IncompatibilityMetric> .

<https://uor.foundation/observable/sigma_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "sigma_metric" ;
  rdfs:comment "σ: the grounding metric, pinned sites / total sites." ;
  <https://uor.foundation/observable/metricDomain> "computation state" ;
  <https://uor.foundation/observable/metricRange> "decimal in [0, 1]" ;
  <https://uor.foundation/observable/referencesIdentity> <https://uor.foundation/op/GS_2> .

<https://uor.foundation/observable/jacobian_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "jacobian_metric" ;
  rdfs:comment "J_k: per-site curvature, ∂_R f_k." ;
  <https://uor.foundation/observable/metricDomain> "computation state × site index" ;
  <https://uor.foundation/observable/metricRange> "decimal" ;
  <https://uor.foundation/observable/referencesClass> <https://uor.foundation/observable/Jacobian> ;
  <https://uor.foundation/observable/referencesIdentity> <https://uor.foundation/op/DC_6> .

<https://uor.foundation/observable/betti_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "betti_metric" ;
  rdfs:comment "β_k: per-dimension Betti number of the constraint nerve." ;
  <https://uor.foundation/observable/metricDomain> "simplicial complex × dimension" ;
  <https://uor.foundation/observable/metricRange> "non-negative integer" ;
  <https://uor.foundation/observable/referencesClass> <https://uor.foundation/observable/BettiNumber> .

<https://uor.foundation/observable/euler_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "euler_metric" ;
  rdfs:comment "χ: Euler characteristic, Σ(−1)^k β_k." ;
  <https://uor.foundation/observable/metricDomain> "simplicial complex" ;
  <https://uor.foundation/observable/metricRange> "integer" ;
  <https://uor.foundation/observable/referencesIdentity> <https://uor.foundation/op/IT_2> .

<https://uor.foundation/observable/residual_metric>
  a owl:NamedIndividual , <https://uor.foundation/observable/BaseMetric> ;
  rdfs:label "residual_metric" ;
  rdfs:comment "r: count of free (unpinned) sites, the residual entropy." ;
  <https://uor.foundation/observable/metricDomain> "computation state" ;
  <https://uor.foundation/observable/metricRange> "non-negative integer" ;
  <https://uor.foundation/observable/referencesClass> <https://uor.foundation/observable/ResidualEntropy> .

# Namespace: carry
<https://uor.foundation/carry/>
  a owl:Ontology ;
  rdfs:label "UOR Carry Algebra" ;
  rdfs:comment "Carry chain algebra: generate/propagate/kill event classification, carry profiles, encoding configurations, and encoding quality metrics for d_Δ optimization." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/partition/> ;
.

<https://uor.foundation/carry/CarryChain>
  a owl:Class ;
  rdfs:label "CarryChain" ;
  rdfs:comment "The Boolean function chain c_{k+1} = or(and(x_k, y_k), and(xor(x_k, y_k), c_k)). The carry chain is the algebraic mechanism behind the incompatibility metric d_Δ." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/carry/CarryEvent>
  a owl:Class ;
  rdfs:label "CarryEvent" ;
  rdfs:comment "A single carry event at site k. Three kinds: Generate (and(x_k, y_k) = 1), Propagate (xor(x_k, y_k) = 1 and c_k = 1), Kill (neither generate nor propagate)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/carry/CarryProfile>
  a owl:Class ;
  rdfs:label "CarryProfile" ;
  rdfs:comment "The complete carry pattern for an addition x + y. Aggregates carry events across all sites into counts and position masks." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/carry/EncodingConfiguration>
  a owl:Class ;
  rdfs:label "EncodingConfiguration" ;
  rdfs:comment "A mapping from a finite symbol set S to Z/(2^k)Z where 2^k ≥ |S|. Determines how domain values are represented as ring elements." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/carry/EncodingQuality>
  a owl:Class ;
  rdfs:label "EncodingQuality" ;
  rdfs:comment "The d_Δ quality metric for an encoding over observed data. Measures how well an encoding minimizes carry-induced metric incompatibility." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/carry/CarryDepthObservable>
  a owl:Class ;
  rdfs:label "CarryDepthObservable" ;
  rdfs:comment "Observes the carry depth of a Datum in the W₂ tower, computed as the maximum carry-chain length in any operation producing it. Used as the bound observable for the carryConstraintKind BoundConstraint." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/carry/chainLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "chainLength" ;
  rdfs:comment "The number of sites in this carry chain." ;
  rdfs:domain <https://uor.foundation/carry/CarryChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/generateMask>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "generateMask" ;
  rdfs:comment "Bit mask of site positions where carry is generated: and(x_k, y_k) = 1." ;
  rdfs:domain <https://uor.foundation/carry/CarryChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/propagateMask>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "propagateMask" ;
  rdfs:comment "Bit mask of site positions where carry propagates: xor(x_k, y_k) = 1." ;
  rdfs:domain <https://uor.foundation/carry/CarryChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/killMask>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "killMask" ;
  rdfs:comment "Bit mask of site positions where carry is killed: neither generated nor propagated." ;
  rdfs:domain <https://uor.foundation/carry/CarryChain> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/eventKind>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "eventKind" ;
  rdfs:comment "The kind of carry event: Generate, Propagate, or Kill." ;
  rdfs:domain <https://uor.foundation/carry/CarryEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/sitePosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitePosition" ;
  rdfs:comment "The site index k at which this carry event occurs." ;
  rdfs:domain <https://uor.foundation/carry/CarryEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/carryCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "carryCount" ;
  rdfs:comment "The total number of carry events in this profile." ;
  rdfs:domain <https://uor.foundation/carry/CarryProfile> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/maxPropagationLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxPropagationLength" ;
  rdfs:comment "The longest consecutive propagation run in this profile." ;
  rdfs:domain <https://uor.foundation/carry/CarryProfile> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/carry/profileChain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "profileChain" ;
  rdfs:comment "The carry chain that this profile summarizes." ;
  rdfs:domain <https://uor.foundation/carry/CarryProfile> ;
  rdfs:range <https://uor.foundation/carry/CarryChain> .

<https://uor.foundation/carry/symbolSetSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "symbolSetSize" ;
  rdfs:comment "The cardinality of the symbol set S being encoded." ;
  rdfs:domain <https://uor.foundation/carry/EncodingConfiguration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/carry/quantizationBits>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "quantizationBits" ;
  rdfs:comment "The number of bits k used for encoding (2^k ≥ |S|)." ;
  rdfs:domain <https://uor.foundation/carry/EncodingConfiguration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/carry/encodingMap>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "encodingMap" ;
  rdfs:comment "String representation of the mapping from symbols to ring elements." ;
  rdfs:domain <https://uor.foundation/carry/EncodingConfiguration> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/carry/meanDelta>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "meanDelta" ;
  rdfs:comment "The mean d_Δ over observed pairs for this encoding." ;
  rdfs:domain <https://uor.foundation/carry/EncodingQuality> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/carry/discriminationRatio>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "discriminationRatio" ;
  rdfs:comment "The ratio of distinguishable pairs to total pairs under this encoding." ;
  rdfs:domain <https://uor.foundation/carry/EncodingQuality> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/carry/isOptimalEncoding>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isOptimalEncoding" ;
  rdfs:comment "Whether this encoding minimizes Σ d_Δ over observed pairs." ;
  rdfs:domain <https://uor.foundation/carry/EncodingQuality> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

# Namespace: homology
<https://uor.foundation/homology/>
  a owl:Ontology ;
  rdfs:label "UOR Homology" ;
  rdfs:comment "Simplicial complexes, chain complexes, boundary operators, and homology groups for structural reasoning." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/resolver/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/op/> ;
.

<https://uor.foundation/homology/Simplex>
  a owl:Class ;
  rdfs:label "Simplex" ;
  rdfs:comment "A k-simplex: a finite set of k+1 vertices drawn from constraint objects." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/SimplicialComplex>
  a owl:Class ;
  rdfs:label "SimplicialComplex" ;
  rdfs:comment "A simplicial complex: a set of simplices closed under taking faces." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/FaceMap>
  a owl:Class ;
  rdfs:label "FaceMap" ;
  rdfs:comment "A face map d_i: removes vertex i from a simplex, producing a face." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/ChainGroup>
  a owl:Class ;
  rdfs:label "ChainGroup" ;
  rdfs:comment "A free abelian group generated by k-simplices (the k-th chain group C_k)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/BoundaryOperator>
  a owl:Class ;
  rdfs:label "BoundaryOperator" ;
  rdfs:comment "The boundary operator ∂_k: C_k → C_{k-1}. Satisfies ∂² = 0." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/ChainComplex>
  a owl:Class ;
  rdfs:label "ChainComplex" ;
  rdfs:comment "A chain complex: a sequence of chain groups connected by boundary operators." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/HomologyGroup>
  a owl:Class ;
  rdfs:label "HomologyGroup" ;
  rdfs:comment "The k-th homology group H_k = ker(∂_k) / im(∂_{k+1}). Measures k-dimensional holes." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/NerveFunctor>
  a owl:Class ;
  rdfs:label "NerveFunctor" ;
  rdfs:comment "The nerve functor N: maps a set of constraints to a simplicial complex." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/ChainFunctor>
  a owl:Class ;
  rdfs:label "ChainFunctor" ;
  rdfs:comment "The chain functor C: maps a simplicial complex to a chain complex." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/KanComplex>
  a owl:Class ;
  rdfs:label "KanComplex" ;
  rdfs:comment "A simplicial set satisfying the Kan extension condition. The constraint nerve, when promoted from a SimplicialComplex to a KanComplex, carries a full homotopy type — not just its homology groups." ;
  rdfs:subClassOf <https://uor.foundation/homology/SimplicialComplex> ;
.

<https://uor.foundation/homology/HornFiller>
  a owl:Class ;
  rdfs:label "HornFiller" ;
  rdfs:comment "A witness that a given horn (an incomplete simplex boundary) can be filled, certifying the Kan condition at a specific dimension and position." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/PostnikovTruncation>
  a owl:Class ;
  rdfs:label "PostnikovTruncation" ;
  rdfs:comment "The k-th Postnikov truncation τ≤k of the constraint nerve: a KanComplex whose homotopy groups πj vanish for j > k." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/KInvariant>
  a owl:Class ;
  rdfs:label "KInvariant" ;
  rdfs:comment "The k-invariant κk that classifies the extension from the (k−1)-truncation to the k-truncation of the Postnikov tower. Trivial κk means the truncation splits as a product." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/homology/DeformationComplex>
  a owl:Class ;
  rdfs:label "DeformationComplex" ;
  rdfs:comment "The deformation complex of a CompleteType T: a chain complex whose H⁰ = automorphisms, H¹ = first-order deformations, H² = obstructions to extending deformations." ;
  rdfs:subClassOf <https://uor.foundation/homology/ChainComplex> ;
.

<https://uor.foundation/homology/dimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "dimension" ;
  rdfs:comment "The dimension k of a simplex (number of vertices minus one)." ;
  rdfs:domain <https://uor.foundation/homology/Simplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/homology/vertex>
  a owl:ObjectProperty ;
  rdfs:label "vertex" ;
  rdfs:comment "A vertex of this simplex, drawn from the set of constraint objects." ;
  rdfs:domain <https://uor.foundation/homology/Simplex> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/homology/vertexCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "vertexCount" ;
  rdfs:comment "The number of vertices in this simplex (dimension + 1)." ;
  rdfs:domain <https://uor.foundation/homology/Simplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/homology/isFaceOf>
  a owl:ObjectProperty ;
  rdfs:label "isFaceOf" ;
  rdfs:comment "Indicates that this simplex is a face of another simplex." ;
  rdfs:domain <https://uor.foundation/homology/Simplex> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/homology/pinIntersection>
  a owl:ObjectProperty ;
  rdfs:label "pinIntersection" ;
  rdfs:comment "A site coordinate in the partition whose intersection pins this simplex." ;
  rdfs:domain <https://uor.foundation/homology/Simplex> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/homology/hasSimplex>
  a owl:ObjectProperty ;
  rdfs:label "hasSimplex" ;
  rdfs:comment "A simplex belonging to this simplicial complex." ;
  rdfs:domain <https://uor.foundation/homology/SimplicialComplex> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/homology/maxDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxDimension" ;
  rdfs:comment "The maximum dimension of any simplex in this simplicial complex." ;
  rdfs:domain <https://uor.foundation/homology/SimplicialComplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/homology/eulerCharacteristic>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "eulerCharacteristic" ;
  rdfs:comment "The Euler characteristic of this simplicial complex: the alternating sum of simplex counts by dimension." ;
  rdfs:domain <https://uor.foundation/homology/SimplicialComplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/homology/simplicialVertexCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "simplicialVertexCount" ;
  rdfs:comment "The total number of vertices (0-simplices) in this simplicial complex." ;
  rdfs:domain <https://uor.foundation/homology/SimplicialComplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/removesVertex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "removesVertex" ;
  rdfs:comment "The index i of the vertex removed by this face map d_i." ;
  rdfs:domain <https://uor.foundation/homology/FaceMap> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/sourceSimplex>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceSimplex" ;
  rdfs:comment "The source simplex of this face map." ;
  rdfs:domain <https://uor.foundation/homology/FaceMap> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/homology/targetFace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetFace" ;
  rdfs:comment "The target face (result simplex) of this face map." ;
  rdfs:domain <https://uor.foundation/homology/FaceMap> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/homology/degree>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "degree" ;
  rdfs:comment "The degree k of this chain group (the dimension of its generating simplices)." ;
  rdfs:domain <https://uor.foundation/homology/ChainGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/homology/rank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "rank" ;
  rdfs:comment "The rank of a free abelian group (number of generators)." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/generatedBy>
  a owl:ObjectProperty ;
  rdfs:label "generatedBy" ;
  rdfs:comment "A simplex that generates this chain group." ;
  rdfs:domain <https://uor.foundation/homology/ChainGroup> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/homology/sourceGroup>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceGroup" ;
  rdfs:comment "The source chain group C_k of this boundary operator." ;
  rdfs:domain <https://uor.foundation/homology/BoundaryOperator> ;
  rdfs:range <https://uor.foundation/homology/ChainGroup> .

<https://uor.foundation/homology/targetGroup>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetGroup" ;
  rdfs:comment "The target chain group C_{k-1} of this boundary operator." ;
  rdfs:domain <https://uor.foundation/homology/BoundaryOperator> ;
  rdfs:range <https://uor.foundation/homology/ChainGroup> .

<https://uor.foundation/homology/satisfiesBoundarySquaredZero>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "satisfiesBoundarySquaredZero" ;
  rdfs:comment "Whether this boundary operator satisfies the fundamental property ∂² = 0." ;
  rdfs:domain <https://uor.foundation/homology/BoundaryOperator> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/homology/hasChainGroup>
  a owl:ObjectProperty ;
  rdfs:label "hasChainGroup" ;
  rdfs:comment "A chain group belonging to this chain complex." ;
  rdfs:domain <https://uor.foundation/homology/ChainComplex> ;
  rdfs:range <https://uor.foundation/homology/ChainGroup> .

<https://uor.foundation/homology/hasBoundary>
  a owl:ObjectProperty ;
  rdfs:label "hasBoundary" ;
  rdfs:comment "A boundary operator belonging to this chain complex." ;
  rdfs:domain <https://uor.foundation/homology/ChainComplex> ;
  rdfs:range <https://uor.foundation/homology/BoundaryOperator> .

<https://uor.foundation/homology/homologyDegree>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "homologyDegree" ;
  rdfs:comment "The degree k of this homology group H_k." ;
  rdfs:domain <https://uor.foundation/homology/HomologyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/homology/bettiNumber>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bettiNumber" ;
  rdfs:comment "The Betti number β_k = rank(H_k): the rank of this homology group." ;
  rdfs:domain <https://uor.foundation/homology/HomologyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/kanWitness>
  a owl:ObjectProperty ;
  rdfs:label "kanWitness" ;
  rdfs:comment "A horn filler witnessing the Kan condition for this complex." ;
  rdfs:domain <https://uor.foundation/homology/KanComplex> ;
  rdfs:range <https://uor.foundation/homology/HornFiller> .

<https://uor.foundation/homology/hornDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hornDimension" ;
  rdfs:comment "The dimension of the horn that this filler completes." ;
  rdfs:domain <https://uor.foundation/homology/HornFiller> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/hornPosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hornPosition" ;
  rdfs:comment "The position (missing face index) of the horn that this filler completes." ;
  rdfs:domain <https://uor.foundation/homology/HornFiller> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/truncationLevel>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "truncationLevel" ;
  rdfs:comment "The truncation level k of this Postnikov truncation τ≤k." ;
  rdfs:domain <https://uor.foundation/homology/PostnikovTruncation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/truncationSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "truncationSource" ;
  rdfs:comment "The KanComplex from which this Postnikov truncation is derived." ;
  rdfs:domain <https://uor.foundation/homology/PostnikovTruncation> ;
  rdfs:range <https://uor.foundation/homology/KanComplex> .

<https://uor.foundation/homology/kInvariant>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "kInvariant" ;
  rdfs:comment "The k-invariant classifying the extension at this truncation level." ;
  rdfs:domain <https://uor.foundation/homology/PostnikovTruncation> ;
  rdfs:range <https://uor.foundation/homology/KInvariant> .

<https://uor.foundation/homology/kInvariantTrivial>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "kInvariantTrivial" ;
  rdfs:comment "True iff this k-invariant is trivial, meaning the Postnikov truncation splits as a product." ;
  rdfs:domain <https://uor.foundation/homology/KInvariant> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/homology/deformationBase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "deformationBase" ;
  rdfs:comment "The CompleteType whose deformation complex this is." ;
  rdfs:domain <https://uor.foundation/homology/DeformationComplex> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/homology/tangentDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "tangentDimension" ;
  rdfs:comment "The dimension of the tangent space H¹(Def(T)): the number of first-order deformations." ;
  rdfs:domain <https://uor.foundation/homology/DeformationComplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/obstructionDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionDimension" ;
  rdfs:comment "The dimension of the obstruction space H²(Def(T)): the number of independent obstructions to extending deformations." ;
  rdfs:domain <https://uor.foundation/homology/DeformationComplex> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/homology/groundedIn>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedIn" ;
  rdfs:comment "The homology group that grounds this Betti number observable." ;
  rdfs:domain <https://uor.foundation/observable/BettiNumber> ;
  rdfs:range <https://uor.foundation/homology/HomologyGroup> .

<https://uor.foundation/homology/laplacianOf>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "laplacianOf" ;
  rdfs:comment "The chain complex whose Laplacian determines this spectral gap." ;
  rdfs:domain <https://uor.foundation/observable/SpectralGap> ;
  rdfs:range <https://uor.foundation/homology/ChainComplex> .

<https://uor.foundation/homology/homologicalAnalysis>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "homologicalAnalysis" ;
  rdfs:comment "The chain complex used for homological analysis of a resolution state." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/homology/ChainComplex> .

<https://uor.foundation/homology/boundarySquaredZero>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "boundarySquaredZero" ;
  rdfs:comment "∂² = 0: the boundary of a boundary is zero." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_boundarySquaredZero_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_boundarySquaredZero_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_boundarySquaredZero_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/homology/nerveFunctorN>
  a owl:NamedIndividual , <https://uor.foundation/homology/NerveFunctor> ;
  rdfs:label "nerveFunctorN" ;
  rdfs:comment "The nerve functor N: constraints → simplicial complex." .

<https://uor.foundation/homology/chainFunctorC>
  a owl:NamedIndividual , <https://uor.foundation/homology/ChainFunctor> ;
  rdfs:label "chainFunctorC" ;
  rdfs:comment "The chain functor C: simplicial complex → chain complex." .

<https://uor.foundation/homology/psi_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "psi_4" ;
  rdfs:comment "ψ_4: HomologyGroups → BettiNumbers (extraction functor)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_psi_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_psi_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_psi_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/homology/indexBridge>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "indexBridge" ;
  rdfs:comment "Index bridge: connects Euler characteristic to alternating Betti sum." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_indexBridge_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_indexBridge_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_indexBridge_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

# Namespace: cohomology
<https://uor.foundation/cohomology/>
  a owl:Ontology ;
  rdfs:label "UOR Cohomology" ;
  rdfs:comment "Cochain complexes, sheaf cohomology, and local-to-global obstruction detection." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/homology/> ;
  owl:imports <https://uor.foundation/resolver/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/partition/> ;
.

<https://uor.foundation/cohomology/CochainGroup>
  a owl:Class ;
  rdfs:label "CochainGroup" ;
  rdfs:comment "A cochain group: the dual of a chain group, maps chains to coefficients." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/CoboundaryOperator>
  a owl:Class ;
  rdfs:label "CoboundaryOperator" ;
  rdfs:comment "The coboundary operator δ^k: C^k → C^{k+1}. Satisfies δ² = 0." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/CochainComplex>
  a owl:Class ;
  rdfs:label "CochainComplex" ;
  rdfs:comment "A cochain complex: a sequence of cochain groups connected by coboundary operators." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/CohomologyGroup>
  a owl:Class ;
  rdfs:label "CohomologyGroup" ;
  rdfs:comment "The k-th cohomology group H^k = ker(δ^k) / im(δ^{k-1}). Measures k-dimensional obstructions." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/Sheaf>
  a owl:Class ;
  rdfs:label "Sheaf" ;
  rdfs:comment "A sheaf F over a simplicial complex: assigns data to each simplex with restriction maps." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/Stalk>
  a owl:Class ;
  rdfs:label "Stalk" ;
  rdfs:comment "A stalk F_σ: the local data of a sheaf at a simplex σ." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/Section>
  a owl:Class ;
  rdfs:label "Section" ;
  rdfs:comment "A global section of a sheaf: a consistent choice of local data across all simplices." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/LocalSection>
  a owl:Class ;
  rdfs:label "LocalSection" ;
  rdfs:comment "A local section: a consistent choice of data over a subcomplex." ;
  rdfs:subClassOf <https://uor.foundation/cohomology/Section> ;
.

<https://uor.foundation/cohomology/RestrictionMap>
  a owl:Class ;
  rdfs:label "RestrictionMap" ;
  rdfs:comment "A restriction map ρ_{σ,τ}: maps data from a simplex to a face." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/GluingObstruction>
  a owl:Class ;
  rdfs:label "GluingObstruction" ;
  rdfs:comment "A gluing obstruction: a cohomology class that detects when local sections fail to glue." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cohomology/cochainDegree>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cochainDegree" ;
  rdfs:comment "The degree k of this cochain group C^k." ;
  rdfs:domain <https://uor.foundation/cohomology/CochainGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/cohomology/cochainRank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cochainRank" ;
  rdfs:comment "The rank (dimension) of this cochain group." ;
  rdfs:domain <https://uor.foundation/cohomology/CochainGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/cohomology/dualOf>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dualOf" ;
  rdfs:comment "The chain group that this cochain group is dual to." ;
  rdfs:domain <https://uor.foundation/cohomology/CochainGroup> ;
  rdfs:range <https://uor.foundation/homology/ChainGroup> .

<https://uor.foundation/cohomology/coboundarySource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "coboundarySource" ;
  rdfs:comment "The source cochain group of this coboundary operator." ;
  rdfs:domain <https://uor.foundation/cohomology/CoboundaryOperator> ;
  rdfs:range <https://uor.foundation/cohomology/CochainGroup> .

<https://uor.foundation/cohomology/coboundaryTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "coboundaryTarget" ;
  rdfs:comment "The target cochain group of this coboundary operator." ;
  rdfs:domain <https://uor.foundation/cohomology/CoboundaryOperator> ;
  rdfs:range <https://uor.foundation/cohomology/CochainGroup> .

<https://uor.foundation/cohomology/satisfiesCoboundarySquaredZero>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "satisfiesCoboundarySquaredZero" ;
  rdfs:comment "Whether this coboundary operator satisfies δ² = 0." ;
  rdfs:domain <https://uor.foundation/cohomology/CoboundaryOperator> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/cohomology/hasCochainGroup>
  a owl:ObjectProperty ;
  rdfs:label "hasCochainGroup" ;
  rdfs:comment "A cochain group belonging to this cochain complex." ;
  rdfs:domain <https://uor.foundation/cohomology/CochainComplex> ;
  rdfs:range <https://uor.foundation/cohomology/CochainGroup> .

<https://uor.foundation/cohomology/hasCoboundary>
  a owl:ObjectProperty ;
  rdfs:label "hasCoboundary" ;
  rdfs:comment "A coboundary operator belonging to this cochain complex." ;
  rdfs:domain <https://uor.foundation/cohomology/CochainComplex> ;
  rdfs:range <https://uor.foundation/cohomology/CoboundaryOperator> .

<https://uor.foundation/cohomology/cohomologyDegree>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cohomologyDegree" ;
  rdfs:comment "The degree k of this cohomology group H^k." ;
  rdfs:domain <https://uor.foundation/cohomology/CohomologyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/cohomology/cohomologyRank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cohomologyRank" ;
  rdfs:comment "The rank (dimension) of this cohomology group." ;
  rdfs:domain <https://uor.foundation/cohomology/CohomologyGroup> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/cohomology/sheafOver>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sheafOver" ;
  rdfs:comment "The simplicial complex that this sheaf is defined over." ;
  rdfs:domain <https://uor.foundation/cohomology/Sheaf> ;
  rdfs:range <https://uor.foundation/homology/SimplicialComplex> .

<https://uor.foundation/cohomology/coefficientIn>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "coefficientIn" ;
  rdfs:comment "The coefficient ring of this sheaf." ;
  rdfs:domain <https://uor.foundation/cohomology/Sheaf> ;
  rdfs:range <https://uor.foundation/schema/Ring> .

<https://uor.foundation/cohomology/hasStalks>
  a owl:ObjectProperty ;
  rdfs:label "hasStalks" ;
  rdfs:comment "A stalk belonging to this sheaf." ;
  rdfs:domain <https://uor.foundation/cohomology/Sheaf> ;
  rdfs:range <https://uor.foundation/cohomology/Stalk> .

<https://uor.foundation/cohomology/stalkAt>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stalkAt" ;
  rdfs:comment "The simplex at which this stalk is located." ;
  rdfs:domain <https://uor.foundation/cohomology/Stalk> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/cohomology/restrictsFrom>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "restrictsFrom" ;
  rdfs:comment "The source simplex of this restriction map." ;
  rdfs:domain <https://uor.foundation/cohomology/RestrictionMap> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/cohomology/restrictsTo>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "restrictsTo" ;
  rdfs:comment "The target simplex (face) of this restriction map." ;
  rdfs:domain <https://uor.foundation/cohomology/RestrictionMap> ;
  rdfs:range <https://uor.foundation/homology/Simplex> .

<https://uor.foundation/cohomology/hasGlobalSection>
  a owl:ObjectProperty ;
  rdfs:label "hasGlobalSection" ;
  rdfs:comment "A global section of this sheaf." ;
  rdfs:domain <https://uor.foundation/cohomology/Sheaf> ;
  rdfs:range <https://uor.foundation/cohomology/Section> .

<https://uor.foundation/cohomology/obstructionClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "obstructionClass" ;
  rdfs:comment "The cohomology class that this gluing obstruction represents." ;
  rdfs:domain <https://uor.foundation/cohomology/GluingObstruction> ;
  rdfs:range <https://uor.foundation/cohomology/CohomologyGroup> .

<https://uor.foundation/cohomology/addressesSuggestion>
  a owl:ObjectProperty ;
  rdfs:label "addressesSuggestion" ;
  rdfs:comment "The refinement suggestion that, if applied, would resolve this gluing obstruction. Computed by the kernel when ψ₆ detects H^1 ≠ 0: the obstruction class indexes the site pair that is incompatible, and the suggestion targets that pair with a new bridging constraint." ;
  rdfs:domain <https://uor.foundation/cohomology/GluingObstruction> ;
  rdfs:range <https://uor.foundation/resolver/RefinementSuggestion> .

<https://uor.foundation/cohomology/sheafAnalysis>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sheafAnalysis" ;
  rdfs:comment "The sheaf analysis associated with a resolution state." ;
  rdfs:domain <https://uor.foundation/resolver/ResolutionState> ;
  rdfs:range <https://uor.foundation/cohomology/Sheaf> .

<https://uor.foundation/cohomology/coboundarySquaredZero>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "coboundarySquaredZero" ;
  rdfs:comment "δ² = 0: the coboundary of a coboundary is zero." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_coboundarySquaredZero_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_coboundarySquaredZero_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_coboundarySquaredZero_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/cohomology/deRhamDuality>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "deRhamDuality" ;
  rdfs:comment "Discrete de Rham duality: H^k ≅ Hom(H_k, R)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_deRhamDuality_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_deRhamDuality_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_deRhamDuality_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/cohomology/sheafCohomologyBridge>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "sheafCohomologyBridge" ;
  rdfs:comment "Sheaf cohomology equals simplicial cohomology for constant sheaves." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_sheafCohomologyBridge_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_sheafCohomologyBridge_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_sheafCohomologyBridge_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/cohomology/localGlobalPrinciple>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "localGlobalPrinciple" ;
  rdfs:comment "Local-global principle: H^1(K; F) = 0 implies all local sections glue to global sections." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_localGlobalPrinciple_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_localGlobalPrinciple_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_localGlobalPrinciple_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

# Namespace: proof
<https://uor.foundation/proof/>
  a owl:Ontology ;
  rdfs:label "UOR Proofs" ;
  rdfs:comment "Kernel-produced verification proofs attesting to algebraic properties of UOR objects and operations." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/derivation/> ;
  owl:imports <https://uor.foundation/observable/> ;
.

<https://uor.foundation/proof/Proof>
  a owl:Class ;
  rdfs:label "Proof" ;
  rdfs:comment "A kernel-produced attestation that a given algebraic property holds. The root class for all proof types." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/CoherenceProof>
  a owl:Class ;
  rdfs:label "CoherenceProof" ;
  rdfs:comment "A proof of coherence: the type system and ring structure are mutually consistent at a given quantum level." ;
  rdfs:subClassOf <https://uor.foundation/proof/Proof> ;
.

<https://uor.foundation/proof/ComputationCertificate>
  a owl:Class ;
  rdfs:label "ComputationCertificate" ;
  rdfs:comment "A proof confirmed by exhaustive execution over R_n at a specific quantum level. The kernel ran the identity against all 2^n inputs and observed that it holds. The proof:atWittLevel property records the level; proof:witness links to the WitnessData. CriticalIdentityProof is a subclass of ComputationCertificate." ;
  rdfs:subClassOf <https://uor.foundation/proof/Proof> ;
.

<https://uor.foundation/proof/AxiomaticDerivation>
  a owl:Class ;
  rdfs:label "AxiomaticDerivation" ;
  rdfs:comment "A proof that follows from previously established axioms or definitions by equational, structural, or topological reasoning. The proof:derivationWitness property links to a derivation:Derivation individual recording the rewrite chain. All pipeline, constraint, observable, and topological identities are AxiomaticDerivations." ;
  rdfs:subClassOf <https://uor.foundation/proof/Proof> ;
.

<https://uor.foundation/proof/CriticalIdentityProof>
  a owl:Class ;
  rdfs:label "CriticalIdentityProof" ;
  rdfs:comment "A proof of the critical identity: neg(bnot(x)) = succ(x) for all x in R_n. This is the foundational theorem of the UOR kernel." ;
  rdfs:subClassOf <https://uor.foundation/proof/ComputationCertificate> ;
.

<https://uor.foundation/proof/WitnessData>
  a owl:Class ;
  rdfs:label "WitnessData" ;
  rdfs:comment "Supporting data for a proof: specific examples, counter-examples checked, or intermediate computation results." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/ImpossibilityWitness>
  a owl:Class ;
  rdfs:label "ImpossibilityWitness" ;
  rdfs:comment "A formal witness that a topological signature (χ, β_k) is impossible to achieve for any ConstrainedType. Carries the algebraic reason and the verification domain grounding the impossibility." ;
  rdfs:subClassOf <https://uor.foundation/proof/Proof> ;
.

<https://uor.foundation/proof/MorphospaceRecord>
  a owl:Class ;
  rdfs:label "MorphospaceRecord" ;
  rdfs:comment "A formal record of a morphospace boundary point — either an achievable or forbidden topological signature. Aggregated by MorphospaceBoundary to form the queryable morphospace map." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/MorphospaceBoundary>
  a owl:Class ;
  rdfs:label "MorphospaceBoundary" ;
  rdfs:comment "An aggregate of ImpossibilityWitness instances forming the queryable morphospace map. SPARQL over this structure answers achievability queries in O(1)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/InductiveProof>
  a owl:Class ;
  rdfs:label "InductiveProof" ;
  rdfs:comment "A proof by structural induction on the quantum level index k. Carries a base case proof, an inductive step proof, and the minimum k for which the induction holds." ;
  rdfs:subClassOf <https://uor.foundation/proof/Proof> ;
.

<https://uor.foundation/proof/ProofStrategy>
  a owl:Class ;
  rdfs:label "ProofStrategy" ;
  rdfs:comment "A controlled vocabulary of proof methods. Each proof individual carries exactly one strategy from this vocabulary, enabling compilation to verified theorem provers." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/DerivationTerm>
  a owl:Class ;
  rdfs:label "DerivationTerm" ;
  rdfs:comment "Root AST node for proof construction terms. Distinct from schema:TermExpression which represents mathematical terms; DerivationTerm represents proof constructions (tactic applications, lemma invocations, induction scaffolding)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/proof/TacticApplication>
  a owl:Class ;
  rdfs:label "TacticApplication" ;
  rdfs:comment "A proof step applying a named tactic (from ProofStrategy) with arguments. Maps to a Lean4 tactic invocation." ;
  rdfs:subClassOf <https://uor.foundation/proof/DerivationTerm> ;
.

<https://uor.foundation/proof/LemmaInvocation>
  a owl:Class ;
  rdfs:label "LemmaInvocation" ;
  rdfs:comment "A proof step invoking a previously proved identity as a lemma. References the identity via proof:dependsOn." ;
  rdfs:subClassOf <https://uor.foundation/proof/DerivationTerm> ;
.

<https://uor.foundation/proof/InductionStep>
  a owl:Class ;
  rdfs:label "InductionStep" ;
  rdfs:comment "A proof step performing structural induction: base case derivation, inductive hypothesis, and step derivation." ;
  rdfs:subClassOf <https://uor.foundation/proof/DerivationTerm> ;
.

<https://uor.foundation/proof/ComputationStep>
  a owl:Class ;
  rdfs:label "ComputationStep" ;
  rdfs:comment "A proof step performing exhaustive computation at a specific quantum level as verification witness." ;
  rdfs:subClassOf <https://uor.foundation/proof/DerivationTerm> ;
.

<https://uor.foundation/proof/InhabitanceImpossibilityWitness>
  a owl:Class ;
  rdfs:label "InhabitanceImpossibilityWitness" ;
  rdfs:comment "A specialisation of proof:ImpossibilityWitness produced when the inhabitance search determines that the carrier of a ConstrainedType is empty. Aggregates into the existing proof:MorphospaceBoundary alongside other impossibility witnesses, inheriting its O(1) amortised lookup discipline for previously resolved signatures." ;
  rdfs:subClassOf <https://uor.foundation/proof/ImpossibilityWitness> ;
.

<https://uor.foundation/proof/verified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "verified" ;
  rdfs:comment "Whether this proof has been verified by the kernel." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/proof/timestamp>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "timestamp" ;
  rdfs:comment "The time at which this proof was produced." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#dateTime> .

<https://uor.foundation/proof/witness>
  a owl:ObjectProperty ;
  rdfs:label "witness" ;
  rdfs:comment "Supporting witness data for this proof." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/proof/WitnessData> .

<https://uor.foundation/proof/criticalIdentity>
  a owl:AnnotationProperty ;
  rdfs:label "criticalIdentity" ;
  rdfs:comment "Human-readable statement of the critical identity proven. E.g., 'neg(bnot(x)) = succ(x) for all x in R_n'. Annotation only — proof:provesIdentity is the typed reference." ;
  rdfs:domain <https://uor.foundation/proof/CriticalIdentityProof> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/proof/x>
  a owl:DatatypeProperty ;
  rdfs:label "x" ;
  rdfs:comment "A specific input value used as a witness for the critical identity check." ;
  rdfs:domain <https://uor.foundation/proof/WitnessData> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/proof/bnot_x>
  a owl:DatatypeProperty ;
  rdfs:label "bnot_x" ;
  rdfs:comment "The value bnot(x) for a witness x." ;
  rdfs:domain <https://uor.foundation/proof/WitnessData> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/proof/neg_bnot_x>
  a owl:DatatypeProperty ;
  rdfs:label "neg_bnot_x" ;
  rdfs:comment "The value neg(bnot(x)) for a witness x." ;
  rdfs:domain <https://uor.foundation/proof/WitnessData> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/proof/succ_x>
  a owl:DatatypeProperty ;
  rdfs:label "succ_x" ;
  rdfs:comment "The value succ(x) for a witness x." ;
  rdfs:domain <https://uor.foundation/proof/WitnessData> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/proof/holds>
  a owl:DatatypeProperty ;
  rdfs:label "holds" ;
  rdfs:comment "Whether the identity neg(bnot(x)) = succ(x) holds for this specific witness." ;
  rdfs:domain <https://uor.foundation/proof/WitnessData> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/proof/provesIdentity>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "provesIdentity" ;
  rdfs:comment "The algebraic identity this proof establishes. Provides a canonical object reference alongside the existing proof:criticalIdentity string property, which remains for human readability." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/proof/atWittLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "atWittLevel" ;
  rdfs:comment "The quantum level at which this computation certificate was produced. A ComputationCertificate at schema:Q0 confirms the identity holds for all 256 inputs of R_8. A certificate at schema:Q1 confirms it for all 65,536 inputs of R_16." ;
  rdfs:domain <https://uor.foundation/proof/ComputationCertificate> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/proof/wittNote>
  a owl:AnnotationProperty ;
  rdfs:label "wittNote" ;
  rdfs:comment "Human-readable quantum level note, e.g. 'n=8, 256 inputs'. Annotation only — proof:atWittLevel is the typed assertion." ;
  rdfs:domain <https://uor.foundation/proof/ComputationCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/proof/universalScope>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "universalScope" ;
  rdfs:comment "True when this axiomatic derivation holds for all quantum levels by the definition of Z/(2^n)Z. False when the derivation depends on a property specific to a particular ring size. All current AxiomaticDerivation individuals in the spec carry universalScope true." ;
  rdfs:domain <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/proof/derivationWitness>
  a owl:ObjectProperty ;
  rdfs:label "derivationWitness" ;
  rdfs:comment "The derivation chain that witnesses this axiomatic derivation. Links a proof:AxiomaticDerivation to the derivation:Derivation individual recording the rewrite sequence. Optional at the spec level — the conformance suite requires only that the proof individual exists; full derivation chains live in generated artifacts." ;
  rdfs:domain <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:range <https://uor.foundation/derivation/Derivation> .

<https://uor.foundation/proof/forbidsSignature>
  a owl:AnnotationProperty ;
  rdfs:label "forbidsSignature" ;
  rdfs:comment "The topological signature (χ, β_k) that this ImpossibilityWitness formally forbids, expressed as a symbolic notation string (e.g., 'β₀ = 0')." ;
  rdfs:domain <https://uor.foundation/proof/ImpossibilityWitness> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/proof/impossibilityReason>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "impossibilityReason" ;
  rdfs:comment "Human-readable statement of the algebraic reason the signature is impossible (e.g., 'β₀ = 0 violates MS_1')." ;
  rdfs:domain <https://uor.foundation/proof/ImpossibilityWitness> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/proof/impossibilityDomain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "impossibilityDomain" ;
  rdfs:comment "The verification domain grounding the impossibility (e.g., Pipeline for β₀ = 0, Algebraic for χ > n)." ;
  rdfs:domain <https://uor.foundation/proof/ImpossibilityWitness> ;
  rdfs:range <https://uor.foundation/op/VerificationDomain> .

<https://uor.foundation/proof/achievabilityStatus>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "achievabilityStatus" ;
  rdfs:comment "The achievability classification of a proof-linked observable signature: Achievable or Forbidden." ;
  rdfs:domain <https://uor.foundation/proof/ImpossibilityWitness> ;
  rdfs:range <https://uor.foundation/observable/AchievabilityStatus> .

<https://uor.foundation/proof/verifiedAtLevel>
  a owl:ObjectProperty ;
  rdfs:label "verifiedAtLevel" ;
  rdfs:comment "The specific quantum level at which an empirical verification or impossibility witness was established." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/proof/morphospaceRecord>
  a owl:ObjectProperty ;
  rdfs:label "morphospaceRecord" ;
  rdfs:comment "Links a MorphospaceBoundary to one of its constituent MorphospaceRecord individuals." ;
  rdfs:domain <https://uor.foundation/proof/MorphospaceBoundary> ;
  rdfs:range <https://uor.foundation/proof/MorphospaceRecord> .

<https://uor.foundation/proof/boundaryType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundaryType" ;
  rdfs:comment "Whether this MorphospaceRecord represents an impossibility boundary (from below) or an achievability boundary (from above)." ;
  rdfs:domain <https://uor.foundation/proof/MorphospaceRecord> ;
  rdfs:range <https://uor.foundation/observable/AchievabilityStatus> .

<https://uor.foundation/proof/baseCase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "baseCase" ;
  rdfs:comment "The proof that the claim holds at the base level k_0." ;
  rdfs:domain <https://uor.foundation/proof/InductiveProof> ;
  rdfs:range <https://uor.foundation/proof/Proof> .

<https://uor.foundation/proof/inductiveStep>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inductiveStep" ;
  rdfs:comment "The proof that if the claim holds at Q_k, it holds at Q_{k+1}." ;
  rdfs:domain <https://uor.foundation/proof/InductiveProof> ;
  rdfs:range <https://uor.foundation/proof/Proof> .

<https://uor.foundation/proof/validForKAtLeast>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "validForKAtLeast" ;
  rdfs:comment "The minimum k for which the induction is valid." ;
  rdfs:domain <https://uor.foundation/proof/InductiveProof> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/proof/strategy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "strategy" ;
  rdfs:comment "The proof method from the ProofStrategy controlled vocabulary. Determines the compilation target (e.g., `by ring`, `by simp`, `by induction`)." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/proof/ProofStrategy> .

<https://uor.foundation/proof/dependsOn>
  a owl:ObjectProperty ;
  rdfs:label "dependsOn" ;
  rdfs:comment "An identity that this proof depends on as a lemma. Forms the proof dependency DAG. Leaf proofs (provable from definitions alone) have no dependsOn assertions." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/proof/formalDerivation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "formalDerivation" ;
  rdfs:comment "The formal proof construction term: a DerivationTerm AST node encoding the tactic script, lemma chain, or induction scaffold that constitutes the proof." ;
  rdfs:domain <https://uor.foundation/proof/Proof> ;
  rdfs:range <https://uor.foundation/proof/DerivationTerm> .

<https://uor.foundation/proof/contradictionProof>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "contradictionProof" ;
  rdfs:comment "The Lean 4 by-contradiction derivation over the predicate vocabulary attesting that no value tuple satisfies the constraint system." ;
  rdfs:domain <https://uor.foundation/proof/InhabitanceImpossibilityWitness> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/proof/grounded>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "grounded" ;
  rdfs:comment "The type:ConstrainedType whose carrier this witness certifies as empty." ;
  rdfs:domain <https://uor.foundation/proof/InhabitanceImpossibilityWitness> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/proof/searchTrace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "searchTrace" ;
  rdfs:comment "The audit trail of the inhabitance search up to the contradiction." ;
  rdfs:domain <https://uor.foundation/proof/InhabitanceImpossibilityWitness> ;
  rdfs:range <https://uor.foundation/trace/InhabitanceSearchTrace> .

<https://uor.foundation/proof/RingAxiom>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "RingAxiom" ;
  rdfs:comment "Follows from ZMod ring axioms. Lean4 tactic: `by ring`." .

<https://uor.foundation/proof/DecideQ0>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "DecideQ0" ;
  rdfs:comment "Decidable at Q0 by exhaustive evaluation. Lean4: `by native_decide`." .

<https://uor.foundation/proof/BitwiseInduction>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "BitwiseInduction" ;
  rdfs:comment "Induction on bit width n. Lean4: `by induction n`." .

<https://uor.foundation/proof/GroupPresentation>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "GroupPresentation" ;
  rdfs:comment "From dihedral group presentation. Lean4: `by group`." .

<https://uor.foundation/proof/Simplification>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "Simplification" ;
  rdfs:comment "By simplification with cited lemmas. Lean4: `by simp [lemmalist]`." .

<https://uor.foundation/proof/ChineseRemainder>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "ChineseRemainder" ;
  rdfs:comment "By Chinese Remainder Theorem. Lean4: `by exact ZMod.chineseRemainder ...`." .

<https://uor.foundation/proof/EulerPoincare>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "EulerPoincare" ;
  rdfs:comment "By Euler-Poincare formula applied to the constraint nerve." .

<https://uor.foundation/proof/ProductFormula>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "ProductFormula" ;
  rdfs:comment "By Ostrowski product formula or derived valuation arguments." .

<https://uor.foundation/proof/Composition>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "Composition" ;
  rdfs:comment "By composing proofs of sub-identities. Lean4: `by exact ...`." .

<https://uor.foundation/proof/Contradiction>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "Contradiction" ;
  rdfs:comment "By deriving contradiction for impossibility witnesses. Lean4: `by contradiction`." .

<https://uor.foundation/proof/Computation>
  a owl:NamedIndividual , <https://uor.foundation/proof/ProofStrategy> ;
  rdfs:label "Computation" ;
  rdfs:comment "By computation at a specified quantum level. Lean4: `by native_decide`." .

<https://uor.foundation/proof/prf_criticalIdentity>
