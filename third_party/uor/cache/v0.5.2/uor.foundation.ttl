  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_2" ;
  rdfs:comment "Carry propagates at site k iff xor(x_k, y_k) = 1 and c_k = 1. Extends CA_2 (carry recurrence) and WC_3 (Witt polynomial recurrence)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_3" ;
  rdfs:comment "Carry kills at site k iff and(x_k, y_k) = 0 and xor(x_k, y_k) = 0. Complement of CY_1 and CY_2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_4" ;
  rdfs:comment "d_Δ(x,y) = |carryCount(x+y) − hammingDistance(x,y)|. The metric incompatibility IS the discrepancy between carry count and Hamming distance. Strengthens WC_6." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_5" ;
  rdfs:comment "Optimal encoding theorem: the encoding that minimizes Σ d_Δ over observed pairs is the one where the carry chain’s significance hierarchy matches the domain’s dependency structure." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_6" ;
  rdfs:comment "Site ordering theorem: d_Δ is minimized when high-significance sites (upstream in the carry chain) encode the most structurally informative observables." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CY_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CY_7" ;
  rdfs:comment "Carry lookahead: the carry chain for n sites is computable in O(log n) using prefix computation on generate/propagate pairs." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CY_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CY_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CY_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_1" ;
  rdfs:comment "σ(C) = (n − freeRank(C)) / n. The saturation metric is the complement of free site ratio. Derives from SC_2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_2" ;
  rdfs:comment "χ = Σ(−1)^k β_k. The Euler characteristic of the constraint nerve. Derives from IT_2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_3" ;
  rdfs:comment "Index theorem: Σκ_k − χ = S_residual / ln 2. Links all six metrics. Derives from IT_7a." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_4" ;
  rdfs:comment "J_k = 0 for pinned sites. The Jacobian vanishes on resolved sites." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_5" ;
  rdfs:comment "d_Δ > 0 iff carry ≠ 0. The metric discrepancy equals the Witt defect. Derives from WC_6." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/BM_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "BM_6" ;
  rdfs:comment "Metric composition tower: d_Δ → {σ, J_k} → β_k → χ → r. Each metric derives from previous ones." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_BM_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_BM_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_BM_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GL_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GL_1" ;
  rdfs:comment "σ = lower adjoint evaluated at current type. The saturation metric is the lower adjoint of the Galois connection. Derives from SC_2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GL_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GL_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GL_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
