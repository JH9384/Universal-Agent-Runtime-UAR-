  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_2a_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/PT_2b>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PT_2b" ;
  rdfs:comment "Sum type partition coproduct: the partition of a sum type is the coproduct of the variant partitions." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PT_2b_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PT_2b_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PT_2b_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GD_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GD_6" ;
  rdfs:comment "Geodesic predicate decomposition: a trace is geodesic iff it is both AR_1-ordered and DC_10-selected." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GD_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GD_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GD_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_1" ;
  rdfs:comment "LiftChain(Q_j, Q_k) is valid CompleteType tower iff every chainStep WittLift has trivial or resolved LiftObstruction." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_2" ;
  rdfs:comment "Obstruction count bound: the number of non-trivial LiftObstructions in a chain is at most the chain length." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_3" ;
  rdfs:comment "Resolved basis size formula: the basis size at Q_k equals basisSize(Q_j) + chainLength + obstructionResolutionCost." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_4" ;
  rdfs:comment "Flat tower characterization: isFlat(chain) iff obstructionCount = 0 iff HolonomyGroup trivial at every step." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_5" ;
  rdfs:comment "LiftChainCertificate existence: a CompleteType at Q_k satisfies IT_7d with a witness chain." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_6" ;
  rdfs:comment "Single-step reduction: QT_3 with chainLength=1 and cost=0 reduces to QLS_3." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_7" ;
  rdfs:comment "Flat chain basis size: for flat chains, resolvedBasisSize(Q_k) = basisSize(Q_j) + (k - j)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CC_PINS>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CC_PINS" ;
  rdfs:comment "Carry-constraint site-pinning map: pinsSites(CarryConstraint(p)) equals the set of bit positions where p has a 1 plus the first-zero stopping position." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CC_PINS_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CC_PINS_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CC_PINS_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/CC_COST_SITE>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CC_COST_SITE" ;
  rdfs:comment "Carry-constraint cost-to-site count: the number of sites pinned by a CarryConstraint equals popcount plus one for the stopping position." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CC_COST_SITE_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CC_COST_SITE_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CC_COST_SITE_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Enumerative> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/jsat_RR>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "jsat_RR" ;
  rdfs:comment "CRT joint satisfiability: two ResidueConstraints are jointly satisfiable iff the gcd of their moduli divides the difference of their residues." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_jsat_RR_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_jsat_RR_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_jsat_RR_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/jsat_CR>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "jsat_CR" ;
  rdfs:comment "Carry-residue joint satisfiability: a CarryConstraint and ResidueConstraint are jointly satisfiable iff the carry-pinned sites are compatible with the residue class." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_jsat_CR_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_jsat_CR_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_jsat_CR_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/jsat_CC>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "jsat_CC" ;
  rdfs:comment "Carry-carry joint satisfiability: two CarryConstraints are jointly satisfiable iff their bit-patterns have no conflicting positions." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_jsat_CC_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_jsat_CC_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_jsat_CC_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Enumerative> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/D_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "D_8" ;
  rdfs:comment "Dihedral inverse formula: the inverse of r^a s^p in D_(2^n) is r^(-(−1)^p a mod 2^n) s^p." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_D_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_D_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_D_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/D_9>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "D_9" ;
  rdfs:comment "Dihedral reflection order: every reflection element r^k s^1 in D_(2^n) has order 2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_D_9_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_D_9_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_D_9_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/EXP_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "EXP_1" ;
  rdfs:comment "Monotone carrier characterization: a ConstrainedType has an upward-closed carrier iff every ResidueConstraint has residue = modulus - 1 and no CarryConstraint or DepthConstraint appears." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_EXP_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_EXP_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_EXP_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/EXP_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "EXP_2" ;
  rdfs:comment "Monotone constraint count: the number of expressible monotone ConstrainedTypes at quantum level Q_n is 2^n, corresponding to the principal filter count." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_EXP_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_EXP_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_EXP_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Enumerative> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/EXP_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "EXP_3" ;
  rdfs:comment "SumType carrier semantics: the carrier of a SumType is the coproduct (disjoint union) of component carriers, not the set-theoretic union." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_EXP_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_EXP_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_EXP_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/ST_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_3" ;
  rdfs:comment "SumType Euler characteristic additivity: for a SumType with topologically disjoint component nerves, the Euler characteristic is additive." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/ST_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_4" ;
  rdfs:comment "SumType Betti number additivity: for disjoint component nerves, all Betti numbers are additive." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/ST_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_5" ;
  rdfs:comment "SumType completeness transfer: a SumType A+B is CompleteType iff both A and B are CompleteType and they have equal quantum levels." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/ST_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_6" ;
  rdfs:comment "SumType tag site unique existence: every PartitionCoproduct A + B has exactly one tag site, logically distinct from every data site of A and B, carrying the ln 2 entropy quantum of ST_2." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/ST_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_7" ;
  rdfs:comment "SumType variant tagging: the constraints of a PartitionCoproduct decompose into the operands' constraints plus one tag-pinning constraint per variant (tag = 0 for the left variant, tag = 1 for the right)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/ST_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_8" ;
  rdfs:comment "SumType variant nerve disjointness bridge: a PartitionCoproduct constructed via ST_6 + ST_7 + the foundation layout convention produces topologically disjoint component nerves. Bridges the existing conditional ST_3 and ST_4 to PartitionCoproduct constructions concretely." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/ST_9>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_9" ;
  rdfs:comment "SumType Euler corollary for PartitionCoproduct constructions: combining ST_8's disjointness guarantee with the universal ST_3 yields Euler additivity for any A + B assembled via the PartitionCoproduct construction." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_9_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_9_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_9_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/ST_10>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "ST_10" ;
  rdfs:comment "SumType Betti corollary for PartitionCoproduct constructions: combining ST_8's disjointness guarantee with the universal ST_4 yields Betti additivity at every dimension for any A + B assembled via the PartitionCoproduct construction." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_ST_10_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_ST_10_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_ST_10_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/CPT_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_1" ;
  rdfs:comment "Cartesian partition product site additivity: siteBudget(A ⊠ B) = siteBudget(A) + siteBudget(B). UOR sites are bit widths; |A ⊠ B| = 2^{n_A} · 2^{n_B} = 2^{n_A + n_B}, so sites add even though cardinalities multiply." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/CPT_2a>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_2a" ;
  rdfs:comment "Cartesian partition product partition map: Π(A ⊠ B) = CartesianPartitionProduct(Π(A), Π(B))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_2a_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_2a_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_2a_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/CPT_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_3" ;
  rdfs:comment "Cartesian partition product Euler multiplicativity: χ(N(C(A ⊠ B))) = χ(N(C(A))) · χ(N(C(B))). Distinguishes CartesianPartitionProduct (multiplicative χ, Künneth) from PartitionProduct (additive χ, site-disjoint union)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/CPT_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_4" ;
  rdfs:comment "Cartesian partition product Künneth formula: Betti numbers compose via the Künneth convolution — β_k(A ⊠ B) = Σ_{i+j=k} β_i(A) · β_j(B). Routed through primitive_cartesian_nerve_betti when a CartesianProductShape marker is declared on the combined shape." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/CPT_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_5" ;
  rdfs:comment "Cartesian partition product entropy additivity: S(A ⊠ B) = S(A) + S(B). Matches PT_4's additive Shannon convention for independent subsystems and is consistent pointwise with IT_7a/b on the combined system (no cross-factor bilinearity required)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Thermodynamic> .

<https://uor.foundation/op/CPT_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CPT_6" ;
  rdfs:comment "Cartesian partition product distributes over PartitionCoproduct: A ⊠ (B + C) ≡ (A ⊠ B) + (A ⊠ C) with equality at the siteBudget, SITE_COUNT, Euler, and entropy levels simultaneously. Does NOT extend to PartitionProduct — distributing ⊠ over × fails at the site-budget level because it duplicates the outer factor." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_CPT_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_CPT_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_CPT_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/TS_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_8" ;
  rdfs:comment "Betti-1 minimum constraint count: the minimum number of constraints needed to achieve first Betti number beta_1 = k in the constraint nerve is 2k + 1." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/TS_9>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_9" ;
  rdfs:comment "TypeSynthesisResolver termination: the resolver terminates in at most 2^n steps for any target signature at quantum level Q_n, returning either a ConstrainedType or a ForbiddenSignature certificate." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_9_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_9_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_9_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/TS_10>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "TS_10" ;
  rdfs:comment "ForbiddenSignature membership criterion: a topological signature is a ForbiddenSignature iff no ConstrainedType with at most n constraints realises it at quantum level Q_n." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_TS_10_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_TS_10_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_TS_10_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_8>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_8" ;
  rdfs:comment "ObstructionChain length bound: the length of the ObstructionChain from Q_j to Q_k is at most (k-j) times C(basisSize(Q_j), 3)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_8_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_8_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/IndexTheoretic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/WT_9>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "WT_9" ;
  rdfs:comment "TowerCompletenessResolver termination: the resolver terminates for any finite LiftChain within the QT_8 bound, producing a CompleteType certificate or a bounded ObstructionChain." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_WT_9_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_WT_9_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_WT_9_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Pipeline> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/COEFF_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "COEFF_1" ;
  rdfs:comment "Standard coefficient ring: the coefficient ring for all psi-pipeline cohomology computations in uor.foundation is Z/2Z, consistent with MN_7." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_COEFF_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_COEFF_1_rhs> ;
