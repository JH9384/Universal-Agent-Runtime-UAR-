<https://uor.foundation/op/IT_7d>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "IT_7d" ;
  rdfs:comment "UOR index theorem (completeness criterion): resolution is complete iff χ(N(C)) = n and all Betti numbers vanish." ;
