  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GL_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GL_3" ;
  rdfs:comment "CompleteType = fixpoint of Galois connection, σ=1, r=0. Derives from IT_7d." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GL_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GL_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GL_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GL_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GL_4" ;
  rdfs:comment "Type refinement = ascending in type lattice = descending in site freedom. The Galois connection reverses order." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GL_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GL_4_rhs> ;
