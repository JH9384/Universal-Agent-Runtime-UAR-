<https://uor.foundation/op/CIC_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "CIC_7" ;
  rdfs:comment "Certificate issuance: a MeasurementEvent verifying P(outcome k) = |α_k|² admits a BornRuleVerification certificate." ;
