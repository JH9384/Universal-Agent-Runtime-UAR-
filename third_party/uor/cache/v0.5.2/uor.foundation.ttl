  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Topological> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GR_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_6" ;
  rdfs:comment "Grounding re-entry free rank: for a session at full grounding, a new query q has freeRank equal to the number of q's site coordinates not already bound." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GR_6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/GR_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_7" ;
  rdfs:comment "Grounding degree degradation: after re-entry with query q, the grounding degree becomes min(current sigma, 1 - freeRank(q)/n)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_7_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_GR_7_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/QM_6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "QM_6" ;
  rdfs:comment "Amplitude index set characterization: the amplitude index set of a SuperposedSiteState over ConstrainedType T at Q_n is the set of monotone pinning trajectories consistent with T's constraints." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_QM_6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_QM_6_rhs> ;
