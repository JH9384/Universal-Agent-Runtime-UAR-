<https://uor.foundation/op/SD_5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_5" ;
  rdfs:comment "GraphType constraint nerve = graph nerve, β_k equality." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_SD_5_lhs> ;
