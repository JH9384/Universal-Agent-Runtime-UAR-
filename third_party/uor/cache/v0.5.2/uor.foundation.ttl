  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/leaseRemainingBudget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leaseRemainingBudget" ;
  rdfs:comment "The remaining site budget at this checkpoint." ;
