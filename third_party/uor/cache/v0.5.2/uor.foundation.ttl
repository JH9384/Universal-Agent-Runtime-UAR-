@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix uor:  <https://uor.foundation/> .
@prefix u:  <https://uor.foundation/u/> .
@prefix schema:  <https://uor.foundation/schema/> .
@prefix op:  <https://uor.foundation/op/> .
@prefix query:  <https://uor.foundation/query/> .
@prefix resolver:  <https://uor.foundation/resolver/> .
@prefix type:  <https://uor.foundation/type/> .
@prefix partition:  <https://uor.foundation/partition/> .
@prefix foundation:  <https://uor.foundation/foundation/> .
@prefix observable:  <https://uor.foundation/observable/> .
@prefix carry:  <https://uor.foundation/carry/> .
@prefix homology:  <https://uor.foundation/homology/> .
@prefix cohomology:  <https://uor.foundation/cohomology/> .
@prefix proof:  <https://uor.foundation/proof/> .
@prefix derivation:  <https://uor.foundation/derivation/> .
@prefix trace:  <https://uor.foundation/trace/> .
@prefix cert:  <https://uor.foundation/cert/> .
@prefix morphism:  <https://uor.foundation/morphism/> .
@prefix state:  <https://uor.foundation/state/> .
@prefix reduction:  <https://uor.foundation/reduction/> .
@prefix convergence:  <https://uor.foundation/convergence/> .
@prefix division:  <https://uor.foundation/division/> .
@prefix interaction:  <https://uor.foundation/interaction/> .
@prefix monoidal:  <https://uor.foundation/monoidal/> .
@prefix operad:  <https://uor.foundation/operad/> .
@prefix effect:  <https://uor.foundation/effect/> .
@prefix predicate:  <https://uor.foundation/predicate/> .
@prefix parallel:  <https://uor.foundation/parallel/> .
@prefix stream:  <https://uor.foundation/stream/> .
@prefix failure:  <https://uor.foundation/failure/> .
@prefix linear:  <https://uor.foundation/linear/> .
@prefix recursion:  <https://uor.foundation/recursion/> .
@prefix region:  <https://uor.foundation/region/> .
@prefix boundary:  <https://uor.foundation/boundary/> .
@prefix conformance:  <https://uor.foundation/conformance/> .

<https://uor.foundation/>
  a owl:Ontology ;
  rdfs:label "UOR Foundation" ;
  owl:versionInfo "0.5.2" .

<https://uor.foundation/space>
  a owl:AnnotationProperty ;
  rdfs:label "space" ;
  rdfs:comment "Whether this module belongs to kernel-space (immutable, compiled), user-space (parameterizable, runtime), or bridge (kernel-computed, user-consumed). Values: 'kernel', 'user', 'bridge'." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

# Namespace: u
<https://uor.foundation/u/>
  a owl:Ontology ;
  rdfs:label "UOR Content Addressing" ;
  rdfs:comment "Content-addressable identifiers for ring elements. Each element carries a unique content-derived identifier." ;
  uor:space "kernel" ;
.

<https://uor.foundation/u/Element>
  a owl:Class ;
  rdfs:label "Element" ;
  rdfs:comment "A content-addressable ring element. Each Element uniquely identifies a piece of content via its hash-derived identifier." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/u/length>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "length" ;
  rdfs:comment "The number of Braille glyphs in an address string." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/u/addresses>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "addresses" ;
  rdfs:comment "The datum that this address references. Inverse of schema:glyph." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/u/digest>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "digest" ;
  rdfs:comment "The content hash of this address. Format: (blake3|sha256) colon followed by 64 lowercase hex characters. The algorithm prefix must match u:digestAlgorithm." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/u/digestAlgorithm>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "digestAlgorithm" ;
  rdfs:comment "The hash algorithm used to produce u:digest. Allowed values: 'blake3' (primary), 'sha256' (secondary)." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/u/canonicalBytes>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "canonicalBytes" ;
  rdfs:comment "The canonical byte serialisation of the addressed datum, per Amendment 43 section 2: header(k) || le_bytes(x, k+1). This is the exact byte string hashed to produce u:digest." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#hexBinary> .

<https://uor.foundation/u/wittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "wittLength" ;
  rdfs:comment "The Witt level n of this element. The element encodes a datum in R_n = Z/(2^n)Z." ;
  rdfs:domain <https://uor.foundation/u/Element> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

# Namespace: schema
<https://uor.foundation/schema/>
  a owl:Ontology ;
  rdfs:label "UOR Schema" ;
  rdfs:comment "Core value types and term language for the UOR ring substrate. Defines Datum (ring element), Term (syntactic expression), and the Ring container." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/u/> ;
.

<https://uor.foundation/schema/Datum>
  a owl:Class ;
  rdfs:label "Datum" ;
  rdfs:comment "An element of the ring Z/(2^n)Z at a specific Witt level n. The primary semantic value type. Disjoint from Term: datums are values, terms are syntactic expressions that evaluate to datums." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/schema/Term> ;
.

<https://uor.foundation/schema/Term>
  a owl:Class ;
  rdfs:label "Term" ;
  rdfs:comment "A syntactic expression in the UOR term language. Terms are evaluated to produce Datums. Disjoint from Datum." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/schema/Datum> ;
.

<https://uor.foundation/schema/Triad>
  a owl:Class ;
  rdfs:label "Triad" ;
  rdfs:comment "A three-component structure encoding an element's position in the UOR address space: stratum (ring layer), spectrum (bit pattern), and address (content-addressable position in the Braille glyph encoding). The three required functional properties schema:triadStratum, schema:triadSpectrum, and schema:triadAddress project a Triad onto its TwoAdicValuation, WalshHadamardImage, and Address coordinates respectively." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/Literal>
  a owl:Class ;
  rdfs:label "Literal" ;
  rdfs:comment "A term that directly denotes a datum value. A Literal is a leaf node in the term language — it refers to a concrete Datum via schema:denotes without being a Datum itself." ;
  rdfs:subClassOf <https://uor.foundation/schema/Term> ;
  rdfs:subClassOf <https://uor.foundation/schema/SurfaceSymbol> ;
.

<https://uor.foundation/schema/Application>
  a owl:Class ;
  rdfs:label "Application" ;
  rdfs:comment "A term formed by applying an operation to one or more argument terms. The application's value is the result of evaluating the operator on the evaluated arguments." ;
  rdfs:subClassOf <https://uor.foundation/schema/Term> ;
.

<https://uor.foundation/schema/Ring>
  a owl:Class ;
  rdfs:label "Ring" ;
  rdfs:comment "The ambient ring Z/(2^n)Z at a specific Witt level n. The Ring is the primary data structure of the UOR kernel. Its two generators (negation and complement) produce the dihedral group D_{2^n} that governs the invariance frame." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/W16Ring>
  a owl:Class ;
  rdfs:label "W16Ring" ;
  rdfs:comment "The concrete ring Z/(2^16)Z at Witt level 16. Subclass of schema:Ring. Carries 65,536 elements. W16Ring is the first extension of the default Q0 ring and is the target of Amendment 26's universality proofs." ;
  rdfs:subClassOf <https://uor.foundation/schema/Ring> ;
.

<https://uor.foundation/schema/WittLevel>
  a owl:Class ;
  rdfs:label "WittLevel" ;
  rdfs:comment "A named Witt level Q_k at which the UOR ring operates. Level Q_k uses 8*(k+1) bits, 2^(8*(k+1)) states, and modulus 2^(8*(k+1)). The named individuals Q0-Q3 are the spec-defined reference levels. The class is open: Prism implementations operating at higher levels declare their own WittLevel individuals. The nextWittLevel property forms an unbounded chain Q0 -> Q1 -> Q2 -> ..." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/TermExpression>
  a owl:Class ;
  rdfs:label "TermExpression" ;
  rdfs:comment "Root AST node for parsed EBNF term expressions. Identity lhs/rhs values are instances of TermExpression subtypes. Maps to the `term` production in the EBNF grammar." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/LiteralExpression>
  a owl:Class ;
  rdfs:label "LiteralExpression" ;
  rdfs:comment "A leaf AST node: an integer literal, variable reference, or named constant." ;
  rdfs:subClassOf <https://uor.foundation/schema/TermExpression> ;
.

<https://uor.foundation/schema/ApplicationExpression>
  a owl:Class ;
  rdfs:label "ApplicationExpression" ;
  rdfs:comment "An AST node representing operator application: an operator applied to an argument list (e.g., add(x, y))." ;
  rdfs:subClassOf <https://uor.foundation/schema/TermExpression> ;
.

<https://uor.foundation/schema/InfixExpression>
  a owl:Class ;
  rdfs:label "InfixExpression" ;
  rdfs:comment "An AST node for infix relations and logical connectives (e.g., x <= y, P -> Q, a = b)." ;
  rdfs:subClassOf <https://uor.foundation/schema/TermExpression> ;
.

<https://uor.foundation/schema/SetExpression>
  a owl:Class ;
  rdfs:label "SetExpression" ;
  rdfs:comment "An AST node for set-builder notation (e.g., {x : P(x)})." ;
  rdfs:subClassOf <https://uor.foundation/schema/TermExpression> ;
.

<https://uor.foundation/schema/CompositionExpression>
  a owl:Class ;
  rdfs:label "CompositionExpression" ;
  rdfs:comment "An AST node for function composition (f compose g)." ;
  rdfs:subClassOf <https://uor.foundation/schema/TermExpression> ;
.

<https://uor.foundation/schema/ForAllDeclaration>
  a owl:Class ;
  rdfs:label "ForAllDeclaration" ;
  rdfs:comment "A structured quantifier binding: typed variable declarations with a domain and quantifier kind (universal or existential). Replaces the string-valued op:forAll property." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/VariableBinding>
  a owl:Class ;
  rdfs:label "VariableBinding" ;
  rdfs:comment "A single variable binding: a variable name bound to a domain type (e.g., x in R_n)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/QuantifierKind>
  a owl:Class ;
  rdfs:label "QuantifierKind" ;
  rdfs:comment "The kind of quantifier: Universal (forall) or Existential (exists). Controlled vocabulary with exactly 2 individuals." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/SurfaceSymbol>
  a owl:Class ;
  rdfs:label "SurfaceSymbol" ;
  rdfs:comment "An abstract leaf value that a grounding map can accept as surface input. Has no direct instances: every SurfaceSymbol is either a Datum-denoting schema:Literal or an xsd-typed schema:HostValue, and the two cases are disjoint." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/HostValue>
  a owl:Class ;
  rdfs:label "HostValue" ;
  rdfs:comment "An xsd-typed value that denotes a host datatype rather than a ring datum. Used in property-position slots whose range is xsd and as the host-side input of a grounding map." ;
  rdfs:subClassOf <https://uor.foundation/schema/SurfaceSymbol> ;
  owl:disjointWith <https://uor.foundation/schema/Term> ;
  owl:disjointWith <https://uor.foundation/schema/Datum> ;
.

<https://uor.foundation/schema/HostStringLiteral>
  a owl:Class ;
  rdfs:label "HostStringLiteral" ;
  rdfs:comment "A host string literal carrying an xsd:string value." ;
  rdfs:subClassOf <https://uor.foundation/schema/HostValue> ;
.

<https://uor.foundation/schema/HostBooleanLiteral>
  a owl:Class ;
  rdfs:label "HostBooleanLiteral" ;
  rdfs:comment "A host boolean literal carrying an xsd:boolean value." ;
  rdfs:subClassOf <https://uor.foundation/schema/HostValue> ;
.

<https://uor.foundation/schema/ValueTuple>
  a owl:Class ;
  rdfs:label "ValueTuple" ;
  rdfs:comment "An ordered tuple of values drawn from a type:ConstrainedType's carrier. Serves as the witness form for cert:InhabitanceCertificate when verified is true." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/schema/value>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "value" ;
  rdfs:comment "The integer value of a datum element. For a Datum in Z/(2^n)Z, this is an integer in [0, 2^n)." ;
  rdfs:domain <https://uor.foundation/schema/Datum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/wittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "wittLength" ;
  rdfs:comment "The Witt level n of a datum, where the datum's ring is Z/(2^n)Z. Determines the bit width and modulus of the datum." ;
  rdfs:domain <https://uor.foundation/schema/Datum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/stratum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stratum" ;
  rdfs:comment "The ring-layer index of a datum, indicating its position in the stratification of Z/(2^n)Z." ;
  rdfs:domain <https://uor.foundation/schema/Datum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/spectrum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "spectrum" ;
  rdfs:comment "The bit-pattern representation of a datum, encoding its position in the hypercube geometry of Z/(2^n)Z." ;
  rdfs:domain <https://uor.foundation/schema/Datum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/element>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "element" ;
  rdfs:comment "The content-addressable element associated with this datum, linking the algebraic value to its identifier." ;
  rdfs:domain <https://uor.foundation/schema/Datum> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/schema/operator>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operator" ;
  rdfs:comment "The operation applied in an Application term." ;
  rdfs:domain <https://uor.foundation/schema/Application> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/schema/argument>
  a owl:ObjectProperty ;
  rdfs:label "argument" ;
  rdfs:comment "An argument term in an Application. The ordering of arguments follows rdf:List semantics." ;
  rdfs:domain <https://uor.foundation/schema/Application> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/schema/ringWittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "ringWittLength" ;
  rdfs:comment "The bit width n of the ring Z/(2^n)Z. Distinct from schema:wittLength on Datum — ringWittLength is the container's bit width; datum wittLength is a membership property." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/modulus>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "modulus" ;
  rdfs:comment "The modulus 2^n of the ring. Equals 2 raised to the power of ringWittLength." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/generator>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "generator" ;
  rdfs:comment "The generator element π₁ (value = 1) of the ring. Under iterated successor application, π₁ generates all ring elements." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/schema/negation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "negation" ;
  rdfs:comment "The ring reflection involution: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <https://uor.foundation/op/Involution> .

<https://uor.foundation/schema/complement>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "complement" ;
  rdfs:comment "The hypercube reflection involution: bnot(x) = (2^n - 1) ⊕ x. The second generator of the dihedral group D_{2^n}." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <https://uor.foundation/op/Involution> .

<https://uor.foundation/schema/denotes>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "denotes" ;
  rdfs:comment "The datum value that a Literal term denotes. Bridges the Term/Datum disjointness: a Literal refers to a Datum without being one. Evaluation of a Literal produces its denoted Datum." ;
  rdfs:domain <https://uor.foundation/schema/Literal> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/schema/bitsWidth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bitsWidth" ;
  rdfs:comment "The bit width 8*(k+1) of this Witt level." ;
  rdfs:domain <https://uor.foundation/schema/WittLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/cycleSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cycleSize" ;
  rdfs:comment "The number of distinct states 2^(8*(k+1)) at this Witt level." ;
  rdfs:domain <https://uor.foundation/schema/WittLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/nextWittLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "nextWittLevel" ;
  rdfs:comment "The next Witt level in the chain: Q_k -> Q_(k+1). The chain is unbounded; Q3 points to Q4, which is not a named individual in the spec but may be declared by Prism implementations." ;
  rdfs:domain <https://uor.foundation/schema/WittLevel> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/schema/wittLevelPredecessor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "wittLevelPredecessor" ;
  rdfs:comment "The predecessor Witt level in the chain: Q_(k+1) -> Q_k. Inverse of nextWittLevel. If nextWittLevel(Q_k) = Q_(k+1), then wittLevelPredecessor(Q_(k+1)) = Q_k. Formalizes the chain extension protocol (QL_8)." ;
  rdfs:domain <https://uor.foundation/schema/WittLevel> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/schema/atWittLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "atWittLevel" ;
  rdfs:comment "The Witt level at which this Ring instance operates. Links a concrete Ring individual to its WittLevel." ;
  rdfs:domain <https://uor.foundation/schema/Ring> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/schema/W16bitWidth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "W16bitWidth" ;
  rdfs:comment "Bit width of the Q1 ring: 16." ;
  rdfs:domain <https://uor.foundation/schema/W16Ring> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/W16capacity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "W16capacity" ;
  rdfs:comment "Carrier set size of the Q1 ring: 65,536 elements." ;
  rdfs:domain <https://uor.foundation/schema/W16Ring> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/schema/boundVariables>
  a owl:ObjectProperty ;
  rdfs:label "boundVariables" ;
  rdfs:comment "The variable bindings in a quantifier declaration. Non-functional: a ForAllDeclaration may bind multiple variables." ;
  rdfs:domain <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:range <https://uor.foundation/schema/VariableBinding> .

<https://uor.foundation/schema/variableDomain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "variableDomain" ;
  rdfs:comment "The domain type of a variable binding (e.g., schema:Ring, type:ConstrainedType)." ;
  rdfs:domain <https://uor.foundation/schema/VariableBinding> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/schema/variableName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "variableName" ;
  rdfs:comment "The name of a bound variable (e.g., 'x', 'y', 'n')." ;
  rdfs:domain <https://uor.foundation/schema/VariableBinding> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/schema/quantifierKind>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "quantifierKind" ;
  rdfs:comment "The kind of quantifier: Universal or Existential." ;
  rdfs:domain <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:range <https://uor.foundation/schema/QuantifierKind> .

<https://uor.foundation/schema/expressionOperator>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "expressionOperator" ;
  rdfs:comment "The operator in an application expression (e.g., op:add, op:neg)." ;
  rdfs:domain <https://uor.foundation/schema/ApplicationExpression> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/schema/leftOperand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftOperand" ;
  rdfs:comment "The left operand of an infix expression." ;
  rdfs:domain <https://uor.foundation/schema/InfixExpression> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/schema/rightOperand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightOperand" ;
  rdfs:comment "The right operand of an infix expression." ;
  rdfs:domain <https://uor.foundation/schema/InfixExpression> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/schema/arguments>
  a owl:ObjectProperty ;
  rdfs:label "arguments" ;
  rdfs:comment "The argument list of an application expression. Non-functional: an application may take multiple arguments." ;
  rdfs:domain <https://uor.foundation/schema/ApplicationExpression> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/schema/literalValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "literalValue" ;
  rdfs:comment "The string representation of a literal expression value (e.g., '42', 'x', 'pi1')." ;
  rdfs:domain <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/schema/infixOperator>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "infixOperator" ;
  rdfs:comment "The operator symbol in an infix expression (e.g., '=', '\\u{2264}', '\\u{2192}')." ;
  rdfs:domain <https://uor.foundation/schema/InfixExpression> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/schema/hostString>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hostString" ;
  rdfs:comment "The string value carried by a HostStringLiteral." ;
  rdfs:domain <https://uor.foundation/schema/HostStringLiteral> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/schema/hostBoolean>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "hostBoolean" ;
  rdfs:comment "The boolean value carried by a HostBooleanLiteral." ;
  rdfs:domain <https://uor.foundation/schema/HostBooleanLiteral> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/schema/triadStratum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "triadStratum" ;
  rdfs:comment "The stratum component of a Triad: the datum's two-adic valuation, indexing its layer in the ring stratification. Semantically corresponds to query:TwoAdicValuation." ;
  rdfs:domain <https://uor.foundation/schema/Triad> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/triadSpectrum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "triadSpectrum" ;
  rdfs:comment "The spectrum component of a Triad: the datum's Walsh-Hadamard transform image, indexing its position in the hypercube spectral decomposition. Semantically corresponds to query:WalshHadamardImage." ;
  rdfs:domain <https://uor.foundation/schema/Triad> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/triadAddress>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "triadAddress" ;
  rdfs:comment "The address component of a Triad: the datum's content-addressable position in the ring's Braille glyph encoding. Semantically corresponds to query:Address (renamed from RingElement in v0.2.2 W8)." ;
  rdfs:domain <https://uor.foundation/schema/Triad> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/schema/Universal>
  a owl:NamedIndividual , <https://uor.foundation/schema/QuantifierKind> ;
  rdfs:label "Universal" ;
  rdfs:comment "Universal quantification (forall)." .

<https://uor.foundation/schema/Existential>
  a owl:NamedIndividual , <https://uor.foundation/schema/QuantifierKind> ;
  rdfs:label "Existential" ;
  rdfs:comment "Existential quantification (exists)." .

<https://uor.foundation/schema/pi1>
  a owl:NamedIndividual , <https://uor.foundation/schema/Datum> ;
  rdfs:label "π₁" ;
  rdfs:comment "The unique generator of R_n under successor. Value = 1 at every Witt level. Under iterated application of succ, π₁ generates every element of the ring." ;
  <https://uor.foundation/schema/value> "1"^^xsd:integer .

<https://uor.foundation/schema/zero>
  a owl:NamedIndividual , <https://uor.foundation/schema/Datum> ;
  rdfs:label "zero" ;
  rdfs:comment "The additive identity of the ring. Value = 0 at every Witt level. op:add(x, zero) = x for all x in R_n." ;
  <https://uor.foundation/schema/value> "0"^^xsd:integer .

<https://uor.foundation/schema/W8>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W8" ;
  rdfs:comment "Witt level 0: 8-bit ring Z/256Z, 256 states. The reference level for all ComputationCertificate proofs in the spec." ;
  <https://uor.foundation/schema/bitsWidth> "8"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "256"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W16> .

<https://uor.foundation/schema/W16>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W16" ;
  rdfs:comment "Witt level 1: 16-bit ring Z/65536Z, 65,536 states." ;
  <https://uor.foundation/schema/bitsWidth> "16"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "65536"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W24> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W8> .

<https://uor.foundation/schema/W24>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W24" ;
  rdfs:comment "Witt level 2: 24-bit ring Z/16777216Z, 16,777,216 states." ;
  <https://uor.foundation/schema/bitsWidth> "24"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "16777216"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W32> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W16> .

<https://uor.foundation/schema/W32>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W32" ;
  rdfs:comment "Witt level 3: 32-bit ring Z/4294967296Z, 4,294,967,296 states. The highest 32-bit-and-below named level in the v0.2.1 spec; v0.2.2 Phase C extends the tower with the dense and powers-of-two set." ;
  <https://uor.foundation/schema/bitsWidth> "32"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "4294967296"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W40> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W24> .

<https://uor.foundation/schema/W40>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W40" ;
  rdfs:comment "Witt level 4: 40-bit ring Z/2^40 Z. Backed by u64 with a 40-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "40"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "1099511627776"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W48> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W32> .

<https://uor.foundation/schema/W48>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W48" ;
  rdfs:comment "Witt level 5: 48-bit ring Z/2^48 Z. Backed by u64 with a 48-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "48"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "281474976710656"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W56> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W40> .

<https://uor.foundation/schema/W56>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W56" ;
  rdfs:comment "Witt level 6: 56-bit ring Z/2^56 Z. Backed by u64 with a 56-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "56"^^xsd:integer ;
  <https://uor.foundation/schema/cycleSize> "72057594037927936"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W64> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W48> .

<https://uor.foundation/schema/W64>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W64" ;
  rdfs:comment "Witt level 7: 64-bit ring Z/2^64 Z. Backed by u64 directly (exact fit; no mask). v0.2.2 Phase C. cycle_size = 2^64 exceeds i64 representation and is omitted; codegen derives it from bit_width." ;
  <https://uor.foundation/schema/bitsWidth> "64"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W72> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W56> .

<https://uor.foundation/schema/W72>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W72" ;
  rdfs:comment "Witt level 8: 72-bit ring Z/2^72 Z. Backed by u128 with a 72-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "72"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W80> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W64> .

<https://uor.foundation/schema/W80>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W80" ;
  rdfs:comment "Witt level 9: 80-bit ring Z/2^80 Z. Backed by u128 with an 80-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "80"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W88> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W72> .

<https://uor.foundation/schema/W88>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W88" ;
  rdfs:comment "Witt level 10: 88-bit ring Z/2^88 Z. Backed by u128 with an 88-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "88"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W96> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W80> .

<https://uor.foundation/schema/W96>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W96" ;
  rdfs:comment "Witt level 11: 96-bit ring Z/2^96 Z. Backed by u128 with a 96-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "96"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W104> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W88> .

<https://uor.foundation/schema/W104>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W104" ;
  rdfs:comment "Witt level 12: 104-bit ring Z/2^104 Z. Backed by u128 with a 104-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "104"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W112> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W96> .

<https://uor.foundation/schema/W112>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W112" ;
  rdfs:comment "Witt level 13: 112-bit ring Z/2^112 Z. Backed by u128 with a 112-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "112"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W120> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W104> .

<https://uor.foundation/schema/W120>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W120" ;
  rdfs:comment "Witt level 14: 120-bit ring Z/2^120 Z. Backed by u128 with a 120-bit mask at the arithmetic boundary. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "120"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W128> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W112> .

<https://uor.foundation/schema/W128>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W128" ;
  rdfs:comment "Witt level 15: 128-bit ring Z/2^128 Z. Backed by u128 directly (exact fit; no mask). The largest native-backed Witt level; levels above W128 use the Limbs<N> generic kernel emitted in Phase C.3. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "128"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W160> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W120> .

<https://uor.foundation/schema/W160>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W160" ;
  rdfs:comment "Witt level: 160-bit ring (SHA-1 digest carrier). Backed by Limbs<3> with a 160-bit mask. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "160"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W192> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W128> .

<https://uor.foundation/schema/W192>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W192" ;
  rdfs:comment "Witt level: 192-bit ring (P-192 carrier). Backed by Limbs<3>. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "192"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W224> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W160> .

<https://uor.foundation/schema/W224>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W224" ;
  rdfs:comment "Witt level: 224-bit ring (SHA-224 digest carrier). Backed by Limbs<4> with a 224-bit mask. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "224"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W256> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W192> .

<https://uor.foundation/schema/W256>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W256" ;
  rdfs:comment "Witt level: 256-bit ring (SHA-256, blake3, secp256k1, P-256 carrier). Backed by Limbs<4> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "256"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W384> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W224> .

<https://uor.foundation/schema/W384>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W384" ;
  rdfs:comment "Witt level: 384-bit ring (SHA-384, P-384 carrier). Backed by Limbs<6> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "384"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W448> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W256> .

<https://uor.foundation/schema/W448>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W448" ;
  rdfs:comment "Witt level: 448-bit ring (Curve448 carrier). Backed by Limbs<7> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "448"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W512> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W384> .

<https://uor.foundation/schema/W512>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W512" ;
  rdfs:comment "Witt level: 512-bit ring (SHA-512 carrier). Backed by Limbs<8> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "512"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W520> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W448> .

<https://uor.foundation/schema/W520>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W520" ;
  rdfs:comment "Witt level: 520-bit ring (P-521 prime carrier, lower-bound). Backed by Limbs<9> with a 520-bit mask. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "520"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W528> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W512> .

<https://uor.foundation/schema/W528>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W528" ;
  rdfs:comment "Witt level: 528-bit ring (P-521 prime carrier, upper-bound; P-521 elements are constrained by an additional residue check). Backed by Limbs<9> with a 528-bit mask. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "528"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W1024> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W520> .

<https://uor.foundation/schema/W1024>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W1024" ;
  rdfs:comment "Witt level: 1024-bit ring (RSA-1024 carrier). Backed by Limbs<16> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "1024"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W2048> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W528> .

<https://uor.foundation/schema/W2048>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W2048" ;
  rdfs:comment "Witt level: 2048-bit ring (RSA-2048 carrier). Backed by Limbs<32> directly (exact fit; no mask). v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "2048"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W4096> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W1024> .

<https://uor.foundation/schema/W4096>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W4096" ;
  rdfs:comment "Witt level: 4096-bit ring (RSA-4096, BFV/CKKS HE ring dimension carrier). Backed by Limbs<64>. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "4096"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W8192> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W2048> .

<https://uor.foundation/schema/W8192>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W8192" ;
  rdfs:comment "Witt level: 8192-bit ring (lattice-based crypto carrier). Backed by Limbs<128>. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "8192"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W12288> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W4096> .

<https://uor.foundation/schema/W12288>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W12288" ;
  rdfs:comment "Witt level: 12288-bit ring (BFV/BGV HE ring dimension at n=12288). Backed by Limbs<192>. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "12288"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W16384> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W8192> .

<https://uor.foundation/schema/W16384>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W16384" ;
  rdfs:comment "Witt level: 16384-bit ring (post-quantum lattice parameter). Backed by Limbs<256>. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "16384"^^xsd:integer ;
  <https://uor.foundation/schema/nextWittLevel> <https://uor.foundation/schema/W32768> ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W12288> .

<https://uor.foundation/schema/W32768>
  a owl:NamedIndividual , <https://uor.foundation/schema/WittLevel> ;
  rdfs:label "W32768" ;
  rdfs:comment "Witt level: 32768-bit ring (post-quantum / extreme-precision arithmetic carrier). Backed by Limbs<512>. The highest foundation-shipped level in v0.2.2; downstream Prism implementations may declare higher levels via the `witt_level` conformance declaration form. v0.2.2 Phase C." ;
  <https://uor.foundation/schema/bitsWidth> "32768"^^xsd:integer ;
  <https://uor.foundation/schema/wittLevelPredecessor> <https://uor.foundation/schema/W16384> .

<https://uor.foundation/schema/term_criticalIdentity_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_criticalIdentity_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "neg(bnot(x))" .

<https://uor.foundation/schema/term_criticalIdentity_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_criticalIdentity_rhs" ;
  rdfs:comment "" ;
