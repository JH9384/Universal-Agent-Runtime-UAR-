<https://uor.foundation/op/NV_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "NV_2" ;
  rdfs:comment "Mayer–Vietoris: β_k(C₁ ∪ C₂) computable from parts and intersection." ;
