<https://uor.foundation/proof/prf_MS_2>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_MS_2" ;
  rdfs:comment "Proof of MS_2: Euler capacity ceiling χ ≤ n. Derived from TS_1 constraint nerve dimension bound." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/MS_2> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_MS_3>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_MS_3" ;
  rdfs:comment "Proof of MS_3: Betti monotonicity under constraint addition. Formalisation of TS_3." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/MS_3> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
