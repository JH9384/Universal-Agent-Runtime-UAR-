<https://uor.foundation/op/psi_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "psi_1" ;
  rdfs:comment "ψ_1: Constraints → SimplicialComplex (nerve construction). Maps a set of constraints to its nerve simplicial complex." ;
