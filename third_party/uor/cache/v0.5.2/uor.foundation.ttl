  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_QM_6_step" ;
  rdfs:comment "Inductive step for QM_6: monotone pinning trajectories at Q_{k+1} extend those at Q_k by the site lattice ordering (monotone extension property)." ;
