<https://uor.foundation/op/SD_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_2" ;
  rdfs:comment "SymbolType grounding: argmin_{encoding} Σ d_Δ over observed pairs (CY_5)." ;
