  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/expiryEpoch>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "expiryEpoch" ;
  rdfs:comment "The epoch at which this managed lease expires." ;
  rdfs:domain <https://uor.foundation/reduction/ManagedLease> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/leaseBudget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leaseBudget" ;
  rdfs:comment "The total site budget allocated to this managed lease." ;
  rdfs:domain <https://uor.foundation/reduction/ManagedLease> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/sourceStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceStage" ;
  rdfs:comment "The source stage emitting back-pressure." ;
  rdfs:domain <https://uor.foundation/reduction/BackPressureSignal> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/targetStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetStage" ;
  rdfs:comment "The target stage receiving back-pressure." ;
  rdfs:domain <https://uor.foundation/reduction/BackPressureSignal> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/deferralReason>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "deferralReason" ;
  rdfs:comment "The reason for deferring these queries." ;
  rdfs:domain <https://uor.foundation/reduction/DeferredQuerySet> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/infeasibilityKind>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "infeasibilityKind" ;
  rdfs:comment "The kind of infeasibility detected." ;
  rdfs:domain <https://uor.foundation/reduction/FeasibilityResult> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/failureStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "failureStage" ;
  rdfs:comment "The reduction stage at which the pipeline failure occurred." ;
  rdfs:domain <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/finalGrounding>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "finalGrounding" ;
  rdfs:comment "The final grounding level achieved on pipeline success." ;
  rdfs:domain <https://uor.foundation/reduction/PipelineSuccess> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/preservedGrounding>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "preservedGrounding" ;
  rdfs:comment "Whether grounding was preserved across the epoch boundary." ;
  rdfs:domain <https://uor.foundation/reduction/EpochBoundary> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/reduction/rootTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rootTerm" ;
  rdfs:comment "The root term expression of a CompileUnit — the top-level syntactic node from which all sub-expressions descend." ;
  rdfs:domain <https://uor.foundation/reduction/CompileUnit> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/unitWittLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unitWittLevel" ;
  rdfs:comment "The quantum level at which this CompileUnit operates." ;
  rdfs:domain <https://uor.foundation/reduction/CompileUnit> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/reduction/thermodynamicBudget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "thermodynamicBudget" ;
  rdfs:comment "The Landauer-bounded energy budget for this CompileUnit's resolution, measured in k_B T ln 2 units." ;
  rdfs:domain <https://uor.foundation/reduction/CompileUnit> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/targetDomains>
  a owl:ObjectProperty ;
  rdfs:label "targetDomains" ;
  rdfs:comment "The verification domain(s) targeted by this CompileUnit." ;
  rdfs:domain <https://uor.foundation/reduction/CompileUnit> ;
  rdfs:range <https://uor.foundation/op/VerificationDomain> .

<https://uor.foundation/reduction/unitAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unitAddress" ;
  rdfs:comment "Content-addressable identifier computed as the u:Element of the root term’s transitive closure. Computed by stage_initialization, not declared by the submitter. Excludes budget, domains, and quantum level to enable memoization." ;
  rdfs:domain <https://uor.foundation/reduction/CompileUnit> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/reduction/preflightOrder>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "preflightOrder" ;
  rdfs:comment "Zero-based execution order for preflight checks. Lower indices execute first. BudgetSolvencyCheck (order 0) must precede all others." ;
  rdfs:domain <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/ofFailure>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "ofFailure" ;
  rdfs:comment "The PipelineFailureReason (or class) this field belongs to." ;
  rdfs:domain <https://uor.foundation/reduction/FailureField> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/reduction/fieldName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "fieldName" ;
  rdfs:comment "Snake_case name of the Rust field on the generated PipelineFailure variant." ;
  rdfs:domain <https://uor.foundation/reduction/FailureField> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/fieldType>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "fieldType" ;
  rdfs:comment "Rust type for the field, expressed as a literal type string the codegen emits verbatim (e.g., \"&'static str\", \"usize\", \"ReductionStep\")." ;
  rdfs:domain <https://uor.foundation/reduction/FailureField> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/maxVarCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxVarCount" ;
  rdfs:comment "Maximum variable count the SAT decider supports." ;
  rdfs:domain <https://uor.foundation/reduction/SatBound> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/maxClauseCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxClauseCount" ;
  rdfs:comment "Maximum clause count the SAT decider supports." ;
  rdfs:domain <https://uor.foundation/reduction/SatBound> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/maxLiteralsPerClause>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxLiteralsPerClause" ;
  rdfs:comment "Maximum literals per clause (2 for 2-SAT, higher for Horn)." ;
  rdfs:domain <https://uor.foundation/reduction/SatBound> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/preflightBudgetNs>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "preflightBudgetNs" ;
  rdfs:comment "Preflight-stage time budget in nanoseconds at the v0.2.1 reference hardware." ;
  rdfs:domain <https://uor.foundation/reduction/TimingBound> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/runtimeBudgetNs>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "runtimeBudgetNs" ;
  rdfs:comment "Runtime-stage time budget in nanoseconds at the v0.2.1 reference hardware." ;
  rdfs:domain <https://uor.foundation/reduction/TimingBound> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/stage_initialization>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Initialization" ;
  rdfs:comment "Stage 0: initialize state vector to identity." ;
  <https://uor.foundation/reduction/stageIndex> "0"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Initialization" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω⁰" .

<https://uor.foundation/reduction/stage_declare>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Declare" ;
  rdfs:comment "Stage 1: dispatch resolver (δ selects)." ;
  <https://uor.foundation/reduction/stageIndex> "1"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Declare" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω¹" .

<https://uor.foundation/reduction/stage_factorize>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Factorize" ;
  rdfs:comment "Stage 2: produce valid ring address (G grounds)." ;
  <https://uor.foundation/reduction/stageIndex> "2"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Factorize" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω²" .

<https://uor.foundation/reduction/stage_resolve>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Resolve" ;
  rdfs:comment "Stage 3: resolve constraints (Π terminates)." ;
  <https://uor.foundation/reduction/stageIndex> "3"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Resolve" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω³" .

<https://uor.foundation/reduction/stage_attest>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Attest" ;
  rdfs:comment "Stage 4: accumulate without contradiction (α consistent)." ;
  <https://uor.foundation/reduction/stageIndex> "4"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Attest" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω⁴" .

<https://uor.foundation/reduction/stage_extract>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Extract" ;
  rdfs:comment "Stage 5: extract coherent output (P projects)." ;
  <https://uor.foundation/reduction/stageIndex> "5"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Extract" ;
  <https://uor.foundation/reduction/expectedPhase> "Ω⁵" .

<https://uor.foundation/reduction/stage_convergence>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:label "Convergence" ;
  rdfs:comment "Terminal stage: reduction has reached the convergence angle π." ;
  <https://uor.foundation/reduction/stageIndex> "6"^^xsd:integer ;
  <https://uor.foundation/reduction/stageName> "Convergence" ;
  <https://uor.foundation/reduction/expectedPhase> "π" .

<https://uor.foundation/reduction/gate_initialization>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_initialization" ;
  rdfs:comment "Phase gate at stage 0 boundary: checks Ω⁰ = 1." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_initialization> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω⁰" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/gate_declare>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_declare" ;
  rdfs:comment "Phase gate at stage 1 boundary: checks Ω¹." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_declare> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω¹" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/gate_factorize>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_factorize" ;
  rdfs:comment "Phase gate at stage 2 boundary: checks Ω²." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_factorize> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω²" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/gate_resolve>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_resolve" ;
  rdfs:comment "Phase gate at stage 3 boundary: checks Ω³." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_resolve> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω³" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/gate_attest>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_attest" ;
  rdfs:comment "Phase gate at stage 4 boundary: checks Ω⁴." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_attest> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω⁴" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/gate_extract>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:label "gate_extract" ;
  rdfs:comment "Phase gate at stage 5 boundary: checks Ω⁵." ;
  <https://uor.foundation/reduction/gateStage> <https://uor.foundation/reduction/stage_extract> ;
  <https://uor.foundation/reduction/gateExpectedPhase> "Ω⁵" ;
  <https://uor.foundation/reduction/gateResult> "true"^^xsd:boolean .

<https://uor.foundation/reduction/euler_reduction_instance>
  a owl:NamedIndividual , <https://uor.foundation/reduction/EulerReduction> ;
  rdfs:label "euler_reduction_instance" ;
  rdfs:comment "The canonical Euler reduction instance with Ω = e^{iπ/6} and 6 stages." ;
  <https://uor.foundation/reduction/phaseParameter> "e^{iπ/6}" ;
  <https://uor.foundation/reduction/stageCount> "6"^^xsd:integer ;
  <https://uor.foundation/reduction/convergenceAngle> "π" .

<https://uor.foundation/reduction/phase_schedule>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PhaseRotationScheduler> ;
  rdfs:label "phase_schedule" ;
  rdfs:comment "The canonical phase rotation schedule for the 6-stage reduction." ;
  <https://uor.foundation/reduction/rotationSchedule> "Ω⁰, Ω¹, Ω², Ω³, Ω⁴, Ω⁵" ;
  <https://uor.foundation/reduction/baseAngle> "π/6" .

<https://uor.foundation/reduction/convergence_target>
  a owl:NamedIndividual , <https://uor.foundation/reduction/TargetConvergenceAngle> ;
  rdfs:label "convergence_target" ;
  rdfs:comment "The default convergence target angle π." ;
  <https://uor.foundation/reduction/targetAngle> "π" .

<https://uor.foundation/reduction/conjugate_rollback>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ComplexConjugateRollback> ;
  rdfs:label "conjugate_rollback" ;
  rdfs:comment "The canonical complex conjugate rollback operation: z → z̄." ;
  <https://uor.foundation/reduction/rollbackTarget> <https://uor.foundation/reduction/stage_initialization> .

<https://uor.foundation/reduction/DispatchMiss>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "DispatchMiss" ;
  rdfs:comment "Failure: no resolver matched the dispatch query." ;
  <https://uor.foundation/reduction/failureKind> "DispatchMiss" .

<https://uor.foundation/reduction/GroundingFailure>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "GroundingFailure" ;
  rdfs:comment "Failure: grounding to a valid ring address failed." ;
  <https://uor.foundation/reduction/failureKind> "GroundingFailure" .

<https://uor.foundation/reduction/ConvergenceStall>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "ConvergenceStall" ;
  rdfs:comment "Failure: reduction stalled before reaching convergence angle." ;
  <https://uor.foundation/reduction/failureKind> "ConvergenceStall" .

<https://uor.foundation/reduction/ContradictionDetected>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "ContradictionDetected" ;
  rdfs:comment "Failure: accumulation detected a logical contradiction." ;
  <https://uor.foundation/reduction/failureKind> "ContradictionDetected" .

<https://uor.foundation/reduction/CoherenceViolation>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "CoherenceViolation" ;
  rdfs:comment "Failure: coherence constraint violated during extraction." ;
  <https://uor.foundation/reduction/failureKind> "CoherenceViolation" .

<https://uor.foundation/reduction/ShapeMismatch>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:label "ShapeMismatch" ;
  rdfs:comment "Failure: the CompileUnit's root term produced a value of a shape other than the caller-declared expected shape. Introduced in v0.2.2 W14 as part of the typed pipeline::run::<T> entry point." ;
  <https://uor.foundation/reduction/failureKind> "ShapeMismatch" .

<https://uor.foundation/reduction/FullGroundingSuccess>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PipelineSuccess> ;
  rdfs:label "FullGroundingSuccess" ;
  rdfs:comment "Successful termination: all sites saturated." ;
  <https://uor.foundation/reduction/groundingReached> "true"^^xsd:boolean .

<https://uor.foundation/reduction/FeasibilityCheck>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "FeasibilityCheck" ;
  rdfs:comment "Preflight: checks that the reduction can reach convergence." ;
  <https://uor.foundation/reduction/preflightKind> "Feasibility" ;
  <https://uor.foundation/reduction/preflightOrder> "1"^^xsd:integer .

<https://uor.foundation/reduction/DispatchCoverageCheck>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "DispatchCoverageCheck" ;
  rdfs:comment "Preflight: checks that every dispatch query has a resolver." ;
  <https://uor.foundation/reduction/preflightKind> "DispatchCoverage" ;
  <https://uor.foundation/reduction/preflightOrder> "2"^^xsd:integer .

<https://uor.foundation/reduction/PackageCoherenceCheck>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "PackageCoherenceCheck" ;
  rdfs:comment "Preflight: checks package-level coherence constraints." ;
  <https://uor.foundation/reduction/preflightKind> "PackageCoherence" ;
  <https://uor.foundation/reduction/preflightOrder> "3"^^xsd:integer .

<https://uor.foundation/reduction/default_service_window>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ServiceWindow> ;
  rdfs:label "default_service_window" ;
  rdfs:comment "The default service window: 3 epochs, zero offset." ;
  <https://uor.foundation/reduction/windowSize> "3"^^xsd:integer ;
  <https://uor.foundation/reduction/windowOffset> "0"^^xsd:integer .

<https://uor.foundation/reduction/advance_init_to_declare>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionAdvance> ;
  rdfs:label "advance_init_to_declare" ;
  rdfs:comment "Advancement from Initialization to Declare." ;
  <https://uor.foundation/reduction/advanceFrom> <https://uor.foundation/reduction/stage_initialization> ;
  <https://uor.foundation/reduction/advanceTo> <https://uor.foundation/reduction/stage_declare> .

<https://uor.foundation/reduction/atomic_transaction>
  a owl:NamedIndividual , <https://uor.foundation/reduction/ReductionTransaction> ;
  rdfs:label "atomic_transaction" ;
  rdfs:comment "An all-or-nothing atomic reduction transaction." ;
  <https://uor.foundation/reduction/transactionPolicy> "AllOrNothing" .

<https://uor.foundation/reduction/empty_guard>
  a owl:NamedIndividual , <https://uor.foundation/reduction/GuardExpression> ;
  rdfs:label "empty_guard" ;
  rdfs:comment "A trivially satisfied guard with no predicates." .

<https://uor.foundation/reduction/identity_effect>
  a owl:NamedIndividual , <https://uor.foundation/reduction/TransitionEffect> ;
  rdfs:label "identity_effect" ;
  rdfs:comment "The identity effect: no state changes." .

<https://uor.foundation/reduction/true_predicate>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PredicateExpression> ;
  rdfs:label "true_predicate" ;
  rdfs:comment "A predicate that always evaluates to true." ;
  <https://uor.foundation/reduction/predicateField> "*" ;
  <https://uor.foundation/reduction/predicateOperator> "true" ;
  <https://uor.foundation/reduction/predicateValue> "*" .

<https://uor.foundation/reduction/noop_bind>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PropertyBind> ;
  rdfs:label "noop_bind" ;
  rdfs:comment "A no-op property binding that changes nothing." ;
  <https://uor.foundation/reduction/bindTarget> "none" ;
  <https://uor.foundation/reduction/bindValue> "unchanged" .

<https://uor.foundation/reduction/Pending>
  a owl:NamedIndividual , <https://uor.foundation/reduction/LeaseState> ;
  rdfs:label "Pending" ;
  rdfs:comment "Lease is pending activation." ;
  <https://uor.foundation/reduction/leasePhase> "Pending" .

<https://uor.foundation/reduction/Active>
  a owl:NamedIndividual , <https://uor.foundation/reduction/LeaseState> ;
  rdfs:label "Active" ;
  rdfs:comment "Lease is active and resources are allocated." ;
  <https://uor.foundation/reduction/leasePhase> "Active" .

<https://uor.foundation/reduction/Released>
  a owl:NamedIndividual , <https://uor.foundation/reduction/LeaseState> ;
  rdfs:label "Released" ;
  rdfs:comment "Lease has been explicitly released." ;
  <https://uor.foundation/reduction/leasePhase> "Released" .

<https://uor.foundation/reduction/Expired>
  a owl:NamedIndividual , <https://uor.foundation/reduction/LeaseState> ;
  rdfs:label "Expired" ;
  rdfs:comment "Lease has expired due to timeout." ;
  <https://uor.foundation/reduction/leasePhase> "Expired" .

<https://uor.foundation/reduction/Suspended>
  a owl:NamedIndividual , <https://uor.foundation/reduction/LeaseState> ;
  rdfs:label "Suspended" ;
  rdfs:comment "Lease is temporarily suspended." ;
  <https://uor.foundation/reduction/leasePhase> "Suspended" .

<https://uor.foundation/reduction/FeasibilityWitness>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FeasibilityResult> ;
  rdfs:label "FeasibilityWitness" ;
  rdfs:comment "Preflight result: reduction is feasible." ;
  <https://uor.foundation/reduction/feasibilityKind> "Feasible" .

<https://uor.foundation/reduction/InfeasibilityWitness>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FeasibilityResult> ;
  rdfs:label "InfeasibilityWitness" ;
  rdfs:comment "Preflight result: reduction is infeasible." ;
  <https://uor.foundation/reduction/feasibilityKind> "Infeasible" ;
  <https://uor.foundation/reduction/feasibilityWitness> "obstruction detected" .

<https://uor.foundation/reduction/PreflightTiming>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "PreflightTiming" ;
  rdfs:comment "Preflight: timing feasibility check." ;
  <https://uor.foundation/reduction/preflightKind> "Timing" ;
  <https://uor.foundation/reduction/preflightOrder> "4"^^xsd:integer .

<https://uor.foundation/reduction/RuntimeTiming>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "RuntimeTiming" ;
  rdfs:comment "Preflight: runtime timing bounds check." ;
  <https://uor.foundation/reduction/preflightKind> "RuntimeTiming" ;
  <https://uor.foundation/reduction/preflightOrder> "5"^^xsd:integer .

<https://uor.foundation/reduction/BudgetSolvencyCheck>
  a owl:NamedIndividual , <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:label "BudgetSolvencyCheck" ;
  rdfs:comment "Preflight: verifies thermodynamicBudget ≥ bitsWidth(unitWittLevel) × ln 2. Rejects the CompileUnit if the budget is absent or insufficient. Must execute before all other preflights (preflightOrder 0). Cost is O(1) per CS_4." ;
  <https://uor.foundation/reduction/preflightKind> "BudgetSolvency" ;
  <https://uor.foundation/reduction/preflightOrder> "0"^^xsd:integer .

<https://uor.foundation/reduction/BackPressureDefault>
  a owl:NamedIndividual , <https://uor.foundation/reduction/BackPressureSignal> ;
  rdfs:label "BackPressureDefault" ;
  rdfs:comment "Default back-pressure signal with medium threshold." ;
  <https://uor.foundation/reduction/pressureLevel> "Medium" ;
  <https://uor.foundation/reduction/pressureThreshold> "0.75"^^xsd:decimal .

<https://uor.foundation/reduction/dispatchMiss_queryIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "dispatchMiss_queryIri_field" ;
  rdfs:comment "DispatchMiss field carrying the query IRI that failed to dispatch." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/DispatchMiss> ;
  <https://uor.foundation/reduction/fieldName> "query_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/dispatchMiss_tableIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "dispatchMiss_tableIri_field" ;
  rdfs:comment "DispatchMiss field carrying the dispatch table IRI that failed to find a matching rule." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/DispatchMiss> ;
  <https://uor.foundation/reduction/fieldName> "table_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/groundingFailure_reasonIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "groundingFailure_reasonIri_field" ;
  rdfs:comment "GroundingFailure field carrying the morphism:GroundingMap IRI whose image missed the ring." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/GroundingFailure> ;
  <https://uor.foundation/reduction/fieldName> "reason_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/convergenceStall_stage_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "convergenceStall_stage_field" ;
  rdfs:comment "ConvergenceStall field carrying the IRI of the ReductionStep at which the phase-rotation scheduler stopped advancing." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ConvergenceStall> ;
  <https://uor.foundation/reduction/fieldName> "stage_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/convergenceStall_angle_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "convergenceStall_angle_field" ;
  rdfs:comment "ConvergenceStall field carrying the last reduction:convergenceAngle reached, encoded as a milli-radian integer to preserve `Eq` on PipelineFailure." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ConvergenceStall> ;
  <https://uor.foundation/reduction/fieldName> "angle_milliradians" ;
  <https://uor.foundation/reduction/fieldType> "i64" .

<https://uor.foundation/reduction/contradictionDetected_atStep_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "contradictionDetected_atStep_field" ;
  rdfs:comment "ContradictionDetected field carrying the derivation:stepIndex of the accumulation step." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ContradictionDetected> ;
  <https://uor.foundation/reduction/fieldName> "at_step" ;
  <https://uor.foundation/reduction/fieldType> "usize" .

<https://uor.foundation/reduction/contradictionDetected_traceIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "contradictionDetected_traceIri_field" ;
  rdfs:comment "ContradictionDetected field pointing to the trace:ComputationTrace record." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ContradictionDetected> ;
  <https://uor.foundation/reduction/fieldName> "trace_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/coherenceViolation_sitePosition_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "coherenceViolation_sitePosition_field" ;
  rdfs:comment "CoherenceViolation field carrying the site position where the conformance:PackageCoherenceCheck failed." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/CoherenceViolation> ;
  <https://uor.foundation/reduction/fieldName> "site_position" ;
  <https://uor.foundation/reduction/fieldType> "usize" .

<https://uor.foundation/reduction/coherenceViolation_constraintIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "coherenceViolation_constraintIri_field" ;
  rdfs:comment "CoherenceViolation field carrying the failing constraint IRI." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/CoherenceViolation> ;
  <https://uor.foundation/reduction/fieldName> "constraint_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/shapeMismatch_expected_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "shapeMismatch_expected_field" ;
  rdfs:comment "ShapeMismatch field carrying the expected shape IRI declared by the caller of pipeline::run::<T>." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ShapeMismatch> ;
  <https://uor.foundation/reduction/fieldName> "expected" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/shapeMismatch_got_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "shapeMismatch_got_field" ;
  rdfs:comment "ShapeMismatch field carrying the actual shape IRI produced by the CompileUnit's root term." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/reduction/ShapeMismatch> ;
  <https://uor.foundation/reduction/fieldName> "got" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/liftObstruction_sitePosition_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "liftObstruction_sitePosition_field" ;
  rdfs:comment "LiftObstructionFailure field carrying the site position from the resolver:LiftRefinementSuggestion." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/failure/LiftObstructionFailure> ;
  <https://uor.foundation/reduction/fieldName> "site_position" ;
  <https://uor.foundation/reduction/fieldType> "usize" .

<https://uor.foundation/reduction/liftObstruction_obstructionClassIri_field>
  a owl:NamedIndividual , <https://uor.foundation/reduction/FailureField> ;
  rdfs:label "liftObstruction_obstructionClassIri_field" ;
  rdfs:comment "LiftObstructionFailure field carrying the obstruction class IRI from the LiftRefinementSuggestion." ;
  <https://uor.foundation/reduction/ofFailure> <https://uor.foundation/failure/LiftObstructionFailure> ;
  <https://uor.foundation/reduction/fieldName> "obstruction_class_iri" ;
  <https://uor.foundation/reduction/fieldType> "&'static str" .

<https://uor.foundation/reduction/TwoSatBound>
  a owl:NamedIndividual , <https://uor.foundation/reduction/SatBound> ;
  rdfs:label "TwoSatBound" ;
  rdfs:comment "v0.2.1 2-SAT decider bounds. Drives TWO_SAT_MAX_VARS and the corresponding Lean fuel constant." ;
  <https://uor.foundation/reduction/maxVarCount> "256"^^xsd:integer ;
  <https://uor.foundation/reduction/maxClauseCount> "512"^^xsd:integer ;
  <https://uor.foundation/reduction/maxLiteralsPerClause> "2"^^xsd:integer .

<https://uor.foundation/reduction/HornSatBound>
  a owl:NamedIndividual , <https://uor.foundation/reduction/SatBound> ;
  rdfs:label "HornSatBound" ;
  rdfs:comment "v0.2.1 Horn-SAT decider bounds." ;
  <https://uor.foundation/reduction/maxVarCount> "256"^^xsd:integer ;
  <https://uor.foundation/reduction/maxClauseCount> "512"^^xsd:integer ;
  <https://uor.foundation/reduction/maxLiteralsPerClause> "8"^^xsd:integer .

<https://uor.foundation/reduction/PreflightTimingBound>
  a owl:NamedIndividual , <https://uor.foundation/reduction/TimingBound> ;
  rdfs:label "PreflightTimingBound" ;
  rdfs:comment "v0.2.1 preflight-stage time budget." ;
  <https://uor.foundation/reduction/preflightBudgetNs> "10000000"^^xsd:integer .

<https://uor.foundation/reduction/RuntimeTimingBound>
  a owl:NamedIndividual , <https://uor.foundation/reduction/TimingBound> ;
  rdfs:label "RuntimeTimingBound" ;
  rdfs:comment "v0.2.1 runtime-stage time budget." ;
  <https://uor.foundation/reduction/runtimeBudgetNs> "10000000"^^xsd:integer .

# Namespace: convergence
<https://uor.foundation/convergence/>
  a owl:Ontology ;
  rdfs:label "UOR Convergence Tower" ;
  rdfs:comment "Hopf convergence tower: four levels R, C, H, O corresponding to the four normed division algebras of dimensions 1, 2, 4, 8. Each level carries a Hopf fibration fiber and Betti signature." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/reduction/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/homology/> ;
.

<https://uor.foundation/convergence/ConvergenceLevel>
  a owl:Class ;
  rdfs:label "ConvergenceLevel" ;
  rdfs:comment "A level in the convergence tower. Four instances: R (dim 1), C (dim 2), H (dim 4), O (dim 8)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/convergence/HopfFiber>
  a owl:Class ;
  rdfs:label "HopfFiber" ;
  rdfs:comment "The fiber of the Hopf fibration at a convergence level. Four instances: S⁰, S¹, S³, S⁷." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/convergence/ConvergenceResidual>
  a owl:Class ;
  rdfs:label "ConvergenceResidual" ;
  rdfs:comment "The unresolved structure at a convergence level. The β_{2^k−1} = 1 Betti number that persists." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/convergence/CommutativeSubspace>
  a owl:Class ;
  rdfs:label "CommutativeSubspace" ;
  rdfs:comment "The subspace U(1) ⊂ SU(2) selected when pairwise interaction converges." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/convergence/AssociativeSubalgebra>
  a owl:Class ;
  rdfs:label "AssociativeSubalgebra" ;
  rdfs:comment "The subspace H ⊂ O selected when triple interaction converges." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/convergence/algebraDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "algebraDimension" ;
  rdfs:comment "The dimension of the division algebra at this level (1, 2, 4, or 8)." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/convergence/bettiSignature>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bettiSignature" ;
  rdfs:comment "The Betti number signature at this convergence level." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/fiberType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "fiberType" ;
  rdfs:comment "The Hopf fiber associated with this convergence level." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:range <https://uor.foundation/convergence/HopfFiber> .

<https://uor.foundation/convergence/characteristicIdentity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "characteristicIdentity" ;
  rdfs:comment "The characteristic identity at this convergence level (existence, feedback, choice, self-reference)." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/levelName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "levelName" ;
  rdfs:comment "Human-readable name of this convergence level." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/fiberDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "fiberDimension" ;
  rdfs:comment "The dimension of the Hopf fiber sphere." ;
  rdfs:domain <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/convergence/totalSpace>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "totalSpace" ;
  rdfs:comment "The total space of the Hopf fibration." ;
  rdfs:domain <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/baseSpace>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "baseSpace" ;
  rdfs:comment "The base space of the Hopf fibration." ;
  rdfs:domain <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/fiberSphere>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "fiberSphere" ;
  rdfs:comment "The fiber sphere designation (e.g. S⁰, S¹)." ;
  rdfs:domain <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/convergence/residualBetti>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "residualBetti" ;
  rdfs:comment "The persistent Betti number at this residual." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceResidual> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/convergence/residualDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "residualDimension" ;
  rdfs:comment "The dimension at which the residual persists." ;
  rdfs:domain <https://uor.foundation/convergence/ConvergenceResidual> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/convergence/subspaceRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "subspaceRef" ;
  rdfs:comment "The commutative subspace selected by pairwise convergence." ;
  rdfs:domain <https://uor.foundation/convergence/CommutativeSubspace> ;
  rdfs:range <https://uor.foundation/convergence/CommutativeSubspace> .

<https://uor.foundation/convergence/subalgebraRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "subalgebraRef" ;
  rdfs:comment "The associative subalgebra selected by triple convergence." ;
  rdfs:domain <https://uor.foundation/convergence/AssociativeSubalgebra> ;
  rdfs:range <https://uor.foundation/convergence/AssociativeSubalgebra> .

<https://uor.foundation/convergence/commutatorRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "commutatorRef" ;
  rdfs:comment "Reference to the commutator pair for this convergence." ;
  rdfs:domain <https://uor.foundation/convergence/CommutativeSubspace> ;
  rdfs:range <https://uor.foundation/observable/Commutator> .

<https://uor.foundation/convergence/associatorRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "associatorRef" ;
  rdfs:comment "Reference to the associator triple for this convergence." ;
  rdfs:domain <https://uor.foundation/convergence/AssociativeSubalgebra> ;
  rdfs:range <https://uor.foundation/interaction/AssociatorTriple> .

<https://uor.foundation/convergence/L0_State>
  a owl:NamedIndividual , <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:label "L0_State" ;
  rdfs:comment "Level 0: R (reals), dimension 1, existence." ;
  <https://uor.foundation/convergence/algebraDimension> "1"^^xsd:integer ;
  <https://uor.foundation/convergence/bettiSignature> "[1]" ;
  <https://uor.foundation/convergence/fiberType> <https://uor.foundation/convergence/hopf_S0> ;
  <https://uor.foundation/convergence/characteristicIdentity> "existence" ;
  <https://uor.foundation/convergence/levelName> "R" .

<https://uor.foundation/convergence/L1_Memory>
  a owl:NamedIndividual , <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:label "L1_Memory" ;
  rdfs:comment "Level 1: C (complex), dimension 2, feedback." ;
  <https://uor.foundation/convergence/algebraDimension> "2"^^xsd:integer ;
  <https://uor.foundation/convergence/bettiSignature> "[1,1]" ;
  <https://uor.foundation/convergence/fiberType> <https://uor.foundation/convergence/hopf_S1> ;
  <https://uor.foundation/convergence/characteristicIdentity> "feedback" ;
  <https://uor.foundation/convergence/levelName> "C" .

<https://uor.foundation/convergence/L2_Agency>
  a owl:NamedIndividual , <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:label "L2_Agency" ;
  rdfs:comment "Level 2: H (quaternions), dimension 4, choice." ;
  <https://uor.foundation/convergence/algebraDimension> "4"^^xsd:integer ;
  <https://uor.foundation/convergence/bettiSignature> "[1,0,0,1]" ;
  <https://uor.foundation/convergence/fiberType> <https://uor.foundation/convergence/hopf_S3> ;
  <https://uor.foundation/convergence/characteristicIdentity> "choice" ;
  <https://uor.foundation/convergence/levelName> "H" .

<https://uor.foundation/convergence/L3_Self>
  a owl:NamedIndividual , <https://uor.foundation/convergence/ConvergenceLevel> ;
  rdfs:label "L3_Self" ;
  rdfs:comment "Level 3: O (octonions), dimension 8, self-reference." ;
  <https://uor.foundation/convergence/algebraDimension> "8"^^xsd:integer ;
  <https://uor.foundation/convergence/bettiSignature> "[1,0,0,0,0,0,0,1]" ;
  <https://uor.foundation/convergence/fiberType> <https://uor.foundation/convergence/hopf_S7> ;
  <https://uor.foundation/convergence/characteristicIdentity> "self-reference" ;
  <https://uor.foundation/convergence/levelName> "O" .

<https://uor.foundation/convergence/hopf_S0>
  a owl:NamedIndividual , <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:label "hopf_S0" ;
  rdfs:comment "Hopf fiber S⁰: dimension 0, total space S¹, base pt." ;
  <https://uor.foundation/convergence/fiberDimension> "0"^^xsd:integer ;
  <https://uor.foundation/convergence/totalSpace> "S¹" ;
  <https://uor.foundation/convergence/baseSpace> "pt" ;
  <https://uor.foundation/convergence/fiberSphere> "S⁰" .

<https://uor.foundation/convergence/hopf_S1>
  a owl:NamedIndividual , <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:label "hopf_S1" ;
  rdfs:comment "Hopf fiber S¹: dimension 1, total space S³, base S²." ;
  <https://uor.foundation/convergence/fiberDimension> "1"^^xsd:integer ;
  <https://uor.foundation/convergence/totalSpace> "S³" ;
  <https://uor.foundation/convergence/baseSpace> "S²" ;
  <https://uor.foundation/convergence/fiberSphere> "S¹" .

<https://uor.foundation/convergence/hopf_S3>
  a owl:NamedIndividual , <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:label "hopf_S3" ;
  rdfs:comment "Hopf fiber S³: dimension 3, total space S⁷, base S⁴." ;
  <https://uor.foundation/convergence/fiberDimension> "3"^^xsd:integer ;
  <https://uor.foundation/convergence/totalSpace> "S⁷" ;
  <https://uor.foundation/convergence/baseSpace> "S⁴" ;
  <https://uor.foundation/convergence/fiberSphere> "S³" .

<https://uor.foundation/convergence/hopf_S7>
  a owl:NamedIndividual , <https://uor.foundation/convergence/HopfFiber> ;
  rdfs:label "hopf_S7" ;
  rdfs:comment "Hopf fiber S⁷: dimension 7, total space S¹⁵, base S⁸." ;
  <https://uor.foundation/convergence/fiberDimension> "7"^^xsd:integer ;
  <https://uor.foundation/convergence/totalSpace> "S¹⁵" ;
  <https://uor.foundation/convergence/baseSpace> "S⁸" ;
  <https://uor.foundation/convergence/fiberSphere> "S⁷" .

# Namespace: division
<https://uor.foundation/division/>
  a owl:Ontology ;
  rdfs:label "UOR Division Algebras" ;
  rdfs:comment "The four normed division algebras R, C, H, O and the Cayley-Dickson construction." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/convergence/> ;
.

<https://uor.foundation/division/NormedDivisionAlgebra>
  a owl:Class ;
  rdfs:label "NormedDivisionAlgebra" ;
  rdfs:comment "An algebra over R that is a division ring with multiplicative norm. Exactly four exist (Hurwitz theorem): R, C, H, O." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/division/CayleyDicksonConstruction>
  a owl:Class ;
  rdfs:label "CayleyDicksonConstruction" ;
  rdfs:comment "The doubling construction that builds each division algebra from the previous: R → C → H → O." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/division/MultiplicationTable>
  a owl:Class ;
  rdfs:label "MultiplicationTable" ;
  rdfs:comment "The explicit product rules for a division algebra’s basis elements." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/division/AlgebraCommutator>
  a owl:Class ;
  rdfs:label "AlgebraCommutator" ;
  rdfs:comment "The commutator [a,b] = ab − ba. Zero for R and C; non-zero for H and O." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/division/AlgebraAssociator>
  a owl:Class ;
  rdfs:label "AlgebraAssociator" ;
  rdfs:comment "The associator [a,b,c] = (ab)c − a(bc). Zero for R, C, H; non-zero for O." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/division/algebraDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "algebraDimension" ;
  rdfs:comment "The dimension of this division algebra (1, 2, 4, or 8)." ;
  rdfs:domain <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/division/isCommutative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isCommutative" ;
  rdfs:comment "Whether multiplication in this algebra is commutative." ;
  rdfs:domain <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/division/isAssociative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isAssociative" ;
  rdfs:comment "Whether multiplication in this algebra is associative." ;
  rdfs:domain <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/division/basisElements>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "basisElements" ;
  rdfs:comment "The basis elements of this division algebra." ;
  rdfs:domain <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/division/algebraMultiplicationTable>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "algebraMultiplicationTable" ;
  rdfs:comment "The multiplication table for this algebra." ;
  rdfs:domain <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:range <https://uor.foundation/division/MultiplicationTable> .

<https://uor.foundation/division/cayleyDicksonSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "cayleyDicksonSource" ;
  rdfs:comment "The source algebra of the Cayley-Dickson doubling." ;
  rdfs:domain <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:range <https://uor.foundation/division/NormedDivisionAlgebra> .

<https://uor.foundation/division/cayleyDicksonTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "cayleyDicksonTarget" ;
  rdfs:comment "The target algebra of the Cayley-Dickson doubling." ;
  rdfs:domain <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:range <https://uor.foundation/division/NormedDivisionAlgebra> .

<https://uor.foundation/division/adjoinedElement>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "adjoinedElement" ;
  rdfs:comment "The new basis element adjoined by this doubling step." ;
  rdfs:domain <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/division/conjugationRule>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "conjugationRule" ;
  rdfs:comment "The conjugation and multiplication rule for the adjoined element." ;
  rdfs:domain <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/division/RealAlgebra>
  a owl:NamedIndividual , <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:label "RealAlgebra" ;
  rdfs:comment "The real numbers R: dimension 1, commutative, associative." ;
  <https://uor.foundation/division/algebraDimension> "1"^^xsd:integer ;
  <https://uor.foundation/division/isCommutative> "true"^^xsd:boolean ;
  <https://uor.foundation/division/isAssociative> "true"^^xsd:boolean ;
  <https://uor.foundation/division/basisElements> "{1}" .

<https://uor.foundation/division/ComplexAlgebra>
  a owl:NamedIndividual , <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:label "ComplexAlgebra" ;
  rdfs:comment "The complex numbers C: dimension 2, commutative, associative." ;
  <https://uor.foundation/division/algebraDimension> "2"^^xsd:integer ;
  <https://uor.foundation/division/isCommutative> "true"^^xsd:boolean ;
  <https://uor.foundation/division/isAssociative> "true"^^xsd:boolean ;
  <https://uor.foundation/division/basisElements> "{1, i}" .

<https://uor.foundation/division/QuaternionAlgebra>
  a owl:NamedIndividual , <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:label "QuaternionAlgebra" ;
  rdfs:comment "The quaternions H: dimension 4, non-commutative, associative." ;
  <https://uor.foundation/division/algebraDimension> "4"^^xsd:integer ;
  <https://uor.foundation/division/isCommutative> "false"^^xsd:boolean ;
  <https://uor.foundation/division/isAssociative> "true"^^xsd:boolean ;
  <https://uor.foundation/division/basisElements> "{1, i, j, k}" .

<https://uor.foundation/division/OctonionAlgebra>
  a owl:NamedIndividual , <https://uor.foundation/division/NormedDivisionAlgebra> ;
  rdfs:label "OctonionAlgebra" ;
  rdfs:comment "The octonions O: dimension 8, non-commutative, non-associative." ;
  <https://uor.foundation/division/algebraDimension> "8"^^xsd:integer ;
  <https://uor.foundation/division/isCommutative> "false"^^xsd:boolean ;
  <https://uor.foundation/division/isAssociative> "false"^^xsd:boolean ;
  <https://uor.foundation/division/basisElements> "{1, i, j, k, l, il, jl, kl}" .

<https://uor.foundation/division/cayleyDickson_R_to_C>
  a owl:NamedIndividual , <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:label "cayleyDickson_R_to_C" ;
  rdfs:comment "Cayley-Dickson doubling R → C: adjoin i with i² = −1." ;
  <https://uor.foundation/division/cayleyDicksonSource> <https://uor.foundation/division/RealAlgebra> ;
  <https://uor.foundation/division/cayleyDicksonTarget> <https://uor.foundation/division/ComplexAlgebra> ;
  <https://uor.foundation/division/adjoinedElement> "i" ;
  <https://uor.foundation/division/conjugationRule> "i² = −1" .

<https://uor.foundation/division/cayleyDickson_C_to_H>
  a owl:NamedIndividual , <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:label "cayleyDickson_C_to_H" ;
  rdfs:comment "Cayley-Dickson doubling C → H: adjoin j with j² = −1, ij = k, ji = −k." ;
  <https://uor.foundation/division/cayleyDicksonSource> <https://uor.foundation/division/ComplexAlgebra> ;
  <https://uor.foundation/division/cayleyDicksonTarget> <https://uor.foundation/division/QuaternionAlgebra> ;
  <https://uor.foundation/division/adjoinedElement> "j" ;
  <https://uor.foundation/division/conjugationRule> "ij = k, ji = −k" .

<https://uor.foundation/division/cayleyDickson_H_to_O>
  a owl:NamedIndividual , <https://uor.foundation/division/CayleyDicksonConstruction> ;
  rdfs:label "cayleyDickson_H_to_O" ;
  rdfs:comment "Cayley-Dickson doubling H → O: adjoin l, non-associative Fano plane products." ;
  <https://uor.foundation/division/cayleyDicksonSource> <https://uor.foundation/division/QuaternionAlgebra> ;
  <https://uor.foundation/division/cayleyDicksonTarget> <https://uor.foundation/division/OctonionAlgebra> ;
  <https://uor.foundation/division/adjoinedElement> "l" ;
  <https://uor.foundation/division/conjugationRule> "non-associative Fano plane products" .

# Namespace: interaction
<https://uor.foundation/interaction/>
  a owl:Ontology ;
  rdfs:label "UOR Interaction Algebra" ;
  rdfs:comment "Multi-entity interaction: commutator states, associator triples, negotiation convergence." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/convergence/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/schema/> ;
.

<https://uor.foundation/interaction/InteractionContext>
  a owl:Class ;
  rdfs:label "InteractionContext" ;
  rdfs:comment "Two entities sharing sites through composed operations. Properties: entityA, entityB, sharedSiteMask, commutatorNorm." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/CommutatorState>
  a owl:Class ;
  rdfs:label "CommutatorState" ;
  rdfs:comment "The norm ‖[δ_A, ι_B]‖ on shared sites. Zero iff operators commute on the shared domain." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/AssociatorState>
  a owl:Class ;
  rdfs:label "AssociatorState" ;
  rdfs:comment "The norm of the three-way associator on shared sites." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/AssociatorTriple>
  a owl:Class ;
  rdfs:label "AssociatorTriple" ;
  rdfs:comment "Three entities whose interaction exhibits non-associativity due to read-write interleaving." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/ThreeWaySite>
  a owl:Class ;
  rdfs:label "ThreeWaySite" ;
  rdfs:comment "A site shared by all three entities in an AssociatorTriple." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/NegotiationTrace>
  a owl:Class ;
  rdfs:label "NegotiationTrace" ;
  rdfs:comment "Sequence of CommutatorStates across interaction steps." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/MutualModelTrace>
  a owl:Class ;
  rdfs:label "MutualModelTrace" ;
  rdfs:comment "Sequence of AssociatorStates across interaction steps." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/InteractionNerve>
  a owl:Class ;
  rdfs:label "InteractionNerve" ;
  rdfs:comment "Simplicial complex of N-entity coupling." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/InteractionComposition>
  a owl:Class ;
  rdfs:label "InteractionComposition" ;
  rdfs:comment "IC(A,B) = κ(session(A,B)). Combined interaction-composition operator." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/interaction/entityA>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "entityA" ;
  rdfs:comment "First entity in the interaction context." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionContext> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/interaction/entityB>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "entityB" ;
  rdfs:comment "Second entity in the interaction context." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionContext> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/interaction/sharedSiteMask>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sharedSiteMask" ;
  rdfs:comment "Bitmask identifying which sites are shared between the two entities." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionContext> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/commutatorNorm>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "commutatorNorm" ;
  rdfs:comment "The norm of the commutator on shared sites. Zero iff the operators commute." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionContext> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/commutatorValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "commutatorValue" ;
  rdfs:comment "The computed commutator norm value." ;
  rdfs:domain <https://uor.foundation/interaction/CommutatorState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/associatorNorm>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "associatorNorm" ;
  rdfs:comment "The norm of the three-way associator on shared sites." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/tripleComponentA>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "tripleComponentA" ;
  rdfs:comment "First component datum in the associator triple." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorTriple> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/interaction/tripleComponentB>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "tripleComponentB" ;
  rdfs:comment "Second component datum in the associator triple." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorTriple> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/interaction/tripleComponentC>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "tripleComponentC" ;
  rdfs:comment "Third component datum in the associator triple." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorTriple> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/interaction/sitePosition>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitePosition" ;
  rdfs:comment "The position index of the shared site." ;
  rdfs:domain <https://uor.foundation/interaction/ThreeWaySite> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/leftGroupingValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leftGroupingValue" ;
  rdfs:comment "Value under left-associative grouping (AB)C." ;
  rdfs:domain <https://uor.foundation/interaction/ThreeWaySite> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/rightGroupingValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "rightGroupingValue" ;
  rdfs:comment "Value under right-associative grouping A(BC)." ;
  rdfs:domain <https://uor.foundation/interaction/ThreeWaySite> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/isPinned>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isPinned" ;
  rdfs:comment "Whether this site is pinned by a lease constraint." ;
  rdfs:domain <https://uor.foundation/interaction/ThreeWaySite> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/interaction/pinningPair>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "pinningPair" ;
  rdfs:comment "Identifier of the entity pair that pins this site." ;
  rdfs:domain <https://uor.foundation/interaction/ThreeWaySite> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/interaction/negotiationSteps>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "negotiationSteps" ;
  rdfs:comment "Number of steps in the negotiation trace." ;
  rdfs:domain <https://uor.foundation/interaction/NegotiationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/isConvergent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isConvergent" ;
  rdfs:comment "Whether the trace converges to zero commutator or zero associator." ;
  rdfs:domain <https://uor.foundation/interaction/NegotiationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/interaction/modelConvergent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "modelConvergent" ;
  rdfs:comment "Whether the mutual model trace converges." ;
  rdfs:domain <https://uor.foundation/interaction/MutualModelTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/interaction/nerveDimension>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "nerveDimension" ;
  rdfs:comment "Maximum dimension of the interaction nerve simplicial complex." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionNerve> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/nerveBettiNumbers>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "nerveBettiNumbers" ;
  rdfs:comment "Betti number sequence of the interaction nerve." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionNerve> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/reificationDepth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "reificationDepth" ;
  rdfs:comment "Depth of the interaction composition reification." ;
  rdfs:domain <https://uor.foundation/interaction/InteractionComposition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/traceLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "traceLength" ;
  rdfs:comment "The number of steps in a negotiation trace." ;
  rdfs:domain <https://uor.foundation/interaction/NegotiationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/interaction/convergenceRate>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "convergenceRate" ;
  rdfs:comment "The rate at which the negotiation trace converges." ;
  rdfs:domain <https://uor.foundation/interaction/NegotiationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/interaction/terminalValue>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "terminalValue" ;
  rdfs:comment "The terminal value of the negotiation trace." ;
  rdfs:domain <https://uor.foundation/interaction/NegotiationTrace> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/interaction/associatorProfileRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "associatorProfileRef" ;
  rdfs:comment "Reference to the observable describing the associativity profile." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorTriple> ;
  rdfs:range <https://uor.foundation/observable/Observable> .

<https://uor.foundation/interaction/associatorNormValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "associatorNormValue" ;
  rdfs:comment "The maximum norm of the associator for this triple." ;
  rdfs:domain <https://uor.foundation/interaction/AssociatorTriple> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

# Namespace: monoidal
<https://uor.foundation/monoidal/>
  a owl:Ontology ;
  rdfs:label "UOR Monoidal Composition" ;
  rdfs:comment "Sequential composition of computations via monoidal product A ⊗ B." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/reduction/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/schema/> ;
.

<https://uor.foundation/monoidal/MonoidalProduct>
  a owl:Class ;
  rdfs:label "MonoidalProduct" ;
  rdfs:comment "A ⊗ B: the sequential composition of two computations. Output of A feeds input of B." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/monoidal/MonoidalUnit>
  a owl:Class ;
  rdfs:label "MonoidalUnit" ;
  rdfs:comment "The identity computation I: passes input through unchanged. I ⊗ A ≅ A ≅ A ⊗ I." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/monoidal/MonoidalAssociator>
  a owl:Class ;
  rdfs:label "MonoidalAssociator" ;
  rdfs:comment "The witness that (A⊗B)⊗C ≅ A⊗(B⊗C). The associativity isomorphism." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/monoidal/leftOperand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftOperand" ;
  rdfs:comment "The left operand in the monoidal product A ⊗ B." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalProduct> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/monoidal/rightOperand>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightOperand" ;
  rdfs:comment "The right operand in the monoidal product A ⊗ B." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalProduct> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/monoidal/composedResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "composedResult" ;
  rdfs:comment "The result datum of the composed computation A ⊗ B." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalProduct> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/monoidal/saturationValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "saturationValue" ;
  rdfs:comment "σ(A⊗B) relationship: saturation of the sequential composition." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalProduct> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/monoidal/unitWitnessRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unitWitnessRef" ;
  rdfs:comment "Certificate witnessing I ⊗ A ≅ A ≅ A ⊗ I." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalUnit> ;
  rdfs:range <https://uor.foundation/cert/Certificate> .

<https://uor.foundation/monoidal/associatorLeft>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "associatorLeft" ;
  rdfs:comment "The left-grouped product (A⊗B)⊗C." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalAssociator> ;
  rdfs:range <https://uor.foundation/monoidal/MonoidalProduct> .

<https://uor.foundation/monoidal/associatorRight>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "associatorRight" ;
  rdfs:comment "The right-grouped product A⊗(B⊗C)." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalAssociator> ;
  rdfs:range <https://uor.foundation/monoidal/MonoidalProduct> .

<https://uor.foundation/monoidal/associatorWitnessRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "associatorWitnessRef" ;
  rdfs:comment "Certificate witnessing the associativity isomorphism (A⊗B)⊗C ≅ A⊗(B⊗C)." ;
  rdfs:domain <https://uor.foundation/monoidal/MonoidalAssociator> ;
  rdfs:range <https://uor.foundation/cert/Certificate> .

# Namespace: operad
<https://uor.foundation/operad/>
  a owl:Ontology ;
  rdfs:label "UOR Operad Composition" ;
  rdfs:comment "Structural type nesting via operad composition. Governs how types compose: Table(Tuple(Sequence(Symbol(...))))." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/carry/> ;
  owl:imports <https://uor.foundation/morphism/> ;
.

<https://uor.foundation/operad/StructuralOperad>
  a owl:Class ;
  rdfs:label "StructuralOperad" ;
  rdfs:comment "The composition structure on the eight structural types. Governs how types nest." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/operad/OperadComposition>
  a owl:Class ;
  rdfs:label "OperadComposition" ;
  rdfs:comment "A specific nesting: outer type F applied to inner type G." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/operad/operadStructure>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operadStructure" ;
  rdfs:comment "The structural operad defining this composition." ;
  rdfs:domain <https://uor.foundation/operad/StructuralOperad> ;
  rdfs:range <https://uor.foundation/operad/StructuralOperad> .

<https://uor.foundation/operad/outerType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "outerType" ;
  rdfs:comment "The outer type F in the nesting F(G)." ;
  rdfs:domain <https://uor.foundation/operad/OperadComposition> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/operad/innerType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "innerType" ;
  rdfs:comment "The inner type G in the nesting F(G)." ;
  rdfs:domain <https://uor.foundation/operad/OperadComposition> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/operad/composedType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "composedType" ;
  rdfs:comment "The resulting composed type F(G)." ;
  rdfs:domain <https://uor.foundation/operad/OperadComposition> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/operad/composedSiteCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "composedSiteCount" ;
  rdfs:comment "Site count of the composed type F(G)." ;
  rdfs:domain <https://uor.foundation/operad/OperadComposition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/operad/composedGrounding>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "composedGrounding" ;
  rdfs:comment "Grounding of the composed type F(G)." ;
  rdfs:domain <https://uor.foundation/operad/OperadComposition> ;
  rdfs:range <https://uor.foundation/morphism/GroundingMap> .

# Namespace: effect
<https://uor.foundation/effect/>
  a owl:Ontology ;
  rdfs:label "UOR Effect Algebra" ;
  rdfs:comment "Typed endomorphisms on state:Context classified by site target. Formalizes what reduction guard-effect pairs do to the site budget." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/cert/> ;
.

<https://uor.foundation/effect/Effect>
  a owl:Class ;
  rdfs:label "Effect" ;
  rdfs:comment "A typed endomorphism on state:Context. Maps one site-budget configuration to another. The atomic unit of state mutation in the kernel." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/effect/ReversibleEffect>
  a owl:Class ;
  rdfs:label "ReversibleEffect" ;
  rdfs:comment "An effect that has a well-defined inverse. PinningEffect and PhaseEffect are reversible; ExternalEffect and CompositeEffect are not in general." ;
  rdfs:subClassOf <https://uor.foundation/effect/Effect> ;
.

<https://uor.foundation/effect/PinningEffect>
  a owl:Class ;
  rdfs:label "PinningEffect" ;
  rdfs:comment "Pins a single free site to a definite value. Decrements freeRank by exactly 1. The effect produced by constraint resolution." ;
  rdfs:subClassOf <https://uor.foundation/effect/ReversibleEffect> ;
.

<https://uor.foundation/effect/UnbindingEffect>
  a owl:Class ;
  rdfs:label "UnbindingEffect" ;
  rdfs:comment "Releases a pinned site back to free state. Increments freeRank by exactly 1. The effect produced by session boundary reset." ;
  rdfs:subClassOf <https://uor.foundation/effect/Effect> ;
.

<https://uor.foundation/effect/PhaseEffect>
  a owl:Class ;
  rdfs:label "PhaseEffect" ;
  rdfs:comment "Rotates the reduction phase angle by Ω^k. Does not alter the site budget. The effect produced by reduction step transitions." ;
  rdfs:subClassOf <https://uor.foundation/effect/ReversibleEffect> ;
.

<https://uor.foundation/effect/CompositeEffect>
  a owl:Class ;
  rdfs:label "CompositeEffect" ;
  rdfs:comment "An ordered sequence of effects applied atomically. The composition E₁ ; E₂ applies E₁ then E₂." ;
  rdfs:subClassOf <https://uor.foundation/effect/Effect> ;
.

<https://uor.foundation/effect/ExternalEffect>
  a owl:Class ;
  rdfs:label "ExternalEffect" ;
  rdfs:comment "An opaque effect declared by a Prism implementation. The kernel treats it as a site-budget transformation satisfying the declared commutation contract. Must carry an effect:externalEffectShape linking to a conformance:EffectShape." ;
  rdfs:subClassOf <https://uor.foundation/effect/Effect> ;
.

<https://uor.foundation/effect/EffectTarget>
  a owl:Class ;
  rdfs:label "EffectTarget" ;
  rdfs:comment "The set of site coordinates that an effect reads or writes. Determines commutation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/effect/DisjointnessWitness>
  a owl:Class ;
  rdfs:label "DisjointnessWitness" ;
  rdfs:comment "A certificate that two EffectTargets have empty intersection, enabling commutative reordering." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/effect/effectTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "effectTarget" ;
  rdfs:comment "The site coordinates this effect touches." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/effect/targetSites>
  a owl:ObjectProperty ;
  rdfs:label "targetSites" ;
  rdfs:comment "The individual site coordinates in this target set." ;
  rdfs:domain <https://uor.foundation/effect/EffectTarget> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/effect/compositeHead>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositeHead" ;
  rdfs:comment "The first effect in the composite sequence." ;
  rdfs:domain <https://uor.foundation/effect/CompositeEffect> ;
  rdfs:range <https://uor.foundation/effect/Effect> .

<https://uor.foundation/effect/compositeTail>
  a owl:ObjectProperty ;
  rdfs:label "compositeTail" ;
  rdfs:comment "Subsequent effects in the composite sequence (ordered by effect:compositeIndex)." ;
  rdfs:domain <https://uor.foundation/effect/CompositeEffect> ;
  rdfs:range <https://uor.foundation/effect/Effect> .

<https://uor.foundation/effect/disjointnessLeft>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessLeft" ;
  rdfs:comment "The left target in the disjointness claim." ;
  rdfs:domain <https://uor.foundation/effect/DisjointnessWitness> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/effect/disjointnessRight>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessRight" ;
  rdfs:comment "The right target in the disjointness claim." ;
  rdfs:domain <https://uor.foundation/effect/DisjointnessWitness> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/effect/preContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "preContext" ;
  rdfs:comment "The context before effect application." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/effect/postContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "postContext" ;
  rdfs:comment "The context after effect application." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/effect/externalEffectShape>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "externalEffectShape" ;
  rdfs:comment "The conformance shape that this external effect satisfies." ;
  rdfs:domain <https://uor.foundation/effect/ExternalEffect> ;
  rdfs:range <https://uor.foundation/conformance/EffectShape> .

<https://uor.foundation/effect/freeRankDelta>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "freeRankDelta" ;
  rdfs:comment "Change in freeRank: −1 for PinningEffect, +1 for UnbindingEffect, 0 for PhaseEffect." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/effect/phaseAngleDelta>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "phaseAngleDelta" ;
  rdfs:comment "The phase rotation applied, expressed as Ω^k." ;
  rdfs:domain <https://uor.foundation/effect/PhaseEffect> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/effect/compositeIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "compositeIndex" ;
  rdfs:comment "Position within a CompositeEffect sequence." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/effect/isCommutativeWith>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isCommutativeWith" ;
  rdfs:comment "Computed: true iff effectTargets are disjoint with the compared effect. Derived from DisjointnessWitness existence." ;
  rdfs:domain <https://uor.foundation/effect/Effect> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/effect/targetCardinality>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetCardinality" ;
  rdfs:comment "Number of site coordinates in this target set." ;
  rdfs:domain <https://uor.foundation/effect/EffectTarget> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: predicate
<https://uor.foundation/predicate/>
  a owl:Ontology ;
  rdfs:label "UOR Predicates and Dispatch" ;
  rdfs:comment "Boolean-valued functions on kernel objects. Formalizes resolver dispatch, reduction guard evaluation, and conditional resolution paths." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/partition/> ;
.

<https://uor.foundation/predicate/Predicate>
  a owl:Class ;
  rdfs:label "Predicate" ;
  rdfs:comment "A total, pure, boolean-valued function on a kernel object. Evaluation terminates for all inputs and produces no side effects." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/predicate/TypePredicate>
  a owl:Class ;
  rdfs:label "TypePredicate" ;
  rdfs:comment "A predicate over type:TypeDefinition. Used for resolver dispatch." ;
  rdfs:subClassOf <https://uor.foundation/predicate/Predicate> ;
.

<https://uor.foundation/predicate/StatePredicate>
  a owl:Class ;
  rdfs:label "StatePredicate" ;
  rdfs:comment "A predicate over state:Context or reduction:ReductionState. Used for reduction step guards." ;
  rdfs:subClassOf <https://uor.foundation/predicate/Predicate> ;
.

<https://uor.foundation/predicate/SitePredicate>
  a owl:Class ;
  rdfs:label "SitePredicate" ;
  rdfs:comment "A predicate over partition:SiteIndex. Used for site-level selection in geodesic resolution." ;
  rdfs:subClassOf <https://uor.foundation/predicate/Predicate> ;
.

<https://uor.foundation/predicate/DispatchRule>
  a owl:Class ;
  rdfs:label "DispatchRule" ;
  rdfs:comment "A pair (Predicate, Target) where Target is a resolver:Resolver class. The kernel evaluates the predicate; if true, the target resolver is selected." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/predicate/DispatchTable>
  a owl:Class ;
  rdfs:label "DispatchTable" ;
  rdfs:comment "An ordered set of DispatchRules for a single dispatch point. Must satisfy exhaustiveness and mutual exclusion." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/predicate/GuardedTransition>
  a owl:Class ;
  rdfs:label "GuardedTransition" ;
  rdfs:comment "A triple (StatePredicate, effect:Effect, reduction:ReductionStep). The guard is a StatePredicate; if true, the effect is applied and the reduction advances to the target step." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/predicate/MatchArm>
  a owl:Class ;
  rdfs:label "MatchArm" ;
  rdfs:comment "A single case in a pattern match: a Predicate and a result Term. The match evaluates predicates in order and returns the result of the first matching arm." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/predicate/MatchExpression>
  a owl:Class ;
  rdfs:label "MatchExpression" ;
  rdfs:comment "A term formed by evaluating a sequence of MatchArms. Extends the term language with deterministic conditional evaluation." ;
  rdfs:subClassOf <https://uor.foundation/schema/Term> ;
.

<https://uor.foundation/predicate/evaluatesOver>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "evaluatesOver" ;
  rdfs:comment "The OWL class of objects this predicate accepts as input." ;
  rdfs:domain <https://uor.foundation/predicate/Predicate> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/predicate/dispatchPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchPredicate" ;
  rdfs:comment "The predicate that triggers this dispatch rule." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:range <https://uor.foundation/predicate/Predicate> .

<https://uor.foundation/predicate/dispatchTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchTarget" ;
  rdfs:comment "The resolver class selected when the predicate is satisfied. Range is the OWL class IRI of a resolver:Resolver subclass; v0.2.1 uses class IRIs so the codegen can construct façade structs." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/predicate/dispatchRules>
  a owl:ObjectProperty ;
  rdfs:label "dispatchRules" ;
  rdfs:comment "The ordered set of rules in this table." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchTable> ;
  rdfs:range <https://uor.foundation/predicate/DispatchRule> .

<https://uor.foundation/predicate/dispatchPriority>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchPriority" ;
  rdfs:comment "Non-negative integer priority. Lower priority values are evaluated first; ties within a DispatchTable are resolved by declaration order." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/predicate/evaluatorTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "evaluatorTerm" ;
  rdfs:comment "The evaluator term that must reduce to a boolean-shaped datum on every input of the declared input type." ;
  rdfs:domain <https://uor.foundation/predicate/Predicate> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/predicate/terminationWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "terminationWitness" ;
  rdfs:comment "An IRI or identifier of the proof:Proof / proof:ComputationCertificate attesting that the evaluator halts on all inputs." ;
  rdfs:domain <https://uor.foundation/predicate/Predicate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/predicate/guardPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "guardPredicate" ;
  rdfs:comment "The guard predicate for this transition." ;
  rdfs:domain <https://uor.foundation/predicate/GuardedTransition> ;
  rdfs:range <https://uor.foundation/predicate/StatePredicate> .

<https://uor.foundation/predicate/guardEffect>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "guardEffect" ;
  rdfs:comment "The effect applied when the guard is satisfied." ;
  rdfs:domain <https://uor.foundation/predicate/GuardedTransition> ;
  rdfs:range <https://uor.foundation/effect/Effect> .

<https://uor.foundation/predicate/guardTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "guardTarget" ;
  rdfs:comment "The reduction step to advance to." ;
  rdfs:domain <https://uor.foundation/predicate/GuardedTransition> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/predicate/matchArms>
  a owl:ObjectProperty ;
  rdfs:label "matchArms" ;
  rdfs:comment "The ordered arms of this match expression." ;
  rdfs:domain <https://uor.foundation/predicate/MatchExpression> ;
  rdfs:range <https://uor.foundation/predicate/MatchArm> .

<https://uor.foundation/predicate/armPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "armPredicate" ;
  rdfs:comment "The predicate guarding this arm." ;
  rdfs:domain <https://uor.foundation/predicate/MatchArm> ;
  rdfs:range <https://uor.foundation/predicate/Predicate> .

<https://uor.foundation/predicate/armResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "armResult" ;
  rdfs:comment "The result term if this arm matches." ;
  rdfs:domain <https://uor.foundation/predicate/MatchArm> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/predicate/boundedEvaluator>
  a owl:ObjectProperty ;
  rdfs:label "boundedEvaluator" ;
  rdfs:comment "A termination witness for user-declared predicates. Kernel predicates are total by construction; user-declared predicates must carry a descent measure certifying termination." ;
  rdfs:domain <https://uor.foundation/predicate/Predicate> ;
  rdfs:range <https://uor.foundation/recursion/DescentMeasure> .

<https://uor.foundation/predicate/dispatchIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchIndex" ;
  rdfs:comment "Position in the dispatch table (evaluation order)." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/predicate/isExhaustive>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isExhaustive" ;
  rdfs:comment "True iff the disjunction of all dispatch predicates is a tautology over the input class." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchTable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/predicate/isMutuallyExclusive>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isMutuallyExclusive" ;
  rdfs:comment "True iff no two dispatch predicates can be simultaneously true for any input." ;
  rdfs:domain <https://uor.foundation/predicate/DispatchTable> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/predicate/armIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "armIndex" ;
  rdfs:comment "Position in the match expression (evaluation order)." ;
  rdfs:domain <https://uor.foundation/predicate/MatchArm> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/predicate/always>
  a owl:NamedIndividual , <https://uor.foundation/predicate/Predicate> ;
  rdfs:label "always" ;
  rdfs:comment "True on every Datum. Match-arm default catch-all." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/never>
  a owl:NamedIndividual , <https://uor.foundation/predicate/Predicate> ;
  rdfs:label "never" ;
  rdfs:comment "False on every Datum. Disabled-arm marker." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/isZero>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "isZero" ;
  rdfs:comment "True iff the Datum is the additive identity of its ring." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/isUnit>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "isUnit" ;
  rdfs:comment "True iff the Datum is the multiplicative identity." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/isOdd>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "isOdd" ;
  rdfs:comment "True iff the Datum parity bit is 1." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/isEven>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "isEven" ;
  rdfs:comment "True iff the Datum parity bit is 0." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/isInvolution>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "isInvolution" ;
  rdfs:comment "True iff op(op(x)) = x for the bound op." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/schema/Datum> .

<https://uor.foundation/predicate/sitePinned>
  a owl:NamedIndividual , <https://uor.foundation/predicate/SitePredicate> ;
  rdfs:label "sitePinned" ;
  rdfs:comment "True iff the named site coordinate is currently pinned." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/predicate/siteFree>
  a owl:NamedIndividual , <https://uor.foundation/predicate/SitePredicate> ;
  rdfs:label "siteFree" ;
  rdfs:comment "True iff the named site coordinate is currently free." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/predicate/contradictionReached>
  a owl:NamedIndividual , <https://uor.foundation/predicate/StatePredicate> ;
  rdfs:label "contradictionReached" ;
  rdfs:comment "True iff the resolver has entered a ContradictionBoundary." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/state/ContradictionBoundary> .

<https://uor.foundation/predicate/budgetExhausted>
  a owl:NamedIndividual , <https://uor.foundation/predicate/StatePredicate> ;
  rdfs:label "budgetExhausted" ;
  rdfs:comment "True iff the FreeRank deficit is zero." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/predicate/reductionConverged>
  a owl:NamedIndividual , <https://uor.foundation/predicate/StatePredicate> ;
  rdfs:label "reductionConverged" ;
  rdfs:comment "True iff the reduction fixpoint has been reached." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/reduction/ReductionState> .

<https://uor.foundation/predicate/Is2SatShape>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "Is2SatShape" ;
  rdfs:comment "True on ConstrainedType instances whose constraint nerve contains only disjunctions of width ≤ 2." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/predicate/IsHornShape>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "IsHornShape" ;
  rdfs:comment "True on ConstrainedType instances whose disjunctions each contain at most one positive literal." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/predicate/IsResidualFragment>
  a owl:NamedIndividual , <https://uor.foundation/predicate/TypePredicate> ;
  rdfs:label "IsResidualFragment" ;
  rdfs:comment "Default (catch-all) predicate. True on ConstrainedType instances not classified by Is2SatShape or IsHornShape." ;
  <https://uor.foundation/predicate/evaluatesOver> <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/predicate/InhabitanceDispatchTable>
  a owl:NamedIndividual , <https://uor.foundation/predicate/DispatchTable> ;
  rdfs:label "InhabitanceDispatchTable" ;
  rdfs:comment "The predicate:DispatchTable governing resolver:InhabitanceResolver. Three rules form a partition of type:ConstrainedType: Is2SatShape → TwoSatDecider (priority 0), IsHornShape → HornSatDecider (priority 1), IsResidualFragment → ResidualVerdictResolver (priority 2, catch-all). Total coverage is enforced by reduction:DispatchCoverageCheck; DispatchMiss is unreachable for this table." ;
  <https://uor.foundation/predicate/isExhaustive> "true"^^xsd:boolean ;
  <https://uor.foundation/predicate/isMutuallyExclusive> "true"^^xsd:boolean .

<https://uor.foundation/predicate/inhabitance_rule_2sat>
  a owl:NamedIndividual , <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:label "inhabitance_rule_2sat" ;
  rdfs:comment "Dispatch rule 1 of InhabitanceDispatchTable: Is2SatShape → TwoSatDecider at priority 0." ;
  <https://uor.foundation/predicate/dispatchPredicate> <https://uor.foundation/predicate/Is2SatShape> ;
  <https://uor.foundation/predicate/dispatchTarget> <https://uor.foundation/resolver/TwoSatDecider> ;
  <https://uor.foundation/predicate/dispatchPriority> "0"^^xsd:integer .

<https://uor.foundation/predicate/inhabitance_rule_horn>
  a owl:NamedIndividual , <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:label "inhabitance_rule_horn" ;
  rdfs:comment "Dispatch rule 2 of InhabitanceDispatchTable: IsHornShape → HornSatDecider at priority 1." ;
  <https://uor.foundation/predicate/dispatchPredicate> <https://uor.foundation/predicate/IsHornShape> ;
  <https://uor.foundation/predicate/dispatchTarget> <https://uor.foundation/resolver/HornSatDecider> ;
  <https://uor.foundation/predicate/dispatchPriority> "1"^^xsd:integer .

<https://uor.foundation/predicate/inhabitance_rule_residual>
  a owl:NamedIndividual , <https://uor.foundation/predicate/DispatchRule> ;
  rdfs:label "inhabitance_rule_residual" ;
  rdfs:comment "Dispatch rule 3 (catch-all) of InhabitanceDispatchTable: IsResidualFragment → ResidualVerdictResolver at priority 2. Ensures total coverage." ;
  <https://uor.foundation/predicate/dispatchPredicate> <https://uor.foundation/predicate/IsResidualFragment> ;
  <https://uor.foundation/predicate/dispatchTarget> <https://uor.foundation/resolver/ResidualVerdictResolver> ;
  <https://uor.foundation/predicate/dispatchPriority> "2"^^xsd:integer .

# Namespace: parallel
<https://uor.foundation/parallel/>
  a owl:Ontology ;
  rdfs:label "UOR Parallel Composition" ;
  rdfs:comment "Independent computations over provably disjoint site budgets. Formalizes when execution order is irrelevant." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/monoidal/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/trace/> ;
.

<https://uor.foundation/parallel/ParallelProduct>
  a owl:Class ;
  rdfs:label "ParallelProduct" ;
  rdfs:comment "A ∥ B: two computations with provably disjoint site targets. Execution order does not affect the result." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/parallel/DisjointnessCertificate>
  a owl:Class ;
  rdfs:label "DisjointnessCertificate" ;
  rdfs:comment "A kernel-produced certificate attesting that the site targets of two computations are disjoint." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/parallel/SynchronizationPoint>
  a owl:Class ;
  rdfs:label "SynchronizationPoint" ;
  rdfs:comment "A point where two parallel computations must agree on shared state before proceeding. Only applicable when parallelism is partial." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/parallel/ParallelTrace>
  a owl:Class ;
  rdfs:label "ParallelTrace" ;
  rdfs:comment "A computation trace recording interleaved steps from two parallel computations. Valid iff every interleaving produces the same final context." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationTrace> ;
.

<https://uor.foundation/parallel/SitePartitioning>
  a owl:Class ;
  rdfs:label "SitePartitioning" ;
  rdfs:comment "A partition of the total site budget into disjoint subsets, one per parallel component. The sum of subset cardinalities equals the total site budget." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/parallel/leftComputation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leftComputation" ;
  rdfs:comment "The left parallel component (itself a sequential computation)." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <https://uor.foundation/monoidal/MonoidalProduct> .

<https://uor.foundation/parallel/rightComputation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rightComputation" ;
  rdfs:comment "The right parallel component." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <https://uor.foundation/monoidal/MonoidalProduct> .

<https://uor.foundation/parallel/disjointnessCert>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessCert" ;
  rdfs:comment "The certificate proving site disjointness." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <https://uor.foundation/parallel/DisjointnessCertificate> .

<https://uor.foundation/parallel/certLeftTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certLeftTarget" ;
  rdfs:comment "The site target of the left computation." ;
  rdfs:domain <https://uor.foundation/parallel/DisjointnessCertificate> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/parallel/certRightTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certRightTarget" ;
  rdfs:comment "The site target of the right computation." ;
  rdfs:domain <https://uor.foundation/parallel/DisjointnessCertificate> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/parallel/syncSites>
  a owl:ObjectProperty ;
  rdfs:label "syncSites" ;
  rdfs:comment "The shared sites requiring synchronization." ;
  rdfs:domain <https://uor.foundation/parallel/SynchronizationPoint> ;
  rdfs:range <https://uor.foundation/partition/SiteIndex> .

<https://uor.foundation/parallel/partitionComponents>
  a owl:ObjectProperty ;
  rdfs:label "partitionComponents" ;
  rdfs:comment "The disjoint subsets composing the full site budget." ;
  rdfs:domain <https://uor.foundation/parallel/SitePartitioning> ;
  rdfs:range <https://uor.foundation/effect/EffectTarget> .

<https://uor.foundation/parallel/componentCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "componentCount" ;
  rdfs:comment "Number of parallel components." ;
  rdfs:domain <https://uor.foundation/parallel/SitePartitioning> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/parallel/isFullyDisjoint>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isFullyDisjoint" ;
  rdfs:comment "True iff site targets have zero overlap (no SynchronizationPoints required)." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/parallel/disjointnessCommutation>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessCommutation" ;
  rdfs:comment "Declares whether this parallel product commutes with disjoint effects per FX_4." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/parallel/sitePartition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sitePartition" ;
  rdfs:comment "The partition:Partition this parallel product is over." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/parallel/disjointnessWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessWitness" ;
  rdfs:comment "IRI of a proof of pairwise disjointness of the partition components." ;
  rdfs:domain <https://uor.foundation/parallel/ParallelProduct> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

# Namespace: stream
<https://uor.foundation/stream/>
  a owl:Ontology ;
  rdfs:label "UOR Productive Streams" ;
  rdfs:comment "Coinductive sequences of reduction epochs. Each epoch terminates independently; the stream is the unbounded composition of terminating epochs." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/reduction/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/monoidal/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/schema/> ;
.

<https://uor.foundation/stream/ProductiveStream>
  a owl:Class ;
  rdfs:label "ProductiveStream" ;
  rdfs:comment "An unbounded sequence of reduction epochs where each epoch terminates and produces a well-typed output. The coinductive dual of a finite computation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/stream/Epoch>
  a owl:Class ;
  rdfs:label "Epoch" ;
  rdfs:comment "A single bounded iteration within a productive stream. Each epoch is a complete reduction execution from Initialization through Convergence." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/stream/EpochBoundary>
  a owl:Class ;
  rdfs:label "EpochBoundary" ;
  rdfs:comment "The transition point between consecutive epochs. Carries the continuation context and the epoch output." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/stream/StreamPrefix>
  a owl:Class ;
  rdfs:label "StreamPrefix" ;
  rdfs:comment "A finite prefix of a productive stream: the first k epochs and their outputs. Every finite prefix is computable in finite time." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/stream/StreamMorphism>
  a owl:Class ;
  rdfs:label "StreamMorphism" ;
  rdfs:comment "A transform between productive streams: maps each epoch of the source to an epoch of the target while preserving the productive property." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
.

<https://uor.foundation/stream/Unfold>
  a owl:Class ;
  rdfs:label "Unfold" ;
  rdfs:comment "The coinductive constructor: given an initial context and a step function (a morphism:ComputationDatum), produces a ProductiveStream. The step function must be certified to always reach reduction convergence." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/stream/epochReduction>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "epochReduction" ;
  rdfs:comment "The reduction execution for this epoch." ;
  rdfs:domain <https://uor.foundation/stream/Epoch> ;
  rdfs:range <https://uor.foundation/reduction/EulerReduction> .

<https://uor.foundation/stream/epochOutput>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "epochOutput" ;
  rdfs:comment "The output datum produced by this epoch." ;
  rdfs:domain <https://uor.foundation/stream/Epoch> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/stream/epochContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "epochContext" ;
  rdfs:comment "The context at the start of this epoch." ;
  rdfs:domain <https://uor.foundation/stream/Epoch> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/stream/boundaryFrom>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundaryFrom" ;
  rdfs:comment "The epoch that just completed." ;
  rdfs:domain <https://uor.foundation/stream/EpochBoundary> ;
  rdfs:range <https://uor.foundation/stream/Epoch> .

<https://uor.foundation/stream/boundaryTo>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundaryTo" ;
  rdfs:comment "The epoch about to begin." ;
  rdfs:domain <https://uor.foundation/stream/EpochBoundary> ;
  rdfs:range <https://uor.foundation/stream/Epoch> .

<https://uor.foundation/stream/continuationContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "continuationContext" ;
  rdfs:comment "The context carried across the boundary." ;
  rdfs:domain <https://uor.foundation/stream/EpochBoundary> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/stream/prefixEpochs>
  a owl:ObjectProperty ;
  rdfs:label "prefixEpochs" ;
  rdfs:comment "The epochs in this prefix (ordered by stream:epochIndex)." ;
  rdfs:domain <https://uor.foundation/stream/StreamPrefix> ;
  rdfs:range <https://uor.foundation/stream/Epoch> .

<https://uor.foundation/stream/unfoldSeed>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unfoldSeed" ;
  rdfs:comment "The initial context for the stream." ;
  rdfs:domain <https://uor.foundation/stream/Unfold> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/stream/unfoldStep>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unfoldStep" ;
  rdfs:comment "The certified step function producing each epoch." ;
  rdfs:domain <https://uor.foundation/stream/Unfold> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/stream/unfoldResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unfoldResult" ;
  rdfs:comment "The stream produced by this unfold." ;
  rdfs:domain <https://uor.foundation/stream/Unfold> ;
  rdfs:range <https://uor.foundation/stream/ProductiveStream> .

<https://uor.foundation/stream/epochIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "epochIndex" ;
  rdfs:comment "Zero-based index of this epoch in the stream." ;
  rdfs:domain <https://uor.foundation/stream/Epoch> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/stream/prefixLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "prefixLength" ;
  rdfs:comment "Number of epochs in this prefix." ;
  rdfs:domain <https://uor.foundation/stream/StreamPrefix> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/stream/isProductive>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isProductive" ;
  rdfs:comment "Always true by construction: every epoch terminates. Invariant, not computed." ;
  rdfs:domain <https://uor.foundation/stream/ProductiveStream> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/stream/stepTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stepTerm" ;
  rdfs:comment "A term denoting a function from the current seed value to a pair (head, next_seed)." ;
  rdfs:domain <https://uor.foundation/stream/ProductiveStream> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/stream/productivityWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "productivityWitness" ;
  rdfs:comment "IRI of a proof of stream productivity (coinductive well-foundedness)." ;
  rdfs:domain <https://uor.foundation/stream/ProductiveStream> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

# Namespace: failure
<https://uor.foundation/failure/>
  a owl:Ontology ;
  rdfs:label "UOR Failure Algebra" ;
  rdfs:comment "Partial computations, typed failure propagation, and recovery. Formalizes how computations that cannot reach convergence are represented, composed, and recovered from within the ring substrate." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/reduction/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/trace/> ;
  owl:imports <https://uor.foundation/proof/> ;
.

<https://uor.foundation/failure/ComputationResult>
  a owl:Class ;
  rdfs:label "ComputationResult" ;
  rdfs:comment "The outcome of a computation that may fail: either a Success carrying a datum, or a Failure carrying a typed reason. The coproduct of the success and failure cases." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/failure/Success>
  a owl:Class ;
  rdfs:label "Success" ;
  rdfs:comment "A computation that reached convergence and produced a valid datum. Carries the output datum and the computation certificate." ;
  rdfs:subClassOf <https://uor.foundation/failure/ComputationResult> ;
.

<https://uor.foundation/failure/Failure>
  a owl:Class ;
  rdfs:label "Failure" ;
  rdfs:comment "A computation that could not reach convergence. Carries a typed FailureReason and the reduction state at the point of failure." ;
  rdfs:subClassOf <https://uor.foundation/failure/ComputationResult> ;
.

<https://uor.foundation/failure/FailureReason>
  a owl:Class ;
  rdfs:label "FailureReason" ;
  rdfs:comment "A typed classification of why a computation failed." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/failure/GuardFailure>
  a owl:Class ;
  rdfs:label "GuardFailure" ;
  rdfs:comment "A reduction step guard evaluated to false and no alternative transition exists." ;
  rdfs:subClassOf <https://uor.foundation/failure/FailureReason> ;
.

<https://uor.foundation/failure/ConstraintContradiction>
  a owl:Class ;
  rdfs:label "ConstraintContradiction" ;
  rdfs:comment "Two constraints in the type’s constraint set are jointly unsatisfiable." ;
  rdfs:subClassOf <https://uor.foundation/failure/FailureReason> ;
.

<https://uor.foundation/failure/SiteExhaustion>
  a owl:Class ;
  rdfs:label "SiteExhaustion" ;
  rdfs:comment "The linear budget was exhausted before resolution completed." ;
  rdfs:subClassOf <https://uor.foundation/failure/FailureReason> ;
.

<https://uor.foundation/failure/LiftObstructionFailure>
  a owl:Class ;
  rdfs:label "LiftObstructionFailure" ;
  rdfs:comment "A WittLift encountered a non-trivial obstruction that could not be resolved." ;
  rdfs:subClassOf <https://uor.foundation/failure/FailureReason> ;
.

<https://uor.foundation/failure/PartialComputation>
  a owl:Class ;
  rdfs:label "PartialComputation" ;
  rdfs:comment "A computation that produces a ComputationResult rather than a guaranteed datum. The general case of all computations." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/failure/TotalComputation>
  a owl:Class ;
  rdfs:label "TotalComputation" ;
  rdfs:comment "A computation where the FailureReason type is empty — failure is structurally impossible." ;
  rdfs:subClassOf <https://uor.foundation/failure/PartialComputation> ;
.

<https://uor.foundation/failure/Recovery>
  a owl:Class ;
  rdfs:label "Recovery" ;
  rdfs:comment "A strategy for converting a Failure into a Success by modifying the computation path." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/failure/FailurePropagation>
  a owl:Class ;
  rdfs:label "FailurePropagation" ;
  rdfs:comment "The rule for how failures compose under monoidal and parallel products." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/failure/resultDatum>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "resultDatum" ;
  rdfs:comment "The output datum of a successful computation." ;
  rdfs:domain <https://uor.foundation/failure/Success> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/failure/resultCertificate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "resultCertificate" ;
  rdfs:comment "The certificate attesting the computation’s correctness." ;
  rdfs:domain <https://uor.foundation/failure/Success> ;
  rdfs:range <https://uor.foundation/proof/ComputationCertificate> .

<https://uor.foundation/failure/failureReason>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "failureReason" ;
  rdfs:comment "The typed reason for failure." ;
  rdfs:domain <https://uor.foundation/failure/Failure> ;
  rdfs:range <https://uor.foundation/failure/FailureReason> .

<https://uor.foundation/failure/failureState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "failureState" ;
  rdfs:comment "The reduction state at the point of failure." ;
  rdfs:domain <https://uor.foundation/failure/Failure> ;
  rdfs:range <https://uor.foundation/reduction/ReductionState> .

<https://uor.foundation/failure/failureStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "failureStage" ;
  rdfs:comment "The reduction step where failure occurred." ;
  rdfs:domain <https://uor.foundation/failure/Failure> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/failure/recoveryStrategy>
  a owl:ObjectProperty ;
  rdfs:label "recoveryStrategy" ;
  rdfs:comment "Available recovery strategies for this failure." ;
  rdfs:domain <https://uor.foundation/failure/Failure> ;
  rdfs:range <https://uor.foundation/failure/Recovery> .

<https://uor.foundation/failure/recoveryEffect>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "recoveryEffect" ;
  rdfs:comment "The effect applied to recover from failure." ;
  rdfs:domain <https://uor.foundation/failure/Recovery> ;
  rdfs:range <https://uor.foundation/effect/Effect> .

<https://uor.foundation/failure/recoveryTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "recoveryTarget" ;
  rdfs:comment "The reduction step to retry after recovery." ;
  rdfs:domain <https://uor.foundation/failure/Recovery> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/failure/propagationRule>
  a owl:ObjectProperty ;
  rdfs:label "propagationRule" ;
  rdfs:comment "Which failure reasons propagate through this composition." ;
  rdfs:domain <https://uor.foundation/failure/FailurePropagation> ;
  rdfs:range <https://uor.foundation/failure/FailureReason> .

<https://uor.foundation/failure/isTotal>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isTotal" ;
  rdfs:comment "True iff the computation is a TotalComputation (no possible failure path)." ;
  rdfs:domain <https://uor.foundation/failure/PartialComputation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/failure/failureDepth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "failureDepth" ;
  rdfs:comment "The reduction step index at which failure occurred." ;
  rdfs:domain <https://uor.foundation/failure/Failure> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: linear
<https://uor.foundation/linear/>
  a owl:Ontology ;
  rdfs:label "UOR Linear Resources" ;
  rdfs:comment "Linear discipline on site consumption. Formalizes that each site in a complete resolution path is targeted by exactly one effect." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/trace/> ;
.

<https://uor.foundation/linear/LinearSite>
  a owl:Class ;
  rdfs:label "LinearSite" ;
  rdfs:comment "A site index annotated with a linearity constraint: must be pinned exactly once in any complete resolution path." ;
  rdfs:subClassOf <https://uor.foundation/partition/SiteIndex> ;
.

<https://uor.foundation/linear/LinearEffect>
  a owl:Class ;
  rdfs:label "LinearEffect" ;
  rdfs:comment "A PinningEffect that consumes its target LinearSite. After application, the site is no longer available for pinning by any subsequent effect." ;
  rdfs:subClassOf <https://uor.foundation/effect/PinningEffect> ;
.

<https://uor.foundation/linear/LinearTrace>
  a owl:Class ;
  rdfs:label "LinearTrace" ;
  rdfs:comment "A computation trace where every site in the budget is targeted by exactly one LinearEffect." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationTrace> ;
.

<https://uor.foundation/linear/LinearBudget>
  a owl:Class ;
  rdfs:label "LinearBudget" ;
  rdfs:comment "The multiset of LinearSites available at a given point in resolution. Starts as the full site budget; each LinearEffect removes exactly one element." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/linear/LeaseAllocation>
  a owl:Class ;
  rdfs:label "LeaseAllocation" ;
  rdfs:comment "A binding between a state:ContextLease and a subset of LinearSites. Formalizes what resources a lease claims." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/linear/AffineSite>
  a owl:Class ;
  rdfs:label "AffineSite" ;
  rdfs:comment "A site that may be pinned at most once (but need not be pinned). Relaxation of LinearSite for incomplete resolution paths." ;
  rdfs:subClassOf <https://uor.foundation/partition/SiteIndex> ;
.

<https://uor.foundation/linear/linearTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "linearTarget" ;
  rdfs:comment "The single site consumed by this effect." ;
  rdfs:domain <https://uor.foundation/linear/LinearEffect> ;
  rdfs:range <https://uor.foundation/linear/LinearSite> .

<https://uor.foundation/linear/budgetSites>
  a owl:ObjectProperty ;
  rdfs:label "budgetSites" ;
  rdfs:comment "The sites remaining in the budget." ;
  rdfs:domain <https://uor.foundation/linear/LinearBudget> ;
  rdfs:range <https://uor.foundation/linear/LinearSite> .

<https://uor.foundation/linear/budgetContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "budgetContext" ;
  rdfs:comment "The context associated with this budget state." ;
  rdfs:domain <https://uor.foundation/linear/LinearBudget> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/linear/leaseTarget>
  a owl:ObjectProperty ;
  rdfs:label "leaseTarget" ;
  rdfs:comment "The sites claimed by this lease." ;
  rdfs:domain <https://uor.foundation/linear/LeaseAllocation> ;
  rdfs:range <https://uor.foundation/linear/LinearSite> .

<https://uor.foundation/linear/leaseSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseSource" ;
  rdfs:comment "The ContextLease individual that owns this allocation." ;
  rdfs:domain <https://uor.foundation/linear/LeaseAllocation> ;
  rdfs:range <https://uor.foundation/state/ContextLease> .

<https://uor.foundation/linear/leaseAllocation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseAllocation" ;
  rdfs:comment "Links a state:ContextLease to its LinearSite allocation." ;
  rdfs:domain <https://uor.foundation/state/ContextLease> ;
  rdfs:range <https://uor.foundation/linear/LeaseAllocation> .

<https://uor.foundation/linear/remainingCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "remainingCount" ;
  rdfs:comment "Number of unconsumed sites. Equals freeRank on the associated context." ;
  rdfs:domain <https://uor.foundation/linear/LinearBudget> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/linear/leaseCardinality>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leaseCardinality" ;
  rdfs:comment "Number of sites claimed by this lease." ;
  rdfs:domain <https://uor.foundation/linear/LeaseAllocation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/linear/stackBudgetBytes>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stackBudgetBytes" ;
  rdfs:comment "The stack budget available at the call site in bytes. On embedded targets this is compile-time-known; on std targets it is computed from the thread-local stack frame. Consumed by the MultiplicationResolver to bound the admissible Toom-Cook splitting factor R: deeper recursion requires more stack, so R is capped where stack would overflow." ;
  rdfs:domain <https://uor.foundation/linear/LinearBudget> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: recursion
<https://uor.foundation/recursion/>
  a owl:Ontology ;
  rdfs:label "UOR Bounded Recursion" ;
  rdfs:comment "Self-referential computations with well-founded descent measures guaranteeing termination." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/predicate/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/failure/> ;
  owl:imports <https://uor.foundation/trace/> ;
.

<https://uor.foundation/recursion/BoundedRecursion>
  a owl:Class ;
  rdfs:label "BoundedRecursion" ;
  rdfs:comment "A self-referential computation parameterized by a descent measure. Each recursive step strictly decreases the measure; the computation terminates when the base case predicate is satisfied." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/recursion/DescentMeasure>
  a owl:Class ;
  rdfs:label "DescentMeasure" ;
  rdfs:comment "A well-founded function from computation state to xsd:nonNegativeInteger. Strictly decreases on every recursive step." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/recursion/BaseCase>
  a owl:Class ;
  rdfs:label "BaseCase" ;
  rdfs:comment "The match arm selected when the descent measure reaches zero or the base predicate is satisfied. Produces a direct result without further recursion." ;
  rdfs:subClassOf <https://uor.foundation/predicate/MatchArm> ;
.

<https://uor.foundation/recursion/RecursiveCase>
  a owl:Class ;
  rdfs:label "RecursiveCase" ;
  rdfs:comment "The match arm selected when the descent measure is positive. Applies a decomposition step, decreases the measure, and invokes the recursion." ;
  rdfs:subClassOf <https://uor.foundation/predicate/MatchArm> ;
.

<https://uor.foundation/recursion/RecursiveStep>
  a owl:Class ;
  rdfs:label "RecursiveStep" ;
  rdfs:comment "A single step in a bounded recursion: the decomposition applied before the recursive invocation. Must strictly decrease the DescentMeasure." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/recursion/RecursionTrace>
  a owl:Class ;
  rdfs:label "RecursionTrace" ;
  rdfs:comment "A computation trace recording the sequence of recursive steps, measure values, and the base case result. The trace length is bounded by the initial measure value." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationTrace> ;
.

<https://uor.foundation/recursion/StructuralRecursion>
  a owl:Class ;
  rdfs:label "StructuralRecursion" ;
  rdfs:comment "A bounded recursion where the descent measure is the structural size of the input type (site count, constraint count, or operad nesting depth)." ;
  rdfs:subClassOf <https://uor.foundation/recursion/BoundedRecursion> ;
.

<https://uor.foundation/recursion/measure>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "measure" ;
  rdfs:comment "The descent measure guaranteeing termination." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <https://uor.foundation/recursion/DescentMeasure> .

<https://uor.foundation/recursion/baseCase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "baseCase" ;
  rdfs:comment "The base case match arm." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <https://uor.foundation/recursion/BaseCase> .

<https://uor.foundation/recursion/recursiveCase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "recursiveCase" ;
  rdfs:comment "The recursive case match arm." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <https://uor.foundation/recursion/RecursiveCase> .

<https://uor.foundation/recursion/stepDecomposition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stepDecomposition" ;
  rdfs:comment "The transform applied to decompose the input before recursion." ;
  rdfs:domain <https://uor.foundation/recursion/RecursiveStep> ;
  rdfs:range <https://uor.foundation/morphism/Transform> .

<https://uor.foundation/recursion/stepMeasurePre>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stepMeasurePre" ;
  rdfs:comment "The measure value before this step." ;
  rdfs:domain <https://uor.foundation/recursion/RecursiveStep> ;
  rdfs:range <https://uor.foundation/recursion/DescentMeasure> .

<https://uor.foundation/recursion/stepMeasurePost>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stepMeasurePost" ;
  rdfs:comment "The measure value after this step." ;
  rdfs:domain <https://uor.foundation/recursion/RecursiveStep> ;
  rdfs:range <https://uor.foundation/recursion/DescentMeasure> .

<https://uor.foundation/recursion/basePredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "basePredicate" ;
  rdfs:comment "The predicate that identifies the base case." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <https://uor.foundation/predicate/Predicate> .

<https://uor.foundation/recursion/recursionBody>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "recursionBody" ;
  rdfs:comment "The computation applied at each recursive step (may reference itself via its content address)." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/recursion/initialMeasure>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "initialMeasure" ;
  rdfs:comment "The measure value at the start of recursion. Bounds the maximum recursion depth." ;
  rdfs:domain <https://uor.foundation/recursion/BoundedRecursion> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/recursion/measureValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "measureValue" ;
  rdfs:comment "The current value of the descent measure." ;
  rdfs:domain <https://uor.foundation/recursion/DescentMeasure> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: region
<https://uor.foundation/region/>
  a owl:Ontology ;
  rdfs:label "UOR Address Regions" ;
  rdfs:comment "Spatial locality of content-addressed ring elements. Defines computable working sets for resolver stages, independent of physical memory layout." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/u/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/observable/> ;
.

<https://uor.foundation/region/AddressRegion>
  a owl:Class ;
  rdfs:label "AddressRegion" ;
  rdfs:comment "A contiguous range of u:Element values accessible during a single reduction step. Defines the resolver’s working set." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/region/RegionBound>
  a owl:Class ;
  rdfs:label "RegionBound" ;
  rdfs:comment "The boundary of an AddressRegion: a pair (lowerAddress, upperAddress) in the content-address ordering." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/region/LocalityMetric>
  a owl:Class ;
  rdfs:label "LocalityMetric" ;
  rdfs:comment "A metric on u:Element values determining which addresses are near each other for resolution purposes." ;
  rdfs:subClassOf <https://uor.foundation/observable/MetricObservable> ;
.

<https://uor.foundation/region/WorkingSet>
  a owl:Class ;
  rdfs:label "WorkingSet" ;
  rdfs:comment "The set of AddressRegions needed by a resolver at a specific reduction step for a specific type. Computable from the type’s constraint nerve." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/region/RegionAllocation>
  a owl:Class ;
  rdfs:label "RegionAllocation" ;
  rdfs:comment "An assignment of AddressRegions to reduction steps for a given computation. Enables Prism to pre-compute memory layout." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/region/regionLower>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "regionLower" ;
  rdfs:comment "The lower bound of the address range." ;
  rdfs:domain <https://uor.foundation/region/RegionBound> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/region/regionUpper>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "regionUpper" ;
  rdfs:comment "The upper bound of the address range." ;
  rdfs:domain <https://uor.foundation/region/RegionBound> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/region/regionBound>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "regionBound" ;
  rdfs:comment "The boundary of this region." ;
  rdfs:domain <https://uor.foundation/region/AddressRegion> ;
  rdfs:range <https://uor.foundation/region/RegionBound> .

<https://uor.foundation/region/localityMetric>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "localityMetric" ;
  rdfs:comment "The metric defining contiguity for this region." ;
  rdfs:domain <https://uor.foundation/region/AddressRegion> ;
  rdfs:range <https://uor.foundation/region/LocalityMetric> .

<https://uor.foundation/region/workingSetRegions>
  a owl:ObjectProperty ;
  rdfs:label "workingSetRegions" ;
  rdfs:comment "The address regions composing this working set." ;
  rdfs:domain <https://uor.foundation/region/WorkingSet> ;
  rdfs:range <https://uor.foundation/region/AddressRegion> .

<https://uor.foundation/region/workingSetStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "workingSetStage" ;
  rdfs:comment "The reduction step this working set applies to." ;
  rdfs:domain <https://uor.foundation/region/WorkingSet> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/region/workingSetType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "workingSetType" ;
  rdfs:comment "The type being resolved." ;
  rdfs:domain <https://uor.foundation/region/WorkingSet> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/region/allocationStage>
  a owl:ObjectProperty ;
  rdfs:label "allocationStage" ;
  rdfs:comment "Reduction steps in this allocation." ;
  rdfs:domain <https://uor.foundation/region/RegionAllocation> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/region/allocationWorkingSet>
  a owl:ObjectProperty ;
  rdfs:label "allocationWorkingSet" ;
  rdfs:comment "The working sets assigned to each stage." ;
  rdfs:domain <https://uor.foundation/region/RegionAllocation> ;
  rdfs:range <https://uor.foundation/region/WorkingSet> .

<https://uor.foundation/region/regionCardinality>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "regionCardinality" ;
  rdfs:comment "Number of addresses in this region." ;
  rdfs:domain <https://uor.foundation/region/AddressRegion> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/region/workingSetSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "workingSetSize" ;
  rdfs:comment "Total addresses across all regions in the working set." ;
  rdfs:domain <https://uor.foundation/region/WorkingSet> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: boundary
<https://uor.foundation/boundary/>
  a owl:Ontology ;
  rdfs:label "UOR IO Boundary" ;
  rdfs:comment "Typed interface between kernel computation and the external world. Formalizes how data enters and exits the ring substrate." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/cert/> ;
.

<https://uor.foundation/boundary/IOBoundary>
  a owl:Class ;
  rdfs:label "IOBoundary" ;
  rdfs:comment "A typed interface point between the kernel and the external world. Every data flow into or out of the ring crosses exactly one IOBoundary." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/boundary/Source>
  a owl:Class ;
  rdfs:label "Source" ;
  rdfs:comment "A typed source of external data entering the ring. Carries an expected TypeDefinition describing the shape of incoming data." ;
  rdfs:subClassOf <https://uor.foundation/boundary/IOBoundary> ;
.

<https://uor.foundation/boundary/Sink>
  a owl:Class ;
  rdfs:label "Sink" ;
  rdfs:comment "A typed destination for data leaving the ring. Carries an expected TypeDefinition describing the shape of outgoing data." ;
  rdfs:subClassOf <https://uor.foundation/boundary/IOBoundary> ;
.

<https://uor.foundation/boundary/BoundaryEffect>
  a owl:Class ;
  rdfs:label "BoundaryEffect" ;
  rdfs:comment "An effect that crosses the kernel/external boundary. Specializes effect:ExternalEffect with explicit source or sink binding." ;
  rdfs:subClassOf <https://uor.foundation/effect/ExternalEffect> ;
.

<https://uor.foundation/boundary/IngestEffect>
  a owl:Class ;
  rdfs:label "IngestEffect" ;
  rdfs:comment "A BoundaryEffect that reads from a Source and produces a datum in the ring." ;
  rdfs:subClassOf <https://uor.foundation/boundary/BoundaryEffect> ;
.

<https://uor.foundation/boundary/EmitEffect>
  a owl:Class ;
  rdfs:label "EmitEffect" ;
  rdfs:comment "A BoundaryEffect that writes a ring datum to a Sink." ;
  rdfs:subClassOf <https://uor.foundation/boundary/BoundaryEffect> ;
.

<https://uor.foundation/boundary/BoundaryProtocol>
  a owl:Class ;
  rdfs:label "BoundaryProtocol" ;
  rdfs:comment "A specification of the data shape, ordering, and framing constraints for data crossing a boundary." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/boundary/BoundarySession>
  a owl:Class ;
  rdfs:label "BoundarySession" ;
  rdfs:comment "A Session that includes BoundaryEffects. Extends the session model to track which boundaries were crossed." ;
  rdfs:subClassOf <https://uor.foundation/state/Session> ;
.

<https://uor.foundation/boundary/sourceType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceType" ;
  rdfs:comment "The expected type of data arriving from this source." ;
  rdfs:domain <https://uor.foundation/boundary/Source> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/boundary/sinkType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sinkType" ;
  rdfs:comment "The expected type of data departing through this sink." ;
  rdfs:domain <https://uor.foundation/boundary/Sink> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/boundary/effectBoundary>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "effectBoundary" ;
  rdfs:comment "The boundary this effect crosses." ;
  rdfs:domain <https://uor.foundation/boundary/BoundaryEffect> ;
  rdfs:range <https://uor.foundation/boundary/IOBoundary> .

<https://uor.foundation/boundary/ingestSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "ingestSource" ;
  rdfs:comment "The source being read." ;
  rdfs:domain <https://uor.foundation/boundary/IngestEffect> ;
  rdfs:range <https://uor.foundation/boundary/Source> .

<https://uor.foundation/boundary/emitSink>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "emitSink" ;
  rdfs:comment "The sink being written to." ;
  rdfs:domain <https://uor.foundation/boundary/EmitEffect> ;
  rdfs:range <https://uor.foundation/boundary/Sink> .

<https://uor.foundation/boundary/protocolType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "protocolType" ;
  rdfs:comment "The type specification for boundary data." ;
  rdfs:domain <https://uor.foundation/boundary/BoundaryProtocol> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/boundary/protocolOrdering>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "protocolOrdering" ;
  rdfs:comment "Sequencing constraints on boundary data." ;
  rdfs:domain <https://uor.foundation/boundary/BoundaryProtocol> ;
  rdfs:range <https://uor.foundation/type/Conjunction> .

<https://uor.foundation/boundary/sessionBoundaries>
  a owl:ObjectProperty ;
  rdfs:label "sessionBoundaries" ;
  rdfs:comment "The boundaries crossed during this session." ;
  rdfs:domain <https://uor.foundation/boundary/BoundarySession> ;
  rdfs:range <https://uor.foundation/boundary/IOBoundary> .

<https://uor.foundation/boundary/isIdempotent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isIdempotent" ;
  rdfs:comment "True iff applying the boundary effect twice produces the same result as applying it once." ;
  rdfs:domain <https://uor.foundation/boundary/BoundaryEffect> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/boundary/crossingCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "crossingCount" ;
  rdfs:comment "Total number of boundary crossings in this session." ;
  rdfs:domain <https://uor.foundation/boundary/BoundarySession> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

# Namespace: conformance
<https://uor.foundation/conformance/>
  a owl:Ontology ;
  rdfs:label "UOR Conformance Shapes" ;
  rdfs:comment "SHACL-equivalent constraint shapes defining what a Prism implementation must provide at each extension point. Machine-verifiable contracts." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/predicate/> ;
  owl:imports <https://uor.foundation/parallel/> ;
  owl:imports <https://uor.foundation/stream/> ;
  owl:imports <https://uor.foundation/linear/> ;
  owl:imports <https://uor.foundation/region/> ;
  owl:imports <https://uor.foundation/failure/> ;
  owl:imports <https://uor.foundation/recursion/> ;
  owl:imports <https://uor.foundation/boundary/> ;
  owl:imports <https://uor.foundation/reduction/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/trace/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/morphism/> ;
.

<https://uor.foundation/conformance/Shape>
  a owl:Class ;
  rdfs:label "Shape" ;
  rdfs:comment "A constraint shape that a Prism-declared extension must satisfy. Analogous to sh:NodeShape in SHACL." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/PropertyConstraint>
  a owl:Class ;
  rdfs:label "PropertyConstraint" ;
  rdfs:comment "A single required property within a shape: the property URI, its expected range, minimum and maximum cardinality." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/WittLevelShape>
  a owl:Class ;
  rdfs:label "WittLevelShape" ;
  rdfs:comment "Shape for declaring a new WittLevel beyond Q3." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/EffectShape>
  a owl:Class ;
  rdfs:label "EffectShape" ;
  rdfs:comment "Shape for declaring an ExternalEffect." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/ParallelShape>
  a owl:Class ;
  rdfs:label "ParallelShape" ;
  rdfs:comment "Shape for declaring a ParallelProduct." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/StreamShape>
  a owl:Class ;
  rdfs:label "StreamShape" ;
  rdfs:comment "Shape for declaring a ProductiveStream (targets stream:Unfold, the coinductive constructor)." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/DispatchShape>
  a owl:Class ;
  rdfs:label "DispatchShape" ;
  rdfs:comment "Shape for declaring a new DispatchRule in a DispatchTable." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/LeaseShape>
  a owl:Class ;
  rdfs:label "LeaseShape" ;
  rdfs:comment "Shape for declaring a Lease with LinearSite allocation." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/GroundingShape>
  a owl:Class ;
  rdfs:label "GroundingShape" ;
  rdfs:comment "Shape for declaring a GroundingMap from surface data to the ring." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/ValidationResult>
  a owl:Class ;
  rdfs:label "ValidationResult" ;
  rdfs:comment "The result of validating an extension against a shape: conforms (boolean), and violation details if non-conformant." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/PredicateShape>
  a owl:Class ;
  rdfs:label "PredicateShape" ;
  rdfs:comment "Shape for user-declared predicates. Requires a bounded evaluator (termination witness) and input type declaration." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/InteractionShape>
  a owl:Class ;
  rdfs:label "InteractionShape" ;
  rdfs:comment "Shape describing the required surface of an InteractionDeclaration consumed by the foundation's InteractionDeclarationBuilder: peer protocol, convergence predicate, and commutator state class. Rejects builders missing any of the three." ;
  rdfs:subClassOf <https://uor.foundation/conformance/Shape> ;
.

<https://uor.foundation/conformance/WitnessDatum>
  a owl:Class ;
  rdfs:label "WitnessDatum" ;
  rdfs:comment "Opaque ring element witness. Cannot be constructed outside the foundation crate — only produced by reduction evaluation or the two-phase minting boundary." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/GroundedCoordinate>
  a owl:Class ;
  rdfs:label "GroundedCoordinate" ;
  rdfs:comment "Boundary crossing intermediate for a single grounded coordinate value. Not a WitnessDatum — must be validated and minted by the foundation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/GroundedTuple>
  a owl:Class ;
  rdfs:label "GroundedTuple" ;
  rdfs:comment "Boundary crossing intermediate for a fixed-size array of GroundedCoordinate values. Stack-resident, no heap allocation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/GroundedValueMarker>
  a owl:Class ;
  rdfs:label "GroundedValueMarker" ;
  rdfs:comment "Sealed marker trait class. Implemented only for GroundedCoordinate and GroundedTuple. Prevents downstream crates from substituting arbitrary types." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/ValidatedWrapper>
  a owl:Class ;
  rdfs:label "ValidatedWrapper" ;
  rdfs:comment "Generic validation-proof wrapper. Proves that the inner value was produced by the conformance checker, not fabricated by Prism code." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/WitnessDerivation>
  a owl:Class ;
  rdfs:label "WitnessDerivation" ;
  rdfs:comment "Opaque derivation trace that can only be extended by the rewrite engine. Records rewrite step count and root term content address." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/WitnessSiteBudget>
  a owl:Class ;
  rdfs:label "WitnessSiteBudget" ;
  rdfs:comment "Opaque site budget that can only be decremented by PinningEffect and incremented by UnbindingEffect — never by direct mutation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/ShapeViolationReport>
  a owl:Class ;
  rdfs:label "ShapeViolationReport" ;
  rdfs:comment "Structured violation diagnostic carrying the shape IRI, constraint IRI, property IRI, expected range, cardinality bounds, and violation kind." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/ViolationKind>
  a owl:Class ;
  rdfs:label "ViolationKind" ;
  rdfs:comment "The kind of shape violation: Missing, TypeMismatch, CardinalityViolation, ValueCheck, or LevelMismatch." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/CompileUnitBuilder>
  a owl:Class ;
  rdfs:label "CompileUnitBuilder" ;
  rdfs:comment "Builder for CompileUnit admission. Collects rootTerm, quantumLevelCeiling, thermodynamicBudget, and targetDomains. Validates against CompileUnitShape." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/EffectDeclaration>
  a owl:Class ;
  rdfs:label "EffectDeclaration" ;
  rdfs:comment "Builder for EffectShape. Collects effect name, target sites, budget delta, and commutation flag." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/GroundingDeclaration>
  a owl:Class ;
  rdfs:label "GroundingDeclaration" ;
  rdfs:comment "Builder for GroundingShape. Collects source type, ring mapping, and invertibility contract." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/DispatchDeclaration>
  a owl:Class ;
  rdfs:label "DispatchDeclaration" ;
  rdfs:comment "Builder for DispatchShape. Collects predicate, target resolver, and dispatch priority." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/LeaseDeclaration>
  a owl:Class ;
  rdfs:label "LeaseDeclaration" ;
  rdfs:comment "Builder for LeaseShape. Collects linear site and lease scope." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/StreamDeclaration>
  a owl:Class ;
  rdfs:label "StreamDeclaration" ;
  rdfs:comment "Builder for StreamShape. Collects unfold seed, step term, and productivity witness." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/PredicateDeclaration>
  a owl:Class ;
  rdfs:label "PredicateDeclaration" ;
  rdfs:comment "Builder for PredicateShape. Collects input type, evaluator term, and termination witness." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/ParallelDeclaration>
  a owl:Class ;
  rdfs:label "ParallelDeclaration" ;
  rdfs:comment "Builder for ParallelShape. Collects site partition and disjointness witness." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/WittLevelDeclaration>
  a owl:Class ;
  rdfs:label "WittLevelDeclaration" ;
  rdfs:comment "Builder for WittLevelShape. Collects declared bit width, cycle size, and predecessor level." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/MintingSession>
  a owl:Class ;
  rdfs:label "MintingSession" ;
  rdfs:comment "Boundary session state tracker. Records crossing count and idempotency flag for the two-phase minting boundary." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/PreludeExport>
  a owl:Class ;
  rdfs:label "PreludeExport" ;
  rdfs:comment "An ontology fact recording that a particular OWL class should appear in the foundation crate's `prelude` module re-exports. The v0.2.1 Rust codegen walks PreludeExport individuals filtered by exportsClass to assemble the prelude membership list." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/conformance/targetClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetClass" ;
  rdfs:comment "The OWL class that instances of this shape must belong to." ;
  rdfs:domain <https://uor.foundation/conformance/Shape> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/conformance/requiredProperty>
  a owl:ObjectProperty ;
  rdfs:label "requiredProperty" ;
  rdfs:comment "A required property in this shape." ;
  rdfs:domain <https://uor.foundation/conformance/Shape> ;
  rdfs:range <https://uor.foundation/conformance/PropertyConstraint> .

<https://uor.foundation/conformance/constraintProperty>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "constraintProperty" ;
  rdfs:comment "The property URI that must be present." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/conformance/constraintRange>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "constraintRange" ;
  rdfs:comment "The expected range of the required property." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/conformance/validationShape>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "validationShape" ;
  rdfs:comment "The shape that was validated against." ;
  rdfs:domain <https://uor.foundation/conformance/ValidationResult> ;
  rdfs:range <https://uor.foundation/conformance/Shape> .

<https://uor.foundation/conformance/validationTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "validationTarget" ;
  rdfs:comment "The instance that was validated." ;
  rdfs:domain <https://uor.foundation/conformance/ValidationResult> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/conformance/minCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "minCount" ;
  rdfs:comment "Minimum cardinality of the required property." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/maxCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "maxCount" ;
  rdfs:comment "Maximum cardinality (0 = unbounded)." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/conforms>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "conforms" ;
  rdfs:comment "True iff the target satisfies all constraints of the shape." ;
  rdfs:domain <https://uor.foundation/conformance/ValidationResult> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/conformance/witnessLevel>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "witnessLevel" ;
  rdfs:comment "The quantum level at which this witness datum was minted." ;
  rdfs:domain <https://uor.foundation/conformance/WitnessDatum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/witnessBytes>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "witnessBytes" ;
  rdfs:comment "The raw byte representation of this witness datum." ;
  rdfs:domain <https://uor.foundation/conformance/WitnessDatum> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#hexBinary> .

<https://uor.foundation/conformance/coordinateLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "coordinateLevel" ;
  rdfs:comment "The quantum level tag of this grounded coordinate." ;
  rdfs:domain <https://uor.foundation/conformance/GroundedCoordinate> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/conformance/validatedInner>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "validatedInner" ;
  rdfs:comment "The validated inner value wrapped by this proof." ;
  rdfs:domain <https://uor.foundation/conformance/ValidatedWrapper> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/conformance/shapeIri>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "shapeIri" ;
  rdfs:comment "IRI of the conformance:Shape that was validated against." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/constraintIri>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "constraintIri" ;
  rdfs:comment "IRI of the specific PropertyConstraint that failed." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/propertyIri>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "propertyIri" ;
  rdfs:comment "IRI of the property that was missing or invalid." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/expectedRange>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "expectedRange" ;
  rdfs:comment "The expected range class IRI for the violated property." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/violationMinCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "violationMinCount" ;
  rdfs:comment "The minimum cardinality from the violated constraint." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/violationMaxCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "violationMaxCount" ;
  rdfs:comment "The maximum cardinality from the violated constraint (0 = unbounded)." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/violationKind>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "violationKind" ;
  rdfs:comment "The kind of violation that occurred." ;
  rdfs:domain <https://uor.foundation/conformance/ShapeViolationReport> ;
  rdfs:range <https://uor.foundation/conformance/ViolationKind> .

<https://uor.foundation/conformance/builderRootTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "builderRootTerm" ;
  rdfs:comment "The root term expression for the CompileUnit." ;
  rdfs:domain <https://uor.foundation/conformance/CompileUnitBuilder> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/conformance/builderWittLevelCeiling>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "builderWittLevelCeiling" ;
  rdfs:comment "The widest quantum level the computation may reference." ;
  rdfs:domain <https://uor.foundation/conformance/CompileUnitBuilder> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/conformance/builderThermodynamicBudget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "builderThermodynamicBudget" ;
  rdfs:comment "Landauer-bounded energy budget in kBT ln 2 units." ;
  rdfs:domain <https://uor.foundation/conformance/CompileUnitBuilder> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/conformance/builderTargetDomains>
  a owl:ObjectProperty ;
  rdfs:label "builderTargetDomains" ;
  rdfs:comment "Verification domains targeted by the CompileUnit." ;
  rdfs:domain <https://uor.foundation/conformance/CompileUnitBuilder> ;
  rdfs:range <https://uor.foundation/op/VerificationDomain> .

<https://uor.foundation/conformance/effectName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "effectName" ;
  rdfs:comment "The name of the declared effect." ;
  rdfs:domain <https://uor.foundation/conformance/EffectDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/targetSites>
  a owl:DatatypeProperty ;
  rdfs:label "targetSites" ;
  rdfs:comment "Site coordinates this effect reads or writes." ;
  rdfs:domain <https://uor.foundation/conformance/EffectDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/budgetDelta>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "budgetDelta" ;
  rdfs:comment "The site budget delta (positive = increment, negative = decrement)." ;
  rdfs:domain <https://uor.foundation/conformance/EffectDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/conformance/commutationFlag>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "commutationFlag" ;
  rdfs:comment "Whether this effect commutes with effects on disjoint sites." ;
  rdfs:domain <https://uor.foundation/conformance/EffectDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/conformance/groundingSourceType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingSourceType" ;
  rdfs:comment "The source type of incoming external data." ;
  rdfs:domain <https://uor.foundation/conformance/GroundingDeclaration> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/conformance/ringMapping>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "ringMapping" ;
  rdfs:comment "Description of the mapping from surface data to ring." ;
  rdfs:domain <https://uor.foundation/conformance/GroundingDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/invertibilityContract>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "invertibilityContract" ;
  rdfs:comment "Whether the grounding map is invertible." ;
  rdfs:domain <https://uor.foundation/conformance/GroundingDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/conformance/dispatchPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchPredicate" ;
  rdfs:comment "The predicate expression guarding this dispatch rule." ;
  rdfs:domain <https://uor.foundation/conformance/DispatchDeclaration> ;
  rdfs:range <https://uor.foundation/reduction/PredicateExpression> .

<https://uor.foundation/conformance/targetResolver>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetResolver" ;
  rdfs:comment "The resolver to dispatch to when the predicate holds." ;
  rdfs:domain <https://uor.foundation/conformance/DispatchDeclaration> ;
  rdfs:range <https://uor.foundation/resolver/Resolver> .

<https://uor.foundation/conformance/dispatchPriority>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchPriority" ;
  rdfs:comment "Priority ordering for this dispatch rule (lower = first)." ;
  rdfs:domain <https://uor.foundation/conformance/DispatchDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/linearSite>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "linearSite" ;
  rdfs:comment "The site coordinate allocated linearly by this lease." ;
  rdfs:domain <https://uor.foundation/conformance/LeaseDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/leaseScope>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leaseScope" ;
  rdfs:comment "The scope within which this lease is valid." ;
  rdfs:domain <https://uor.foundation/conformance/LeaseDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/unfoldSeed>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "unfoldSeed" ;
  rdfs:comment "The seed term for the stream unfold constructor." ;
  rdfs:domain <https://uor.foundation/conformance/StreamDeclaration> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/conformance/stepTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stepTerm" ;
  rdfs:comment "The step function term for the stream unfold." ;
  rdfs:domain <https://uor.foundation/conformance/StreamDeclaration> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/conformance/productivityWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "productivityWitness" ;
  rdfs:comment "Evidence that the stream is productive (always produces a next element)." ;
  rdfs:domain <https://uor.foundation/conformance/StreamDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/predicateInputType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "predicateInputType" ;
  rdfs:comment "The input type for the declared predicate." ;
  rdfs:domain <https://uor.foundation/conformance/PredicateDeclaration> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/conformance/evaluatorTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "evaluatorTerm" ;
  rdfs:comment "The evaluator term for the declared predicate." ;
  rdfs:domain <https://uor.foundation/conformance/PredicateDeclaration> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/conformance/terminationWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "terminationWitness" ;
  rdfs:comment "Evidence that the predicate evaluator terminates on all inputs." ;
  rdfs:domain <https://uor.foundation/conformance/PredicateDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/sitePartition>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sitePartition" ;
  rdfs:comment "The site partition for the parallel composition." ;
  rdfs:domain <https://uor.foundation/conformance/ParallelDeclaration> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/conformance/disjointnessWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "disjointnessWitness" ;
  rdfs:comment "Evidence that the site partition components are pairwise disjoint." ;
  rdfs:domain <https://uor.foundation/conformance/ParallelDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/declaredBitWidth>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "declaredBitWidth" ;
  rdfs:comment "The declared bit width for this quantum level." ;
  rdfs:domain <https://uor.foundation/conformance/WittLevelDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/conformance/declaredCycleSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "declaredCycleSize" ;
  rdfs:comment "The declared number of ring states at this level." ;
  rdfs:domain <https://uor.foundation/conformance/WittLevelDeclaration> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/predecessorLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "predecessorLevel" ;
  rdfs:comment "The predecessor quantum level in the chain." ;
  rdfs:domain <https://uor.foundation/conformance/WittLevelDeclaration> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/conformance/sessionCrossingCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sessionCrossingCount" ;
  rdfs:comment "Total boundary crossings in this minting session." ;
  rdfs:domain <https://uor.foundation/conformance/MintingSession> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/conformance/sessionIsIdempotent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sessionIsIdempotent" ;
  rdfs:comment "Whether applying this session's boundary effect twice equals applying it once." ;
  rdfs:domain <https://uor.foundation/conformance/MintingSession> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/conformance/surfaceForm>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "surfaceForm" ;
  rdfs:comment "Top-level EBNF non-terminal name this Shape generates (e.g., \"compile-unit-decl\" for CompileUnitShape)." ;
  rdfs:domain <https://uor.foundation/conformance/Shape> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/surfaceKeyword>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "surfaceKeyword" ;
  rdfs:comment "Literal surface keyword used in the conformance grammar for this property constraint (e.g., \"root_term\", \"witt_level_ceiling\")." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/surfaceProduction>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "surfaceProduction" ;
  rdfs:comment "EBNF non-terminal that the value at this constraint slot must match (e.g., \"program\" for Term ranges, \"name\" for WittLevel ranges, \"decimal-literal\" for xsd:decimal, \"domain-set\" for non-functional IRI lists)." ;
  rdfs:domain <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/exportsClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "exportsClass" ;
  rdfs:comment "The OWL class IRI that the foundation crate's prelude module should re-export." ;
  rdfs:domain <https://uor.foundation/conformance/PreludeExport> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/conformance/exportRustName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "exportRustName" ;
  rdfs:comment "The Rust identifier under which the prelude exposes this symbol. Codegen uses this when the class's generated Rust name differs from a desired prelude alias." ;
  rdfs:domain <https://uor.foundation/conformance/PreludeExport> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/conformance/CompileUnitShape>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "CompileUnitShape" ;
  rdfs:comment "Shape validating that a CompileUnit carries all required properties before reduction admission. The unitAddress property is NOT required — it is computed by stage_initialization after shape validation passes." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/reduction/CompileUnit> ;
  <https://uor.foundation/conformance/surfaceForm> "compile-unit-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/compileUnit_rootTerm_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/compileUnit_unitWittLevel_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/compileUnit_thermodynamicBudget_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/compileUnit_targetDomains_constraint> .

<https://uor.foundation/conformance/compileUnit_rootTerm_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "compileUnit_rootTerm_constraint" ;
  rdfs:comment "Exactly one root term is required. Range is schema:Term." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/reduction/rootTerm> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/schema/Term> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "root_term" ;
  <https://uor.foundation/conformance/surfaceProduction> "program" .

<https://uor.foundation/conformance/compileUnit_unitWittLevel_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "compileUnit_unitWittLevel_constraint" ;
  rdfs:comment "Exactly one quantum level is required. Range is schema:WittLevel." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/reduction/unitWittLevel> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/schema/WittLevel> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "witt_level_ceiling" ;
  <https://uor.foundation/conformance/surfaceProduction> "name" .

<https://uor.foundation/conformance/compileUnit_thermodynamicBudget_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "compileUnit_thermodynamicBudget_constraint" ;
  rdfs:comment "Exactly one thermodynamic budget is required. Shape validates presence and type; the BudgetSolvencyCheck preflight validates the value against the Landauer bound." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/reduction/thermodynamicBudget> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#decimal> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "thermodynamic_budget" ;
  <https://uor.foundation/conformance/surfaceProduction> "decimal-literal" .

<https://uor.foundation/conformance/compileUnit_targetDomains_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "compileUnit_targetDomains_constraint" ;
  rdfs:comment "At least one target verification domain is required. maxCount 0 means unbounded." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/reduction/targetDomains> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/op/VerificationDomain> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "0"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "target_domains" ;
  <https://uor.foundation/conformance/surfaceProduction> "domain-set" .

<https://uor.foundation/conformance/Missing>
  a owl:NamedIndividual , <https://uor.foundation/conformance/ViolationKind> ;
  rdfs:label "Missing" ;
  rdfs:comment "Required property was not set on the builder." .

<https://uor.foundation/conformance/TypeMismatch>
  a owl:NamedIndividual , <https://uor.foundation/conformance/ViolationKind> ;
  rdfs:label "TypeMismatch" ;
  rdfs:comment "Property was set but its value is not an instance of the constraintRange." .

<https://uor.foundation/conformance/CardinalityViolation>
  a owl:NamedIndividual , <https://uor.foundation/conformance/ViolationKind> ;
  rdfs:label "CardinalityViolation" ;
  rdfs:comment "Cardinality violated: too few or too many values provided." .

<https://uor.foundation/conformance/ValueCheck>
  a owl:NamedIndividual , <https://uor.foundation/conformance/ViolationKind> ;
  rdfs:label "ValueCheck" ;
  rdfs:comment "Value-dependent check failed (Tier 2). For example, thermodynamic budget insufficient for Landauer bound." .

<https://uor.foundation/conformance/LevelMismatch>
  a owl:NamedIndividual , <https://uor.foundation/conformance/ViolationKind> ;
  rdfs:label "LevelMismatch" ;
  rdfs:comment "A term's quantum level annotation exceeds the CompileUnit ceiling, or binary operation operands are at different levels without an intervening lift or project." .

<https://uor.foundation/conformance/DispatchShapeInstance>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "DispatchShapeInstance" ;
  rdfs:comment "Shape instance validating predicate:DispatchRule declarations against the dispatch-rule-decl grammar." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/predicate/DispatchRule> ;
  <https://uor.foundation/conformance/surfaceForm> "dispatch-rule-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/dispatch_predicate_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/dispatch_target_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/dispatch_priority_constraint> .

<https://uor.foundation/conformance/dispatch_predicate_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "dispatch_predicate_constraint" ;
  rdfs:comment "Exactly one predicate term selecting this dispatch rule." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/dispatchPredicate> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/schema/Term> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "predicate" ;
  <https://uor.foundation/conformance/surfaceProduction> "term" .

<https://uor.foundation/conformance/dispatch_target_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "dispatch_target_constraint" ;
  rdfs:comment "The resolver class invoked when the predicate holds." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/dispatchTarget> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/resolver/Resolver> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "target_resolver" ;
  <https://uor.foundation/conformance/surfaceProduction> "name" .

<https://uor.foundation/conformance/dispatch_priority_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "dispatch_priority_constraint" ;
  rdfs:comment "Non-negative integer evaluation order; lower values evaluate first." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/dispatchPriority> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "priority" ;
  <https://uor.foundation/conformance/surfaceProduction> "integer-literal" .

<https://uor.foundation/conformance/WittLevelShapeInstance>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "WittLevelShapeInstance" ;
  rdfs:comment "Shape instance validating schema:WittLevel declarations against the witt-level-decl grammar." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/schema/WittLevel> ;
  <https://uor.foundation/conformance/surfaceForm> "witt-level-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/wittLevel_bitWidth_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/wittLevel_cycleSize_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/wittLevel_predecessorLevel_constraint> .

<https://uor.foundation/conformance/wittLevel_bitWidth_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "wittLevel_bitWidth_constraint" ;
  rdfs:comment "Bit width must equal 8·(k+1) for some non-negative integer k." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/schema/bitsWidth> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#positiveInteger> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "bit_width" ;
  <https://uor.foundation/conformance/surfaceProduction> "integer-literal" .

<https://uor.foundation/conformance/wittLevel_cycleSize_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "wittLevel_cycleSize_constraint" ;
  rdfs:comment "Cycle size must equal 2^bit_width." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/schema/cycleSize> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "cycle_size" ;
  <https://uor.foundation/conformance/surfaceProduction> "integer-literal" .

<https://uor.foundation/conformance/wittLevel_predecessorLevel_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "wittLevel_predecessorLevel_constraint" ;
  rdfs:comment "The predecessor WittLevel individual whose nextWittLevel will be updated to point at this new level." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/schema/wittLevelPredecessor> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/schema/WittLevel> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "predecessor_level" ;
  <https://uor.foundation/conformance/surfaceProduction> "name" .

<https://uor.foundation/conformance/PredicateShapeInstance>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "PredicateShapeInstance" ;
  rdfs:comment "Shape instance for predicate:Predicate declarations." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/predicate/Predicate> ;
  <https://uor.foundation/conformance/surfaceForm> "predicate-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/predicate_inputType_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/predicate_evaluator_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/predicate_terminationWitness_constraint> .

<https://uor.foundation/conformance/predicate_inputType_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "predicate_inputType_constraint" ;
  rdfs:comment "Input type the predicate evaluates over." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/evaluatesOver> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/type/TypeDefinition> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "input_type" ;
  <https://uor.foundation/conformance/surfaceProduction> "type-expr" .

<https://uor.foundation/conformance/predicate_evaluator_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "predicate_evaluator_constraint" ;
  rdfs:comment "The evaluator term producing a boolean." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/evaluatorTerm> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/schema/Term> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "evaluator" ;
  <https://uor.foundation/conformance/surfaceProduction> "term" .

<https://uor.foundation/conformance/predicate_terminationWitness_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "predicate_terminationWitness_constraint" ;
  rdfs:comment "IRI of a proof:Proof attesting that the evaluator halts on all inputs." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/predicate/terminationWitness> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#string> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "termination_witness" ;
  <https://uor.foundation/conformance/surfaceProduction> "string-literal" .

<https://uor.foundation/conformance/ParallelShapeInstance>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "ParallelShapeInstance" ;
  rdfs:comment "Shape instance for parallel:ParallelProduct declarations." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/parallel/ParallelProduct> ;
  <https://uor.foundation/conformance/surfaceForm> "parallel-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/parallel_sitePartition_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/parallel_disjointnessWitness_constraint> .

<https://uor.foundation/conformance/parallel_sitePartition_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "parallel_sitePartition_constraint" ;
  rdfs:comment "The site partition this parallel product is over." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/parallel/sitePartition> ;
  <https://uor.foundation/conformance/constraintRange> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "site_partition" ;
  <https://uor.foundation/conformance/surfaceProduction> "name" .

<https://uor.foundation/conformance/parallel_disjointnessWitness_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "parallel_disjointnessWitness_constraint" ;
  rdfs:comment "IRI of a proof of pairwise disjointness of the partition components." ;
  <https://uor.foundation/conformance/constraintProperty> <https://uor.foundation/parallel/disjointnessWitness> ;
  <https://uor.foundation/conformance/constraintRange> <http://www.w3.org/2001/XMLSchema#string> ;
  <https://uor.foundation/conformance/minCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/maxCount> "1"^^xsd:integer ;
  <https://uor.foundation/conformance/surfaceKeyword> "disjointness_witness" ;
  <https://uor.foundation/conformance/surfaceProduction> "string-literal" .

<https://uor.foundation/conformance/StreamShapeInstance>
  a owl:NamedIndividual , <https://uor.foundation/conformance/Shape> ;
  rdfs:label "StreamShapeInstance" ;
  rdfs:comment "Shape instance for stream:ProductiveStream declarations." ;
  <https://uor.foundation/conformance/targetClass> <https://uor.foundation/stream/ProductiveStream> ;
  <https://uor.foundation/conformance/surfaceForm> "stream-decl" ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/stream_unfoldSeed_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/stream_step_constraint> ;
  <https://uor.foundation/conformance/requiredProperty> <https://uor.foundation/conformance/stream_productivityWitness_constraint> .

<https://uor.foundation/conformance/stream_unfoldSeed_constraint>
  a owl:NamedIndividual , <https://uor.foundation/conformance/PropertyConstraint> ;
  rdfs:label "stream_unfoldSeed_constraint" ;
  rdfs:comment "Initial seed value from which the stream unfolds." ;
