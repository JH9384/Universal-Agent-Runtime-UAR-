# Namespace: derivation
<https://uor.foundation/derivation/>
  a owl:Ontology ;
  rdfs:label "UOR Derivations" ;
  rdfs:comment "Computation witnesses recording term rewriting sequences from original terms to their canonical forms." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/resolver/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
.

<https://uor.foundation/derivation/Derivation>
  a owl:Class ;
  rdfs:label "Derivation" ;
  rdfs:comment "A complete term rewriting witness: the full sequence of rewrite steps transforming an original term into its canonical form." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/DerivationStep>
  a owl:Class ;
  rdfs:label "DerivationStep" ;
  rdfs:comment "An abstract step in a derivation. Concrete subclasses are RewriteStep (term-level rewriting) and RefinementStep (type-level refinement)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/RewriteStep>
  a owl:Class ;
  rdfs:label "RewriteStep" ;
  rdfs:comment "A single rewrite step in a derivation: the application of one rewrite rule to transform a term." ;
  rdfs:subClassOf <https://uor.foundation/derivation/DerivationStep> ;
.

<https://uor.foundation/derivation/RefinementStep>
  a owl:Class ;
  rdfs:label "RefinementStep" ;
  rdfs:comment "A type-level refinement step: the application of a constraint to narrow a type, pinning additional site coordinates. Complements RewriteStep (term-level) in the derivation hierarchy." ;
  rdfs:subClassOf <https://uor.foundation/derivation/DerivationStep> ;
.

<https://uor.foundation/derivation/RewriteRule>
  a owl:Class ;
  rdfs:label "RewriteRule" ;
  rdfs:comment "A named rewrite rule that can be applied in a derivation step. Each RewriteRule individual represents a specific algebraic law or normalization strategy used during term rewriting." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/TermMetrics>
  a owl:Class ;
  rdfs:label "TermMetrics" ;
  rdfs:comment "Metrics describing the size and complexity of a term." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/SynthesisStep>
  a owl:Class ;
  rdfs:label "SynthesisStep" ;
  rdfs:comment "A single step in the construction of a SynthesizedType: one constraint added to the synthesis candidate and the resulting change in the constraint nerve's topological signature. Ordered by derivation:stepIndex. Analogous to derivation:RewriteStep in the forward pipeline." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/SynthesisCheckpoint>
  a owl:Class ;
  rdfs:label "SynthesisCheckpoint" ;
  rdfs:comment "A persistent snapshot of a ConstraintSearchState at a specific SynthesisStep, allowing a TypeSynthesisResolver to resume exploration after interruption. Essential at Q1+ scale where exhaustive synthesis is computationally significant." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/InhabitanceStep>
  a owl:Class ;
  rdfs:label "InhabitanceStep" ;
  rdfs:comment "A peer of derivation:SynthesisStep specialised to inhabitance search. Each step represents one navigation in the constraint nerve, either pinning a site to a value or confirming that a predicate evaluates true on the current partial assignment." ;
  rdfs:subClassOf <https://uor.foundation/derivation/SynthesisStep> ;
.

<https://uor.foundation/derivation/InhabitanceCheckpoint>
  a owl:Class ;
  rdfs:label "InhabitanceCheckpoint" ;
  rdfs:comment "A peer of derivation:SynthesisCheckpoint specialised to inhabitance search. Marks an audit point where the resolver state can be restored if the search backtracks." ;
  rdfs:subClassOf <https://uor.foundation/derivation/SynthesisCheckpoint> ;
.

<https://uor.foundation/derivation/DerivationDepthObservable>
  a owl:Class ;
  rdfs:label "DerivationDepthObservable" ;
  rdfs:comment "Observes the derivation depth of a Datum, computed as the maximum nesting level of derivation:RewriteStep applications producing it. Used as the bound observable for the depthConstraintKind BoundConstraint." ;
  rdfs:subClassOf <https://uor.foundation/observable/Observable> ;
.

<https://uor.foundation/derivation/DerivationTrace>
  a owl:Class ;
  rdfs:label "DerivationTrace" ;
  rdfs:comment "An ordered sequence of derivation:RewriteStep events produced by replaying a Derivation. Used by uor-foundation-verify to re-derive a certificate from a content-addressed trace without running the deciders. The traceEventCount property records the trace length." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/derivation/originalTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "originalTerm" ;
  rdfs:comment "The term at the start of the derivation, before any rewriting." ;
  rdfs:domain <https://uor.foundation/derivation/Derivation> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/derivation/canonicalTerm>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "canonicalTerm" ;
  rdfs:comment "The canonical form produced at the end of the derivation." ;
  rdfs:domain <https://uor.foundation/derivation/Derivation> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/derivation/result>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "result" ;
  rdfs:comment "The datum value obtained by evaluating the canonical term." ;
  rdfs:domain <https://uor.foundation/derivation/Derivation> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/derivation/step>
  a owl:ObjectProperty ;
  rdfs:label "step" ;
  rdfs:comment "A rewrite step in this derivation." ;
  rdfs:domain <https://uor.foundation/derivation/Derivation> ;
  rdfs:range <https://uor.foundation/derivation/RewriteStep> .

<https://uor.foundation/derivation/termMetrics>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "termMetrics" ;
  rdfs:comment "Metrics for the canonical term produced by this derivation." ;
  rdfs:domain <https://uor.foundation/derivation/Derivation> ;
  rdfs:range <https://uor.foundation/derivation/TermMetrics> .

<https://uor.foundation/derivation/from>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "from" ;
  rdfs:comment "The term before this rewrite step." ;
  rdfs:domain <https://uor.foundation/derivation/RewriteStep> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/derivation/to>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "to" ;
  rdfs:comment "The term after this rewrite step." ;
  rdfs:domain <https://uor.foundation/derivation/RewriteStep> ;
  rdfs:range <https://uor.foundation/schema/Term> .

<https://uor.foundation/derivation/hasRewriteRule>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "hasRewriteRule" ;
  rdfs:comment "The typed rewrite rule applied in this step. Provides a structured reference to a named RewriteRule individual, complementing the string-valued derivation:rule property." ;
  rdfs:domain <https://uor.foundation/derivation/RewriteStep> ;
  rdfs:range <https://uor.foundation/derivation/RewriteRule> .

<https://uor.foundation/derivation/groundedIn>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedIn" ;
  rdfs:comment "The algebraic identity that grounds this rewrite rule. Links a RewriteRule to the op:Identity individual that justifies its application." ;
  rdfs:domain <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/derivation/stepCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stepCount" ;
  rdfs:comment "The total number of rewrite steps in this derivation." ;
  rdfs:domain <https://uor.foundation/derivation/TermMetrics> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/derivation/termSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "termSize" ;
  rdfs:comment "The number of nodes in the canonical term's syntax tree." ;
  rdfs:domain <https://uor.foundation/derivation/TermMetrics> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/derivation/previousType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "previousType" ;
  rdfs:comment "The type before this refinement step was applied." ;
  rdfs:domain <https://uor.foundation/derivation/RefinementStep> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/derivation/appliedConstraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "appliedConstraint" ;
  rdfs:comment "The constraint that was applied in this refinement step." ;
  rdfs:domain <https://uor.foundation/derivation/RefinementStep> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/derivation/refinedType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "refinedType" ;
  rdfs:comment "The type after this refinement step was applied." ;
  rdfs:domain <https://uor.foundation/derivation/RefinementStep> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/derivation/sitesClosed>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sitesClosed" ;
  rdfs:comment "The number of site coordinates pinned by this refinement step." ;
  rdfs:domain <https://uor.foundation/derivation/RefinementStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/derivation/stepIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stepIndex" ;
  rdfs:comment "Zero-based sequential index of this step within the synthesis derivation." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/derivation/addedConstraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "addedConstraint" ;
  rdfs:comment "The constraint added in this synthesis step." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisStep> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/derivation/signatureBefore>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "signatureBefore" ;
  rdfs:comment "The constraint nerve signature before this synthesis step." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisStep> ;
  rdfs:range <https://uor.foundation/observable/SynthesisSignature> .

<https://uor.foundation/derivation/signatureAfter>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "signatureAfter" ;
  rdfs:comment "The constraint nerve signature after this synthesis step." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisStep> ;
  rdfs:range <https://uor.foundation/observable/SynthesisSignature> .

<https://uor.foundation/derivation/checkpointStep>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "checkpointStep" ;
  rdfs:comment "The SynthesisStep at which this checkpoint was taken." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisCheckpoint> ;
  rdfs:range <https://uor.foundation/derivation/SynthesisStep> .

<https://uor.foundation/derivation/checkpointState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "checkpointState" ;
  rdfs:comment "The ConstraintSearchState snapshot captured by this checkpoint." ;
  rdfs:domain <https://uor.foundation/derivation/SynthesisCheckpoint> ;
  rdfs:range <https://uor.foundation/resolver/ConstraintSearchState> .

<https://uor.foundation/derivation/towerCheckpoint>
  a owl:ObjectProperty ;
  rdfs:label "towerCheckpoint" ;
  rdfs:comment "Links a TowerCompletenessResolver to a SynthesisCheckpoint issued at each completed step. Cross-namespace bridge property: domain is resolver:TowerCompletenessResolver." ;
  rdfs:domain <https://uor.foundation/resolver/TowerCompletenessResolver> ;
  rdfs:range <https://uor.foundation/derivation/SynthesisCheckpoint> .

<https://uor.foundation/derivation/priorState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "priorState" ;
  rdfs:comment "The ConstraintSearchState before this InhabitanceStep was taken." ;
  rdfs:domain <https://uor.foundation/derivation/InhabitanceStep> ;
  rdfs:range <https://uor.foundation/resolver/ConstraintSearchState> .

<https://uor.foundation/derivation/successorState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "successorState" ;
  rdfs:comment "The ConstraintSearchState after this InhabitanceStep was taken." ;
  rdfs:domain <https://uor.foundation/derivation/InhabitanceStep> ;
  rdfs:range <https://uor.foundation/resolver/ConstraintSearchState> .

<https://uor.foundation/derivation/rule>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rule" ;
  rdfs:comment "The predicate:DispatchRule whose evaluation drove this InhabitanceStep." ;
  rdfs:domain <https://uor.foundation/derivation/InhabitanceStep> ;
  rdfs:range <https://uor.foundation/predicate/DispatchRule> .

<https://uor.foundation/derivation/checkpointIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "checkpointIndex" ;
  rdfs:comment "Ordinal index of this checkpoint within the InhabitanceSearchTrace's checkpoint sequence." ;
  rdfs:domain <https://uor.foundation/derivation/InhabitanceCheckpoint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/derivation/traceEventCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "traceEventCount" ;
  rdfs:comment "Number of RewriteStep events recorded in this DerivationTrace. Used by Derivation::replay() to size the fixed-capacity event arena without allocation." ;
  rdfs:domain <https://uor.foundation/derivation/DerivationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/derivation/CriticalIdentityRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "CriticalIdentityRule" ;
  rdfs:comment "The rewrite rule applying the critical identity: neg(bnot(x)) → succ(x). Grounded in op:criticalIdentity." ;
  <https://uor.foundation/derivation/groundedIn> <https://uor.foundation/op/criticalIdentity> .

<https://uor.foundation/derivation/InvolutionRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "InvolutionRule" ;
  rdfs:comment "The rewrite rule applying involution cancellation: f(f(x)) → x for any involution f." .

<https://uor.foundation/derivation/AssociativityRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "AssociativityRule" ;
  rdfs:comment "The rewrite rule applying associativity to re-bracket nested binary operations." .

<https://uor.foundation/derivation/CommutativityRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "CommutativityRule" ;
  rdfs:comment "The rewrite rule applying commutativity to reorder operands of commutative operations." .

<https://uor.foundation/derivation/IdentityElementRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "IdentityElementRule" ;
  rdfs:comment "The rewrite rule eliminating identity elements: add(x, 0) → x, mul(x, 1) → x, xor(x, 0) → x." .

<https://uor.foundation/derivation/NormalizationRule>
  a owl:NamedIndividual , <https://uor.foundation/derivation/RewriteRule> ;
  rdfs:label "NormalizationRule" ;
  rdfs:comment "The rewrite rule normalizing compound expressions to canonical ordering (e.g., sorting operands by address)." .

# Namespace: trace
<https://uor.foundation/trace/>
  a owl:Ontology ;
  rdfs:label "UOR Computation Traces" ;
  rdfs:comment "Execution traces recording the sequence of kernel operations, intermediate results, and accumulated metrics for a computation." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/cert/> ;
  owl:imports <https://uor.foundation/observable/> ;
.

<https://uor.foundation/trace/ComputationTrace>
  a owl:Class ;
  rdfs:label "ComputationTrace" ;
  rdfs:comment "A complete record of a kernel computation: the input, output, every operation step, and accumulated metrics." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/trace/ComputationStep>
  a owl:Class ;
  rdfs:label "ComputationStep" ;
  rdfs:comment "A single step in a computation trace: one operation applied to produce one output from one or more inputs." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/trace/TraceMetrics>
  a owl:Class ;
  rdfs:label "TraceMetrics" ;
  rdfs:comment "Summary metrics for a computation trace: total steps, accumulated ring distance, and accumulated Hamming distance." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/trace/GeodesicTrace>
  a owl:Class ;
  rdfs:label "GeodesicTrace" ;
  rdfs:comment "A computation trace that satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected. The path of least dissipation through the resolution landscape." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationTrace> ;
.

<https://uor.foundation/trace/GeodesicViolation>
  a owl:Class ;
  rdfs:label "GeodesicViolation" ;
  rdfs:comment "A record of a geodesic condition violation at a specific step of a computation trace. Produced by GeodesicValidator when J_k(step_i) < max_\\{free\\} J_k(state_i)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/trace/MeasurementEvent>
  a owl:Class ;
  rdfs:label "MeasurementEvent" ;
  rdfs:comment "A specialized computation step recording a single projective collapse of a SuperposedSiteState. Carries pre-collapse entropy and post-collapse Landauer cost (QM_1)." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationStep> ;
.

<https://uor.foundation/trace/MeasurementOutcome>
  a owl:Class ;
  rdfs:label "MeasurementOutcome" ;
  rdfs:comment "A single outcome of a projective measurement on a SuperposedSiteState, recording the classical site index (outcomeValue) and its Born-rule probability |α_k|² (outcomeProbability). Multiple outcomes form the probability distribution of a measurement." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/trace/InhabitanceSearchTrace>
  a owl:Class ;
  rdfs:label "InhabitanceSearchTrace" ;
  rdfs:comment "A subclass of trace:ComputationTrace specialised to inhabitance-search execution. Records the sequence of derivation:InhabitanceStep entries the resolver traversed and any derivation:InhabitanceCheckpoint entries it crossed." ;
  rdfs:subClassOf <https://uor.foundation/trace/ComputationTrace> ;
.

<https://uor.foundation/trace/input>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "input" ;
  rdfs:comment "The input datum of this computation." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/trace/output>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "output" ;
  rdfs:comment "The output datum of this computation." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/trace/step>
  a owl:ObjectProperty ;
  rdfs:label "step" ;
  rdfs:comment "A computation step in this trace." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/trace/ComputationStep> .

<https://uor.foundation/trace/monodromy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "monodromy" ;
  rdfs:comment "The monodromy accumulated by this computation: the net dihedral group element produced by the full operation sequence." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/observable/DihedralElement> .

<https://uor.foundation/trace/from>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "from" ;
  rdfs:comment "The input datum of this computation step." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/trace/to>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "to" ;
  rdfs:comment "The output datum of this computation step." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/trace/operation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operation" ;
  rdfs:comment "The operation applied in this computation step." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/trace/index>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "index" ;
  rdfs:comment "The zero-based sequential index of this step within its trace." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/stepCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stepCount" ;
  rdfs:comment "Total number of computation steps in this trace." ;
  rdfs:domain <https://uor.foundation/trace/TraceMetrics> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/totalRingDistance>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "totalRingDistance" ;
  rdfs:comment "Total ring-metric distance accumulated across all steps." ;
  rdfs:domain <https://uor.foundation/trace/TraceMetrics> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/totalHammingDistance>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "totalHammingDistance" ;
  rdfs:comment "Total Hamming-metric distance accumulated across all steps." ;
  rdfs:domain <https://uor.foundation/trace/TraceMetrics> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/certifiedBy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedBy" ;
  rdfs:comment "The certificate that attests to the correctness of this computation trace." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/cert/Certificate> .

<https://uor.foundation/trace/residualEntropy>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "residualEntropy" ;
  rdfs:comment "The residual entropy observable remaining after this computation trace, linking to the ThermoObservable taxonomy (TH_9 connection)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/observable/ResidualEntropy> .

<https://uor.foundation/trace/isGeodesic>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isGeodesic" ;
  rdfs:comment "Whether this computation trace satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/trace/geodesicViolation>
  a owl:ObjectProperty ;
  rdfs:label "geodesicViolation" ;
  rdfs:comment "A GeodesicViolation record indicating where the trace deviated from the geodesic condition." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/trace/GeodesicViolation> .

<https://uor.foundation/trace/stepEntropyCost>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stepEntropyCost" ;
  rdfs:comment "The entropy cost of a single computation step. On a geodesic, this equals ln 2 for every step (GD_2)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/cumulativeEntropyCost>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "cumulativeEntropyCost" ;
  rdfs:comment "The total entropy cost accumulated across all steps of a trace. On a geodesic, equals freeRank_initial × ln 2 (GD_3)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/jacobianAtStep>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "jacobianAtStep" ;
  rdfs:comment "The Jacobian value J_k at this step, used by the GeodesicValidator to check DC_10 maximality." ;
  rdfs:domain <https://uor.foundation/trace/ComputationStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/adiabaticallyOrdered>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "adiabaticallyOrdered" ;
  rdfs:comment "Whether the step sequence of this trace follows the AR_1 adiabatic ordering (decreasing freeRank × cost-per-site)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/trace/violationReason>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "violationReason" ;
  rdfs:comment "Human-readable description of why a geodesic violation occurred, citing the step index and the unused higher-J_k option." ;
  rdfs:domain <https://uor.foundation/trace/GeodesicViolation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/trace/measurementEvent>
  a owl:ObjectProperty ;
  rdfs:label "measurementEvent" ;
  rdfs:comment "A MeasurementEvent step within this computation trace." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <https://uor.foundation/trace/MeasurementEvent> .

<https://uor.foundation/trace/preCollapseEntropy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "preCollapseEntropy" ;
  rdfs:comment "The von Neumann entropy S_vN of the SuperposedSiteState before projective collapse." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/postCollapseLandauerCost>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "postCollapseLandauerCost" ;
  rdfs:comment "The Landauer cost incurred by the projective collapse. Equals preCollapseEntropy at β* = ln 2 (QM_1)." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/collapseStep>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "collapseStep" ;
  rdfs:comment "The step index within the enclosing ComputationTrace at which this projective collapse occurred." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/amplitudeVector>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "amplitudeVector" ;
  rdfs:comment "The full pre-collapse amplitude vector of all branches at the time of measurement. Enables Born rule verification (QM_5): P(outcome k) = |α_k|² / Σ|αᵢ|²." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/isAR1Ordered>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isAR1Ordered" ;
  rdfs:comment "Whether this computation trace has steps ordered by the AR_1 adiabatic metric (decreasing freeRank × cost-per-site). One of the two sub-predicates of isGeodesic (GD_6)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/trace/isDC10Selected>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isDC10Selected" ;
  rdfs:comment "Whether each step of this computation trace was selected by the DC_10 Jacobian criterion (maximal J_k among free sites). One of the two sub-predicates of isGeodesic (GD_6)." ;
  rdfs:domain <https://uor.foundation/trace/ComputationTrace> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/trace/outcomeValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "outcomeValue" ;
  rdfs:comment "The classical site index selected by projective collapse in this measurement outcome." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementOutcome> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/trace/outcomeProbability>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "outcomeProbability" ;
  rdfs:comment "The Born-rule probability of this measurement outcome: |α_k|² where α_k is the amplitude of the collapsed site." ;
  rdfs:domain <https://uor.foundation/trace/MeasurementOutcome> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/trace/checkpoint>
  a owl:ObjectProperty ;
  rdfs:label "checkpoint" ;
  rdfs:comment "Checkpoints crossed by the inhabitance search. Each checkpoint marks an audit point where the resolver state can be restored if the search backtracks." ;
  rdfs:domain <https://uor.foundation/trace/InhabitanceSearchTrace> ;
  rdfs:range <https://uor.foundation/derivation/InhabitanceCheckpoint> .

<https://uor.foundation/trace/geodesic_Q0>
  a owl:NamedIndividual , <https://uor.foundation/trace/GeodesicTrace> ;
  rdfs:label "geodesic_Q0" ;
  rdfs:comment "Canonical geodesic trace at quantum level Q0 (n=8). Demonstrates GD_1 through GD_3 at the base level." ;
  <https://uor.foundation/trace/isGeodesic> "true"^^xsd:boolean ;
  <https://uor.foundation/trace/adiabaticallyOrdered> "true"^^xsd:boolean .

<https://uor.foundation/trace/geodesic_Q1>
  a owl:NamedIndividual , <https://uor.foundation/trace/GeodesicTrace> ;
  rdfs:label "geodesic_Q1" ;
  rdfs:comment "Canonical geodesic trace at quantum level Q1 (n=16). Demonstrates geodesic scaling from Q0 to Q1." ;
  <https://uor.foundation/trace/isGeodesic> "true"^^xsd:boolean ;
  <https://uor.foundation/trace/adiabaticallyOrdered> "true"^^xsd:boolean .

<https://uor.foundation/trace/geodesic_Q2>
  a owl:NamedIndividual , <https://uor.foundation/trace/GeodesicTrace> ;
  rdfs:label "geodesic_Q2" ;
  rdfs:comment "Canonical geodesic trace at quantum level Q2 (n=32). Demonstrates geodesic scaling from Q1 to Q2." ;
  <https://uor.foundation/trace/isGeodesic> "true"^^xsd:boolean ;
  <https://uor.foundation/trace/adiabaticallyOrdered> "true"^^xsd:boolean .

<https://uor.foundation/trace/geodesic_Q3>
  a owl:NamedIndividual , <https://uor.foundation/trace/GeodesicTrace> ;
  rdfs:label "geodesic_Q3" ;
  rdfs:comment "Canonical geodesic trace at quantum level Q3 (n=64). Demonstrates geodesic scaling from Q2 to Q3." ;
  <https://uor.foundation/trace/isGeodesic> "true"^^xsd:boolean ;
  <https://uor.foundation/trace/adiabaticallyOrdered> "true"^^xsd:boolean .

<https://uor.foundation/trace/collapse_equal_superposition>
  a owl:NamedIndividual , <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:label "collapse_equal_superposition" ;
  rdfs:comment "Canonical measurement event: collapse of an equal superposition (|α|² = 0.5). Maximum von Neumann entropy S_vN = ln 2. Maximum Landauer cost per QM_1." ;
  <https://uor.foundation/trace/preCollapseEntropy> "0.6931471805599453"^^xsd:decimal ;
  <https://uor.foundation/trace/postCollapseLandauerCost> "0.6931471805599453"^^xsd:decimal .

<https://uor.foundation/trace/collapse_biased>
  a owl:NamedIndividual , <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:label "collapse_biased" ;
  rdfs:comment "Canonical measurement event: collapse of a biased superposition (|α|² = 0.9). Lower entropy than equal superposition. Demonstrates QM_3 bound." ;
  <https://uor.foundation/trace/preCollapseEntropy> "0.325083"^^xsd:decimal ;
  <https://uor.foundation/trace/postCollapseLandauerCost> "0.325083"^^xsd:decimal .

<https://uor.foundation/trace/collapse_classical>
  a owl:NamedIndividual , <https://uor.foundation/trace/MeasurementEvent> ;
  rdfs:label "collapse_classical" ;
  rdfs:comment "Canonical measurement event: collapse of a classical state (|α|² = 1). Zero entropy, zero Landauer cost. Demonstrates QM_4 idempotence." ;
  <https://uor.foundation/trace/preCollapseEntropy> "0"^^xsd:decimal ;
  <https://uor.foundation/trace/postCollapseLandauerCost> "0"^^xsd:decimal .

# Namespace: cert
<https://uor.foundation/cert/>
  a owl:Ontology ;
  rdfs:label "UOR Certificates" ;
  rdfs:comment "Kernel-produced attestation certificates for transforms, isometries, and involutions. Each certificate verifies that a specific structural property holds." ;
  uor:space "bridge" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/proof/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
.

<https://uor.foundation/cert/Certificate>
  a owl:Class ;
  rdfs:label "Certificate" ;
  rdfs:comment "A kernel-produced attestation. The root class for all certificate types." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cert/TransformCertificate>
  a owl:Class ;
  rdfs:label "TransformCertificate" ;
  rdfs:comment "A certificate attesting to the properties of a morphism:Transform. Certifies that the transform maps source to target correctly." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/IsometryCertificate>
  a owl:Class ;
  rdfs:label "IsometryCertificate" ;
  rdfs:comment "A certificate attesting that a morphism:Isometry preserves metric distances. Certifies the transform is a metric isometry with respect to the specified metric." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/InvolutionCertificate>
  a owl:Class ;
  rdfs:label "InvolutionCertificate" ;
  rdfs:comment "A certificate attesting that an operation is an involution: f(f(x)) = x for all x in R_n." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/CompletenessCertificate>
  a owl:Class ;
  rdfs:label "CompletenessCertificate" ;
  rdfs:comment "A certificate attesting that a type:CompleteType satisfies IT_7d: its constraint nerve has χ = n and all Betti numbers β_k = 0. Issued by the kernel after running the full ψ pipeline on the type's constraint set." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/CompletenessAuditTrail>
  a owl:Class ;
  rdfs:label "CompletenessAuditTrail" ;
  rdfs:comment "An ordered collection of CompletenessWitness records belonging to a CompletenessCertificate. Provides full provenance of the certification process: every constraint applied, every site closed, in sequence." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cert/GroundingCertificate>
  a owl:Class ;
  rdfs:label "GroundingCertificate" ;
  rdfs:comment "A certificate attesting that a state:GroundedContext has reached full saturation (σ = 1, freeRank = 0, S = 0, T_ctx = 0) per SC_4. The session-layer dual of CompletenessCertificate." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/GeodesicCertificate>
  a owl:Class ;
  rdfs:label "GeodesicCertificate" ;
  rdfs:comment "A certificate attesting that a trace:GeodesicTrace satisfies both GD_1 conditions: AR_1-ordered and DC_10-selected. Transforms ComputationTrace from descriptive to normative." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/MeasurementCertificate>
  a owl:Class ;
  rdfs:label "MeasurementCertificate" ;
  rdfs:comment "A certificate attesting that a trace:MeasurementEvent respected the von Neumann–Landauer bridge (QM_1): preCollapseEntropy = postCollapseLandauerCost at β* = ln 2." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/GeodesicEvidenceBundle>
  a owl:Class ;
  rdfs:label "GeodesicEvidenceBundle" ;
  rdfs:comment "A structured evidence bundle attesting that each sub-predicate of the geodesic condition (GD_6) holds independently: isAR1Ordered and isDC10Selected. Linked from GeodesicCertificate via evidenceBundle." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cert/BornRuleVerification>
  a owl:Class ;
  rdfs:label "BornRuleVerification" ;
  rdfs:comment "A certificate attesting that a MeasurementEvent outcome probability matches the Born rule: P(outcome k) = |α_k|² (QM_5). Linked from MeasurementCertificate to provide probability distribution verification." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/LiftChainCertificate>
  a owl:Class ;
  rdfs:label "LiftChainCertificate" ;
  rdfs:comment "A kernel-issued certificate attesting that a LiftChain from liftSourceLevel to liftTargetLevel is complete." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/ChainAuditTrail>
  a owl:Class ;
  rdfs:label "ChainAuditTrail" ;
  rdfs:comment "An ordered collection of per-step evidence records for a LiftChainCertificate." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/cert/InhabitanceCertificate>
  a owl:Class ;
  rdfs:label "InhabitanceCertificate" ;
  rdfs:comment "A ComputationCertificate verdict primitive that decides carrier non-emptiness on a type:ConstrainedType. Distinct from cert:CompletenessCertificate, which decides freeRank = 0 on the minimal basis. For ConstrainedType instances admitting multiple satisfying value tuples, InhabitanceCertificate.verified may be true while CompletenessCertificate.verified is false." ;
  rdfs:subClassOf <https://uor.foundation/proof/ComputationCertificate> ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/MultiplicationCertificate>
  a owl:Class ;
  rdfs:label "MultiplicationCertificate" ;
  rdfs:comment "A certificate attesting the cost-optimal Toom-Cook splitting factor R for a Datum<L> × Datum<L> multiplication at a given call-site context (stack budget, const-eval regime). Carries the chosen splitting factor, the recursive sub-multiplication count, and the accumulated Landauer cost in nats (priced per op:OA_5). Produced by resolver:MultiplicationResolver." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/PartitionCertificate>
  a owl:Class ;
  rdfs:label "PartitionCertificate" ;
  rdfs:comment "A certificate attesting the partition component classification of a Datum, assigning it to one of Irreducible, Reducible, Units, or Exterior via the partition:PartitionComponent enumeration. Produced by the bridge partition walk during grounding." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/GenericImpossibilityCertificate>
  a owl:Class ;
  rdfs:label "GenericImpossibilityCertificate" ;
  rdfs:comment "A certificate attesting that a resolver's verdict path produced a generic impossibility witness — the input failed the resolver's admissibility precondition or decision procedure in a way not covered by a more-specific witness. Returned by every Phase D resolver on failure." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/InhabitanceImpossibilityCertificate>
  a owl:Class ;
  rdfs:label "InhabitanceImpossibilityCertificate" ;
  rdfs:comment "A certificate attesting that the inhabitance decider concluded the input is unsatisfiable — there is no value in the carrier that satisfies the declared constraint conjunction. Returned by `resolver::inhabitance::certify` on failure." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/cert/transformType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transformType" ;
  rdfs:comment "The type of transform this certificate attests to (e.g., 'isometry', 'embedding', 'action')." ;
  rdfs:domain <https://uor.foundation/cert/TransformCertificate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/cert/method>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "method" ;
  rdfs:comment "The verification method used to produce this certificate (e.g., 'exhaustive_check', 'symbolic_proof', 'sampling')." ;
  rdfs:domain <https://uor.foundation/cert/Certificate> ;
  rdfs:range <https://uor.foundation/proof/ProofStrategy> .

<https://uor.foundation/cert/operation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operation" ;
  rdfs:comment "The operation this certificate applies to." ;
  rdfs:domain <https://uor.foundation/cert/InvolutionCertificate> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/cert/verified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "verified" ;
  rdfs:comment "Whether this certificate has been verified by the kernel." ;
  rdfs:domain <https://uor.foundation/cert/Certificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/cert/wittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "wittLength" ;
  rdfs:comment "The Witt level at which this certificate was produced." ;
  rdfs:domain <https://uor.foundation/cert/Certificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/cert/timestamp>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "timestamp" ;
  rdfs:comment "The time at which this certificate was issued." ;
  rdfs:domain <https://uor.foundation/cert/Certificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#dateTime> .

<https://uor.foundation/cert/certifies>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifies" ;
  rdfs:comment "The resource this certificate attests to. Links a certificate to the observable, transform, or other entity it covers." ;
  rdfs:domain <https://uor.foundation/cert/Certificate> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/cert/certifiedType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedType" ;
  rdfs:comment "The TypeDefinition whose completeness this certificate attests. The kernel issues this certificate after running the ψ pipeline on the type's constraint set and confirming IT_7d." ;
  rdfs:domain <https://uor.foundation/cert/CompletenessCertificate> ;
  rdfs:range <https://uor.foundation/type/CompleteType> .

<https://uor.foundation/cert/auditTrail>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "auditTrail" ;
  rdfs:comment "The audit trail attesting the certification provenance. Links a CompletenessCertificate to its ordered sequence of CompletenessWitness records." ;
  rdfs:domain <https://uor.foundation/cert/CompletenessCertificate> ;
  rdfs:range <https://uor.foundation/cert/CompletenessAuditTrail> .

<https://uor.foundation/cert/witnessCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "witnessCount" ;
  rdfs:comment "Total number of witness steps in this audit trail." ;
  rdfs:domain <https://uor.foundation/cert/CompletenessAuditTrail> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/cert/certifiedGrounding>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedGrounding" ;
  rdfs:comment "The GroundedContext whose full saturation this certificate attests. Uses IRI string (cert cannot import state)." ;
  rdfs:domain <https://uor.foundation/cert/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/state/GroundedContext> .

<https://uor.foundation/cert/groundingWitness>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingWitness" ;
  rdfs:comment "The GroundingWitness providing step-by-step evidence of the saturation process." ;
  rdfs:domain <https://uor.foundation/cert/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/state/GroundingWitness> .

<https://uor.foundation/cert/certifiedGeodesic>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedGeodesic" ;
  rdfs:comment "The GeodesicTrace whose geodesic status this certificate attests. Uses IRI string (cert cannot import trace)." ;
  rdfs:domain <https://uor.foundation/cert/GeodesicCertificate> ;
  rdfs:range <https://uor.foundation/trace/GeodesicTrace> .

<https://uor.foundation/cert/geodesicTrace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "geodesicTrace" ;
  rdfs:comment "The computation trace that this GeodesicCertificate covers. Redundant with certifiedGeodesic but expresses the inverse direction for queryability." ;
  rdfs:domain <https://uor.foundation/cert/GeodesicCertificate> ;
  rdfs:range <https://uor.foundation/trace/GeodesicTrace> .

<https://uor.foundation/cert/certifiedMeasurement>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedMeasurement" ;
  rdfs:comment "The MeasurementEvent whose QM_1 compliance this certificate attests. Uses IRI string (cert cannot import trace)." ;
  rdfs:domain <https://uor.foundation/cert/MeasurementCertificate> ;
  rdfs:range <https://uor.foundation/trace/MeasurementEvent> .

<https://uor.foundation/cert/vonNeumannEntropy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "vonNeumannEntropy" ;
  rdfs:comment "The von Neumann entropy S_vN of the pre-measurement SuperposedSiteState, recorded by this certificate." ;
  rdfs:domain <https://uor.foundation/cert/MeasurementCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/cert/landauerCost>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "landauerCost" ;
  rdfs:comment "The Landauer cost incurred by the projective collapse, recorded by this certificate. Equals vonNeumannEntropy at β* = ln 2 per QM_1." ;
  rdfs:domain <https://uor.foundation/cert/MeasurementCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/cert/evidenceBundle>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "evidenceBundle" ;
  rdfs:comment "The GeodesicEvidenceBundle attesting to the decomposed sub-predicates (isAR1Ordered, isDC10Selected) of this GeodesicCertificate's geodesic claim." ;
  rdfs:domain <https://uor.foundation/cert/GeodesicCertificate> ;
  rdfs:range <https://uor.foundation/cert/GeodesicEvidenceBundle> .

<https://uor.foundation/cert/bornRuleVerified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bornRuleVerified" ;
  rdfs:comment "Whether this BornRuleVerification certificate confirms that all outcome probabilities match the Born rule (QM_5): P(k) = |α_k|² for every site k." ;
  rdfs:domain <https://uor.foundation/cert/BornRuleVerification> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/cert/certifiedChain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "certifiedChain" ;
  rdfs:comment "The LiftChain this certificate attests to." ;
  rdfs:domain <https://uor.foundation/cert/LiftChainCertificate> ;
  rdfs:range <https://uor.foundation/type/LiftChain> .

<https://uor.foundation/cert/chainAuditTrail>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "chainAuditTrail" ;
  rdfs:comment "The ordered per-step evidence for this certificate." ;
  rdfs:domain <https://uor.foundation/cert/LiftChainCertificate> ;
  rdfs:range <https://uor.foundation/cert/ChainAuditTrail> .

<https://uor.foundation/cert/targetLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetLevel" ;
  rdfs:comment "The quantum level Q_k at which the certificate was issued." ;
  rdfs:domain <https://uor.foundation/cert/LiftChainCertificate> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/cert/sourceLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceLevel" ;
  rdfs:comment "The quantum level Q_j from which the tower was started." ;
  rdfs:domain <https://uor.foundation/cert/LiftChainCertificate> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/cert/chainStepCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "chainStepCount" ;
  rdfs:comment "Number of lift steps in this ChainAuditTrail. Must equal chainLength of the certified LiftChain. Distinct from witnessCount (domain-locked to CompletenessAuditTrail)." ;
  rdfs:domain <https://uor.foundation/cert/ChainAuditTrail> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/cert/isAR1Ordered>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isAR1Ordered" ;
  rdfs:comment "True iff the linked GeodesicTrace is ordered by the AR_1 canonical rewriting rule (smallest lexicographic representative first)." ;
  rdfs:domain <https://uor.foundation/cert/GeodesicEvidenceBundle> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/cert/isDC10Selected>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isDC10Selected" ;
  rdfs:comment "True iff each constraint in the trace was selected by the DC_10 Jacobian oracle at the step where it was applied." ;
  rdfs:domain <https://uor.foundation/cert/GeodesicEvidenceBundle> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/cert/witness>
  a owl:ObjectProperty ;
  rdfs:label "witness" ;
  rdfs:comment "A specific value tuple in the carrier when verified is true; absent otherwise. The witness form for cert:InhabitanceCertificate." ;
  rdfs:domain <https://uor.foundation/cert/InhabitanceCertificate> ;
  rdfs:range <https://uor.foundation/schema/ValueTuple> .

<https://uor.foundation/cert/searchTrace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "searchTrace" ;
  rdfs:comment "The audit trail of the inhabitance search that produced this certificate." ;
  rdfs:domain <https://uor.foundation/cert/InhabitanceCertificate> ;
  rdfs:range <https://uor.foundation/trace/InhabitanceSearchTrace> .

<https://uor.foundation/cert/grounded>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "grounded" ;
  rdfs:comment "The type:ConstrainedType this InhabitanceCertificate is issued for." ;
  rdfs:domain <https://uor.foundation/cert/InhabitanceCertificate> ;
  rdfs:range <https://uor.foundation/type/ConstrainedType> .

<https://uor.foundation/cert/splittingFactor>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "splittingFactor" ;
  rdfs:comment "The Toom-Cook splitting factor R chosen by the multiplication resolver. R = 1 is schoolbook (the const-eval bottom-out); R = 2 is Karatsuba; R >= 3 is Toom-k. The resolver picks the cost-optimal R subject to the call-site's stack budget and const-eval depth constraints." ;
  rdfs:domain <https://uor.foundation/cert/MultiplicationCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/cert/subMultiplicationCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "subMultiplicationCount" ;
  rdfs:comment "The number of recursive sub-multiplications the chosen splitting factor induces for one Datum<L> × Datum<L> multiplication at this call site. For splitting factor R, the count is (2R - 1) for R > 1, and 1 for R = 1." ;
  rdfs:domain <https://uor.foundation/cert/MultiplicationCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/cert/landauerCostNats>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "landauerCostNats" ;
  rdfs:comment "The accumulated Landauer cost of the certified multiplication in nats, priced per op:OA_5 (each irreversible bit erasure costs ln 2 nats in the Archimedean completion). Unit: observable:Nats. The value is an xsd:decimal." ;
  rdfs:domain <https://uor.foundation/cert/MultiplicationCertificate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

# Namespace: morphism
<https://uor.foundation/morphism/>
  a owl:Ontology ;
  rdfs:label "UOR Transforms and Morphisms" ;
  rdfs:comment "Runtime abstractions for maps between UOR objects: transforms, isometries, embeddings, and group actions. The foundation provides the vocabulary; Prism writes the sentences." ;
  uor:space "user" ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/trace/> ;
  owl:imports <https://uor.foundation/homology/> ;
  owl:imports <https://uor.foundation/u/> ;
  owl:imports <https://uor.foundation/derivation/> ;
  owl:imports <https://uor.foundation/cert/> ;
.

<https://uor.foundation/morphism/Transform>
  a owl:Class ;
  rdfs:label "Transform" ;
  rdfs:comment "A map between UOR objects. The root abstraction: source, target, and optionally what structure (if any) is preserved. This is what cert:TransformCertificate certifies." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/morphism/CompositionLaw> ;
.

<https://uor.foundation/morphism/Isometry>
  a owl:Class ;
  rdfs:label "Isometry" ;
  rdfs:comment "A transform that preserves metric structure with respect to a specified metric. In UOR, isometry is metric-relative: neg is a ring isometry, bnot is a Hamming isometry. A transform can be an isometry with respect to one metric but not the other. This is what cert:IsometryCertificate certifies." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/Composition> ;
.

<https://uor.foundation/morphism/Embedding>
  a owl:Class ;
  rdfs:label "Embedding" ;
  rdfs:comment "An injective, structure-preserving transform across quantum levels. The canonical instance is the level embedding ι : R_n → R_{n'} (n < n'), which preserves addition, multiplication, and content addressing." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/Composition> ;
.

<https://uor.foundation/morphism/Action>
  a owl:Class ;
  rdfs:label "Action" ;
  rdfs:comment "The mechanism by which a group applies transforms systematically to a set. Each group element induces a transform of the set. The dihedral action on type space is an action by isometries — every element of D_{2^n} produces an isometric transform of 𝒯_n." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/morphism/Composition>
  a owl:Class ;
  rdfs:label "Composition" ;
  rdfs:comment "A transform formed by composing two or more transforms sequentially. The categorical composition operation that turns transforms into a category." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/Isometry> ;
  owl:disjointWith <https://uor.foundation/morphism/Embedding> ;
  owl:disjointWith <https://uor.foundation/morphism/Identity> ;
.

<https://uor.foundation/morphism/Identity>
  a owl:Class ;
  rdfs:label "Identity" ;
  rdfs:comment "The identity transform on a type: maps every element to itself. The categorical identity morphism." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/Composition> ;
.

<https://uor.foundation/morphism/CompositionLaw>
  a owl:Class ;
  rdfs:label "CompositionLaw" ;
  rdfs:comment "A law governing how operations compose. Records whether the composition is associative, commutative, and what the result operation is. The critical composition law (neg ∘ bnot = succ) is the foundational instance." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/morphism/Transform> ;
.

<https://uor.foundation/morphism/GroundingMap>
  a owl:Class ;
  rdfs:label "GroundingMap" ;
  rdfs:comment "A Transform mapping a surface symbol (any schema:Literal) to its ring datum (a schema:Datum) via the content-addressing bijection. Typed, derivation-witnessed, constraint-preserving map from surface to coordinate. Applies identically across NLP tokens, ARC-AGI grid cells, MIDI notes, pixels, sensor readings, and logical propositions." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/ProjectionMap> ;
.

<https://uor.foundation/morphism/ProjectionMap>
  a owl:Class ;
  rdfs:label "ProjectionMap" ;
  rdfs:comment "A Transform mapping a resolved partition:Partition (address neighbourhood) to an ordered sequence of surface symbols. Output ordering determined by the active state:Frame — the same constraint frame that decomposed the input symbol sequence." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
  owl:disjointWith <https://uor.foundation/morphism/GroundingMap> ;
.

<https://uor.foundation/morphism/GroundingCertificate>
  a owl:Class ;
  rdfs:label "GroundingCertificate" ;
  rdfs:comment "A certificate attesting that a specific grounding round-trip (P∘Π∘G) satisfied the shared-frame condition and landed in the type-equivalent neighbourhood of the source symbol. Witnesses the Surface Symmetry Theorem (op:surfaceSymmetry) for one specific symbol instance." ;
  rdfs:subClassOf <https://uor.foundation/cert/Certificate> ;
.

<https://uor.foundation/morphism/TopologicalDelta>
  a owl:Class ;
  rdfs:label "TopologicalDelta" ;
  rdfs:comment "A topological delta: records changes in topological invariants (Betti numbers, Euler characteristic, nerve structure) before and after a morphism." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/morphism/ComputationDatum>
  a owl:Class ;
  rdfs:label "ComputationDatum" ;
  rdfs:comment "A datum whose ring value is the content address of a cert:TransformCertificate. Represents a certified computation as a first-class value within the ring." ;
  rdfs:subClassOf <https://uor.foundation/schema/Datum> ;
.

<https://uor.foundation/morphism/ApplicationMorphism>
  a owl:Class ;
  rdfs:label "ApplicationMorphism" ;
  rdfs:comment "A transform that applies a ComputationDatum to an input datum, producing an output datum. The output inherits the certificate of the ComputationDatum." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Transform> ;
.

<https://uor.foundation/morphism/PartialApplication>
  a owl:Class ;
  rdfs:label "PartialApplication" ;
  rdfs:comment "A ComputationDatum formed by fixing some but not all inputs of a multi-argument transform." ;
  rdfs:subClassOf <https://uor.foundation/morphism/ComputationDatum> ;
.

<https://uor.foundation/morphism/TransformComposition>
  a owl:Class ;
  rdfs:label "TransformComposition" ;
  rdfs:comment "A ComputationDatum representing the composition f ∘ g of two ComputationDatums. Certified iff both components are certified and range(g) = domain(f)." ;
  rdfs:subClassOf <https://uor.foundation/morphism/ComputationDatum> ;
.

<https://uor.foundation/morphism/Witness>
  a owl:Class ;
  rdfs:label "Witness" ;
  rdfs:comment "Abstract supertype for one specific input/output pair witnessing a Transform." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/morphism/GroundingWitness>
  a owl:Class ;
  rdfs:label "GroundingWitness" ;
  rdfs:comment "One specific surface symbol mapped to one specific grounded address by some GroundingMap." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Witness> ;
  owl:disjointWith <https://uor.foundation/morphism/ProjectionWitness> ;
.

<https://uor.foundation/morphism/ProjectionWitness>
  a owl:Class ;
  rdfs:label "ProjectionWitness" ;
  rdfs:comment "One specific input partition mapped to one specific surface symbol sequence by some ProjectionMap." ;
  rdfs:subClassOf <https://uor.foundation/morphism/Witness> ;
  owl:disjointWith <https://uor.foundation/morphism/GroundingWitness> ;
.

<https://uor.foundation/morphism/SymbolSequence>
  a owl:Class ;
  rdfs:label "SymbolSequence" ;
  rdfs:comment "An ordered sequence of surface symbols. Elements are reified as SequenceElement individuals with explicit position indices." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/morphism/SequenceElement>
  a owl:Class ;
  rdfs:label "SequenceElement" ;
  rdfs:comment "One position in a SymbolSequence: a reified (value, index) pair." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/morphism/source>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "source" ;
  rdfs:comment "The domain of the transform." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/morphism/target>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "target" ;
  rdfs:comment "The codomain of the transform." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/morphism/preserves>
  a owl:ObjectProperty ;
  rdfs:label "preserves" ;
  rdfs:comment "The structure preserved by this transform (if any). E.g., a ring homomorphism preserves addition and multiplication." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/morphism/preservesMetric>
  a owl:ObjectProperty ;
  rdfs:label "preservesMetric" ;
  rdfs:comment "The specific metric this isometry preserves. Points to observable:RingMetric or observable:HammingMetric. A transform that preserves both is an isometry of the full UOR geometry. A transform that preserves one but not the other has nontrivial curvature — observable:CurvatureObservable measures this gap." ;
  rdfs:domain <https://uor.foundation/morphism/Isometry> ;
  rdfs:range <https://uor.foundation/observable/MetricObservable> .

<https://uor.foundation/morphism/sourceQuantum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sourceQuantum" ;
  rdfs:comment "The quantum level n of the source ring for an embedding." ;
  rdfs:domain <https://uor.foundation/morphism/Embedding> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/morphism/targetQuantum>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetQuantum" ;
  rdfs:comment "The quantum level n' of the target ring for an embedding. Must satisfy n' > n (embeddings go to larger rings)." ;
  rdfs:domain <https://uor.foundation/morphism/Embedding> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/morphism/group>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "group" ;
  rdfs:comment "The group acting in this group action." ;
  rdfs:domain <https://uor.foundation/morphism/Action> ;
  rdfs:range <https://uor.foundation/op/Group> .

<https://uor.foundation/morphism/actingOn>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "actingOn" ;
  rdfs:comment "The set being acted upon by this group action." ;
  rdfs:domain <https://uor.foundation/morphism/Action> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Thing> .

<https://uor.foundation/morphism/actionIsometry>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "actionIsometry" ;
  rdfs:comment "Whether every transform induced by this action is an isometry. True for the dihedral action on 𝒯_n (Frame Theorem)." ;
  rdfs:domain <https://uor.foundation/morphism/Action> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/morphism/trace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "trace" ;
  rdfs:comment "The computation trace that realized this transform at runtime. A Transform is an abstraction; a trace is the kernel's record of how it was executed via concrete operations." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <https://uor.foundation/trace/ComputationTrace> .

<https://uor.foundation/morphism/composesWith>
  a owl:ObjectProperty ;
  rdfs:label "composesWith" ;
  rdfs:comment "A transform that this transform can be composed with. The target of this transform must match the source of the composed transform." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <https://uor.foundation/morphism/Transform> .

<https://uor.foundation/morphism/compositionResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionResult" ;
  rdfs:comment "The transform that results from this composition." ;
  rdfs:domain <https://uor.foundation/morphism/Composition> ;
  rdfs:range <https://uor.foundation/morphism/Transform> .

<https://uor.foundation/morphism/compositionComponents>
  a owl:ObjectProperty ;
  rdfs:label "compositionComponents" ;
  rdfs:comment "A component transform of this composition." ;
  rdfs:domain <https://uor.foundation/morphism/Composition> ;
  rdfs:range <https://uor.foundation/morphism/Transform> .

<https://uor.foundation/morphism/identityOn>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "identityOn" ;
  rdfs:comment "The type on which this identity transform acts." ;
  rdfs:domain <https://uor.foundation/morphism/Identity> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/morphism/compositionOrder>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "compositionOrder" ;
  rdfs:comment "The number of component transforms in a composition." ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/morphism/isAssociative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isAssociative" ;
  rdfs:comment "Whether this composition law is associative." ;
  rdfs:domain <https://uor.foundation/morphism/CompositionLaw> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/morphism/isCommutative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isCommutative" ;
  rdfs:comment "Whether this composition law is commutative." ;
  rdfs:domain <https://uor.foundation/morphism/CompositionLaw> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/morphism/lawComponents>
  a owl:ObjectProperty ;
  rdfs:label "lawComponents" ;
  rdfs:comment "An operation that is a component of this composition law." ;
  rdfs:domain <https://uor.foundation/morphism/CompositionLaw> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/morphism/lawResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "lawResult" ;
  rdfs:comment "The operation that results from this composition law." ;
  rdfs:domain <https://uor.foundation/morphism/CompositionLaw> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/morphism/preservedInvariant>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "preservedInvariant" ;
  rdfs:comment "The identity preserved by this transform (reference to the op:Identity that the transform commutes with)." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/morphism/addressCoherence>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "addressCoherence" ;
  rdfs:comment "Certificate that this embedding's addressing diagram commutes: glyph ∘ ι ∘ addresses is well-defined and injective." ;
  rdfs:domain <https://uor.foundation/morphism/Embedding> ;
  rdfs:range <https://uor.foundation/op/Identity> .

<https://uor.foundation/morphism/bettisBefore>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "bettisBefore" ;
  rdfs:comment "Betti numbers before the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <https://uor.foundation/observable/BettiNumber> .

<https://uor.foundation/morphism/bettisAfter>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "bettisAfter" ;
  rdfs:comment "Betti numbers after the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <https://uor.foundation/observable/BettiNumber> .

<https://uor.foundation/morphism/eulerBefore>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "eulerBefore" ;
  rdfs:comment "Euler characteristic before the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/morphism/eulerAfter>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "eulerAfter" ;
  rdfs:comment "Euler characteristic after the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/morphism/nerveBefore>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "nerveBefore" ;
  rdfs:comment "Constraint nerve (simplicial complex) before the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <https://uor.foundation/homology/SimplicialComplex> .

<https://uor.foundation/morphism/nerveAfter>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "nerveAfter" ;
  rdfs:comment "Constraint nerve (simplicial complex) after the morphism." ;
  rdfs:domain <https://uor.foundation/morphism/TopologicalDelta> ;
  rdfs:range <https://uor.foundation/homology/SimplicialComplex> .

<https://uor.foundation/morphism/surfaceSymbol>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "surfaceSymbol" ;
  rdfs:comment "The surface symbol that is the source of this grounding witness." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingWitness> ;
  rdfs:range <https://uor.foundation/schema/SurfaceSymbol> .

<https://uor.foundation/morphism/groundedAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedAddress" ;
  rdfs:comment "The resolved ring address that is the target of this grounding witness." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingWitness> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/groundingDerivation>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingDerivation" ;
  rdfs:comment "The derivation witnessing the content-addressing computation that produced the grounded address from the surface symbol." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:range <https://uor.foundation/derivation/Derivation> .

<https://uor.foundation/morphism/symbolConstraints>
  a owl:ObjectProperty ;
  rdfs:label "symbolConstraints" ;
  rdfs:comment "A typed attribute preserved by this grounding. Non-functional: one assertion per active constraint axis (vertical, horizontal, diagonal)." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/morphism/projectionFrame>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "projectionFrame" ;
  rdfs:comment "The active frame — shared with the grounding that produced the query. The shared-frame condition (Surface Symmetry Theorem) requires G and P to reference the same frame." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:range <https://uor.foundation/state/Frame> .

<https://uor.foundation/morphism/projectionSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "projectionSource" ;
  rdfs:comment "The resolved partition (address neighbourhood) that this projection witness projects back to surface symbols." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionWitness> ;
  rdfs:range <https://uor.foundation/partition/Partition> .

<https://uor.foundation/morphism/projectionOrder>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "projectionOrder" ;
  rdfs:comment "Ordering constraint determining the output symbol sequence. Domain-specific: syntactic position (NLP), row-major scan (ARC), temporal sequence (music)." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:range <https://uor.foundation/type/Conjunction> .

<https://uor.foundation/morphism/roundTripCoherence>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "roundTripCoherence" ;
  rdfs:comment "Completeness criterion: does projecting the grounded source address recover a symbol in the same type class as the input? True iff the shared-frame condition holds." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/morphism/groundingCertMap>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingCertMap" ;
  rdfs:comment "The GroundingMap used in this certified round-trip." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/morphism/GroundingMap> .

<https://uor.foundation/morphism/groundingCertProjection>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingCertProjection" ;
  rdfs:comment "The ProjectionMap used in this certified round-trip." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/morphism/ProjectionMap> .

<https://uor.foundation/morphism/groundingCertSourceSymbol>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingCertSourceSymbol" ;
  rdfs:comment "The surface symbol that entered the grounding boundary." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/schema/Literal> .

<https://uor.foundation/morphism/groundingCertAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingCertAddress" ;
  rdfs:comment "The ring address the symbol was grounded to." ;
  rdfs:domain <https://uor.foundation/morphism/GroundingCertificate> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/referencedCertificate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "referencedCertificate" ;
  rdfs:comment "The certificate this computation datum encodes." ;
  rdfs:domain <https://uor.foundation/morphism/ComputationDatum> ;
  rdfs:range <https://uor.foundation/cert/TransformCertificate> .

<https://uor.foundation/morphism/computationAddress>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "computationAddress" ;
  rdfs:comment "The content address of the referenced certificate." ;
  rdfs:domain <https://uor.foundation/morphism/ComputationDatum> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/applicationTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "applicationTarget" ;
  rdfs:comment "The computation being applied." ;
  rdfs:domain <https://uor.foundation/morphism/ApplicationMorphism> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/morphism/applicationInput>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "applicationInput" ;
  rdfs:comment "The input datum to the application." ;
  rdfs:domain <https://uor.foundation/morphism/ApplicationMorphism> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/morphism/partialBase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "partialBase" ;
  rdfs:comment "The base computation being partially applied." ;
  rdfs:domain <https://uor.foundation/morphism/PartialApplication> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/morphism/boundArguments>
  a owl:ObjectProperty ;
  rdfs:label "boundArguments" ;
  rdfs:comment "The arguments already bound." ;
  rdfs:domain <https://uor.foundation/morphism/PartialApplication> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/morphism/compositionLeft>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionLeft" ;
  rdfs:comment "The outer function f in f ∘ g." ;
  rdfs:domain <https://uor.foundation/morphism/TransformComposition> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/morphism/compositionRight>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionRight" ;
  rdfs:comment "The inner function g in f ∘ g." ;
  rdfs:domain <https://uor.foundation/morphism/TransformComposition> ;
  rdfs:range <https://uor.foundation/morphism/ComputationDatum> .

<https://uor.foundation/morphism/remainingArity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "remainingArity" ;
  rdfs:comment "Number of unbound arguments remaining." ;
  rdfs:domain <https://uor.foundation/morphism/PartialApplication> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/morphism/inputClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inputClass" ;
  rdfs:comment "The OWL class of inputs this transform accepts. Uses OWL2 punning so the value is a class IRI treated as an individual at this position." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/morphism/outputClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "outputClass" ;
  rdfs:comment "The OWL class of outputs this transform produces. Uses OWL2 punning." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/morphism/outputElementClass>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "outputElementClass" ;
  rdfs:comment "When outputClass is a sequence type, the OWL class of individual sequence elements. Uses OWL2 punning." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:range <http://www.w3.org/2002/07/owl#Class> .

<https://uor.foundation/morphism/hasWitness>
  a owl:ObjectProperty ;
  rdfs:label "hasWitness" ;
  rdfs:comment "Zero or more witness pairs documenting specific input/output bindings of this transform." ;
  rdfs:domain <https://uor.foundation/morphism/Transform> ;
  rdfs:range <https://uor.foundation/morphism/Witness> .

<https://uor.foundation/morphism/hasElement>
  a owl:ObjectProperty ;
  rdfs:label "hasElement" ;
  rdfs:comment "Membership of a SymbolSequence. The sequence is reconstructed by sorting elements by elementIndex." ;
  rdfs:domain <https://uor.foundation/morphism/SymbolSequence> ;
  rdfs:range <https://uor.foundation/morphism/SequenceElement> .

<https://uor.foundation/morphism/elementValue>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "elementValue" ;
  rdfs:comment "The surface symbol value of this sequence element." ;
  rdfs:domain <https://uor.foundation/morphism/SequenceElement> ;
  rdfs:range <https://uor.foundation/schema/SurfaceSymbol> .

<https://uor.foundation/morphism/elementIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "elementIndex" ;
  rdfs:comment "The zero-based position of this element in the sequence." ;
  rdfs:domain <https://uor.foundation/morphism/SequenceElement> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/morphism/projectionOutput>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "projectionOutput" ;
  rdfs:comment "The single SymbolSequence produced by this projection witness." ;
  rdfs:domain <https://uor.foundation/morphism/ProjectionWitness> ;
  rdfs:range <https://uor.foundation/morphism/SymbolSequence> .

<https://uor.foundation/morphism/criticalComposition>
  a owl:NamedIndividual , <https://uor.foundation/morphism/CompositionLaw> ;
  rdfs:label "criticalComposition" ;
  rdfs:comment "The critical composition law: neg ∘ bnot = succ. This is the operational form of the critical identity theorem. The composition of the two involutions (neg, bnot) yields the successor operation. Non-associative and non-commutative." ;
  <https://uor.foundation/morphism/lawComponents> <https://uor.foundation/op/neg> ;
  <https://uor.foundation/morphism/lawComponents> <https://uor.foundation/op/bnot> ;
  <https://uor.foundation/morphism/lawResult> <https://uor.foundation/op/succ> ;
  <https://uor.foundation/morphism/isAssociative> "false"^^xsd:boolean ;
  <https://uor.foundation/morphism/isCommutative> "false"^^xsd:boolean .

<https://uor.foundation/morphism/IntegerGroundingMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:label "IntegerGroundingMap" ;
  rdfs:comment "Grounds integer surface symbols to ring addresses." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/schema/Literal> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/Utf8GroundingMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:label "Utf8GroundingMap" ;
  rdfs:comment "Grounds UTF-8 host strings to ring addresses." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/schema/HostStringLiteral> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/JsonGroundingMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:label "JsonGroundingMap" ;
  rdfs:comment "Grounds JSON host strings to ring addresses." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/schema/HostStringLiteral> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/DigestGroundingMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:label "DigestGroundingMap" ;
  rdfs:comment "A GroundingMap that maps fixed-size external byte strings to ring datums via a one-way digest function (e.g., SHA-256). Total but not invertible: every input grounds, but distinct inputs may collide; the inverse is computationally unbounded. Preserves no algebraic structure." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/schema/HostStringLiteral> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/BinaryGroundingMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/GroundingMap> ;
  rdfs:label "BinaryGroundingMap" ;
  rdfs:comment "A GroundingMap that maps host-supplied byte sequences to ring datums via a fixed bit-pattern interpretation (e.g., little-endian unsigned integer reading). Total and invertible on its declared bit-width; preserves no algebraic structure beyond bit identity." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/schema/HostStringLiteral> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/u/Element> .

<https://uor.foundation/morphism/IntegerProjectionMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:label "IntegerProjectionMap" ;
  rdfs:comment "Projects partitions to integer symbol sequences." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/morphism/SymbolSequence> ;
  <https://uor.foundation/morphism/outputElementClass> <https://uor.foundation/schema/Literal> .

<https://uor.foundation/morphism/Utf8ProjectionMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:label "Utf8ProjectionMap" ;
  rdfs:comment "Projects partitions to UTF-8 symbol sequences." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/morphism/SymbolSequence> ;
  <https://uor.foundation/morphism/outputElementClass> <https://uor.foundation/schema/HostStringLiteral> .

<https://uor.foundation/morphism/JsonProjectionMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:label "JsonProjectionMap" ;
  rdfs:comment "Projects partitions to JSON symbol sequences." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/morphism/SymbolSequence> ;
  <https://uor.foundation/morphism/outputElementClass> <https://uor.foundation/schema/HostStringLiteral> .

<https://uor.foundation/morphism/DigestProjectionMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:label "DigestProjectionMap" ;
  rdfs:comment "Projects partitions to fixed-size digest symbol sequences. Dual of DigestGroundingMap." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/morphism/SymbolSequence> ;
  <https://uor.foundation/morphism/outputElementClass> <https://uor.foundation/schema/Literal> .

<https://uor.foundation/morphism/BinaryProjectionMap>
  a owl:NamedIndividual , <https://uor.foundation/morphism/ProjectionMap> ;
  rdfs:label "BinaryProjectionMap" ;
  rdfs:comment "Projects partitions to raw byte symbol sequences. Dual of BinaryGroundingMap." ;
  <https://uor.foundation/morphism/inputClass> <https://uor.foundation/partition/Partition> ;
  <https://uor.foundation/morphism/outputClass> <https://uor.foundation/morphism/SymbolSequence> ;
  <https://uor.foundation/morphism/outputElementClass> <https://uor.foundation/schema/Literal> .

# Namespace: state
<https://uor.foundation/state/>
  a owl:Ontology ;
  rdfs:label "UOR State" ;
  rdfs:comment "Parameterized address spaces, context management, binding lifecycle, and state transitions. The user-space overlay onto the kernel's read-only ring substrate." ;
  uor:space "user" ;
  owl:imports <https://uor.foundation/u/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/type/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/trace/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/cert/> ;
.

<https://uor.foundation/state/Context>
  a owl:Class ;
  rdfs:label "Context" ;
  rdfs:comment "A bounded set of populated UOR addresses. The parameter space for a resolution cycle. Contexts hold bindings that map addresses to datum values." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/state/Binding> ;
  owl:disjointWith <https://uor.foundation/state/Frame> ;
  owl:disjointWith <https://uor.foundation/state/Transition> ;
.

<https://uor.foundation/state/Binding>
  a owl:Class ;
  rdfs:label "Binding" ;
  rdfs:comment "The association of a datum value with an address in a context. The write primitive: creating a binding populates an address." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/state/Context> ;
  owl:disjointWith <https://uor.foundation/state/Frame> ;
  owl:disjointWith <https://uor.foundation/state/Transition> ;
.

<https://uor.foundation/state/Frame>
  a owl:Class ;
  rdfs:label "Frame" ;
  rdfs:comment "The visibility boundary determining which bindings are in scope for a given resolution. A frame is a view into a context: it selects which bindings the resolver sees." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/state/Context> ;
  owl:disjointWith <https://uor.foundation/state/Binding> ;
  owl:disjointWith <https://uor.foundation/state/Transition> ;
.

<https://uor.foundation/state/Transition>
  a owl:Class ;
  rdfs:label "Transition" ;
  rdfs:comment "A state change: the transformation of one context into another through binding or unbinding. The sequence of transitions is the application's computation history." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/state/Context> ;
  owl:disjointWith <https://uor.foundation/state/Binding> ;
  owl:disjointWith <https://uor.foundation/state/Frame> ;
.

<https://uor.foundation/state/SessionBoundaryType>
  a owl:Class ;
  rdfs:label "SessionBoundaryType" ;
  rdfs:comment "A typed controlled vocabulary for session boundary reasons. Each individual names a specific reason a context-reset boundary was triggered during a multi-turn session." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/Session>
  a owl:Class ;
  rdfs:label "Session" ;
  rdfs:comment "A bounded sequence of RelationQuery/response pairs sharing a common state:Context. Sessions are the unit of coherent multi-turn reasoning in Prism." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/BindingAccumulator>
  a owl:Class ;
  rdfs:label "BindingAccumulator" ;
  rdfs:comment "The mutable accumulator that appends state:Binding instances to a state:Context as each RelationQuery resolves. Tracks monotonic reduction of aggregate free site space." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/SessionBoundary>
  a owl:Class ;
  rdfs:label "SessionBoundary" ;
  rdfs:comment "Marks a context-reset event within a session stream. Records why the context was reset and provides a clean state:Context for subsequent queries." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/GroundedContext>
  a owl:Class ;
  rdfs:label "GroundedContext" ;
  rdfs:comment "A context that has reached full saturation: σ = 1, freeRank = 0, S = 0, T_ctx = 0 (SC_4). The ground state of the type system. All subsequent queries resolve in O(1) via SC_5." ;
  rdfs:subClassOf <https://uor.foundation/state/Context> ;
.

<https://uor.foundation/state/GroundingWitness>
  a owl:Class ;
  rdfs:label "GroundingWitness" ;
  rdfs:comment "Step-by-step evidence of the saturation process: records which bindings were applied, in what order, to reach full saturation." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/DomainGroundingRecord>
  a owl:Class ;
  rdfs:label "DomainGroundingRecord" ;
  rdfs:comment "An informational/monitoring record tracking the saturation progress of a specific domain within a context. Carries no formal authority — purely observational." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/GroundingPhase>
  a owl:Class ;
  rdfs:label "GroundingPhase" ;
  rdfs:comment "A typed controlled vocabulary for the three phases of context saturation: Open (σ = 0), PartialGrounding (0 < σ < 1), and FullGrounding (σ = 1)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/SharedContext>
  a owl:Class ;
  rdfs:label "SharedContext" ;
  rdfs:comment "A Context visible to more than one Session simultaneously. Holds a set of ContextLease instances that partition its site coordinates among active sessions. Lease disjointness (SR_9) prevents concurrent write conflicts." ;
  rdfs:subClassOf <https://uor.foundation/state/Context> ;
.

<https://uor.foundation/state/ContextLease>
  a owl:Class ;
  rdfs:label "ContextLease" ;
  rdfs:comment "A bounded, exclusive claim on a set of site coordinates within a SharedContext, held by exactly one Session. When the session closes or hits a SessionBoundary, the lease is released and its sites become available for re-leasing." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
  owl:disjointWith <https://uor.foundation/state/Context> ;
  owl:disjointWith <https://uor.foundation/state/Binding> ;
  owl:disjointWith <https://uor.foundation/state/Frame> ;
  owl:disjointWith <https://uor.foundation/state/Transition> ;
.

<https://uor.foundation/state/SessionComposition>
  a owl:Class ;
  rdfs:label "SessionComposition" ;
  rdfs:comment "Records that a Session was formed by merging the binding sets of two or more predecessor sessions. Valid only if all predecessor binding sets pass the cross-session consistency check (SR_8). An invalid composition attempt produces a ContradictionBoundary on the target session." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/state/address>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "address" ;
  rdfs:comment "The UOR address being bound in this binding." ;
  rdfs:domain <https://uor.foundation/state/Binding> ;
  rdfs:range <https://uor.foundation/u/Element> .

<https://uor.foundation/state/content>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "content" ;
  rdfs:comment "The datum value bound to the address in this binding." ;
  rdfs:domain <https://uor.foundation/state/Binding> ;
  rdfs:range <https://uor.foundation/schema/Datum> .

<https://uor.foundation/state/boundType>
  a owl:ObjectProperty ;
  rdfs:label "boundType" ;
  rdfs:comment "The type under which this binding's datum is resolved." ;
  rdfs:domain <https://uor.foundation/state/Binding> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/state/timestamp>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "timestamp" ;
  rdfs:comment "The time at which this binding was created." ;
  rdfs:domain <https://uor.foundation/state/Binding> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#dateTime> .

<https://uor.foundation/state/binding>
  a owl:ObjectProperty ;
  rdfs:label "binding" ;
  rdfs:comment "A binding held in this context." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/capacity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "capacity" ;
  rdfs:comment "The maximum number of bindings this context can hold." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/state/contentAddress>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "contentAddress" ;
  rdfs:comment "The content-derived address of this context, uniquely identifying its current state in the UOR address space." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/state/wittLength>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "wittLength" ;
  rdfs:comment "The Witt level of this context's address space." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/state/activeBindings>
  a owl:ObjectProperty ;
  rdfs:label "activeBindings" ;
  rdfs:comment "The bindings currently in scope for this frame." ;
  rdfs:domain <https://uor.foundation/state/Frame> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/context>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "context" ;
  rdfs:comment "The context this frame is a view of." ;
  rdfs:domain <https://uor.foundation/state/Frame> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/constraint>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "constraint" ;
  rdfs:comment "The type:Constraint determining which bindings from the context are visible in this frame. The resolver applies this constraint to filter the context's binding set, producing the frame's active bindings. An absent constraint means all bindings are visible." ;
  rdfs:domain <https://uor.foundation/state/Frame> ;
  rdfs:range <https://uor.foundation/type/Constraint> .

<https://uor.foundation/state/from>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "from" ;
  rdfs:comment "The context before this transition." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/to>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "to" ;
  rdfs:comment "The context after this transition." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/addedBindings>
  a owl:ObjectProperty ;
  rdfs:label "addedBindings" ;
  rdfs:comment "Bindings added to the context in this transition." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/removedBindings>
  a owl:ObjectProperty ;
  rdfs:label "removedBindings" ;
  rdfs:comment "Bindings removed from the context in this transition." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/trace>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "trace" ;
  rdfs:comment "The computation trace recording the kernel operations that effected this state transition." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/trace/ComputationTrace> .

<https://uor.foundation/state/topologicalSnapshot>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "topologicalSnapshot" ;
  rdfs:comment "A snapshot of topological invariants at this transition point." ;
  rdfs:domain <https://uor.foundation/state/Transition> ;
  rdfs:range <https://uor.foundation/morphism/TopologicalDelta> .

<https://uor.foundation/state/sessionBindings>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sessionBindings" ;
  rdfs:comment "The shared context holding all bindings accumulated across the queries in this session." ;
  rdfs:domain <https://uor.foundation/state/Session> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/sessionQueries>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "sessionQueries" ;
  rdfs:comment "The number of RelationQuery evaluations completed in this session." ;
  rdfs:domain <https://uor.foundation/state/Session> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/state/aggregateSiteDeficit>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "aggregateSiteDeficit" ;
  rdfs:comment "The aggregate FreeRank deficit across all accumulated bindings: the total remaining free sites that have not yet been closed by resolution. Decreases monotonically as the session progresses." ;
  rdfs:domain <https://uor.foundation/state/BindingAccumulator> ;
  rdfs:range <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/state/accumulatedBindings>
  a owl:ObjectProperty ;
  rdfs:label "accumulatedBindings" ;
  rdfs:comment "A binding accumulated by this accumulator from a resolved RelationQuery." ;
  rdfs:domain <https://uor.foundation/state/BindingAccumulator> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/boundaryReason>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "boundaryReason" ;
  rdfs:comment "A human-readable description of why this session boundary was triggered." ;
  rdfs:domain <https://uor.foundation/state/SessionBoundary> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/state/boundaryType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "boundaryType" ;
  rdfs:comment "The typed reason category for this session boundary." ;
  rdfs:domain <https://uor.foundation/state/SessionBoundary> ;
  rdfs:range <https://uor.foundation/state/SessionBoundaryType> .

<https://uor.foundation/state/priorContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "priorContext" ;
  rdfs:comment "The state:Context that was active before this boundary reset." ;
  rdfs:domain <https://uor.foundation/state/SessionBoundary> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/freshContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "freshContext" ;
  rdfs:comment "The clean state:Context produced after this boundary reset, ready for subsequent queries." ;
  rdfs:domain <https://uor.foundation/state/SessionBoundary> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/groundingDegree>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "groundingDegree" ;
  rdfs:comment "The saturation degree σ ∈ \\[0, 1\\] of this context. Defined by SC_2: σ = (n − freeRank) / n." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/state/contextTemperature>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "contextTemperature" ;
  rdfs:comment "The context temperature T_ctx ∈ \\[0, ln 2\\]. Defined by SC_1: T_ctx = freeRank × ln 2 / n. At σ = 1, T_ctx = 0." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/state/isGrounded>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isGrounded" ;
  rdfs:comment "Whether this context has reached full saturation (σ = 1). Equivalent to freeRank = 0, S = 0, T_ctx = 0 per SC_4." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/state/groundingPhase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundingPhase" ;
  rdfs:comment "The current saturation phase of this context: Open, PartialGrounding, or FullGrounding." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <https://uor.foundation/state/GroundingPhase> .

<https://uor.foundation/state/witnessBinding>
  a owl:ObjectProperty ;
  rdfs:label "witnessBinding" ;
  rdfs:comment "A binding that contributed to the saturation process, recorded in this GroundingWitness." ;
  rdfs:domain <https://uor.foundation/state/GroundingWitness> ;
  rdfs:range <https://uor.foundation/state/Binding> .

<https://uor.foundation/state/witnessStep>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "witnessStep" ;
  rdfs:comment "The step index at which a particular binding was applied during the saturation process." ;
  rdfs:domain <https://uor.foundation/state/GroundingWitness> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/state/residualFreeCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "residualFreeCount" ;
  rdfs:comment "The number of free (unbound) sites remaining in this context. At saturation, residualFreeCount = 0." ;
  rdfs:domain <https://uor.foundation/state/Context> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/state/groundedContext>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedContext" ;
  rdfs:comment "The GroundedContext that this DomainGroundingRecord monitors." ;
  rdfs:domain <https://uor.foundation/state/DomainGroundingRecord> ;
  rdfs:range <https://uor.foundation/state/GroundedContext> .

<https://uor.foundation/state/groundedDomain>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedDomain" ;
  rdfs:comment "The domain within the context being tracked by this DomainGroundingRecord." ;
  rdfs:domain <https://uor.foundation/state/DomainGroundingRecord> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/state/domainFreeCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "domainFreeCount" ;
  rdfs:comment "The number of free sites remaining in the specific domain tracked by this DomainGroundingRecord." ;
  rdfs:domain <https://uor.foundation/state/DomainGroundingRecord> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/state/leasedSites>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leasedSites" ;
  rdfs:comment "The subset of sites claimed by this lease. Must be disjoint from all other active leases on the same SharedContext (SR_9)." ;
  rdfs:domain <https://uor.foundation/state/ContextLease> ;
  rdfs:range <https://uor.foundation/partition/FreeRank> .

<https://uor.foundation/state/leaseHolder>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseHolder" ;
  rdfs:comment "The Session that holds this lease." ;
  rdfs:domain <https://uor.foundation/state/ContextLease> ;
  rdfs:range <https://uor.foundation/state/Session> .

<https://uor.foundation/state/leaseSet>
  a owl:ObjectProperty ;
  rdfs:label "leaseSet" ;
  rdfs:comment "A currently active ContextLease on this SharedContext." ;
  rdfs:domain <https://uor.foundation/state/SharedContext> ;
  rdfs:range <https://uor.foundation/state/ContextLease> .

<https://uor.foundation/state/composedFrom>
  a owl:ObjectProperty ;
  rdfs:label "composedFrom" ;
  rdfs:comment "A predecessor session contributing bindings to this composition. Non-functional: one composition may merge two or more sessions." ;
  rdfs:domain <https://uor.foundation/state/SessionComposition> ;
  rdfs:range <https://uor.foundation/state/Session> .

<https://uor.foundation/state/compositionCompatible>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "compositionCompatible" ;
  rdfs:comment "Whether all predecessor binding sets passed the SR_8 consistency check. If false, the composition is invalid and must not be used as a session context." ;
  rdfs:domain <https://uor.foundation/state/SessionComposition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/state/compositionResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionResult" ;
  rdfs:comment "The merged Context produced by a valid composition. Only present when compositionCompatible = true." ;
  rdfs:domain <https://uor.foundation/state/SessionComposition> ;
  rdfs:range <https://uor.foundation/state/Context> .

<https://uor.foundation/state/towerConsistencyVerified>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "towerConsistencyVerified" ;
  rdfs:comment "Whether the LiftChain tower consistency check (SR_8 parametric extension) was performed across all Q_0 through Q_k levels. Required for compositions involving sessions at Q_1 or higher." ;
  rdfs:domain <https://uor.foundation/state/SessionComposition> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/state/linearSite>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "linearSite" ;
  rdfs:comment "The site coordinate allocated linearly by this lease." ;
  rdfs:domain <https://uor.foundation/state/ContextLease> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/state/leaseScope>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leaseScope" ;
  rdfs:comment "The lexical or session scope within which this lease is valid." ;
  rdfs:domain <https://uor.foundation/state/ContextLease> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/state/groundedTriad>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "groundedTriad" ;
  rdfs:comment "The triadic coordinate of the datum carried in this grounded context: its (stratum, spectrum, address) bundle. Computed by the kernel at grounding time and immutable thereafter." ;
  rdfs:domain <https://uor.foundation/state/GroundedContext> ;
  rdfs:range <https://uor.foundation/schema/Triad> .

<https://uor.foundation/state/ExplicitReset>
  a owl:NamedIndividual , <https://uor.foundation/state/SessionBoundaryType> ;
  rdfs:label "ExplicitReset" ;
  rdfs:comment "The caller explicitly requested a context reset. All accumulated bindings are discarded." .

<https://uor.foundation/state/ConvergenceBoundary>
  a owl:NamedIndividual , <https://uor.foundation/state/SessionBoundaryType> ;
  rdfs:label "ConvergenceBoundary" ;
  rdfs:comment "The session resolver determined that no further queries can reduce the aggregate site deficit." .

<https://uor.foundation/state/ContradictionBoundary>
  a owl:NamedIndividual , <https://uor.foundation/state/SessionBoundaryType> ;
  rdfs:label "ContradictionBoundary" ;
  rdfs:comment "A new query produced a type contradiction with an accumulated binding. Context must reset before resolution can continue." .

<https://uor.foundation/state/Open>
  a owl:NamedIndividual , <https://uor.foundation/state/GroundingPhase> ;
  rdfs:label "Open" ;
  rdfs:comment "The context has σ = 0: no bindings accumulated, all sites are free. The initial phase of every session." .

<https://uor.foundation/state/PartialGrounding>
  a owl:NamedIndividual , <https://uor.foundation/state/GroundingPhase> ;
  rdfs:label "PartialGrounding" ;
  rdfs:comment "The context has 0 < σ < 1: some sites are pinned by accumulated bindings, but free sites remain. The accumulation phase." .

<https://uor.foundation/state/FullGrounding>
  a owl:NamedIndividual , <https://uor.foundation/state/GroundingPhase> ;
  rdfs:label "FullGrounding" ;
  rdfs:comment "The context has σ = 1: all sites are pinned, freeRank = 0. The ground state. All subsequent queries resolve in O(1) via SC_5." .

<https://uor.foundation/state/ground_state>
  a owl:NamedIndividual , <https://uor.foundation/state/GroundedContext> ;
  rdfs:label "ground_state" ;
  rdfs:comment "The canonical ground-state witness: a GroundedContext at σ = 1, freeRank = 0, T_ctx = 0, S = 0 (SC_4). Demonstrates that full saturation is achievable and O(1) resolution (SC_5) is realized." ;
  <https://uor.foundation/state/groundingDegree> "1"^^xsd:decimal ;
  <https://uor.foundation/state/contextTemperature> "0"^^xsd:decimal ;
  <https://uor.foundation/state/isGrounded> "true"^^xsd:boolean ;
  <https://uor.foundation/state/residualFreeCount> "0"^^xsd:integer ;
  <https://uor.foundation/state/groundingPhase> <https://uor.foundation/state/FullGrounding> .

# Namespace: reduction
<https://uor.foundation/reduction/>
  a owl:Ontology ;
  rdfs:label "UOR Euler Reduction" ;
  rdfs:comment "Sequential composition of the foundation's nine inter-algebra maps into a parameterized reduction pipeline. Defines stages, phase gates, rollback, and epochs." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/op/> ;
  owl:imports <https://uor.foundation/state/> ;
  owl:imports <https://uor.foundation/partition/> ;
  owl:imports <https://uor.foundation/resolver/> ;
  owl:imports <https://uor.foundation/morphism/> ;
  owl:imports <https://uor.foundation/observable/> ;
  owl:imports <https://uor.foundation/predicate/> ;
  owl:imports <https://uor.foundation/effect/> ;
  owl:imports <https://uor.foundation/schema/> ;
  owl:imports <https://uor.foundation/u/> ;
.

<https://uor.foundation/reduction/EulerReduction>
  a owl:Class ;
  rdfs:label "EulerReduction" ;
  rdfs:comment "The composite endofunctor ψ = ψ_9 ∘ … ∘ ψ_1, parameterized by Ω = e^{iπ/6}." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PhaseRotationScheduler>
  a owl:Class ;
  rdfs:label "PhaseRotationScheduler" ;
  rdfs:comment "Schedule Ω⁰, Ω¹, …, Ω⁵ assigning a phase angle to each stage of the reduction." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/TargetConvergenceAngle>
  a owl:Class ;
  rdfs:label "TargetConvergenceAngle" ;
  rdfs:comment "The angle at which the reduction terminates (default: π)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PhaseGateAttestation>
  a owl:Class ;
  rdfs:label "PhaseGateAttestation" ;
  rdfs:comment "Validation at each stage boundary checking that the accumulated phase angle matches the expected Ω^k." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ComplexConjugateRollback>
  a owl:Class ;
  rdfs:label "ComplexConjugateRollback" ;
  rdfs:comment "Recovery operation when a phase gate fails: z → z̄. Involutory: applying twice yields the original value." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ReductionStep>
  a owl:Class ;
  rdfs:label "ReductionStep" ;
  rdfs:comment "A named stage of the reduction. The standard reduction has six stages (Initialization through Convergence)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ReductionState>
  a owl:Class ;
  rdfs:label "ReductionState" ;
  rdfs:comment "State of reduction execution at a specific point, including the current stage, phase angle, and pinned mask." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ReductionRule>
  a owl:Class ;
  rdfs:label "ReductionRule" ;
  rdfs:comment "Guard-effect pair governing stage transitions in the reduction. The guard must be satisfied before the effect is applied." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/Epoch>
  a owl:Class ;
  rdfs:label "Epoch" ;
  rdfs:comment "Temporal segment of reduction execution. Each epoch represents one complete pass through the reduction stages." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/EpochBoundary>
  a owl:Class ;
  rdfs:label "EpochBoundary" ;
  rdfs:comment "Transition between epochs. Carries metadata about the epoch boundary crossing." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PredicateExpression>
  a owl:Class ;
  rdfs:label "PredicateExpression" ;
  rdfs:comment "A Boolean expression over the reduction state. The atomic guard unit." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/GuardExpression>
  a owl:Class ;
  rdfs:label "GuardExpression" ;
  rdfs:comment "A conjunction of PredicateExpressions that must hold for a transition to fire." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/TransitionEffect>
  a owl:Class ;
  rdfs:label "TransitionEffect" ;
  rdfs:comment "State changes applied when a transition fires. Contains PropertyBind steps." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PropertyBind>
  a owl:Class ;
  rdfs:label "PropertyBind" ;
  rdfs:comment "A single site pinning: target site + value." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ReductionAdvance>
  a owl:Class ;
  rdfs:label "ReductionAdvance" ;
  rdfs:comment "Advancement from one ReductionStep to the next." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ServiceWindow>
  a owl:Class ;
  rdfs:label "ServiceWindow" ;
  rdfs:comment "A sliding window over recent epochs providing BaseContext." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ReductionTransaction>
  a owl:Class ;
  rdfs:label "ReductionTransaction" ;
  rdfs:comment "An atomic group of state changes within the reduction." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PipelineSuccess>
  a owl:Class ;
  rdfs:label "PipelineSuccess" ;
  rdfs:comment "Successful termination (FullGrounding)." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PipelineFailureReason>
  a owl:Class ;
  rdfs:label "PipelineFailureReason" ;
  rdfs:comment "Typed failure: DispatchMiss, GroundingFailure, ConvergenceStall, etc." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/PreflightCheck>
  a owl:Class ;
  rdfs:label "PreflightCheck" ;
  rdfs:comment "A pre-execution validation: feasibility, dispatch coverage, coherence." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/FeasibilityResult>
  a owl:Class ;
  rdfs:label "FeasibilityResult" ;
  rdfs:comment "Result of a preflight check: feasibility witness or infeasibility witness." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/LeaseState>
  a owl:Class ;
  rdfs:label "LeaseState" ;
  rdfs:comment "Lifecycle of a partitioned context lease: Pending → Active → Released/Expired/Suspended." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ManagedLease>
  a owl:Class ;
  rdfs:label "ManagedLease" ;
  rdfs:comment "A context lease with lifecycle tracking." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/LeaseCheckpoint>
  a owl:Class ;
  rdfs:label "LeaseCheckpoint" ;
  rdfs:comment "Snapshot of lease state at a point in time." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/BackPressureSignal>
  a owl:Class ;
  rdfs:label "BackPressureSignal" ;
  rdfs:comment "Flow control when reduction produces faster than downstream can consume." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/DeferredQuerySet>
  a owl:Class ;
  rdfs:label "DeferredQuerySet" ;
  rdfs:comment "Queries postponed to a future epoch." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/SubleaseTransfer>
  a owl:Class ;
  rdfs:label "SubleaseTransfer" ;
  rdfs:comment "Transfer of a lease from one computation to another." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/ComparisonPredicate>
  a owl:Class ;
  rdfs:label "ComparisonPredicate" ;
  rdfs:comment "Predicate comparing a state field against a value." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/ConjunctionPredicate>
  a owl:Class ;
  rdfs:label "ConjunctionPredicate" ;
  rdfs:comment "Conjunction (AND) of multiple predicates." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/DisjunctionPredicate>
  a owl:Class ;
  rdfs:label "DisjunctionPredicate" ;
  rdfs:comment "Disjunction (OR) of multiple predicates." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/NegationPredicate>
  a owl:Class ;
  rdfs:label "NegationPredicate" ;
  rdfs:comment "Negation (NOT) of a single predicate." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/MembershipPredicate>
  a owl:Class ;
  rdfs:label "MembershipPredicate" ;
  rdfs:comment "Predicate testing membership of an element in a set." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/GroundingPredicate>
  a owl:Class ;
  rdfs:label "GroundingPredicate" ;
  rdfs:comment "Predicate testing whether grounding exceeds a threshold." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/SiteCoveragePredicate>
  a owl:Class ;
  rdfs:label "SiteCoveragePredicate" ;
  rdfs:comment "Predicate testing whether a site coverage target is met." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/EqualsPredicate>
  a owl:Class ;
  rdfs:label "EqualsPredicate" ;
  rdfs:comment "Predicate testing equality of two expressions." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/NonNullPredicate>
  a owl:Class ;
  rdfs:label "NonNullPredicate" ;
  rdfs:comment "Predicate testing that a field is non-null." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/QuerySubtypePredicate>
  a owl:Class ;
  rdfs:label "QuerySubtypePredicate" ;
  rdfs:comment "Predicate testing whether a query is a subtype of a given type." ;
  rdfs:subClassOf <https://uor.foundation/reduction/PredicateExpression> ;
.

<https://uor.foundation/reduction/CompileUnit>
  a owl:Class ;
  rdfs:label "CompileUnit" ;
  rdfs:comment "The typed input graph submitted to the reduction pipeline. Packages a root Term, target quantum level, verification domains, and thermodynamic budget. Stage 0 accepts exactly one CompileUnit and initializes the reduction state vector from it." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/FailureField>
  a owl:Class ;
  rdfs:label "FailureField" ;
  rdfs:comment "An ontology fact describing a single field on a reduction:PipelineFailureReason variant. The v0.2.1 Rust codegen walks FailureField individuals filtered by ofFailure to assemble the PipelineFailure enum's variant fields. Adding a new field to a failure variant requires only adding a new FailureField individual." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/SatBound>
  a owl:Class ;
  rdfs:label "SatBound" ;
  rdfs:comment "Declarative bound for SAT-fragment deciders. The v0.2.1 pipeline driver reads these individuals at codegen time to emit the bounded iterative Tarjan SCC (2-SAT) and unit propagation (Horn-SAT) implementations." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/TimingBound>
  a owl:Class ;
  rdfs:label "TimingBound" ;
  rdfs:comment "Declarative timing bound for reduction pipeline stages. Values in nanoseconds at the v0.2.1 reference hardware." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/reduction/phaseParameter>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "phaseParameter" ;
  rdfs:comment "The base phase parameter Ω for this reduction (e.g., e^{iπ/6})." ;
  rdfs:domain <https://uor.foundation/reduction/EulerReduction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/stageCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stageCount" ;
  rdfs:comment "The number of stages in this reduction." ;
  rdfs:domain <https://uor.foundation/reduction/EulerReduction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/convergenceAngle>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "convergenceAngle" ;
  rdfs:comment "The cumulative phase angle at which the reduction converges." ;
  rdfs:domain <https://uor.foundation/reduction/EulerReduction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/composedOfMaps>
  a owl:ObjectProperty ;
  rdfs:label "composedOfMaps" ;
  rdfs:comment "The ordered list of ψ-maps that compose this reduction." ;
  rdfs:domain <https://uor.foundation/reduction/EulerReduction> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/rotationSchedule>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "rotationSchedule" ;
  rdfs:comment "String representation of the rotation schedule Ω⁰, Ω¹, …, Ω⁵." ;
  rdfs:domain <https://uor.foundation/reduction/PhaseRotationScheduler> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/baseAngle>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "baseAngle" ;
  rdfs:comment "The base angle π/6 from which the schedule is derived." ;
  rdfs:domain <https://uor.foundation/reduction/PhaseRotationScheduler> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/targetAngle>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetAngle" ;
  rdfs:comment "The target convergence angle (default: π)." ;
  rdfs:domain <https://uor.foundation/reduction/TargetConvergenceAngle> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/gateStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "gateStage" ;
  rdfs:comment "The reduction stage at which this gate is applied." ;
  rdfs:domain <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/reduction/gateExpectedPhase>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "gateExpectedPhase" ;
  rdfs:comment "The expected phase angle Ω^k at this gate." ;
  rdfs:domain <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/gateResult>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "gateResult" ;
  rdfs:comment "Whether the phase gate check passed or failed." ;
  rdfs:domain <https://uor.foundation/reduction/PhaseGateAttestation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/reduction/rollbackTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rollbackTarget" ;
  rdfs:comment "The reduction stage to which execution rolls back on gate failure." ;
  rdfs:domain <https://uor.foundation/reduction/ComplexConjugateRollback> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/reduction/stageIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stageIndex" ;
  rdfs:comment "Zero-based index of this stage in the reduction." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/stageName>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "stageName" ;
  rdfs:comment "Human-readable name of this reduction stage." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/expectedPhase>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "expectedPhase" ;
  rdfs:comment "The expected phase angle Ω^k at this stage." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/entryGuard>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "entryGuard" ;
  rdfs:comment "A typed predicate evaluated on the current ReductionState. Must be satisfied to enter this stage." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <https://uor.foundation/predicate/StatePredicate> .

<https://uor.foundation/reduction/exitGuard>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "exitGuard" ;
  rdfs:comment "A typed predicate that must be satisfied before the reduction advances past this stage." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <https://uor.foundation/predicate/StatePredicate> .

<https://uor.foundation/reduction/stageEffect>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "stageEffect" ;
  rdfs:comment "The effect applied by this stage upon successful exit." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionStep> ;
  rdfs:range <https://uor.foundation/effect/Effect> .

<https://uor.foundation/reduction/currentStage>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "currentStage" ;
  rdfs:comment "The reduction stage at which execution is currently positioned." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionState> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/reduction/phaseAngle>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "phaseAngle" ;
  rdfs:comment "The accumulated phase angle at the current point." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/pinnedMask>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pinnedMask" ;
  rdfs:comment "Bit mask of sites that are pinned (resolved) at this point." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/freeRank>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "freeRank" ;
  rdfs:comment "The number of free (unresolved) sites at this point." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/transitionGuard>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transitionGuard" ;
  rdfs:comment "A typed GuardedTransition from predicate/ governing the stage transition." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionRule> ;
  rdfs:range <https://uor.foundation/predicate/GuardedTransition> .

<https://uor.foundation/reduction/transitionEffect>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transitionEffect" ;
  rdfs:comment "The effect applied when this transition fires." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionRule> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/transitionAdvance>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "transitionAdvance" ;
  rdfs:comment "Whether this transition advances to the next stage." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionRule> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/reduction/epochIndex>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "epochIndex" ;
  rdfs:comment "Zero-based index of this epoch in the reduction execution." ;
  rdfs:domain <https://uor.foundation/reduction/Epoch> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/epochDatum>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "epochDatum" ;
  rdfs:comment "Metadata or summary datum for this epoch." ;
  rdfs:domain <https://uor.foundation/reduction/Epoch> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/epochBoundaryType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "epochBoundaryType" ;
  rdfs:comment "The type of epoch boundary crossing (e.g., normal, forced, timeout)." ;
  rdfs:domain <https://uor.foundation/reduction/EpochBoundary> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/predicateField>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "predicateField" ;
  rdfs:comment "The state field this predicate tests." ;
  rdfs:domain <https://uor.foundation/reduction/PredicateExpression> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/predicateOperator>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "predicateOperator" ;
  rdfs:comment "The comparison operator (e.g., '=', '<', '>=')." ;
  rdfs:domain <https://uor.foundation/reduction/PredicateExpression> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/predicateValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "predicateValue" ;
  rdfs:comment "The value against which the field is compared." ;
  rdfs:domain <https://uor.foundation/reduction/PredicateExpression> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/guardPredicates>
  a owl:ObjectProperty ;
  rdfs:label "guardPredicates" ;
  rdfs:comment "The predicate expressions that compose this guard." ;
  rdfs:domain <https://uor.foundation/reduction/GuardExpression> ;
  rdfs:range <https://uor.foundation/reduction/PredicateExpression> .

<https://uor.foundation/reduction/effectBindings>
  a owl:ObjectProperty ;
  rdfs:label "effectBindings" ;
  rdfs:comment "The property bind steps applied by this effect." ;
  rdfs:domain <https://uor.foundation/reduction/TransitionEffect> ;
  rdfs:range <https://uor.foundation/reduction/PropertyBind> .

<https://uor.foundation/reduction/bindTarget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bindTarget" ;
  rdfs:comment "The target site identifier for this binding." ;
  rdfs:domain <https://uor.foundation/reduction/PropertyBind> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/bindValue>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "bindValue" ;
  rdfs:comment "The value to pin the target site to." ;
  rdfs:domain <https://uor.foundation/reduction/PropertyBind> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/advanceFrom>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "advanceFrom" ;
  rdfs:comment "The source stage of the advancement." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionAdvance> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/reduction/advanceTo>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "advanceTo" ;
  rdfs:comment "The target stage of the advancement." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionAdvance> ;
  rdfs:range <https://uor.foundation/reduction/ReductionStep> .

<https://uor.foundation/reduction/windowSize>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "windowSize" ;
  rdfs:comment "The number of recent epochs in this service window." ;
  rdfs:domain <https://uor.foundation/reduction/ServiceWindow> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/windowOffset>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "windowOffset" ;
  rdfs:comment "The starting epoch offset of this service window." ;
  rdfs:domain <https://uor.foundation/reduction/ServiceWindow> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/transactionPolicy>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "transactionPolicy" ;
  rdfs:comment "The execution policy for this transaction (e.g., AllOrNothing, BestEffort)." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionTransaction> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/transactionOutcome>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transactionOutcome" ;
  rdfs:comment "The outcome of this transaction (e.g., committed, rolled back)." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionTransaction> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/failureKind>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "failureKind" ;
  rdfs:comment "The kind of pipeline failure (e.g., DispatchMiss, ConvergenceStall)." ;
  rdfs:domain <https://uor.foundation/reduction/PipelineFailureReason> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/preflightKind>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "preflightKind" ;
  rdfs:comment "The kind of preflight check (e.g., feasibility, dispatch coverage)." ;
  rdfs:domain <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/preflightResult>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "preflightResult" ;
  rdfs:comment "The result of the preflight check (e.g., pass, fail)." ;
  rdfs:domain <https://uor.foundation/reduction/PreflightCheck> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/groundingReached>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "groundingReached" ;
  rdfs:comment "Whether full grounding was achieved." ;
  rdfs:domain <https://uor.foundation/reduction/PipelineSuccess> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/reduction/feasibilityKind>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "feasibilityKind" ;
  rdfs:comment "The kind of feasibility result (e.g., Feasible, Infeasible)." ;
  rdfs:domain <https://uor.foundation/reduction/FeasibilityResult> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/feasibilityWitness>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "feasibilityWitness" ;
  rdfs:comment "The witness justifying the feasibility or infeasibility result." ;
  rdfs:domain <https://uor.foundation/reduction/FeasibilityResult> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/leasePhase>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leasePhase" ;
  rdfs:comment "The lifecycle phase of a lease (e.g., Pending, Active, Released)." ;
  rdfs:domain <https://uor.foundation/reduction/LeaseState> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/managedLeaseId>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "managedLeaseId" ;
  rdfs:comment "Unique identifier for this managed lease." ;
  rdfs:domain <https://uor.foundation/reduction/ManagedLease> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/leaseLifecycle>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseLifecycle" ;
  rdfs:comment "The current lifecycle state of this managed lease." ;
  rdfs:domain <https://uor.foundation/reduction/ManagedLease> ;
  rdfs:range <https://uor.foundation/reduction/LeaseState> .

<https://uor.foundation/reduction/checkpointEpoch>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "checkpointEpoch" ;
  rdfs:comment "The epoch index at which this checkpoint was taken." ;
  rdfs:domain <https://uor.foundation/reduction/LeaseCheckpoint> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/checkpointState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "checkpointState" ;
  rdfs:comment "The reduction state captured at this checkpoint." ;
  rdfs:domain <https://uor.foundation/reduction/LeaseCheckpoint> ;
  rdfs:range <https://uor.foundation/reduction/ReductionState> .

<https://uor.foundation/reduction/pressureLevel>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pressureLevel" ;
  rdfs:comment "The current back-pressure level (e.g., Low, Medium, High)." ;
  rdfs:domain <https://uor.foundation/reduction/BackPressureSignal> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/reduction/pressureThreshold>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "pressureThreshold" ;
  rdfs:comment "The threshold at which back-pressure activates." ;
  rdfs:domain <https://uor.foundation/reduction/BackPressureSignal> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#decimal> .

<https://uor.foundation/reduction/deferredCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "deferredCount" ;
  rdfs:comment "The number of queries in this deferred set." ;
  rdfs:domain <https://uor.foundation/reduction/DeferredQuerySet> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/deferralEpoch>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "deferralEpoch" ;
  rdfs:comment "The epoch in which these queries were deferred." ;
  rdfs:domain <https://uor.foundation/reduction/DeferredQuerySet> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/sourceLeaseRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "sourceLeaseRef" ;
  rdfs:comment "The lease being transferred from." ;
  rdfs:domain <https://uor.foundation/reduction/SubleaseTransfer> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/targetLeaseRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "targetLeaseRef" ;
  rdfs:comment "The lease being transferred to." ;
  rdfs:domain <https://uor.foundation/reduction/SubleaseTransfer> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/transferredBudget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "transferredBudget" ;
  rdfs:comment "The site budget transferred between leases." ;
  rdfs:domain <https://uor.foundation/reduction/SubleaseTransfer> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/transferCompleted>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "transferCompleted" ;
  rdfs:comment "Whether the sublease transfer has been completed." ;
  rdfs:domain <https://uor.foundation/reduction/SubleaseTransfer> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/reduction/comparisonField>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "comparisonField" ;
  rdfs:comment "The state field tested by this comparison predicate." ;
  rdfs:domain <https://uor.foundation/reduction/ComparisonPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/comparisonOperator>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "comparisonOperator" ;
  rdfs:comment "The comparison operator (e.g., '=', '<', '>=')." ;
  rdfs:domain <https://uor.foundation/reduction/ComparisonPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/comparisonValue>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "comparisonValue" ;
  rdfs:comment "The value against which the comparison is made." ;
  rdfs:domain <https://uor.foundation/reduction/ComparisonPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/conjuncts>
  a owl:ObjectProperty ;
  rdfs:label "conjuncts" ;
  rdfs:comment "A conjunct predicate in a conjunction." ;
  rdfs:domain <https://uor.foundation/reduction/ConjunctionPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/disjuncts>
  a owl:ObjectProperty ;
  rdfs:label "disjuncts" ;
  rdfs:comment "A disjunct predicate in a disjunction." ;
  rdfs:domain <https://uor.foundation/reduction/DisjunctionPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/negatedPredicate>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "negatedPredicate" ;
  rdfs:comment "The predicate being negated." ;
  rdfs:domain <https://uor.foundation/reduction/NegationPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/membershipSet>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "membershipSet" ;
  rdfs:comment "The set against which membership is tested." ;
  rdfs:domain <https://uor.foundation/reduction/MembershipPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/membershipElement>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "membershipElement" ;
  rdfs:comment "The element being tested for set membership." ;
  rdfs:domain <https://uor.foundation/reduction/MembershipPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/groundingThreshold>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "groundingThreshold" ;
  rdfs:comment "The grounding threshold above which the predicate holds." ;
  rdfs:domain <https://uor.foundation/reduction/GroundingPredicate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/coverageTarget>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "coverageTarget" ;
  rdfs:comment "The site coverage target expression." ;
  rdfs:domain <https://uor.foundation/reduction/SiteCoveragePredicate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/equalityLeft>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "equalityLeft" ;
  rdfs:comment "The left-hand side of an equality test." ;
  rdfs:domain <https://uor.foundation/reduction/EqualsPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/equalityRight>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "equalityRight" ;
  rdfs:comment "The right-hand side of an equality test." ;
  rdfs:domain <https://uor.foundation/reduction/EqualsPredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/nonNullField>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "nonNullField" ;
  rdfs:comment "The field that must be non-null." ;
  rdfs:domain <https://uor.foundation/reduction/NonNullPredicate> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/reduction/queryTypeRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "queryTypeRef" ;
  rdfs:comment "The query type reference for subtype testing." ;
  rdfs:domain <https://uor.foundation/reduction/QuerySubtypePredicate> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/siteState>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "siteState" ;
  rdfs:comment "The site state descriptor within a reduction state." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionState> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/transactionScope>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transactionScope" ;
  rdfs:comment "The scope of sites affected by this transaction." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionTransaction> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/transactionStatus>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "transactionStatus" ;
  rdfs:comment "Current status of this transaction (e.g., pending, committed)." ;
  rdfs:domain <https://uor.foundation/reduction/ReductionTransaction> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/reduction/baseContextRef>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "baseContextRef" ;
  rdfs:comment "Reference to the base context provided by this service window." ;
