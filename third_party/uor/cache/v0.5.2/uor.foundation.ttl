<https://uor.foundation/op/MC_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "MC_1" ;
  rdfs:comment "Lease partition conserves total budget: the sum of freeRank over all leases equals the SharedContext freeRank." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_MC_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_MC_1_rhs> ;
