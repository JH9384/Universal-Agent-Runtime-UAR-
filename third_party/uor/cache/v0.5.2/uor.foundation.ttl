<https://uor.foundation/op/GL_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GL_2" ;
  rdfs:comment "r = complement of upper adjoint image. The residual freedom is what the type closure does not reach." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GL_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GL_2_rhs> ;
