  rdfs:label "prf_AR_5_step" ;
  rdfs:comment "Inductive step for AR_5: if greedy vs adiabatic bound holds at Q_k, it holds at Q_{k+1} by QLS_5 (universal identity preservation under quantum lift)." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/AR_5> ;
