  <https://uor.foundation/schema/variableName> "BoundaryEffect e" .

<https://uor.foundation/schema/term_IH_1_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_1_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "InhabitanceCertificate(T).verified" .

<https://uor.foundation/schema/term_IH_1_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_1_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "carrier(T) ≠ ∅" .

<https://uor.foundation/schema/term_IH_1_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_IH_1_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "T : type:ConstrainedType" .

<https://uor.foundation/schema/term_IH_2a_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_2a_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "cost(TwoSatDecider, T)" .

<https://uor.foundation/schema/term_IH_2a_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_2a_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "O(n + m)" .

<https://uor.foundation/schema/term_IH_2a_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_IH_2a_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "T : type:ConstrainedType | Is2SatShape(T)" .

<https://uor.foundation/schema/term_IH_2b_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_2b_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "cost(HornSatDecider, T)" .

<https://uor.foundation/schema/term_IH_2b_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_2b_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "O(n + m)" .

<https://uor.foundation/schema/term_IH_2b_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_IH_2b_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "T : type:ConstrainedType | IsHornShape(T)" .

<https://uor.foundation/schema/term_IH_3_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_3_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "carrier(reduce(T))" .

<https://uor.foundation/schema/term_IH_3_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_IH_3_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "carrier(T)" .

<https://uor.foundation/schema/term_IH_3_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_IH_3_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "T : type:ConstrainedType" .

<https://uor.foundation/schema/term_boundarySquaredZero_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_boundarySquaredZero_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "∂_k(∂_{k+1}(c))" .

<https://uor.foundation/schema/term_boundarySquaredZero_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_boundarySquaredZero_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "0" .

<https://uor.foundation/schema/term_boundarySquaredZero_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_boundarySquaredZero_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "c ∈ C_{k+1}" .

<https://uor.foundation/schema/term_psi_4_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_psi_4_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "β_k(K)" .

<https://uor.foundation/schema/term_psi_4_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_psi_4_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "rank(H_k(K))" .

<https://uor.foundation/schema/term_psi_4_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_psi_4_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "simplicial complex K" .

<https://uor.foundation/schema/term_indexBridge_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_indexBridge_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "χ(K)" .

<https://uor.foundation/schema/term_indexBridge_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_indexBridge_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "Σ_k (-1)^k β_k" .

<https://uor.foundation/schema/term_indexBridge_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_indexBridge_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "finite simplicial complex K" .

<https://uor.foundation/schema/term_coboundarySquaredZero_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_coboundarySquaredZero_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "δ^{k+1}(δ^k(f))" .

<https://uor.foundation/schema/term_coboundarySquaredZero_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_coboundarySquaredZero_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "0" .

<https://uor.foundation/schema/term_coboundarySquaredZero_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_coboundarySquaredZero_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "f ∈ C^k" .

<https://uor.foundation/schema/term_deRhamDuality_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_deRhamDuality_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "H^k(K; R)" .

<https://uor.foundation/schema/term_deRhamDuality_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_deRhamDuality_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "Hom(H_k(K), R)" .

<https://uor.foundation/schema/term_deRhamDuality_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_deRhamDuality_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "simplicial complex K, ring R" .

<https://uor.foundation/schema/term_sheafCohomologyBridge_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_sheafCohomologyBridge_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "H^k(K; F_R)" .

<https://uor.foundation/schema/term_sheafCohomologyBridge_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_sheafCohomologyBridge_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "H^k(K; R)" .

<https://uor.foundation/schema/term_sheafCohomologyBridge_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_sheafCohomologyBridge_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "constant sheaf F_R over K" .

<https://uor.foundation/schema/term_localGlobalPrinciple_lhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_localGlobalPrinciple_lhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "H^1(K; F) = 0" .

<https://uor.foundation/schema/term_localGlobalPrinciple_rhs>
  a owl:NamedIndividual , <https://uor.foundation/schema/LiteralExpression> ;
  rdfs:label "term_localGlobalPrinciple_rhs" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/literalValue> "all local sections glue" .

<https://uor.foundation/schema/term_localGlobalPrinciple_forAll>
  a owl:NamedIndividual , <https://uor.foundation/schema/ForAllDeclaration> ;
  rdfs:label "term_localGlobalPrinciple_forAll" ;
  rdfs:comment "" ;
  <https://uor.foundation/schema/variableName> "sheaf F over K" .

# Namespace: op
<https://uor.foundation/op/>
  a owl:Ontology ;
  rdfs:label "UOR Operations" ;
  rdfs:comment "Ring operations, involutions, algebraic identities, and the dihedral symmetry group D_{2^n} generated by neg and bnot." ;
  uor:space "kernel" ;
  owl:imports <https://uor.foundation/schema/> ;
.

<https://uor.foundation/op/Operation>
  a owl:Class ;
  rdfs:label "Operation" ;
  rdfs:comment "An operation on the ring Z/(2^n)Z. The root class for all UOR kernel operations." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/UnaryOp>
  a owl:Class ;
  rdfs:label "UnaryOp" ;
  rdfs:comment "A unary operation on the ring: takes one datum and produces one datum." ;
  rdfs:subClassOf <https://uor.foundation/op/Operation> ;
.

<https://uor.foundation/op/BinaryOp>
  a owl:Class ;
  rdfs:label "BinaryOp" ;
  rdfs:comment "A binary operation on the ring: takes two datums and produces one datum." ;
  rdfs:subClassOf <https://uor.foundation/op/Operation> ;
.

<https://uor.foundation/op/Involution>
  a owl:Class ;
  rdfs:label "Involution" ;
  rdfs:comment "A unary operation f such that f(f(x)) = x for all x in R_n. The two UOR involutions are neg (ring reflection) and bnot (hypercube reflection)." ;
  rdfs:subClassOf <https://uor.foundation/op/UnaryOp> ;
.

<https://uor.foundation/op/Identity>
  a owl:Class ;
  rdfs:label "Identity" ;
  rdfs:comment "An algebraic identity: a statement that two expressions are equal for all inputs. The critical identity is neg(bnot(x)) = succ(x) for all x in R_n." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/Group>
  a owl:Class ;
  rdfs:label "Group" ;
  rdfs:comment "A group: a set with an associative binary operation, an identity element, and inverses for every element." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/DihedralGroup>
  a owl:Class ;
  rdfs:label "DihedralGroup" ;
  rdfs:comment "The dihedral group D_{2^n} of order 2^(n+1), generated by the ring reflection (neg) and the hypercube reflection (bnot). This group governs the symmetry of the UOR type space." ;
  rdfs:subClassOf <https://uor.foundation/op/Group> ;
.

<https://uor.foundation/op/VerificationDomain>
  a owl:Class ;
  rdfs:label "VerificationDomain" ;
  rdfs:comment "A named mathematical discipline through which an algebraic identity is established and grounded. Every op:Identity individual references at least one VerificationDomain via op:verificationDomain. The nine canonical domain individuals are kernel-level constants defined in op/." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/GeometricCharacter>
  a owl:Class ;
  rdfs:label "GeometricCharacter" ;
  rdfs:comment "The geometric role of a ring operation in the UOR dual-geometry (ring + hypercube). Every op:Operation individual references exactly one GeometricCharacter via op:hasGeometricCharacter. The nine canonical individuals correspond to the action types of the dihedral group D_{2^n}." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/WittLevelBinding>
  a owl:Class ;
  rdfs:label "WittLevelBinding" ;
  rdfs:comment "A record linking an op:Identity individual to a specific quantum level at which it has been verified. Non-functional: one WittLevelBinding per (Identity, WittLevel) pair verified." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/QuantumThermodynamicDomain>
  a owl:Class ;
  rdfs:label "QuantumThermodynamicDomain" ;
  rdfs:comment "A verification domain at the intersection of quantum superposition and classical thermodynamics. Identities in this domain require both SuperpositionDomain and Thermodynamic reasoning simultaneously." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/ValidityScopeKind>
  a owl:Class ;
  rdfs:label "ValidityScopeKind" ;
  rdfs:comment "Root class for validity scope individuals. Instances are the four named scope kinds: Universal, ParametricLower, ParametricRange, and LevelSpecific." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/ComposedOperation>
  a owl:Class ;
  rdfs:label "ComposedOperation" ;
  rdfs:comment "An operation formed by composing ring operations, witnessed by op:composedOf and morphism/CompositionLaw." ;
  rdfs:subClassOf <https://uor.foundation/op/Operation> ;
  rdfs:subClassOf <https://uor.foundation/morphism/Composition> ;
.

<https://uor.foundation/op/DispatchOperation>
  a owl:Class ;
  rdfs:label "DispatchOperation" ;
  rdfs:comment "δ: Query × ResolverRegistry → Resolver. Non-commutative, non-associative, arity 2." ;
  rdfs:subClassOf <https://uor.foundation/op/ComposedOperation> ;
.

<https://uor.foundation/op/InferenceOperation>
  a owl:Class ;
  rdfs:label "InferenceOperation" ;
  rdfs:comment "ι = P ∘ Π ∘ G (the φ-pipeline composed). Non-commutative, non-associative, arity 2." ;
  rdfs:subClassOf <https://uor.foundation/op/ComposedOperation> ;
.

<https://uor.foundation/op/AccumulationOperation>
  a owl:Class ;
  rdfs:label "AccumulationOperation" ;
  rdfs:comment "α: Binding × Context → Context. Non-commutative, associative at convergence (SR_10), arity 2." ;
  rdfs:subClassOf <https://uor.foundation/op/ComposedOperation> ;
.

<https://uor.foundation/op/LeasePartitionOperation>
  a owl:Class ;
  rdfs:label "LeasePartitionOperation" ;
  rdfs:comment "λ: SharedContext × ℕ → ContextLease^k. Non-commutative, non-associative, arity 2." ;
  rdfs:subClassOf <https://uor.foundation/op/ComposedOperation> ;
.

<https://uor.foundation/op/SessionCompositionOperation>
  a owl:Class ;
  rdfs:label "SessionCompositionOperation" ;
  rdfs:comment "κ: Session × Session → Session. Commutative (disjoint leases), associative (SR_8), arity 2." ;
  rdfs:subClassOf <https://uor.foundation/op/ComposedOperation> ;
.

<https://uor.foundation/op/GroupPresentation>
  a owl:Class ;
  rdfs:label "GroupPresentation" ;
  rdfs:comment "A structured group presentation: generators and relations as typed data rather than prose strings." ;
  rdfs:subClassOf <http://www.w3.org/2002/07/owl#Thing> ;
.

<https://uor.foundation/op/arity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "arity" ;
  rdfs:comment "The number of arguments this operation takes. 1 for unary operations, 2 for binary operations." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/op/hasGeometricCharacter>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "hasGeometricCharacter" ;
  rdfs:comment "The geometric role of this operation in the UOR ring and hypercube geometry. Functional: each operation has exactly one geometric character." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <https://uor.foundation/op/GeometricCharacter> .

<https://uor.foundation/op/commutative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "commutative" ;
  rdfs:comment "Whether this binary operation satisfies op(x,y) = op(y,x) for all x, y in R_n." ;
  rdfs:domain <https://uor.foundation/op/BinaryOp> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/associative>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "associative" ;
  rdfs:comment "Whether this binary operation satisfies op(op(x,y),z) = op(x,op(y,z)) for all x, y, z in R_n." ;
  rdfs:domain <https://uor.foundation/op/BinaryOp> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/identity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "identity" ;
  rdfs:comment "The identity element of this binary operation: the value e such that op(x, e) = op(e, x) = x for all x in R_n." ;
  rdfs:domain <https://uor.foundation/op/BinaryOp> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#integer> .

<https://uor.foundation/op/inverse>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inverse" ;
  rdfs:comment "The inverse operation: the operation inv_op such that op(x, inv_op(x)) = e for all x, where e is the identity." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/composedOf>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "composedOf" ;
  rdfs:comment "Ordered list of operations this operation is composed from. Uses rdf:List to preserve application order (first element applied innermost). E.g., succ = neg ∘ bnot is encoded as [op:neg, op:bnot] meaning neg applied to the result of bnot." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <http://www.w3.org/1999/02/22-rdf-syntax-ns#List> .

<https://uor.foundation/op/lhs>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "lhs" ;
  rdfs:comment "The left-hand side of an algebraic identity as a typed AST node (schema:TermExpression)." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/op/rhs>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "rhs" ;
  rdfs:comment "The right-hand side of an algebraic identity as a typed AST node (schema:TermExpression)." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/op/forAll>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "forAll" ;
  rdfs:comment "The quantifier scope: a typed declaration of the variable(s) over which this identity holds." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/schema/ForAllDeclaration> .

<https://uor.foundation/op/generatedBy>
  a owl:ObjectProperty ;
  rdfs:label "generatedBy" ;
  rdfs:comment "An operation that generates this group. The dihedral group D_{2^n} is generated by op:neg and op:bnot." ;
  rdfs:domain <https://uor.foundation/op/Group> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/order>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "order" ;
  rdfs:comment "The number of elements in the group. For D_{2^n}, the order is 2^(n+1)." ;
  rdfs:domain <https://uor.foundation/op/Group> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#positiveInteger> .

<https://uor.foundation/op/presentation>
  a owl:AnnotationProperty ;
  rdfs:label "presentation" ;
  rdfs:comment "The group presentation (generators and relations). Example: ⟨r, s | r^{2^n} = s² = e, srs = r⁻¹⟩" ;
  rdfs:domain <https://uor.foundation/op/Group> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/op/verificationDomain>
  a owl:ObjectProperty ;
  rdfs:label "verificationDomain" ;
  rdfs:comment "The mathematical discipline(s) through which this identity is established. Range is op:VerificationDomain. Non-functional: composite identities (e.g. IT_7a–IT_7d) reference multiple domain individuals." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/op/VerificationDomain> .

<https://uor.foundation/op/verifiedAtLevel>
  a owl:ObjectProperty ;
  rdfs:label "verifiedAtLevel" ;
  rdfs:comment "Links an Identity individual to a WittLevelBinding attesting verification at a specific quantum level. Non-functional: one binding per (Identity, WittLevel) pair." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/op/WittLevelBinding> .

<https://uor.foundation/op/bindingLevel>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "bindingLevel" ;
  rdfs:comment "The quantum level at which this WittLevelBinding was verified." ;
  rdfs:domain <https://uor.foundation/op/WittLevelBinding> ;
  rdfs:range <https://uor.foundation/schema/WittLevel> .

<https://uor.foundation/op/universallyValid>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "universallyValid" ;
  rdfs:comment "True iff this identity holds for all n ≥ 1 (proved symbolically by induction on the ring axioms, not just exhaustively at Q0). Identities that reference 8-bit-specific constants receive universallyValid = false." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/enumVariant>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "enumVariant" ;
  rdfs:comment "The canonical Rust enum variant name corresponding to this VerificationDomain individual. Provides formal alignment between the OWL individual and the generated Rust enum." ;
  rdfs:domain <https://uor.foundation/op/VerificationDomain> ;
  rdfs:range <https://uor.foundation/op/VerificationDomain> .

<https://uor.foundation/op/validityKind>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "validityKind" ;
  rdfs:comment "The structured validity scope of this identity, replacing the binary universallyValid flag. Required on all new Identity individuals." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <https://uor.foundation/op/ValidityScopeKind> .

<https://uor.foundation/op/validKMin>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "validKMin" ;
  rdfs:comment "Minimum quantum level index k for ParametricLower and ParametricRange scopes." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/op/validKMax>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "validKMax" ;
  rdfs:comment "Maximum quantum level index k (inclusive) for ParametricRange scope." ;
  rdfs:domain <https://uor.foundation/op/Identity> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/op/composedOfOps>
  a owl:ObjectProperty ;
  rdfs:label "composedOfOps" ;
  rdfs:comment "References a constituent operation of a ComposedOperation. Non-functional: a composed operation may reference multiple constituent operations." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/operatorSignature>
  a owl:AnnotationProperty ;
  rdfs:label "operatorSignature" ;
  rdfs:comment "Human-readable type signature describing the domain and codomain of a composed operation (e.g., 'Query × Registry → Resolver')." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/op/dispatchSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchSource" ;
  rdfs:comment "The source selector for a dispatch operation." ;
  rdfs:domain <https://uor.foundation/op/DispatchOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/dispatchTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "dispatchTarget" ;
  rdfs:comment "The target resolver for a dispatch operation." ;
  rdfs:domain <https://uor.foundation/op/DispatchOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/inferenceSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inferenceSource" ;
  rdfs:comment "The source data for an inference operation." ;
  rdfs:domain <https://uor.foundation/op/InferenceOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/inferenceTarget>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inferenceTarget" ;
  rdfs:comment "The target type for an inference operation." ;
  rdfs:domain <https://uor.foundation/op/InferenceOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/inferencePipeline>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "inferencePipeline" ;
  rdfs:comment "The pipeline through which inference is performed." ;
  rdfs:domain <https://uor.foundation/op/InferenceOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/accumulationBase>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "accumulationBase" ;
  rdfs:comment "The base value for an accumulation operation." ;
  rdfs:domain <https://uor.foundation/op/AccumulationOperation> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/op/accumulationBinding>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "accumulationBinding" ;
  rdfs:comment "The binding accumulator for an accumulation operation." ;
  rdfs:domain <https://uor.foundation/op/AccumulationOperation> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/op/leaseSource>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseSource" ;
  rdfs:comment "The source context for a lease partition operation." ;
  rdfs:domain <https://uor.foundation/op/LeasePartitionOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/leaseFactor>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "leaseFactor" ;
  rdfs:comment "The partition factor for a lease partition operation." ;
  rdfs:domain <https://uor.foundation/op/LeasePartitionOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/leasePartitionCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "leasePartitionCount" ;
  rdfs:comment "The number of partitions in a lease partition operation." ;
  rdfs:domain <https://uor.foundation/op/LeasePartitionOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/op/compositionLeftSession>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionLeftSession" ;
  rdfs:comment "The left session in a session composition operation." ;
  rdfs:domain <https://uor.foundation/op/SessionCompositionOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/compositionRightSession>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "compositionRightSession" ;
  rdfs:comment "The right session in a session composition operation." ;
  rdfs:domain <https://uor.foundation/op/SessionCompositionOperation> ;
  rdfs:range <https://uor.foundation/op/Operation> .

<https://uor.foundation/op/operatorDomainType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operatorDomainType" ;
  rdfs:comment "The domain type of a composed operation." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/op/operatorRangeType>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "operatorRangeType" ;
  rdfs:comment "The range type of a composed operation." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <https://uor.foundation/type/TypeDefinition> .

<https://uor.foundation/op/operatorComplexity>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "operatorComplexity" ;
  rdfs:comment "The computational complexity class of a composed operation." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#string> .

<https://uor.foundation/op/operatorIdempotent>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "operatorIdempotent" ;
  rdfs:comment "Whether this composed operation is idempotent." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/composedOperatorCount>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "composedOperatorCount" ;
  rdfs:comment "The number of constituent operations in a composed operation." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#nonNegativeInteger> .

<https://uor.foundation/op/isInvolutory>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isInvolutory" ;
  rdfs:comment "Whether applying this operation twice yields the identity." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/convergenceGuarantee>
  a owl:ObjectProperty , owl:FunctionalProperty ;
  rdfs:label "convergenceGuarantee" ;
  rdfs:comment "Description of the convergence guarantee for this operation." ;
  rdfs:domain <https://uor.foundation/op/ComposedOperation> ;
  rdfs:range <https://uor.foundation/schema/TermExpression> .

<https://uor.foundation/op/isRingOp>
  a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "isRingOp" ;
  rdfs:comment "True iff this Operation participates in the Z/(2^n)Z ring-arithmetic vocabulary. Annotation drives the Lean RingOp class generation in UOR/Enforcement.lean." ;
  rdfs:domain <https://uor.foundation/op/Operation> ;
  rdfs:range <http://www.w3.org/2001/XMLSchema#boolean> .

<https://uor.foundation/op/Enumerative>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Enumerative" ;
  rdfs:comment "Established by exhaustive traversal of R_n. Valid for all identities where the ring is finite." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Enumerative> .

<https://uor.foundation/op/Algebraic>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Algebraic" ;
  rdfs:comment "Established by equational reasoning from ring or group axioms. Covers derivations via associativity, commutativity, inverse laws, and group presentations." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/Geometric>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Geometric" ;
  rdfs:comment "Established by isometry, symmetry, or GeometricCharacter arguments. Covers dihedral actions, fixed-point analysis, automorphism groups, and affine embeddings." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Geometric> .

<https://uor.foundation/op/Analytical>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Analytical" ;
  rdfs:comment "Established via discrete differential calculus or metric analysis. Covers ring/Hamming derivatives (DC_), metric divergence (AM_), and adiabatic scheduling (AR_)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Analytical> .

<https://uor.foundation/op/Thermodynamic>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Thermodynamic" ;
  rdfs:comment "Established via entropy, Landauer bounds, or Boltzmann distributions. Covers site entropy (TH_), reversible computation (RC_), and phase transitions." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Thermodynamic> .

<https://uor.foundation/op/Topological>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Topological" ;
  rdfs:comment "Established via simplicial homology, cohomology, or constraint nerve analysis. Covers homological algebra (HA_) and the ψ-pipeline base chain ψ_1..ψ_6 (constraint nerve construction, chain functor, homology, Betti extraction, dualization, cohomology)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Topological> .

<https://uor.foundation/op/Pipeline>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "Pipeline" ;
  rdfs:comment "Established by the inter-algebra map structure of the resolution pipeline. Covers φ-maps (phi_1–phi_6) and the ψ-pipeline tower ψ_7..ψ_9 (Postnikov truncation, homotopy group extraction, k-invariant computation). The earlier ψ_1..ψ_6 chain (constraint nerve → simplicial homology) is established under op:Topological." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Pipeline> .

<https://uor.foundation/op/IndexTheoretic>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "IndexTheoretic" ;
  rdfs:comment "Established by the composition of Analytical and Topological reasoning. The only domain requiring multiple op:verificationDomain assertions. Covers the UOR Index Theorem (IT_7a–IT_7d)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/IndexTheoretic> .

<https://uor.foundation/op/SuperpositionDomain>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "SuperpositionDomain" ;
  rdfs:comment "Established by superposition analysis of site states. Covers identities involving superposed (non-classical) site assignments where sites carry complex amplitudes." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/SuperpositionDomain> .

<https://uor.foundation/op/QuantumThermodynamic>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "QuantumThermodynamic" ;
  rdfs:comment "Established by the intersection of quantum superposition analysis and classical thermodynamic reasoning. Covers identities relating von Neumann entropy of superposed states to Landauer costs of projective collapse (QM_)." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/QuantumThermodynamic> .

<https://uor.foundation/op/ArithmeticValuation>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "ArithmeticValuation" ;
  rdfs:comment "Established by number-theoretic valuation arguments including p-adic absolute values, the Ostrowski product formula, and the arithmetic of global fields. Covers identities grounded in the product formula |x|_p · |x|_∞ = 1 and the Witt–Ostrowski derivation chain." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/ArithmeticValuation> .

<https://uor.foundation/op/ComposedAlgebraic>
  a owl:NamedIndividual , <https://uor.foundation/op/VerificationDomain> ;
  rdfs:label "ComposedAlgebraic" ;
  rdfs:comment "Verification domain for composed operation identities — algebraic properties of operator compositions including dispatch, inference, accumulation, lease, and session composition operations." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/ComposedAlgebraic> .

<https://uor.foundation/op/Universal>
  a owl:NamedIndividual , <https://uor.foundation/op/ValidityScopeKind> ;
  rdfs:label "Universal" ;
  rdfs:comment "Holds for all k in N. No minimum k constraint." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/ParametricLower>
  a owl:NamedIndividual , <https://uor.foundation/op/ValidityScopeKind> ;
  rdfs:label "ParametricLower" ;
  rdfs:comment "Holds for all k >= k_min, where k_min is given by validKMin." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/ParametricLower> .

<https://uor.foundation/op/ParametricRange>
  a owl:NamedIndividual , <https://uor.foundation/op/ValidityScopeKind> ;
  rdfs:label "ParametricRange" ;
  rdfs:comment "Holds for k_min <= k <= k_max. Both validKMin and validKMax required." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/ParametricRange> .

<https://uor.foundation/op/LevelSpecific>
  a owl:NamedIndividual , <https://uor.foundation/op/ValidityScopeKind> ;
  rdfs:label "LevelSpecific" ;
  rdfs:comment "Holds only at exactly one level, given by a WittLevelBinding." ;
  <https://uor.foundation/op/enumVariant> <https://uor.foundation/op/LevelSpecific> .

<https://uor.foundation/op/RingReflection>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "RingReflection" ;
  rdfs:comment "Reflection through the origin of the additive ring: neg(x) = -x mod 2^n. One of the two generators of D_{2^n}." .

<https://uor.foundation/op/HypercubeReflection>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "HypercubeReflection" ;
  rdfs:comment "Reflection through the centre of the hypercube: bnot(x) = (2^n-1) ⊕ x. The second generator of D_{2^n}." .

<https://uor.foundation/op/Rotation>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "Rotation" ;
  rdfs:comment "Rotation by one step: succ(x) = (x+1) mod 2^n. The composition of the two reflections." .

<https://uor.foundation/op/RotationInverse>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "RotationInverse" ;
  rdfs:comment "Rotation by one step in the reverse direction: pred(x) = (x-1) mod 2^n." .

<https://uor.foundation/op/Translation>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "Translation" ;
  rdfs:comment "Translation along the ring axis: add(x,y), sub(x,y). Preserves Hamming distance locally." .

<https://uor.foundation/op/Scaling>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "Scaling" ;
  rdfs:comment "Scaling along the ring axis: mul(x,y) = (x×y) mod 2^n." .

<https://uor.foundation/op/HypercubeTranslation>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "HypercubeTranslation" ;
  rdfs:comment "Translation along the hypercube axis: xor(x,y) = x ⊕ y. Preserves ring distance locally." .

<https://uor.foundation/op/HypercubeProjection>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "HypercubeProjection" ;
  rdfs:comment "Projection onto a hypercube face: and(x,y) = x ∧ y. Idempotent; collapses dimensions." .

<https://uor.foundation/op/HypercubeJoin>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "HypercubeJoin" ;
  rdfs:comment "Join on the hypercube lattice: or(x,y) = x ∨ y. Idempotent; dual to projection." .

<https://uor.foundation/op/Quotient>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "Quotient" ;
  rdfs:comment "Euclidean quotient along the ring axis: div(a,b) — the structural dual of Scaling. Geometric character of `op:div` per ADR-053." .

<https://uor.foundation/op/Remainder>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "Remainder" ;
  rdfs:comment "Euclidean remainder along the ring axis: mod(a,b). Complement of Quotient — together they realize the divmod fold-rule. Geometric character of `op:mod` per ADR-053." .

<https://uor.foundation/op/IteratedScaling>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "IteratedScaling" ;
  rdfs:comment "Iterated multiplicative scaling along the ring axis: pow(base, exp) = base^exp mod 2^n. Extends the multiplicative Scaling axis via square-and-multiply iteration. Geometric character of `op:pow` per ADR-053." .

<https://uor.foundation/op/ConstraintSelection>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "ConstraintSelection" ;
  rdfs:comment "Geometric character of dispatch: constraint-guided selection over the resolver registry lattice." .

<https://uor.foundation/op/ResolutionTraversal>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "ResolutionTraversal" ;
  rdfs:comment "Geometric character of inference: traversal through the φ-pipeline resolution graph P ∘ Π ∘ G." .

<https://uor.foundation/op/SiteBinding>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "SiteBinding" ;
  rdfs:comment "Geometric character of accumulation: progressive pinning of site states in the context lattice." .

<https://uor.foundation/op/SitePartition>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "SitePartition" ;
  rdfs:comment "Geometric character of lease partition: splitting a shared context into disjoint site-set leases." .

<https://uor.foundation/op/SessionMerge>
  a owl:NamedIndividual , <https://uor.foundation/op/GeometricCharacter> ;
  rdfs:label "SessionMerge" ;
  rdfs:comment "Geometric character of session composition: merging disjoint lease sessions into a unified resolution context." .

<https://uor.foundation/op/neg>
  a owl:NamedIndividual , <https://uor.foundation/op/Involution> ;
  rdfs:label "neg" ;
  rdfs:comment "Ring reflection: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}. neg(neg(x)) = x (involution property)." ;
  <https://uor.foundation/op/arity> "1"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/RingReflection> .

<https://uor.foundation/op/bnot>
  a owl:NamedIndividual , <https://uor.foundation/op/Involution> ;
  rdfs:label "bnot" ;
  rdfs:comment "Hypercube reflection: bnot(x) = (2^n - 1) ⊕ x (bitwise complement). The second generator of D_{2^n}. bnot(bnot(x)) = x." ;
  <https://uor.foundation/op/arity> "1"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/HypercubeReflection> .

<https://uor.foundation/op/succ>
  a owl:NamedIndividual , <https://uor.foundation/op/UnaryOp> ;
  rdfs:label "succ" ;
  rdfs:comment "Successor: succ(x) = neg(bnot(x)) = (x + 1) mod 2^n. The critical identity: succ is the composition neg ∘ bnot." ;
  <https://uor.foundation/op/arity> "1"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Rotation> ;
  <https://uor.foundation/op/composedOf> ( <https://uor.foundation/op/neg> <https://uor.foundation/op/bnot> ) ;
  <https://uor.foundation/op/inverse> <https://uor.foundation/op/pred> .

<https://uor.foundation/op/pred>
  a owl:NamedIndividual , <https://uor.foundation/op/UnaryOp> ;
  rdfs:label "pred" ;
  rdfs:comment "Predecessor: pred(x) = bnot(neg(x)) = (x - 1) mod 2^n. The inverse of succ. pred is the composition bnot ∘ neg." ;
  <https://uor.foundation/op/arity> "1"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/RotationInverse> ;
  <https://uor.foundation/op/composedOf> ( <https://uor.foundation/op/bnot> <https://uor.foundation/op/neg> ) ;
  <https://uor.foundation/op/inverse> <https://uor.foundation/op/succ> .

<https://uor.foundation/op/add>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "add" ;
  rdfs:comment "Ring addition: add(x, y) = (x + y) mod 2^n. Commutative, associative; identity element is 0." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Translation> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/identity> "0"^^xsd:integer ;
  <https://uor.foundation/op/inverse> <https://uor.foundation/op/sub> .

<https://uor.foundation/op/sub>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "sub" ;
  rdfs:comment "Ring subtraction: sub(x, y) = (x - y) mod 2^n. Not commutative, not associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Translation> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean .

<https://uor.foundation/op/mul>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "mul" ;
  rdfs:comment "Ring multiplication: mul(x, y) = (x × y) mod 2^n. Commutative, associative; identity element is 1." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Scaling> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/identity> "1"^^xsd:integer .

<https://uor.foundation/op/xor>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "xor" ;
  rdfs:comment "Bitwise exclusive or: xor(x, y) = x ⊕ y. Commutative, associative; identity element is 0." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/HypercubeTranslation> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/identity> "0"^^xsd:integer .

<https://uor.foundation/op/and>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "and" ;
  rdfs:comment "Bitwise and: and(x, y) = x ∧ y. Commutative, associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/HypercubeProjection> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean .

<https://uor.foundation/op/or>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "or" ;
  rdfs:comment "Bitwise or: or(x, y) = x ∨ y. Commutative, associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/HypercubeJoin> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean .

<https://uor.foundation/op/le>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "le" ;
  rdfs:comment "Byte-level less-than-or-equal: le(x, y) = 1 if x ≤ y else 0. Operands compared as big-endian unsigned byte sequences. The catamorphism fold-rule emits Literal(1) on true, Literal(0) on false." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "false"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ConstraintSelection> .

<https://uor.foundation/op/lt>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "lt" ;
  rdfs:comment "Byte-level less-than: lt(x, y) = 1 if x < y else 0. Operands compared as big-endian unsigned byte sequences." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "false"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ConstraintSelection> .

<https://uor.foundation/op/ge>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "ge" ;
  rdfs:comment "Byte-level greater-than-or-equal: ge(x, y) = 1 if x ≥ y else 0. Operands compared as big-endian unsigned byte sequences." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "false"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ConstraintSelection> .

<https://uor.foundation/op/gt>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "gt" ;
  rdfs:comment "Byte-level greater-than: gt(x, y) = 1 if x > y else 0. Operands compared as big-endian unsigned byte sequences." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "false"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ConstraintSelection> .

<https://uor.foundation/op/concat>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "concat" ;
  rdfs:comment "Byte-sequence concatenation: concat(x, y) = x ⧺ y. The substrate's byte-packing primitive — admits header serialization and other byte-array construction patterns. Result length is len(x) + len(y), carried by the source-polymorphic TermValue (inline up to the application's carrier width, else borrowed or streamed — no fixed ceiling)." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "false"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/HypercubeJoin> ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean .

<https://uor.foundation/op/div>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "div" ;
  rdfs:comment "Euclidean quotient: div(a, b) = q where a = q·b + r, 0 ⇐ r < b. Total on the ring for b > 0; b = 0 emits a ShapeViolation. Operands read as unsigned big-endian integers at the operand width." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Quotient> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean .

<https://uor.foundation/op/mod>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "mod" ;
  rdfs:comment "Euclidean remainder: mod(a, b) = r where a = q·b + r, 0 ⇐ r < b. Total on the ring for b > 0; b = 0 emits a ShapeViolation. Operands read as unsigned big-endian integers at the operand width." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/Remainder> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean .

<https://uor.foundation/op/pow>
  a owl:NamedIndividual , <https://uor.foundation/op/BinaryOp> ;
  rdfs:label "pow" ;
  rdfs:comment "Modular exponentiation: pow(base, exp) = base^exp mod 2^n. Fold-rule: square-and-multiply over exp bits. pow(_, 0) = 1; pow(0, b > 0) = 0." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/isRingOp> "true"^^xsd:boolean ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/IteratedScaling> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean .

<https://uor.foundation/op/dispatch>
  a owl:NamedIndividual , <https://uor.foundation/op/DispatchOperation> ;
  rdfs:label "dispatch" ;
  rdfs:comment "δ(q, R) = R(q): dispatches a query to the matching resolver in the registry. Non-commutative, non-associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ConstraintSelection> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/operatorSignature> "Query × ResolverRegistry → Resolver" .

<https://uor.foundation/op/infer>
  a owl:NamedIndividual , <https://uor.foundation/op/InferenceOperation> ;
  rdfs:label "infer" ;
  rdfs:comment "ι(s, C) = P(Π(G(s, C))): the φ-pipeline composed into a single inference step. Non-commutative, non-associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/ResolutionTraversal> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/operatorSignature> "Symbol × Context → ResolvedType" .

<https://uor.foundation/op/accumulate>
  a owl:NamedIndividual , <https://uor.foundation/op/AccumulationOperation> ;
  rdfs:label "accumulate" ;
  rdfs:comment "α(b, C) = C': accumulates a binding into a resolution context, pinning a site. Non-commutative, associative at convergence (SR_10)." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/SiteBinding> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/operatorSignature> "Binding × Context → Context" .

<https://uor.foundation/op/partition_op>
  a owl:NamedIndividual , <https://uor.foundation/op/LeasePartitionOperation> ;
  rdfs:label "partition_op" ;
  rdfs:comment "λ(S, k) = (L₁, …, Lₖ): partitions a shared context into k disjoint leases. Non-commutative, non-associative." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/SitePartition> ;
  <https://uor.foundation/op/commutative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "false"^^xsd:boolean ;
  <https://uor.foundation/op/operatorSignature> "SharedContext × ℕ → ContextLease^k" .

<https://uor.foundation/op/compose_op>
  a owl:NamedIndividual , <https://uor.foundation/op/SessionCompositionOperation> ;
  rdfs:label "compose_op" ;
  rdfs:comment "κ(S₁, S₂) = S₁ ∪ S₂: composes two sessions with disjoint leases into one. Commutative, associative (SR_8)." ;
  <https://uor.foundation/op/arity> "2"^^xsd:integer ;
  <https://uor.foundation/op/hasGeometricCharacter> <https://uor.foundation/op/SessionMerge> ;
  <https://uor.foundation/op/commutative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/associative> "true"^^xsd:boolean ;
  <https://uor.foundation/op/operatorSignature> "Session × Session → Session" .

<https://uor.foundation/op/criticalIdentity>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "Critical Identity" ;
  rdfs:comment "The foundational theorem of the UOR kernel: neg(bnot(x)) = succ(x) for all x in R_n. This identity links the two involutions (neg and bnot) to the successor operation, making succ derivable from neg and bnot." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_criticalIdentity_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_criticalIdentity_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_criticalIdentity_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> ;
  <https://uor.foundation/op/universallyValid> "true"^^xsd:boolean ;
  <https://uor.foundation/op/validityKind> <https://uor.foundation/op/Universal> .

<https://uor.foundation/op/AD_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "AD_1" ;
  rdfs:comment "Addressing bijection: addresses(glyph(d)) = d. Round-trip from datum through glyph and back is identity." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_AD_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_AD_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_AD_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> .

<https://uor.foundation/op/AD_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "AD_2" ;
  rdfs:comment "Embedding coherence: glyph(ι(addresses(a))) = ι_addr(a). The addressing diagram commutes through embeddings." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_AD_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_AD_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_AD_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Analytical> .

<https://uor.foundation/op/R_A1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A1" ;
  rdfs:comment "Additive associativity: add(x, add(y, z)) = add(add(x, y), z)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_A2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A2" ;
  rdfs:comment "Additive identity: add(x, 0) = x." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_A3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A3" ;
  rdfs:comment "Additive inverse: add(x, neg(x)) = 0." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_A4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A4" ;
  rdfs:comment "Additive commutativity: add(x, y) = add(y, x)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_A5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A5" ;
  rdfs:comment "Subtraction definition: sub(x, y) = add(x, neg(y))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_A6>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_A6" ;
  rdfs:comment "Negation involution: neg(neg(x)) = x." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_A6_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_A6_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_A6_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_M1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_M1" ;
  rdfs:comment "Multiplicative associativity: mul(x, mul(y, z)) = mul(mul(x, y), z)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_M1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_M1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_M1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_M2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_M2" ;
  rdfs:comment "Multiplicative identity: mul(x, 1) = x." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_M2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_M2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_M2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_M3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_M3" ;
  rdfs:comment "Multiplicative commutativity: mul(x, y) = mul(y, x)." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_M3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_M3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_M3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_M4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_M4" ;
  rdfs:comment "Distributivity: mul(x, add(y, z)) = add(mul(x, y), mul(x, z))." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_M4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_M4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_M4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/R_M5>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "R_M5" ;
  rdfs:comment "Annihilation: mul(x, 0) = 0." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_R_M5_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_R_M5_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_R_M5_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/DV_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "DV_1" ;
  rdfs:comment "Division right-identity: div(a, 1) = a." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_DV_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_DV_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_DV_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/DV_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "DV_2" ;
  rdfs:comment "Division left-absorbing: div(0, b) = 0 for b ≠ 0." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_DV_2_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_DV_2_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_DV_2_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/DV_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "DV_3" ;
  rdfs:comment "Division-of-multiplication recovery: div(mul(a, b), b) = a for b ≠ 0 in the unit cone." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_DV_3_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_DV_3_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_DV_3_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/DV_4>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "DV_4" ;
  rdfs:comment "Euclidean compatibility: a = add(mul(div(a, b), b), mod(a, b)) for b ≠ 0." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_DV_4_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_DV_4_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_DV_4_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/PW_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PW_1" ;
  rdfs:comment "Zero exponent identity: pow(a, 0) = 1." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_PW_1_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_PW_1_rhs> ;
  <https://uor.foundation/op/forAll> <https://uor.foundation/schema/term_PW_1_forAll> ;
  <https://uor.foundation/op/verificationDomain> <https://uor.foundation/op/Algebraic> .

<https://uor.foundation/op/PW_2>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "PW_2" ;
