<https://uor.foundation/op/SD_7>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_7" ;
  rdfs:comment "TreeType β_1=0, β_0=1 topological constraints." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_SD_7_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_SD_7_rhs> ;
