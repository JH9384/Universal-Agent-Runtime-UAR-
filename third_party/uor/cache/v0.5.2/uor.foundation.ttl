<https://uor.foundation/proof/prf_DV_1>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_DV_1" ;
  rdfs:comment "Axiomatic derivation of DV_1 (div right-identity). Holds at every quantum level: floor(a / 1) = a." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/DV_1> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_DV_2>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_DV_2" ;
  rdfs:comment "Axiomatic derivation of DV_2 (div left-absorbing). Holds by the Euclidean-algorithm rule floor(0 / b) = 0 for b ≠ 0." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/DV_2> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_DV_3>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_DV_3" ;
  rdfs:comment "Axiomatic derivation of DV_3 (div-of-mul recovery). Holds whenever mul(a, b) is in the unit cone (no overflow); the Euclidean-algorithm yields q = a and r = 0." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/DV_3> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_DV_4>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_DV_4" ;
  rdfs:comment "Axiomatic derivation of DV_4 (Euclidean compatibility). Direct consequence of the Euclidean-algorithm definition: a = q·b + r with 0 ≤ r < b." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/DV_4> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_PW_1>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_PW_1" ;
  rdfs:comment "Axiomatic derivation of PW_1 (zero-exp identity). Base case of the square-and-multiply construction: empty product = 1." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/PW_1> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_PW_2>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_PW_2" ;
  rdfs:comment "Axiomatic derivation of PW_2 (unit-exp identity). Follows from PW_1 + one square-and-multiply step: a · 1 = a." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/PW_2> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

<https://uor.foundation/proof/prf_PW_3>
  a owl:NamedIndividual , <https://uor.foundation/proof/AxiomaticDerivation> ;
  rdfs:label "prf_PW_3" ;
  rdfs:comment "Axiomatic derivation of PW_3 (additive-exp decomposition). Square-and-multiply reduces pow(a, b+c) to interleaved multiplications of pow(a, b) and pow(a, c) within the ring." ;
  <https://uor.foundation/proof/provesIdentity> <https://uor.foundation/op/PW_3> ;
  <https://uor.foundation/proof/universalScope> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/verified> "true"^^xsd:boolean ;
  <https://uor.foundation/proof/strategy> <https://uor.foundation/proof/RingAxiom> .

