<https://uor.foundation/op/SD_1>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "SD_1" ;
  rdfs:comment "ScalarType grounding: quantize(value, range, bits) produces ring element where d_R reflects value proximity." ;
