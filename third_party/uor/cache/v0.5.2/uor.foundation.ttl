<https://uor.foundation/op/NV_3>
  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "NV_3" ;
  rdfs:comment "Single constraint addition: Δβ_k ∈ {−1, 0, +1} per dimension." ;
