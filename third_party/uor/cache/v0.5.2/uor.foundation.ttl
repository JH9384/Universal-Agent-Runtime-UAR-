  a owl:NamedIndividual , <https://uor.foundation/op/Identity> ;
  rdfs:label "GR_8" ;
  rdfs:comment "Session composition validity: compose(S_A, S_B) is valid at Q_k iff all pinned-site intersections agree at every tower level Q_0 through Q_k." ;
  <https://uor.foundation/op/lhs> <https://uor.foundation/schema/term_GR_8_lhs> ;
  <https://uor.foundation/op/rhs> <https://uor.foundation/schema/term_GR_8_rhs> ;
