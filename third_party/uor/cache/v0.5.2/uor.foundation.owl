  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_M2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_M2</rdfs:label>
    <rdfs:comment>Hamming metric triangle inequality.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OB_M2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OB_M2_rhs"/>
