    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_8</rdfs:label>
    <rdfs:comment>TableType = SequenceType(TupleType(S)), functorial decomposition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DD_1</rdfs:label>
    <rdfs:comment>Dispatch determinism: same query and same registry always yield the same resolver.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DD_2</rdfs:label>
    <rdfs:comment>Dispatch coverage: every query in the registry domain has a matching resolver.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PI_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PI_1</rdfs:label>
    <rdfs:comment>Inference idempotence: ι(ι(s,C),C) = ι(s,C) on GroundedContext.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PI_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PI_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PI_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PI_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PI_2</rdfs:label>
    <rdfs:comment>Inference soundness: ι(s,C) resolves to a type consistent with C.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PI_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PI_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PI_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PI_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PI_3</rdfs:label>
    <rdfs:comment>Inference composition: ι = P ∘ Π ∘ G (references phi_4).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PI_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PI_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PI_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PI_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PI_4</rdfs:label>
    <rdfs:comment>Inference complexity: O(n) worst case, O(1) on CompleteType.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PI_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PI_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PI_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PI_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PI_5</rdfs:label>
    <rdfs:comment>Inference coherence: roundTrip(P(Π(G(s)))) = s.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PI_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PI_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PI_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PA_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PA_1</rdfs:label>
    <rdfs:comment>Accumulation permutation invariance: accumulating bindings in any order yields the same saturated context (derives from SR_10).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PA_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PA_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PA_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PA_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PA_2</rdfs:label>
    <rdfs:comment>Accumulation monotonicity: α(b,C) ⊇ C (the context only grows, never loses bindings). Derives from SR_1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PA_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PA_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PA_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PA_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PA_3</rdfs:label>
    <rdfs:comment>Accumulation soundness: α(b,C) preserves all previously satisfied constraints. Derives from SR_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PA_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PA_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PA_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PA_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PA_4</rdfs:label>
    <rdfs:comment>Accumulation base preservation: α does not modify previously pinned sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PA_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PA_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PA_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PA_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PA_5</rdfs:label>
    <rdfs:comment>Accumulation identity: α(∅, C) = C.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PA_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PA_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PA_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PL_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PL_1</rdfs:label>
    <rdfs:comment>Lease disjointness: partitioned leases have pairwise disjoint site sets (derives from SR_9).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PL_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PL_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PL_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PL_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PL_2</rdfs:label>
    <rdfs:comment>Lease conservation: union of all leases equals the original shared context (derives from MC_1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PL_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PL_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PL_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PL_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PL_3</rdfs:label>
    <rdfs:comment>Lease coverage: every site in the shared context appears in exactly one lease (derives from MC_6).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PL_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PL_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PL_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PK_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PK_1</rdfs:label>
    <rdfs:comment>Composition validity: κ(S₁,S₂) is a valid session if S₁,S₂ have disjoint leases (derives from SR_8).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PK_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PK_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PK_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PK_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PK_2</rdfs:label>
    <rdfs:comment>Distributed resolution: resolving in κ(S₁,S₂) equals resolving in S₁ or S₂ independently (derives from MC_7).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PK_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PK_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PK_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PP_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PP_1</rdfs:label>
    <rdfs:comment>Pipeline unification: κ(λₖ(α*(ι(s,·))),C) = resolve(s,C). The full composed pipeline equals the top-level resolution function.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PP_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PP_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PP_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PE_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PE_1</rdfs:label>
    <rdfs:comment>Stage 0 initializes state vector to 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PE_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PE_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PE_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PE_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PE_2</rdfs:label>
    <rdfs:comment>Stage 1 dispatches resolver (δ selects).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PE_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PE_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PE_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PE_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PE_3</rdfs:label>
    <rdfs:comment>Stage 2 produces valid ring address (G grounds).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PE_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PE_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PE_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PE_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PE_4</rdfs:label>
    <rdfs:comment>Stage 3 resolves constraints (Π terminates).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PE_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PE_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PE_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PE_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PE_5</rdfs:label>
