  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_D_9">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_D_9</rdfs:label>
    <rdfs:comment>Proof of D_9: reflection order 2 follows from D_7 composition: (r^k s)(r^k s) = identity.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/D_9"/>
