    <rdfs:label>term_ST_5_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>CompleteType(A + B)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_ST_5_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_ST_5_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>CompleteType(A) and CompleteType(B) and Q(A)=Q(B)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_ST_5_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_ST_5_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SumType A + B</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_ST_6_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_ST_6_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>∃! tagSite(A + B)</uor:schema/literalValue>
