  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_7</rdfs:label>
    <rdfs:comment>External effects must match their declared shape.</rdfs:comment>
