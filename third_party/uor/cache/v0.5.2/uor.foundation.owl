  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_AR_5">
    <rdf:type rdf:resource="https://uor.foundation/proof/InductiveProof"/>
    <rdfs:label>prf_AR_5</rdfs:label>
    <rdfs:comment>Inductive proof of AR_5: greedy vs adiabatic cost difference is at most 5%. Base case at Q0 by exhaustive evaluation; inductive step by QLS_5 (identity preservation under lift).</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/AR_5"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/baseCase rdf:resource="https://uor.foundation/proof/prf_AR_5_base"/>
    <uor:proof/inductiveStep rdf:resource="https://uor.foundation/proof/prf_AR_5_step"/>
    <uor:proof/validForKAtLeast rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:proof/validForKAtLeast>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/BitwiseInduction"/>
  </owl:NamedIndividual>

