    <rdfs:label>term_X_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_2_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_2_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>bnot(x)</uor:schema/literalValue>
