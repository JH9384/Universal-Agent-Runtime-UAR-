  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_jsat_CC_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_jsat_CC_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
