    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CM_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CM_1</rdfs:label>
    <rdfs:comment>Constraint redundancy criterion.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CM_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CM_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CM_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CM_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CM_2</rdfs:label>
    <rdfs:comment>Minimal cover via greedy irredundant removal.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CM_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CM_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CM_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CM_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CM_3</rdfs:label>
    <rdfs:comment>Minimum constraint count to cover n sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CM_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CM_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CM_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CR_1</rdfs:label>
    <rdfs:comment>Residue constraint cost is the step formula.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CR_2</rdfs:label>
    <rdfs:comment>Carry constraint cost is the popcount of the pattern.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CR_3</rdfs:label>
    <rdfs:comment>Depth constraint cost is sum of residue and carry costs.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CR_4</rdfs:label>
    <rdfs:comment>Composite constraint cost is subadditive.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CR_5</rdfs:label>
    <rdfs:comment>Optimal resolution order is increasing cost.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/F_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>F_1</rdfs:label>
    <rdfs:comment>Site monotonicity: a pinned site cannot be unpinned.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_F_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_F_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_F_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/F_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>F_2</rdfs:label>
    <rdfs:comment>Site budget upper bound: at most n pin operations to close.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_F_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_F_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_F_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/F_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>F_3</rdfs:label>
    <rdfs:comment>Site budget conservation: pinned + free = total sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_F_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_F_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_F_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/F_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>F_4</rdfs:label>
    <rdfs:comment>Site budget closure: closed iff all sites pinned.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_F_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_F_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_F_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FL_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FL_1</rdfs:label>
    <rdfs:comment>Site lattice bottom: all sites free.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FL_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FL_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FL_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FL_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FL_2</rdfs:label>
    <rdfs:comment>Site lattice top: all sites pinned.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FL_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FL_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FL_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FL_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FL_3</rdfs:label>
    <rdfs:comment>Site lattice join is union of pinnings.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FL_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FL_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FL_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FL_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FL_4</rdfs:label>
    <rdfs:comment>Site lattice height equals n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FL_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FL_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FL_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_1</rdfs:label>
    <rdfs:comment>Unit partition membership: x is a unit iff site_0(x) = 1 (x is odd).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_2</rdfs:label>
    <rdfs:comment>Exterior partition membership: x is exterior iff x is not in the carrier of T.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_3</rdfs:label>
    <rdfs:comment>Irreducible partition membership: x is irreducible iff x is not a unit, exterior, or reducible.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_4</rdfs:label>
    <rdfs:comment>Reducible partition membership: x is reducible iff x is not a unit, exterior, or irreducible.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_5</rdfs:label>
    <rdfs:comment>2-adic decomposition: every element factors as 2^{v(x)} times an odd unit.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_6</rdfs:label>
    <rdfs:comment>Stratum size formula.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_7</rdfs:label>
    <rdfs:comment>Base type partition cardinalities.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_1</rdfs:label>
    <rdfs:comment>Site extraction: site_k(x) is the k-th bit of x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_2</rdfs:label>
    <rdfs:comment>Site 0 is parity.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_3</rdfs:label>
    <rdfs:comment>Progressive site determination: site_k given lower sites determines x mod 2^{k+1}.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_4</rdfs:label>
    <rdfs:comment>Cumulative site determination: sites 0..k together determine x mod 2^{k+1}.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_5</rdfs:label>
    <rdfs:comment>Complete site determination: all n sites determine x uniquely.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_6</rdfs:label>
    <rdfs:comment>Stratum from sites: v_2(x) is the minimum k where site_k(x) = 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FS_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FS_7</rdfs:label>
    <rdfs:comment>Depth bound: depth(x) ≤ v_2(x) for irreducible elements.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FS_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FS_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FS_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RE_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RE_1</rdfs:label>
    <rdfs:comment>Resolution strategy equivalence: dihedral, canonical-form, and evaluation resolvers all compute the same partition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RE_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RE_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RE_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IR_1</rdfs:label>
    <rdfs:comment>Resolution monotonicity: pinned count never decreases.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IR_2</rdfs:label>
    <rdfs:comment>Resolution convergence bound: at most n iterations.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IR_3</rdfs:label>
    <rdfs:comment>Convergence rate definition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IR_4</rdfs:label>
    <rdfs:comment>Resolution termination: loop terminates if constraint set spans all sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SF_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SF_1</rdfs:label>
    <rdfs:comment>Optimal resolution level for a factor: n ≡ 0 (mod ord_g(2)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SF_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SF_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SF_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SF_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SF_2</rdfs:label>
    <rdfs:comment>Constraint ordering by step cost: smaller step_g first.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SF_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SF_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SF_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RD_1</rdfs:label>
    <rdfs:comment>Resolution determinism: same type and constraint sequence yield unique partition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RD_2</rdfs:label>
    <rdfs:comment>Order independence: complete constraint sets yield the same partition regardless of order.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SE_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SE_1</rdfs:label>
    <rdfs:comment>Evaluation resolver directly computes the set-theoretic partition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SE_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SE_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SE_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SE_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SE_2</rdfs:label>
    <rdfs:comment>Dihedral factorization resolver yields the same partition via orbit decomposition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SE_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SE_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SE_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SE_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SE_3</rdfs:label>
    <rdfs:comment>Canonical form resolver yields the same partition via confluent rewrite.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SE_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SE_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SE_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SE_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SE_4</rdfs:label>
    <rdfs:comment>All three strategies compute the same set-theoretic partition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SE_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SE_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SE_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OO_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OO_1</rdfs:label>
    <rdfs:comment>Benefit of a constraint is the number of new pins it provides.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OO_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OO_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OO_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OO_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OO_2</rdfs:label>
    <rdfs:comment>Constraint cost is step or popcount depending on type.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OO_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OO_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OO_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OO_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OO_3</rdfs:label>
    <rdfs:comment>Greedy selection maximizes benefit-to-cost ratio.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OO_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OO_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OO_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OO_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OO_4</rdfs:label>
    <rdfs:comment>Greedy approximation achieves (1 − 1/e) ≈ 63% of optimal.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OO_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OO_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OO_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OO_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OO_5</rdfs:label>
    <rdfs:comment>Tiebreaker: prefer vertical (residue) before horizontal (carry).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OO_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OO_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OO_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_1</rdfs:label>
    <rdfs:comment>Minimum convergence rate: 1 site per iteration (worst case).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CB_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_2</rdfs:label>
    <rdfs:comment>Maximum convergence rate: n sites in 1 iteration (best case).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CB_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_3</rdfs:label>
    <rdfs:comment>Expected residue constraint rate: ⌊log_2(m)⌋ sites per constraint.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CB_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_4</rdfs:label>
    <rdfs:comment>Stall detection: convergenceRate &lt; 1 for 2 iterations suggests insufficiency.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CB_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_5</rdfs:label>
    <rdfs:comment>Sufficiency criterion: pin union covers all site positions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_5_rhs"/>
