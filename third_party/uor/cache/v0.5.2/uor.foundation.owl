  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_DV_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_DV_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of DV_1 (div right-identity). Holds at every quantum level: floor(a / 1) = a.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/DV_1"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_DV_2">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_DV_2</rdfs:label>
    <rdfs:comment>Axiomatic derivation of DV_2 (div left-absorbing). Holds by the Euclidean-algorithm rule floor(0 / b) = 0 for b ≠ 0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/DV_2"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_DV_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_DV_3</rdfs:label>
    <rdfs:comment>Axiomatic derivation of DV_3 (div-of-mul recovery). Holds whenever mul(a, b) is in the unit cone (no overflow); the Euclidean-algorithm yields q = a and r = 0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/DV_3"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_DV_4">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_DV_4</rdfs:label>
    <rdfs:comment>Axiomatic derivation of DV_4 (Euclidean compatibility). Direct consequence of the Euclidean-algorithm definition: a = q·b + r with 0 ≤ r &lt; b.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/DV_4"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_PW_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_PW_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of PW_1 (zero-exp identity). Base case of the square-and-multiply construction: empty product = 1.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/PW_1"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_PW_2">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_PW_2</rdfs:label>
    <rdfs:comment>Axiomatic derivation of PW_2 (unit-exp identity). Follows from PW_1 + one square-and-multiply step: a · 1 = a.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/PW_2"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_PW_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_PW_3</rdfs:label>
    <rdfs:comment>Axiomatic derivation of PW_3 (additive-exp decomposition). Square-and-multiply reduces pow(a, b+c) to interleaved multiplications of pow(a, b) and pow(a, c) within the ring.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/PW_3"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_B_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_B_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of B_1. Holds at all quantum levels by definition of Z/(2^n)Z.</rdfs:comment>
