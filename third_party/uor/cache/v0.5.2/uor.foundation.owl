  <owl:NamedIndividual rdf:about="https://uor.foundation/op/T_A1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>T_A1</rdfs:label>
    <rdfs:comment>Dihedral group acts on constraints by transforming them.</rdfs:comment>
