    <rdfs:label>term_X_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>pred(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>sub(x, 1)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_X_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_5_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_5_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>neg(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_5_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_5_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>add(bnot(x), 1)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_5_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_X_5_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_6_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_6_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>bnot(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_6_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_6_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>pred(neg(x))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_6_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_X_6_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_7_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_7_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>xor(x, y)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_7_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_X_7_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>add(x, y) - 2 * and(x, y)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_X_7_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_X_7_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x, y ∈ Z (before mod)</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>succ^{2^n}(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>x</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_1_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_D_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>neg(succ(neg(x)))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_3_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_3_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>pred(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_3_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_D_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>bnot(neg(x))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>pred(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_D_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_5_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_5_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>D_{2^n}</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_5_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_5_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>{succ^k, neg ∘ succ^k : 0 ≤ k &lt; 2^n}</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_5_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_D_5_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>n ≥ 1</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>R_n×</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>Z/2 × Z/2^{n-2}</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_1_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_U_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>n ≥ 3</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_2_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_2_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>R_1× ≅ {1}; R_2× ≅ Z/2</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_2_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_2_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>special cases for small n</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_2_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_U_2_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>n ∈ {1, 2}</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>ord(u)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_3_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_3_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>lcm(ord((-1)^a), ord(3^b))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_3_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_U_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>u = (-1)^a · 3^b ∈ R_n×</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>ord_g(2)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>divides φ(g)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_U_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>g odd</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_5_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_5_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>step_g</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_5_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_U_5_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>2 * ((g - (2^n mod g)) mod g) + 1</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_U_5_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_U_5_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>g odd, g &gt; 1</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_AG_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_AG_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>μ_u</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_AG_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_AG_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
