  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_P1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_P1</rdfs:label>
    <rdfs:comment>Path length is additive under concatenation.</rdfs:comment>
