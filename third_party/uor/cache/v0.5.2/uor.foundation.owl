  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CY_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CY_3</rdfs:label>
    <rdfs:comment>Carry kills at site k iff and(x_k, y_k) = 0 and xor(x_k, y_k) = 0. Complement of CY_1 and CY_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CY_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CY_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CY_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CY_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CY_4</rdfs:label>
    <rdfs:comment>d_Δ(x,y) = |carryCount(x+y) − hammingDistance(x,y)|. The metric incompatibility IS the discrepancy between carry count and Hamming distance. Strengthens WC_6.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CY_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CY_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CY_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CY_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CY_5</rdfs:label>
    <rdfs:comment>Optimal encoding theorem: the encoding that minimizes Σ d_Δ over observed pairs is the one where the carry chain’s significance hierarchy matches the domain’s dependency structure.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CY_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CY_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CY_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CY_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CY_6</rdfs:label>
    <rdfs:comment>Site ordering theorem: d_Δ is minimized when high-significance sites (upstream in the carry chain) encode the most structurally informative observables.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CY_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CY_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CY_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CY_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CY_7</rdfs:label>
    <rdfs:comment>Carry lookahead: the carry chain for n sites is computable in O(log n) using prefix computation on generate/propagate pairs.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CY_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CY_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CY_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_1</rdfs:label>
    <rdfs:comment>σ(C) = (n − freeRank(C)) / n. The saturation metric is the complement of free site ratio. Derives from SC_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_2</rdfs:label>
    <rdfs:comment>χ = Σ(−1)^k β_k. The Euler characteristic of the constraint nerve. Derives from IT_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_3</rdfs:label>
    <rdfs:comment>Index theorem: Σκ_k − χ = S_residual / ln 2. Links all six metrics. Derives from IT_7a.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_4</rdfs:label>
    <rdfs:comment>J_k = 0 for pinned sites. The Jacobian vanishes on resolved sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_5</rdfs:label>
    <rdfs:comment>d_Δ &gt; 0 iff carry ≠ 0. The metric discrepancy equals the Witt defect. Derives from WC_6.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BM_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BM_6</rdfs:label>
    <rdfs:comment>Metric composition tower: d_Δ → {σ, J_k} → β_k → χ → r. Each metric derives from previous ones.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BM_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BM_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BM_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GL_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GL_1</rdfs:label>
    <rdfs:comment>σ = lower adjoint evaluated at current type. The saturation metric is the lower adjoint of the Galois connection. Derives from SC_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GL_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GL_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GL_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GL_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GL_2</rdfs:label>
    <rdfs:comment>r = complement of upper adjoint image. The residual freedom is what the type closure does not reach.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GL_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GL_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GL_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GL_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GL_3</rdfs:label>
    <rdfs:comment>CompleteType = fixpoint of Galois connection, σ=1, r=0. Derives from IT_7d.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GL_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GL_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GL_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GL_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GL_4</rdfs:label>
    <rdfs:comment>Type refinement = ascending in type lattice = descending in site freedom. The Galois connection reverses order.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GL_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GL_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GL_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/NV_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>NV_1</rdfs:label>
    <rdfs:comment>nerve(C₁ ∪ C₂) = nerve(C₁) ∪ nerve(C₂) for disjoint constraint domains.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_NV_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_NV_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_NV_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/NV_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>NV_2</rdfs:label>
    <rdfs:comment>Mayer–Vietoris: β_k(C₁ ∪ C₂) computable from parts and intersection.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_NV_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_NV_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_NV_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/NV_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>NV_3</rdfs:label>
    <rdfs:comment>Single constraint addition: Δβ_k ∈ {−1, 0, +1} per dimension.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_NV_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_NV_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_NV_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/NV_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>NV_4</rdfs:label>
    <rdfs:comment>Constraint accumulation monotonicity: β_k non-increasing under SR_1. Derives from SR_1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_NV_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_NV_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_NV_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_1</rdfs:label>
    <rdfs:comment>ScalarType grounding: quantize(value, range, bits) produces ring element where d_R reflects value proximity.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_2</rdfs:label>
    <rdfs:comment>SymbolType grounding: argmin_{encoding} Σ d_Δ over observed pairs (CY_5).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_3</rdfs:label>
    <rdfs:comment>SequenceType = free monoid on element type with backbone constraint.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_4</rdfs:label>
    <rdfs:comment>TupleType site count = Σ field site counts, site ordering follows CY_6.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_5</rdfs:label>
    <rdfs:comment>GraphType constraint nerve = graph nerve, β_k equality.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_6</rdfs:label>
    <rdfs:comment>SetType d_Δ invariant under element permutation, D_{2n} symmetry.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SD_6_forAll"/>
