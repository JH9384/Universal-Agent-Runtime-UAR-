    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/EulerPoincare"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_RG_2">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_RG_2</rdfs:label>
    <rdfs:comment>Axiomatic derivation of RG_2: diameter bound.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/RG_2"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_RG_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_RG_3</rdfs:label>
    <rdfs:comment>Axiomatic derivation of RG_3: addressable space bound.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/RG_3"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_RG_4">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_RG_4</rdfs:label>
    <rdfs:comment>Axiomatic derivation of RG_4: working set containment.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/RG_4"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IO_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IO_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IO_1: ingest type conformance.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IO_1"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IO_2">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IO_2</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IO_2: emit type conformance.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IO_2"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IO_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IO_3</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IO_3: grounding validity.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IO_3"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IO_4">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IO_4</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IO_4: projection validity.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IO_4"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IO_5">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IO_5</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IO_5: non-vacuous crossing.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IO_5"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_CS_6">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_CS_6</rdfs:label>
    <rdfs:comment>Axiomatic derivation of CS_6: budget solvency rejection.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/CS_6"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Simplification"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_CS_7">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_CS_7</rdfs:label>
    <rdfs:comment>Axiomatic derivation of CS_7: unit address computation.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/CS_7"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IH_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IH_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of IH_1 (inhabitance soundness): cert:InhabitanceCertificate(T).verified iff carrier(T) ≠ ∅.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IH_1"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IH_2a">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IH_2a</rdfs:label>
    <rdfs:comment>Cost identity for the 2-SAT decider on Is2SatShape instances. Inherited from the classical 2-SAT polynomial decision procedure.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IH_2a"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IH_2b">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IH_2b</rdfs:label>
    <rdfs:comment>Cost identity for the Horn-SAT decider on IsHornShape instances. Inherited from the classical Horn-SAT polynomial decision procedure via unit propagation.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IH_2b"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_IH_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_IH_3</rdfs:label>
    <rdfs:comment>Carrier preservation under basis reduction. Discharged against resolver:JacobianGuidedResolver and resolver:guidingJacobian vocabulary.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/IH_3"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <!-- Namespace: derivation -->
  <owl:Ontology rdf:about="https://uor.foundation/derivation/">
    <rdfs:label>UOR Derivations</rdfs:label>
    <rdfs:comment>Computation witnesses recording term rewriting sequences from original terms to their canonical forms.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/resolver/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/derivation/Derivation">
    <rdfs:label>Derivation</rdfs:label>
    <rdfs:comment>A complete term rewriting witness: the full sequence of rewrite steps transforming an original term into its canonical form.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/DerivationStep">
    <rdfs:label>DerivationStep</rdfs:label>
    <rdfs:comment>An abstract step in a derivation. Concrete subclasses are RewriteStep (term-level rewriting) and RefinementStep (type-level refinement).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/RewriteStep">
    <rdfs:label>RewriteStep</rdfs:label>
    <rdfs:comment>A single rewrite step in a derivation: the application of one rewrite rule to transform a term.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/derivation/DerivationStep"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/RefinementStep">
    <rdfs:label>RefinementStep</rdfs:label>
    <rdfs:comment>A type-level refinement step: the application of a constraint to narrow a type, pinning additional site coordinates. Complements RewriteStep (term-level) in the derivation hierarchy.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/derivation/DerivationStep"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/RewriteRule">
    <rdfs:label>RewriteRule</rdfs:label>
    <rdfs:comment>A named rewrite rule that can be applied in a derivation step. Each RewriteRule individual represents a specific algebraic law or normalization strategy used during term rewriting.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/TermMetrics">
    <rdfs:label>TermMetrics</rdfs:label>
    <rdfs:comment>Metrics describing the size and complexity of a term.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/SynthesisStep">
    <rdfs:label>SynthesisStep</rdfs:label>
    <rdfs:comment>A single step in the construction of a SynthesizedType: one constraint added to the synthesis candidate and the resulting change in the constraint nerve&apos;s topological signature. Ordered by derivation:stepIndex. Analogous to derivation:RewriteStep in the forward pipeline.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/SynthesisCheckpoint">
    <rdfs:label>SynthesisCheckpoint</rdfs:label>
    <rdfs:comment>A persistent snapshot of a ConstraintSearchState at a specific SynthesisStep, allowing a TypeSynthesisResolver to resume exploration after interruption. Essential at Q1+ scale where exhaustive synthesis is computationally significant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/InhabitanceStep">
    <rdfs:label>InhabitanceStep</rdfs:label>
    <rdfs:comment>A peer of derivation:SynthesisStep specialised to inhabitance search. Each step represents one navigation in the constraint nerve, either pinning a site to a value or confirming that a predicate evaluates true on the current partial assignment.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/InhabitanceCheckpoint">
    <rdfs:label>InhabitanceCheckpoint</rdfs:label>
    <rdfs:comment>A peer of derivation:SynthesisCheckpoint specialised to inhabitance search. Marks an audit point where the resolver state can be restored if the search backtracks.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/derivation/SynthesisCheckpoint"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/DerivationDepthObservable">
    <rdfs:label>DerivationDepthObservable</rdfs:label>
    <rdfs:comment>Observes the derivation depth of a Datum, computed as the maximum nesting level of derivation:RewriteStep applications producing it. Used as the bound observable for the depthConstraintKind BoundConstraint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/derivation/DerivationTrace">
    <rdfs:label>DerivationTrace</rdfs:label>
    <rdfs:comment>An ordered sequence of derivation:RewriteStep events produced by replaying a Derivation. Used by uor-foundation-verify to re-derive a certificate from a content-addressed trace without running the deciders. The traceEventCount property records the trace length.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/originalTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>originalTerm</rdfs:label>
    <rdfs:comment>The term at the start of the derivation, before any rewriting.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/Derivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/canonicalTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>canonicalTerm</rdfs:label>
    <rdfs:comment>The canonical form produced at the end of the derivation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/Derivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/result">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>result</rdfs:label>
    <rdfs:comment>The datum value obtained by evaluating the canonical term.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/Derivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/step">
    <rdfs:label>step</rdfs:label>
    <rdfs:comment>A rewrite step in this derivation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/Derivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/RewriteStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/termMetrics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>termMetrics</rdfs:label>
    <rdfs:comment>Metrics for the canonical term produced by this derivation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/Derivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/TermMetrics"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/from">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>from</rdfs:label>
    <rdfs:comment>The term before this rewrite step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RewriteStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/to">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>to</rdfs:label>
    <rdfs:comment>The term after this rewrite step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RewriteStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/hasRewriteRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hasRewriteRule</rdfs:label>
    <rdfs:comment>The typed rewrite rule applied in this step. Provides a structured reference to a named RewriteRule individual, complementing the string-valued derivation:rule property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RewriteStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/groundedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedIn</rdfs:label>
    <rdfs:comment>The algebraic identity that grounds this rewrite rule. Links a RewriteRule to the op:Identity individual that justifies its application.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/stepCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepCount</rdfs:label>
    <rdfs:comment>The total number of rewrite steps in this derivation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/TermMetrics"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/termSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>termSize</rdfs:label>
    <rdfs:comment>The number of nodes in the canonical term&apos;s syntax tree.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/TermMetrics"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/previousType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>previousType</rdfs:label>
    <rdfs:comment>The type before this refinement step was applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RefinementStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/appliedConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>appliedConstraint</rdfs:label>
    <rdfs:comment>The constraint that was applied in this refinement step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RefinementStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/refinedType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>refinedType</rdfs:label>
    <rdfs:comment>The type after this refinement step was applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RefinementStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/sitesClosed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitesClosed</rdfs:label>
    <rdfs:comment>The number of site coordinates pinned by this refinement step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/RefinementStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/stepIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepIndex</rdfs:label>
    <rdfs:comment>Zero-based sequential index of this step within the synthesis derivation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/addedConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>addedConstraint</rdfs:label>
    <rdfs:comment>The constraint added in this synthesis step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/signatureBefore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>signatureBefore</rdfs:label>
    <rdfs:comment>The constraint nerve signature before this synthesis step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/signatureAfter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>signatureAfter</rdfs:label>
    <rdfs:comment>The constraint nerve signature after this synthesis step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/checkpointStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>checkpointStep</rdfs:label>
    <rdfs:comment>The SynthesisStep at which this checkpoint was taken.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisCheckpoint"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/SynthesisStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/checkpointState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>checkpointState</rdfs:label>
    <rdfs:comment>The ConstraintSearchState snapshot captured by this checkpoint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/SynthesisCheckpoint"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ConstraintSearchState"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/towerCheckpoint">
    <rdfs:label>towerCheckpoint</rdfs:label>
    <rdfs:comment>Links a TowerCompletenessResolver to a SynthesisCheckpoint issued at each completed step. Cross-namespace bridge property: domain is resolver:TowerCompletenessResolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/SynthesisCheckpoint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/priorState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>priorState</rdfs:label>
    <rdfs:comment>The ConstraintSearchState before this InhabitanceStep was taken.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/InhabitanceStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ConstraintSearchState"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/successorState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>successorState</rdfs:label>
    <rdfs:comment>The ConstraintSearchState after this InhabitanceStep was taken.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/InhabitanceStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ConstraintSearchState"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/derivation/rule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rule</rdfs:label>
    <rdfs:comment>The predicate:DispatchRule whose evaluation drove this InhabitanceStep.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/InhabitanceStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/checkpointIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>checkpointIndex</rdfs:label>
    <rdfs:comment>Ordinal index of this checkpoint within the InhabitanceSearchTrace&apos;s checkpoint sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/InhabitanceCheckpoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/derivation/traceEventCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>traceEventCount</rdfs:label>
    <rdfs:comment>Number of RewriteStep events recorded in this DerivationTrace. Used by Derivation::replay() to size the fixed-capacity event arena without allocation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/derivation/DerivationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/CriticalIdentityRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>CriticalIdentityRule</rdfs:label>
    <rdfs:comment>The rewrite rule applying the critical identity: neg(bnot(x)) → succ(x). Grounded in op:criticalIdentity.</rdfs:comment>
    <uor:derivation/groundedIn rdf:resource="https://uor.foundation/op/criticalIdentity"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/InvolutionRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>InvolutionRule</rdfs:label>
    <rdfs:comment>The rewrite rule applying involution cancellation: f(f(x)) → x for any involution f.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/AssociativityRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>AssociativityRule</rdfs:label>
    <rdfs:comment>The rewrite rule applying associativity to re-bracket nested binary operations.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/CommutativityRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>CommutativityRule</rdfs:label>
    <rdfs:comment>The rewrite rule applying commutativity to reorder operands of commutative operations.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/IdentityElementRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>IdentityElementRule</rdfs:label>
    <rdfs:comment>The rewrite rule eliminating identity elements: add(x, 0) → x, mul(x, 1) → x, xor(x, 0) → x.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/derivation/NormalizationRule">
    <rdf:type rdf:resource="https://uor.foundation/derivation/RewriteRule"/>
    <rdfs:label>NormalizationRule</rdfs:label>
    <rdfs:comment>The rewrite rule normalizing compound expressions to canonical ordering (e.g., sorting operands by address).</rdfs:comment>
  </owl:NamedIndividual>

  <!-- Namespace: trace -->
  <owl:Ontology rdf:about="https://uor.foundation/trace/">
    <rdfs:label>UOR Computation Traces</rdfs:label>
    <rdfs:comment>Execution traces recording the sequence of kernel operations, intermediate results, and accumulated metrics for a computation.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/trace/ComputationTrace">
    <rdfs:label>ComputationTrace</rdfs:label>
    <rdfs:comment>A complete record of a kernel computation: the input, output, every operation step, and accumulated metrics.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/ComputationStep">
    <rdfs:label>ComputationStep</rdfs:label>
    <rdfs:comment>A single step in a computation trace: one operation applied to produce one output from one or more inputs.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/TraceMetrics">
    <rdfs:label>TraceMetrics</rdfs:label>
    <rdfs:comment>Summary metrics for a computation trace: total steps, accumulated ring distance, and accumulated Hamming distance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/GeodesicTrace">
    <rdfs:label>GeodesicTrace</rdfs:label>
    <rdfs:comment>A computation trace that satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected. The path of least dissipation through the resolution landscape.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/GeodesicViolation">
    <rdfs:label>GeodesicViolation</rdfs:label>
    <rdfs:comment>A record of a geodesic condition violation at a specific step of a computation trace. Produced by GeodesicValidator when J_k(step_i) &lt; max_\{free\} J_k(state_i).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/MeasurementEvent">
    <rdfs:label>MeasurementEvent</rdfs:label>
    <rdfs:comment>A specialized computation step recording a single projective collapse of a SuperposedSiteState. Carries pre-collapse entropy and post-collapse Landauer cost (QM_1).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationStep"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/MeasurementOutcome">
    <rdfs:label>MeasurementOutcome</rdfs:label>
    <rdfs:comment>A single outcome of a projective measurement on a SuperposedSiteState, recording the classical site index (outcomeValue) and its Born-rule probability |α_k|² (outcomeProbability). Multiple outcomes form the probability distribution of a measurement.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/trace/InhabitanceSearchTrace">
    <rdfs:label>InhabitanceSearchTrace</rdfs:label>
    <rdfs:comment>A subclass of trace:ComputationTrace specialised to inhabitance-search execution. Records the sequence of derivation:InhabitanceStep entries the resolver traversed and any derivation:InhabitanceCheckpoint entries it crossed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/input">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>input</rdfs:label>
    <rdfs:comment>The input datum of this computation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/output">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>output</rdfs:label>
    <rdfs:comment>The output datum of this computation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/step">
    <rdfs:label>step</rdfs:label>
    <rdfs:comment>A computation step in this trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/ComputationStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/monodromy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>monodromy</rdfs:label>
    <rdfs:comment>The monodromy accumulated by this computation: the net dihedral group element produced by the full operation sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/DihedralElement"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/from">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>from</rdfs:label>
    <rdfs:comment>The input datum of this computation step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/to">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>to</rdfs:label>
    <rdfs:comment>The output datum of this computation step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/operation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operation</rdfs:label>
    <rdfs:comment>The operation applied in this computation step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/index">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>index</rdfs:label>
    <rdfs:comment>The zero-based sequential index of this step within its trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/stepCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepCount</rdfs:label>
    <rdfs:comment>Total number of computation steps in this trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/TraceMetrics"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/totalRingDistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>totalRingDistance</rdfs:label>
    <rdfs:comment>Total ring-metric distance accumulated across all steps.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/TraceMetrics"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/totalHammingDistance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>totalHammingDistance</rdfs:label>
    <rdfs:comment>Total Hamming-metric distance accumulated across all steps.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/TraceMetrics"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/certifiedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedBy</rdfs:label>
    <rdfs:comment>The certificate that attests to the correctness of this computation trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/residualEntropy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residualEntropy</rdfs:label>
    <rdfs:comment>The residual entropy observable remaining after this computation trace, linking to the ThermoObservable taxonomy (TH_9 connection).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/ResidualEntropy"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/isGeodesic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isGeodesic</rdfs:label>
    <rdfs:comment>Whether this computation trace satisfies the dual geodesic condition (GD_1): AR_1-ordered and DC_10-selected.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/geodesicViolation">
    <rdfs:label>geodesicViolation</rdfs:label>
    <rdfs:comment>A GeodesicViolation record indicating where the trace deviated from the geodesic condition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/GeodesicViolation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/stepEntropyCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepEntropyCost</rdfs:label>
    <rdfs:comment>The entropy cost of a single computation step. On a geodesic, this equals ln 2 for every step (GD_2).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/cumulativeEntropyCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cumulativeEntropyCost</rdfs:label>
    <rdfs:comment>The total entropy cost accumulated across all steps of a trace. On a geodesic, equals freeRank_initial × ln 2 (GD_3).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/jacobianAtStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>jacobianAtStep</rdfs:label>
    <rdfs:comment>The Jacobian value J_k at this step, used by the GeodesicValidator to check DC_10 maximality.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/adiabaticallyOrdered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>adiabaticallyOrdered</rdfs:label>
    <rdfs:comment>Whether the step sequence of this trace follows the AR_1 adiabatic ordering (decreasing freeRank × cost-per-site).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/violationReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>violationReason</rdfs:label>
    <rdfs:comment>Human-readable description of why a geodesic violation occurred, citing the step index and the unused higher-J_k option.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/GeodesicViolation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/measurementEvent">
    <rdfs:label>measurementEvent</rdfs:label>
    <rdfs:comment>A MeasurementEvent step within this computation trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/preCollapseEntropy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preCollapseEntropy</rdfs:label>
    <rdfs:comment>The von Neumann entropy S_vN of the SuperposedSiteState before projective collapse.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/postCollapseLandauerCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>postCollapseLandauerCost</rdfs:label>
    <rdfs:comment>The Landauer cost incurred by the projective collapse. Equals preCollapseEntropy at β* = ln 2 (QM_1).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/collapseStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>collapseStep</rdfs:label>
    <rdfs:comment>The step index within the enclosing ComputationTrace at which this projective collapse occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/amplitudeVector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>amplitudeVector</rdfs:label>
    <rdfs:comment>The full pre-collapse amplitude vector of all branches at the time of measurement. Enables Born rule verification (QM_5): P(outcome k) = |α_k|² / Σ|αᵢ|².</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/isAR1Ordered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isAR1Ordered</rdfs:label>
    <rdfs:comment>Whether this computation trace has steps ordered by the AR_1 adiabatic metric (decreasing freeRank × cost-per-site). One of the two sub-predicates of isGeodesic (GD_6).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/isDC10Selected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isDC10Selected</rdfs:label>
    <rdfs:comment>Whether each step of this computation trace was selected by the DC_10 Jacobian criterion (maximal J_k among free sites). One of the two sub-predicates of isGeodesic (GD_6).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/outcomeValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outcomeValue</rdfs:label>
    <rdfs:comment>The classical site index selected by projective collapse in this measurement outcome.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementOutcome"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/trace/outcomeProbability">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outcomeProbability</rdfs:label>
    <rdfs:comment>The Born-rule probability of this measurement outcome: |α_k|² where α_k is the amplitude of the collapsed site.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/MeasurementOutcome"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/trace/checkpoint">
    <rdfs:label>checkpoint</rdfs:label>
    <rdfs:comment>Checkpoints crossed by the inhabitance search. Each checkpoint marks an audit point where the resolver state can be restored if the search backtracks.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/trace/InhabitanceSearchTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/InhabitanceCheckpoint"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/geodesic_Q0">
    <rdf:type rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
    <rdfs:label>geodesic_Q0</rdfs:label>
    <rdfs:comment>Canonical geodesic trace at quantum level Q0 (n=8). Demonstrates GD_1 through GD_3 at the base level.</rdfs:comment>
    <uor:trace/isGeodesic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/isGeodesic>
    <uor:trace/adiabaticallyOrdered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/adiabaticallyOrdered>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/geodesic_Q1">
    <rdf:type rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
    <rdfs:label>geodesic_Q1</rdfs:label>
    <rdfs:comment>Canonical geodesic trace at quantum level Q1 (n=16). Demonstrates geodesic scaling from Q0 to Q1.</rdfs:comment>
    <uor:trace/isGeodesic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/isGeodesic>
    <uor:trace/adiabaticallyOrdered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/adiabaticallyOrdered>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/geodesic_Q2">
    <rdf:type rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
    <rdfs:label>geodesic_Q2</rdfs:label>
    <rdfs:comment>Canonical geodesic trace at quantum level Q2 (n=32). Demonstrates geodesic scaling from Q1 to Q2.</rdfs:comment>
    <uor:trace/isGeodesic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/isGeodesic>
    <uor:trace/adiabaticallyOrdered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/adiabaticallyOrdered>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/geodesic_Q3">
    <rdf:type rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
    <rdfs:label>geodesic_Q3</rdfs:label>
    <rdfs:comment>Canonical geodesic trace at quantum level Q3 (n=64). Demonstrates geodesic scaling from Q2 to Q3.</rdfs:comment>
    <uor:trace/isGeodesic rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/isGeodesic>
    <uor:trace/adiabaticallyOrdered rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:trace/adiabaticallyOrdered>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/collapse_equal_superposition">
    <rdf:type rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:label>collapse_equal_superposition</rdfs:label>
    <rdfs:comment>Canonical measurement event: collapse of an equal superposition (|α|² = 0.5). Maximum von Neumann entropy S_vN = ln 2. Maximum Landauer cost per QM_1.</rdfs:comment>
    <uor:trace/preCollapseEntropy rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.6931471805599453</uor:trace/preCollapseEntropy>
    <uor:trace/postCollapseLandauerCost rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.6931471805599453</uor:trace/postCollapseLandauerCost>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/collapse_biased">
    <rdf:type rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:label>collapse_biased</rdfs:label>
    <rdfs:comment>Canonical measurement event: collapse of a biased superposition (|α|² = 0.9). Lower entropy than equal superposition. Demonstrates QM_3 bound.</rdfs:comment>
    <uor:trace/preCollapseEntropy rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.325083</uor:trace/preCollapseEntropy>
    <uor:trace/postCollapseLandauerCost rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.325083</uor:trace/postCollapseLandauerCost>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/trace/collapse_classical">
    <rdf:type rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
    <rdfs:label>collapse_classical</rdfs:label>
    <rdfs:comment>Canonical measurement event: collapse of a classical state (|α|² = 1). Zero entropy, zero Landauer cost. Demonstrates QM_4 idempotence.</rdfs:comment>
    <uor:trace/preCollapseEntropy rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</uor:trace/preCollapseEntropy>
    <uor:trace/postCollapseLandauerCost rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</uor:trace/postCollapseLandauerCost>
  </owl:NamedIndividual>

  <!-- Namespace: cert -->
  <owl:Ontology rdf:about="https://uor.foundation/cert/">
    <rdfs:label>UOR Certificates</rdfs:label>
    <rdfs:comment>Kernel-produced attestation certificates for transforms, isometries, and involutions. Each certificate verifies that a specific structural property holds.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/proof/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/cert/Certificate">
    <rdfs:label>Certificate</rdfs:label>
    <rdfs:comment>A kernel-produced attestation. The root class for all certificate types.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/TransformCertificate">
    <rdfs:label>TransformCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting to the properties of a morphism:Transform. Certifies that the transform maps source to target correctly.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/IsometryCertificate">
    <rdfs:label>IsometryCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a morphism:Isometry preserves metric distances. Certifies the transform is a metric isometry with respect to the specified metric.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/InvolutionCertificate">
    <rdfs:label>InvolutionCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that an operation is an involution: f(f(x)) = x for all x in R_n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/CompletenessCertificate">
    <rdfs:label>CompletenessCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a type:CompleteType satisfies IT_7d: its constraint nerve has χ = n and all Betti numbers β_k = 0. Issued by the kernel after running the full ψ pipeline on the type&apos;s constraint set.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/CompletenessAuditTrail">
    <rdfs:label>CompletenessAuditTrail</rdfs:label>
    <rdfs:comment>An ordered collection of CompletenessWitness records belonging to a CompletenessCertificate. Provides full provenance of the certification process: every constraint applied, every site closed, in sequence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/GroundingCertificate">
    <rdfs:label>GroundingCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a state:GroundedContext has reached full saturation (σ = 1, freeRank = 0, S = 0, T_ctx = 0) per SC_4. The session-layer dual of CompletenessCertificate.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/GeodesicCertificate">
    <rdfs:label>GeodesicCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a trace:GeodesicTrace satisfies both GD_1 conditions: AR_1-ordered and DC_10-selected. Transforms ComputationTrace from descriptive to normative.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/MeasurementCertificate">
    <rdfs:label>MeasurementCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a trace:MeasurementEvent respected the von Neumann–Landauer bridge (QM_1): preCollapseEntropy = postCollapseLandauerCost at β* = ln 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/GeodesicEvidenceBundle">
    <rdfs:label>GeodesicEvidenceBundle</rdfs:label>
    <rdfs:comment>A structured evidence bundle attesting that each sub-predicate of the geodesic condition (GD_6) holds independently: isAR1Ordered and isDC10Selected. Linked from GeodesicCertificate via evidenceBundle.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/BornRuleVerification">
    <rdfs:label>BornRuleVerification</rdfs:label>
    <rdfs:comment>A certificate attesting that a MeasurementEvent outcome probability matches the Born rule: P(outcome k) = |α_k|² (QM_5). Linked from MeasurementCertificate to provide probability distribution verification.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/LiftChainCertificate">
    <rdfs:label>LiftChainCertificate</rdfs:label>
    <rdfs:comment>A kernel-issued certificate attesting that a LiftChain from liftSourceLevel to liftTargetLevel is complete.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/ChainAuditTrail">
    <rdfs:label>ChainAuditTrail</rdfs:label>
    <rdfs:comment>An ordered collection of per-step evidence records for a LiftChainCertificate.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/InhabitanceCertificate">
    <rdfs:label>InhabitanceCertificate</rdfs:label>
    <rdfs:comment>A ComputationCertificate verdict primitive that decides carrier non-emptiness on a type:ConstrainedType. Distinct from cert:CompletenessCertificate, which decides freeRank = 0 on the minimal basis. For ConstrainedType instances admitting multiple satisfying value tuples, InhabitanceCertificate.verified may be true while CompletenessCertificate.verified is false.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/MultiplicationCertificate">
    <rdfs:label>MultiplicationCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting the cost-optimal Toom-Cook splitting factor R for a Datum&lt;L&gt; × Datum&lt;L&gt; multiplication at a given call-site context (stack budget, const-eval regime). Carries the chosen splitting factor, the recursive sub-multiplication count, and the accumulated Landauer cost in nats (priced per op:OA_5). Produced by resolver:MultiplicationResolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/PartitionCertificate">
    <rdfs:label>PartitionCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting the partition component classification of a Datum, assigning it to one of Irreducible, Reducible, Units, or Exterior via the partition:PartitionComponent enumeration. Produced by the bridge partition walk during grounding.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/GenericImpossibilityCertificate">
    <rdfs:label>GenericImpossibilityCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a resolver&apos;s verdict path produced a generic impossibility witness — the input failed the resolver&apos;s admissibility precondition or decision procedure in a way not covered by a more-specific witness. Returned by every Phase D resolver on failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cert/InhabitanceImpossibilityCertificate">
    <rdfs:label>InhabitanceImpossibilityCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that the inhabitance decider concluded the input is unsatisfiable — there is no value in the carrier that satisfies the declared constraint conjunction. Returned by `resolver::inhabitance::certify` on failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/transformType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transformType</rdfs:label>
    <rdfs:comment>The type of transform this certificate attests to (e.g., &apos;isometry&apos;, &apos;embedding&apos;, &apos;action&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/TransformCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/method">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>method</rdfs:label>
    <rdfs:comment>The verification method used to produce this certificate (e.g., &apos;exhaustive_check&apos;, &apos;symbolic_proof&apos;, &apos;sampling&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/Certificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/operation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operation</rdfs:label>
    <rdfs:comment>The operation this certificate applies to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/InvolutionCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/verified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>verified</rdfs:label>
    <rdfs:comment>Whether this certificate has been verified by the kernel.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/Certificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/wittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLength</rdfs:label>
    <rdfs:comment>The Witt level at which this certificate was produced.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/Certificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/timestamp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>timestamp</rdfs:label>
    <rdfs:comment>The time at which this certificate was issued.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/Certificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifies">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifies</rdfs:label>
    <rdfs:comment>The resource this certificate attests to. Links a certificate to the observable, transform, or other entity it covers.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/Certificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifiedType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedType</rdfs:label>
    <rdfs:comment>The TypeDefinition whose completeness this certificate attests. The kernel issues this certificate after running the ψ pipeline on the type&apos;s constraint set and confirming IT_7d.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/CompletenessCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/auditTrail">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>auditTrail</rdfs:label>
    <rdfs:comment>The audit trail attesting the certification provenance. Links a CompletenessCertificate to its ordered sequence of CompletenessWitness records.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/CompletenessCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/CompletenessAuditTrail"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/witnessCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>witnessCount</rdfs:label>
    <rdfs:comment>Total number of witness steps in this audit trail.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/CompletenessAuditTrail"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifiedGrounding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedGrounding</rdfs:label>
    <rdfs:comment>The GroundedContext whose full saturation this certificate attests. Uses IRI string (cert cannot import state).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/GroundedContext"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/groundingWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingWitness</rdfs:label>
    <rdfs:comment>The GroundingWitness providing step-by-step evidence of the saturation process.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/GroundingWitness"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifiedGeodesic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedGeodesic</rdfs:label>
    <rdfs:comment>The GeodesicTrace whose geodesic status this certificate attests. Uses IRI string (cert cannot import trace).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GeodesicCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/geodesicTrace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>geodesicTrace</rdfs:label>
    <rdfs:comment>The computation trace that this GeodesicCertificate covers. Redundant with certifiedGeodesic but expresses the inverse direction for queryability.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GeodesicCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifiedMeasurement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedMeasurement</rdfs:label>
    <rdfs:comment>The MeasurementEvent whose QM_1 compliance this certificate attests. Uses IRI string (cert cannot import trace).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MeasurementCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/MeasurementEvent"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/vonNeumannEntropy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>vonNeumannEntropy</rdfs:label>
    <rdfs:comment>The von Neumann entropy S_vN of the pre-measurement SuperposedSiteState, recorded by this certificate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MeasurementCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/landauerCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>landauerCost</rdfs:label>
    <rdfs:comment>The Landauer cost incurred by the projective collapse, recorded by this certificate. Equals vonNeumannEntropy at β* = ln 2 per QM_1.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MeasurementCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/evidenceBundle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>evidenceBundle</rdfs:label>
    <rdfs:comment>The GeodesicEvidenceBundle attesting to the decomposed sub-predicates (isAR1Ordered, isDC10Selected) of this GeodesicCertificate&apos;s geodesic claim.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GeodesicCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/GeodesicEvidenceBundle"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/bornRuleVerified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bornRuleVerified</rdfs:label>
    <rdfs:comment>Whether this BornRuleVerification certificate confirms that all outcome probabilities match the Born rule (QM_5): P(k) = |α_k|² for every site k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/BornRuleVerification"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/certifiedChain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certifiedChain</rdfs:label>
    <rdfs:comment>The LiftChain this certificate attests to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/LiftChain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/chainAuditTrail">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>chainAuditTrail</rdfs:label>
    <rdfs:comment>The ordered per-step evidence for this certificate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/ChainAuditTrail"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/targetLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetLevel</rdfs:label>
    <rdfs:comment>The quantum level Q_k at which the certificate was issued.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/sourceLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceLevel</rdfs:label>
    <rdfs:comment>The quantum level Q_j from which the tower was started.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/chainStepCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>chainStepCount</rdfs:label>
    <rdfs:comment>Number of lift steps in this ChainAuditTrail. Must equal chainLength of the certified LiftChain. Distinct from witnessCount (domain-locked to CompletenessAuditTrail).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/ChainAuditTrail"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/isAR1Ordered">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isAR1Ordered</rdfs:label>
    <rdfs:comment>True iff the linked GeodesicTrace is ordered by the AR_1 canonical rewriting rule (smallest lexicographic representative first).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GeodesicEvidenceBundle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/isDC10Selected">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isDC10Selected</rdfs:label>
    <rdfs:comment>True iff each constraint in the trace was selected by the DC_10 Jacobian oracle at the step where it was applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/GeodesicEvidenceBundle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/witness">
    <rdfs:label>witness</rdfs:label>
    <rdfs:comment>A specific value tuple in the carrier when verified is true; absent otherwise. The witness form for cert:InhabitanceCertificate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/InhabitanceCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/ValueTuple"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/searchTrace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>searchTrace</rdfs:label>
    <rdfs:comment>The audit trail of the inhabitance search that produced this certificate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/InhabitanceCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/InhabitanceSearchTrace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cert/grounded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>grounded</rdfs:label>
    <rdfs:comment>The type:ConstrainedType this InhabitanceCertificate is issued for.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/InhabitanceCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/splittingFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>splittingFactor</rdfs:label>
    <rdfs:comment>The Toom-Cook splitting factor R chosen by the multiplication resolver. R = 1 is schoolbook (the const-eval bottom-out); R = 2 is Karatsuba; R &gt;= 3 is Toom-k. The resolver picks the cost-optimal R subject to the call-site&apos;s stack budget and const-eval depth constraints.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MultiplicationCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/subMultiplicationCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>subMultiplicationCount</rdfs:label>
    <rdfs:comment>The number of recursive sub-multiplications the chosen splitting factor induces for one Datum&lt;L&gt; × Datum&lt;L&gt; multiplication at this call site. For splitting factor R, the count is (2R - 1) for R &gt; 1, and 1 for R = 1.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MultiplicationCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cert/landauerCostNats">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>landauerCostNats</rdfs:label>
    <rdfs:comment>The accumulated Landauer cost of the certified multiplication in nats, priced per op:OA_5 (each irreversible bit erasure costs ln 2 nats in the Archimedean completion). Unit: observable:Nats. The value is an xsd:decimal.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cert/MultiplicationCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <!-- Namespace: morphism -->
  <owl:Ontology rdf:about="https://uor.foundation/morphism/">
    <rdfs:label>UOR Transforms and Morphisms</rdfs:label>
    <rdfs:comment>Runtime abstractions for maps between UOR objects: transforms, isometries, embeddings, and group actions. The foundation provides the vocabulary; Prism writes the sentences.</rdfs:comment>
    <uor:space>user</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
    <owl:imports rdf:resource="https://uor.foundation/homology/"/>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
    <owl:imports rdf:resource="https://uor.foundation/derivation/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/morphism/Transform">
    <rdfs:label>Transform</rdfs:label>
    <rdfs:comment>A map between UOR objects. The root abstraction: source, target, and optionally what structure (if any) is preserved. This is what cert:TransformCertificate certifies.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Isometry">
    <rdfs:label>Isometry</rdfs:label>
    <rdfs:comment>A transform that preserves metric structure with respect to a specified metric. In UOR, isometry is metric-relative: neg is a ring isometry, bnot is a Hamming isometry. A transform can be an isometry with respect to one metric but not the other. This is what cert:IsometryCertificate certifies.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Composition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Embedding">
    <rdfs:label>Embedding</rdfs:label>
    <rdfs:comment>An injective, structure-preserving transform across quantum levels. The canonical instance is the level embedding ι : R_n → R_{n&apos;} (n &lt; n&apos;), which preserves addition, multiplication, and content addressing.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Composition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Action">
    <rdfs:label>Action</rdfs:label>
    <rdfs:comment>The mechanism by which a group applies transforms systematically to a set. Each group element induces a transform of the set. The dihedral action on type space is an action by isometries — every element of D_{2^n} produces an isometric transform of 𝒯_n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Composition">
    <rdfs:label>Composition</rdfs:label>
    <rdfs:comment>A transform formed by composing two or more transforms sequentially. The categorical composition operation that turns transforms into a category.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Isometry"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Embedding"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Identity"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Identity">
    <rdfs:label>Identity</rdfs:label>
    <rdfs:comment>The identity transform on a type: maps every element to itself. The categorical identity morphism.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Composition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/CompositionLaw">
    <rdfs:label>CompositionLaw</rdfs:label>
    <rdfs:comment>A law governing how operations compose. Records whether the composition is associative, commutative, and what the result operation is. The critical composition law (neg ∘ bnot = succ) is the foundational instance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/GroundingMap">
    <rdfs:label>GroundingMap</rdfs:label>
    <rdfs:comment>A Transform mapping a surface symbol (any schema:Literal) to its ring datum (a schema:Datum) via the content-addressing bijection. Typed, derivation-witnessed, constraint-preserving map from surface to coordinate. Applies identically across NLP tokens, ARC-AGI grid cells, MIDI notes, pixels, sensor readings, and logical propositions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/ProjectionMap">
    <rdfs:label>ProjectionMap</rdfs:label>
    <rdfs:comment>A Transform mapping a resolved partition:Partition (address neighbourhood) to an ordered sequence of surface symbols. Output ordering determined by the active state:Frame — the same constraint frame that decomposed the input symbol sequence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/GroundingCertificate">
    <rdfs:label>GroundingCertificate</rdfs:label>
    <rdfs:comment>A certificate attesting that a specific grounding round-trip (P∘Π∘G) satisfied the shared-frame condition and landed in the type-equivalent neighbourhood of the source symbol. Witnesses the Surface Symmetry Theorem (op:surfaceSymmetry) for one specific symbol instance.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/TopologicalDelta">
    <rdfs:label>TopologicalDelta</rdfs:label>
    <rdfs:comment>A topological delta: records changes in topological invariants (Betti numbers, Euler characteristic, nerve structure) before and after a morphism.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/ComputationDatum">
    <rdfs:label>ComputationDatum</rdfs:label>
    <rdfs:comment>A datum whose ring value is the content address of a cert:TransformCertificate. Represents a certified computation as a first-class value within the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/ApplicationMorphism">
    <rdfs:label>ApplicationMorphism</rdfs:label>
    <rdfs:comment>A transform that applies a ComputationDatum to an input datum, producing an output datum. The output inherits the certificate of the ComputationDatum.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/PartialApplication">
    <rdfs:label>PartialApplication</rdfs:label>
    <rdfs:comment>A ComputationDatum formed by fixing some but not all inputs of a multi-argument transform.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/TransformComposition">
    <rdfs:label>TransformComposition</rdfs:label>
    <rdfs:comment>A ComputationDatum representing the composition f ∘ g of two ComputationDatums. Certified iff both components are certified and range(g) = domain(f).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/Witness">
    <rdfs:label>Witness</rdfs:label>
    <rdfs:comment>Abstract supertype for one specific input/output pair witnessing a Transform.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/GroundingWitness">
    <rdfs:label>GroundingWitness</rdfs:label>
    <rdfs:comment>One specific surface symbol mapped to one specific grounded address by some GroundingMap.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Witness"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/ProjectionWitness"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/ProjectionWitness">
    <rdfs:label>ProjectionWitness</rdfs:label>
    <rdfs:comment>One specific input partition mapped to one specific surface symbol sequence by some ProjectionMap.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Witness"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/morphism/GroundingWitness"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/SymbolSequence">
    <rdfs:label>SymbolSequence</rdfs:label>
    <rdfs:comment>An ordered sequence of surface symbols. Elements are reified as SequenceElement individuals with explicit position indices.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/morphism/SequenceElement">
    <rdfs:label>SequenceElement</rdfs:label>
    <rdfs:comment>One position in a SymbolSequence: a reified (value, index) pair.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>source</rdfs:label>
    <rdfs:comment>The domain of the transform.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/target">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>target</rdfs:label>
    <rdfs:comment>The codomain of the transform.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/preserves">
    <rdfs:label>preserves</rdfs:label>
    <rdfs:comment>The structure preserved by this transform (if any). E.g., a ring homomorphism preserves addition and multiplication.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/preservesMetric">
    <rdfs:label>preservesMetric</rdfs:label>
    <rdfs:comment>The specific metric this isometry preserves. Points to observable:RingMetric or observable:HammingMetric. A transform that preserves both is an isometry of the full UOR geometry. A transform that preserves one but not the other has nontrivial curvature — observable:CurvatureObservable measures this gap.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Isometry"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/sourceQuantum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceQuantum</rdfs:label>
    <rdfs:comment>The quantum level n of the source ring for an embedding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Embedding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/targetQuantum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetQuantum</rdfs:label>
    <rdfs:comment>The quantum level n&apos; of the target ring for an embedding. Must satisfy n&apos; &gt; n (embeddings go to larger rings).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Embedding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/group">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>group</rdfs:label>
    <rdfs:comment>The group acting in this group action.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Action"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Group"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/actingOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>actingOn</rdfs:label>
    <rdfs:comment>The set being acted upon by this group action.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Action"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/actionIsometry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>actionIsometry</rdfs:label>
    <rdfs:comment>Whether every transform induced by this action is an isometry. True for the dihedral action on 𝒯_n (Frame Theorem).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Action"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/trace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>trace</rdfs:label>
    <rdfs:comment>The computation trace that realized this transform at runtime. A Transform is an abstraction; a trace is the kernel&apos;s record of how it was executed via concrete operations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/composesWith">
    <rdfs:label>composesWith</rdfs:label>
    <rdfs:comment>A transform that this transform can be composed with. The target of this transform must match the source of the composed transform.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/compositionResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionResult</rdfs:label>
    <rdfs:comment>The transform that results from this composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Composition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/compositionComponents">
    <rdfs:label>compositionComponents</rdfs:label>
    <rdfs:comment>A component transform of this composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Composition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/identityOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>identityOn</rdfs:label>
    <rdfs:comment>The type on which this identity transform acts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/compositionOrder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionOrder</rdfs:label>
    <rdfs:comment>The number of component transforms in a composition.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/isAssociative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isAssociative</rdfs:label>
    <rdfs:comment>Whether this composition law is associative.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/isCommutative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isCommutative</rdfs:label>
    <rdfs:comment>Whether this composition law is commutative.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/lawComponents">
    <rdfs:label>lawComponents</rdfs:label>
    <rdfs:comment>An operation that is a component of this composition law.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/lawResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>lawResult</rdfs:label>
    <rdfs:comment>The operation that results from this composition law.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/preservedInvariant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preservedInvariant</rdfs:label>
    <rdfs:comment>The identity preserved by this transform (reference to the op:Identity that the transform commutes with).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/addressCoherence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>addressCoherence</rdfs:label>
    <rdfs:comment>Certificate that this embedding&apos;s addressing diagram commutes: glyph ∘ ι ∘ addresses is well-defined and injective.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Embedding"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/bettisBefore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bettisBefore</rdfs:label>
    <rdfs:comment>Betti numbers before the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/BettiNumber"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/bettisAfter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bettisAfter</rdfs:label>
    <rdfs:comment>Betti numbers after the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/BettiNumber"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/eulerBefore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>eulerBefore</rdfs:label>
    <rdfs:comment>Euler characteristic before the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/eulerAfter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>eulerAfter</rdfs:label>
    <rdfs:comment>Euler characteristic after the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/nerveBefore">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nerveBefore</rdfs:label>
    <rdfs:comment>Constraint nerve (simplicial complex) before the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/nerveAfter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nerveAfter</rdfs:label>
    <rdfs:comment>Constraint nerve (simplicial complex) after the morphism.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/surfaceSymbol">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>surfaceSymbol</rdfs:label>
    <rdfs:comment>The surface symbol that is the source of this grounding witness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/SurfaceSymbol"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundedAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedAddress</rdfs:label>
    <rdfs:comment>The resolved ring address that is the target of this grounding witness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundingDerivation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingDerivation</rdfs:label>
    <rdfs:comment>The derivation witnessing the content-addressing computation that produced the grounded address from the surface symbol.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/Derivation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/symbolConstraints">
    <rdfs:label>symbolConstraints</rdfs:label>
    <rdfs:comment>A typed attribute preserved by this grounding. Non-functional: one assertion per active constraint axis (vertical, horizontal, diagonal).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/projectionFrame">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>projectionFrame</rdfs:label>
    <rdfs:comment>The active frame — shared with the grounding that produced the query. The shared-frame condition (Surface Symmetry Theorem) requires G and P to reference the same frame.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Frame"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/projectionSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>projectionSource</rdfs:label>
    <rdfs:comment>The resolved partition (address neighbourhood) that this projection witness projects back to surface symbols.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/projectionOrder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>projectionOrder</rdfs:label>
    <rdfs:comment>Ordering constraint determining the output symbol sequence. Domain-specific: syntactic position (NLP), row-major scan (ARC), temporal sequence (music).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Conjunction"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/roundTripCoherence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>roundTripCoherence</rdfs:label>
    <rdfs:comment>Completeness criterion: does projecting the grounded source address recover a symbol in the same type class as the input? True iff the shared-frame condition holds.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundingCertMap">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingCertMap</rdfs:label>
    <rdfs:comment>The GroundingMap used in this certified round-trip.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundingCertProjection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingCertProjection</rdfs:label>
    <rdfs:comment>The ProjectionMap used in this certified round-trip.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundingCertSourceSymbol">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingCertSourceSymbol</rdfs:label>
    <rdfs:comment>The surface symbol that entered the grounding boundary.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Literal"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/groundingCertAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingCertAddress</rdfs:label>
    <rdfs:comment>The ring address the symbol was grounded to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/GroundingCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/referencedCertificate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>referencedCertificate</rdfs:label>
    <rdfs:comment>The certificate this computation datum encodes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/TransformCertificate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/computationAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>computationAddress</rdfs:label>
    <rdfs:comment>The content address of the referenced certificate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/applicationTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>applicationTarget</rdfs:label>
    <rdfs:comment>The computation being applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ApplicationMorphism"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/applicationInput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>applicationInput</rdfs:label>
    <rdfs:comment>The input datum to the application.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ApplicationMorphism"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/partialBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>partialBase</rdfs:label>
    <rdfs:comment>The base computation being partially applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/PartialApplication"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/boundArguments">
    <rdfs:label>boundArguments</rdfs:label>
    <rdfs:comment>The arguments already bound.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/PartialApplication"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/compositionLeft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionLeft</rdfs:label>
    <rdfs:comment>The outer function f in f ∘ g.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TransformComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/compositionRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionRight</rdfs:label>
    <rdfs:comment>The inner function g in f ∘ g.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/TransformComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/remainingArity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>remainingArity</rdfs:label>
    <rdfs:comment>Number of unbound arguments remaining.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/PartialApplication"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/inputClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inputClass</rdfs:label>
    <rdfs:comment>The OWL class of inputs this transform accepts. Uses OWL2 punning so the value is a class IRI treated as an individual at this position.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/outputClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outputClass</rdfs:label>
    <rdfs:comment>The OWL class of outputs this transform produces. Uses OWL2 punning.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/outputElementClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outputElementClass</rdfs:label>
    <rdfs:comment>When outputClass is a sequence type, the OWL class of individual sequence elements. Uses OWL2 punning.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/hasWitness">
    <rdfs:label>hasWitness</rdfs:label>
    <rdfs:comment>Zero or more witness pairs documenting specific input/output bindings of this transform.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/Transform"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/Witness"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/hasElement">
    <rdfs:label>hasElement</rdfs:label>
    <rdfs:comment>Membership of a SymbolSequence. The sequence is reconstructed by sorting elements by elementIndex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/SequenceElement"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/elementValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>elementValue</rdfs:label>
    <rdfs:comment>The surface symbol value of this sequence element.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/SequenceElement"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/SurfaceSymbol"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/morphism/elementIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>elementIndex</rdfs:label>
    <rdfs:comment>The zero-based position of this element in the sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/SequenceElement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/morphism/projectionOutput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>projectionOutput</rdfs:label>
    <rdfs:comment>The single SymbolSequence produced by this projection witness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/morphism/ProjectionWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/criticalComposition">
    <rdf:type rdf:resource="https://uor.foundation/morphism/CompositionLaw"/>
    <rdfs:label>criticalComposition</rdfs:label>
    <rdfs:comment>The critical composition law: neg ∘ bnot = succ. This is the operational form of the critical identity theorem. The composition of the two involutions (neg, bnot) yields the successor operation. Non-associative and non-commutative.</rdfs:comment>
    <uor:morphism/lawComponents rdf:resource="https://uor.foundation/op/neg"/>
    <uor:morphism/lawComponents rdf:resource="https://uor.foundation/op/bnot"/>
    <uor:morphism/lawResult rdf:resource="https://uor.foundation/op/succ"/>
    <uor:morphism/isAssociative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:morphism/isAssociative>
    <uor:morphism/isCommutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:morphism/isCommutative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/IntegerGroundingMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:label>IntegerGroundingMap</rdfs:label>
    <rdfs:comment>Grounds integer surface symbols to ring addresses.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/schema/Literal"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/u/Element"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/Utf8GroundingMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:label>Utf8GroundingMap</rdfs:label>
    <rdfs:comment>Grounds UTF-8 host strings to ring addresses.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/u/Element"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/JsonGroundingMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:label>JsonGroundingMap</rdfs:label>
    <rdfs:comment>Grounds JSON host strings to ring addresses.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/u/Element"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/DigestGroundingMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:label>DigestGroundingMap</rdfs:label>
    <rdfs:comment>A GroundingMap that maps fixed-size external byte strings to ring datums via a one-way digest function (e.g., SHA-256). Total but not invertible: every input grounds, but distinct inputs may collide; the inverse is computationally unbounded. Preserves no algebraic structure.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/u/Element"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/BinaryGroundingMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
    <rdfs:label>BinaryGroundingMap</rdfs:label>
    <rdfs:comment>A GroundingMap that maps host-supplied byte sequences to ring datums via a fixed bit-pattern interpretation (e.g., little-endian unsigned integer reading). Total and invertible on its declared bit-width; preserves no algebraic structure beyond bit identity.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/u/Element"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/IntegerProjectionMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:label>IntegerProjectionMap</rdfs:label>
    <rdfs:comment>Projects partitions to integer symbol sequences.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/partition/Partition"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <uor:morphism/outputElementClass rdf:resource="https://uor.foundation/schema/Literal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/Utf8ProjectionMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:label>Utf8ProjectionMap</rdfs:label>
    <rdfs:comment>Projects partitions to UTF-8 symbol sequences.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/partition/Partition"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <uor:morphism/outputElementClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/JsonProjectionMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:label>JsonProjectionMap</rdfs:label>
    <rdfs:comment>Projects partitions to JSON symbol sequences.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/partition/Partition"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <uor:morphism/outputElementClass rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/DigestProjectionMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:label>DigestProjectionMap</rdfs:label>
    <rdfs:comment>Projects partitions to fixed-size digest symbol sequences. Dual of DigestGroundingMap.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/partition/Partition"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <uor:morphism/outputElementClass rdf:resource="https://uor.foundation/schema/Literal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/morphism/BinaryProjectionMap">
    <rdf:type rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
    <rdfs:label>BinaryProjectionMap</rdfs:label>
    <rdfs:comment>Projects partitions to raw byte symbol sequences. Dual of BinaryGroundingMap.</rdfs:comment>
    <uor:morphism/inputClass rdf:resource="https://uor.foundation/partition/Partition"/>
    <uor:morphism/outputClass rdf:resource="https://uor.foundation/morphism/SymbolSequence"/>
    <uor:morphism/outputElementClass rdf:resource="https://uor.foundation/schema/Literal"/>
  </owl:NamedIndividual>

  <!-- Namespace: state -->
  <owl:Ontology rdf:about="https://uor.foundation/state/">
    <rdfs:label>UOR State</rdfs:label>
    <rdfs:comment>Parameterized address spaces, context management, binding lifecycle, and state transitions. The user-space overlay onto the kernel&apos;s read-only ring substrate.</rdfs:comment>
    <uor:space>user</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/state/Context">
    <rdfs:label>Context</rdfs:label>
    <rdfs:comment>A bounded set of populated UOR addresses. The parameter space for a resolution cycle. Contexts hold bindings that map addresses to datum values.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Binding"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Frame"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Transition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/Binding">
    <rdfs:label>Binding</rdfs:label>
    <rdfs:comment>The association of a datum value with an address in a context. The write primitive: creating a binding populates an address.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Context"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Frame"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Transition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/Frame">
    <rdfs:label>Frame</rdfs:label>
    <rdfs:comment>The visibility boundary determining which bindings are in scope for a given resolution. A frame is a view into a context: it selects which bindings the resolver sees.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Context"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Binding"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Transition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/Transition">
    <rdfs:label>Transition</rdfs:label>
    <rdfs:comment>A state change: the transformation of one context into another through binding or unbinding. The sequence of transitions is the application&apos;s computation history.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Context"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Binding"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Frame"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/SessionBoundaryType">
    <rdfs:label>SessionBoundaryType</rdfs:label>
    <rdfs:comment>A typed controlled vocabulary for session boundary reasons. Each individual names a specific reason a context-reset boundary was triggered during a multi-turn session.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/Session">
    <rdfs:label>Session</rdfs:label>
    <rdfs:comment>A bounded sequence of RelationQuery/response pairs sharing a common state:Context. Sessions are the unit of coherent multi-turn reasoning in Prism.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/BindingAccumulator">
    <rdfs:label>BindingAccumulator</rdfs:label>
    <rdfs:comment>The mutable accumulator that appends state:Binding instances to a state:Context as each RelationQuery resolves. Tracks monotonic reduction of aggregate free site space.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/SessionBoundary">
    <rdfs:label>SessionBoundary</rdfs:label>
    <rdfs:comment>Marks a context-reset event within a session stream. Records why the context was reset and provides a clean state:Context for subsequent queries.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/GroundedContext">
    <rdfs:label>GroundedContext</rdfs:label>
    <rdfs:comment>A context that has reached full saturation: σ = 1, freeRank = 0, S = 0, T_ctx = 0 (SC_4). The ground state of the type system. All subsequent queries resolve in O(1) via SC_5.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/state/Context"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/GroundingWitness">
    <rdfs:label>GroundingWitness</rdfs:label>
    <rdfs:comment>Step-by-step evidence of the saturation process: records which bindings were applied, in what order, to reach full saturation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/DomainGroundingRecord">
    <rdfs:label>DomainGroundingRecord</rdfs:label>
    <rdfs:comment>An informational/monitoring record tracking the saturation progress of a specific domain within a context. Carries no formal authority — purely observational.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/GroundingPhase">
    <rdfs:label>GroundingPhase</rdfs:label>
    <rdfs:comment>A typed controlled vocabulary for the three phases of context saturation: Open (σ = 0), PartialGrounding (0 &lt; σ &lt; 1), and FullGrounding (σ = 1).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/SharedContext">
    <rdfs:label>SharedContext</rdfs:label>
    <rdfs:comment>A Context visible to more than one Session simultaneously. Holds a set of ContextLease instances that partition its site coordinates among active sessions. Lease disjointness (SR_9) prevents concurrent write conflicts.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/state/Context"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/ContextLease">
    <rdfs:label>ContextLease</rdfs:label>
    <rdfs:comment>A bounded, exclusive claim on a set of site coordinates within a SharedContext, held by exactly one Session. When the session closes or hits a SessionBoundary, the lease is released and its sites become available for re-leasing.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Context"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Binding"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Frame"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/state/Transition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/state/SessionComposition">
    <rdfs:label>SessionComposition</rdfs:label>
    <rdfs:comment>Records that a Session was formed by merging the binding sets of two or more predecessor sessions. Valid only if all predecessor binding sets pass the cross-session consistency check (SR_8). An invalid composition attempt produces a ContradictionBoundary on the target session.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/address">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>address</rdfs:label>
    <rdfs:comment>The UOR address being bound in this binding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Binding"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/content">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>content</rdfs:label>
    <rdfs:comment>The datum value bound to the address in this binding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Binding"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/boundType">
    <rdfs:label>boundType</rdfs:label>
    <rdfs:comment>The type under which this binding&apos;s datum is resolved.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Binding"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/timestamp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>timestamp</rdfs:label>
    <rdfs:comment>The time at which this binding was created.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Binding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/binding">
    <rdfs:label>binding</rdfs:label>
    <rdfs:comment>A binding held in this context.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/capacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>capacity</rdfs:label>
    <rdfs:comment>The maximum number of bindings this context can hold.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/contentAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>contentAddress</rdfs:label>
    <rdfs:comment>The content-derived address of this context, uniquely identifying its current state in the UOR address space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/wittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLength</rdfs:label>
    <rdfs:comment>The Witt level of this context&apos;s address space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/activeBindings">
    <rdfs:label>activeBindings</rdfs:label>
    <rdfs:comment>The bindings currently in scope for this frame.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Frame"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/context">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>context</rdfs:label>
    <rdfs:comment>The context this frame is a view of.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Frame"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/constraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>constraint</rdfs:label>
    <rdfs:comment>The type:Constraint determining which bindings from the context are visible in this frame. The resolver applies this constraint to filter the context&apos;s binding set, producing the frame&apos;s active bindings. An absent constraint means all bindings are visible.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Frame"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/from">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>from</rdfs:label>
    <rdfs:comment>The context before this transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/to">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>to</rdfs:label>
    <rdfs:comment>The context after this transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/addedBindings">
    <rdfs:label>addedBindings</rdfs:label>
    <rdfs:comment>Bindings added to the context in this transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/removedBindings">
    <rdfs:label>removedBindings</rdfs:label>
    <rdfs:comment>Bindings removed from the context in this transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/trace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>trace</rdfs:label>
    <rdfs:comment>The computation trace recording the kernel operations that effected this state transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/topologicalSnapshot">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>topologicalSnapshot</rdfs:label>
    <rdfs:comment>A snapshot of topological invariants at this transition point.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Transition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/TopologicalDelta"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/sessionBindings">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionBindings</rdfs:label>
    <rdfs:comment>The shared context holding all bindings accumulated across the queries in this session.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Session"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/sessionQueries">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionQueries</rdfs:label>
    <rdfs:comment>The number of RelationQuery evaluations completed in this session.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Session"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/aggregateSiteDeficit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>aggregateSiteDeficit</rdfs:label>
    <rdfs:comment>The aggregate FreeRank deficit across all accumulated bindings: the total remaining free sites that have not yet been closed by resolution. Decreases monotonically as the session progresses.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/BindingAccumulator"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/accumulatedBindings">
    <rdfs:label>accumulatedBindings</rdfs:label>
    <rdfs:comment>A binding accumulated by this accumulator from a resolved RelationQuery.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/BindingAccumulator"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/boundaryReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundaryReason</rdfs:label>
    <rdfs:comment>A human-readable description of why this session boundary was triggered.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionBoundary"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/boundaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundaryType</rdfs:label>
    <rdfs:comment>The typed reason category for this session boundary.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/SessionBoundaryType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/priorContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>priorContext</rdfs:label>
    <rdfs:comment>The state:Context that was active before this boundary reset.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/freshContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>freshContext</rdfs:label>
    <rdfs:comment>The clean state:Context produced after this boundary reset, ready for subsequent queries.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/groundingDegree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingDegree</rdfs:label>
    <rdfs:comment>The saturation degree σ ∈ \[0, 1\] of this context. Defined by SC_2: σ = (n − freeRank) / n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/contextTemperature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>contextTemperature</rdfs:label>
    <rdfs:comment>The context temperature T_ctx ∈ \[0, ln 2\]. Defined by SC_1: T_ctx = freeRank × ln 2 / n. At σ = 1, T_ctx = 0.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/isGrounded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isGrounded</rdfs:label>
    <rdfs:comment>Whether this context has reached full saturation (σ = 1). Equivalent to freeRank = 0, S = 0, T_ctx = 0 per SC_4.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/groundingPhase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingPhase</rdfs:label>
    <rdfs:comment>The current saturation phase of this context: Open, PartialGrounding, or FullGrounding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/GroundingPhase"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/witnessBinding">
    <rdfs:label>witnessBinding</rdfs:label>
    <rdfs:comment>A binding that contributed to the saturation process, recorded in this GroundingWitness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/GroundingWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Binding"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/witnessStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>witnessStep</rdfs:label>
    <rdfs:comment>The step index at which a particular binding was applied during the saturation process.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/GroundingWitness"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/residualFreeCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residualFreeCount</rdfs:label>
    <rdfs:comment>The number of free (unbound) sites remaining in this context. At saturation, residualFreeCount = 0.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/Context"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/groundedContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedContext</rdfs:label>
    <rdfs:comment>The GroundedContext that this DomainGroundingRecord monitors.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/DomainGroundingRecord"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/GroundedContext"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/groundedDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedDomain</rdfs:label>
    <rdfs:comment>The domain within the context being tracked by this DomainGroundingRecord.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/DomainGroundingRecord"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/domainFreeCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>domainFreeCount</rdfs:label>
    <rdfs:comment>The number of free sites remaining in the specific domain tracked by this DomainGroundingRecord.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/DomainGroundingRecord"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/leasedSites">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leasedSites</rdfs:label>
    <rdfs:comment>The subset of sites claimed by this lease. Must be disjoint from all other active leases on the same SharedContext (SR_9).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/ContextLease"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/leaseHolder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseHolder</rdfs:label>
    <rdfs:comment>The Session that holds this lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/ContextLease"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Session"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/leaseSet">
    <rdfs:label>leaseSet</rdfs:label>
    <rdfs:comment>A currently active ContextLease on this SharedContext.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SharedContext"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/ContextLease"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/composedFrom">
    <rdfs:label>composedFrom</rdfs:label>
    <rdfs:comment>A predecessor session contributing bindings to this composition. Non-functional: one composition may merge two or more sessions.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Session"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/compositionCompatible">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionCompatible</rdfs:label>
    <rdfs:comment>Whether all predecessor binding sets passed the SR_8 consistency check. If false, the composition is invalid and must not be used as a session context.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionComposition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/compositionResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionResult</rdfs:label>
    <rdfs:comment>The merged Context produced by a valid composition. Only present when compositionCompatible = true.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/towerConsistencyVerified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>towerConsistencyVerified</rdfs:label>
    <rdfs:comment>Whether the LiftChain tower consistency check (SR_8 parametric extension) was performed across all Q_0 through Q_k levels. Required for compositions involving sessions at Q_1 or higher.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/SessionComposition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/linearSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>linearSite</rdfs:label>
    <rdfs:comment>The site coordinate allocated linearly by this lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/ContextLease"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/state/leaseScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseScope</rdfs:label>
    <rdfs:comment>The lexical or session scope within which this lease is valid.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/ContextLease"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/state/groundedTriad">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedTriad</rdfs:label>
    <rdfs:comment>The triadic coordinate of the datum carried in this grounded context: its (stratum, spectrum, address) bundle. Computed by the kernel at grounding time and immutable thereafter.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/GroundedContext"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Triad"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/ExplicitReset">
    <rdf:type rdf:resource="https://uor.foundation/state/SessionBoundaryType"/>
    <rdfs:label>ExplicitReset</rdfs:label>
    <rdfs:comment>The caller explicitly requested a context reset. All accumulated bindings are discarded.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/ConvergenceBoundary">
    <rdf:type rdf:resource="https://uor.foundation/state/SessionBoundaryType"/>
    <rdfs:label>ConvergenceBoundary</rdfs:label>
    <rdfs:comment>The session resolver determined that no further queries can reduce the aggregate site deficit.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/ContradictionBoundary">
    <rdf:type rdf:resource="https://uor.foundation/state/SessionBoundaryType"/>
    <rdfs:label>ContradictionBoundary</rdfs:label>
    <rdfs:comment>A new query produced a type contradiction with an accumulated binding. Context must reset before resolution can continue.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/Open">
    <rdf:type rdf:resource="https://uor.foundation/state/GroundingPhase"/>
    <rdfs:label>Open</rdfs:label>
    <rdfs:comment>The context has σ = 0: no bindings accumulated, all sites are free. The initial phase of every session.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/PartialGrounding">
    <rdf:type rdf:resource="https://uor.foundation/state/GroundingPhase"/>
    <rdfs:label>PartialGrounding</rdfs:label>
    <rdfs:comment>The context has 0 &lt; σ &lt; 1: some sites are pinned by accumulated bindings, but free sites remain. The accumulation phase.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/FullGrounding">
    <rdf:type rdf:resource="https://uor.foundation/state/GroundingPhase"/>
    <rdfs:label>FullGrounding</rdfs:label>
    <rdfs:comment>The context has σ = 1: all sites are pinned, freeRank = 0. The ground state. All subsequent queries resolve in O(1) via SC_5.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/state/ground_state">
    <rdf:type rdf:resource="https://uor.foundation/state/GroundedContext"/>
    <rdfs:label>ground_state</rdfs:label>
    <rdfs:comment>The canonical ground-state witness: a GroundedContext at σ = 1, freeRank = 0, T_ctx = 0, S = 0 (SC_4). Demonstrates that full saturation is achievable and O(1) resolution (SC_5) is realized.</rdfs:comment>
    <uor:state/groundingDegree rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1</uor:state/groundingDegree>
    <uor:state/contextTemperature rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0</uor:state/contextTemperature>
    <uor:state/isGrounded rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:state/isGrounded>
    <uor:state/residualFreeCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:state/residualFreeCount>
    <uor:state/groundingPhase rdf:resource="https://uor.foundation/state/FullGrounding"/>
  </owl:NamedIndividual>

  <!-- Namespace: reduction -->
  <owl:Ontology rdf:about="https://uor.foundation/reduction/">
    <rdfs:label>UOR Euler Reduction</rdfs:label>
    <rdfs:comment>Sequential composition of the foundation&apos;s nine inter-algebra maps into a parameterized reduction pipeline. Defines stages, phase gates, rollback, and epochs.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/resolver/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/predicate/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/reduction/EulerReduction">
    <rdfs:label>EulerReduction</rdfs:label>
    <rdfs:comment>The composite endofunctor ψ = ψ_9 ∘ … ∘ ψ_1, parameterized by Ω = e^{iπ/6}.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PhaseRotationScheduler">
    <rdfs:label>PhaseRotationScheduler</rdfs:label>
    <rdfs:comment>Schedule Ω⁰, Ω¹, …, Ω⁵ assigning a phase angle to each stage of the reduction.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/TargetConvergenceAngle">
    <rdfs:label>TargetConvergenceAngle</rdfs:label>
    <rdfs:comment>The angle at which the reduction terminates (default: π).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PhaseGateAttestation">
    <rdfs:label>PhaseGateAttestation</rdfs:label>
    <rdfs:comment>Validation at each stage boundary checking that the accumulated phase angle matches the expected Ω^k.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ComplexConjugateRollback">
    <rdfs:label>ComplexConjugateRollback</rdfs:label>
    <rdfs:comment>Recovery operation when a phase gate fails: z → z̄. Involutory: applying twice yields the original value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ReductionStep">
    <rdfs:label>ReductionStep</rdfs:label>
    <rdfs:comment>A named stage of the reduction. The standard reduction has six stages (Initialization through Convergence).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ReductionState">
    <rdfs:label>ReductionState</rdfs:label>
    <rdfs:comment>State of reduction execution at a specific point, including the current stage, phase angle, and pinned mask.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ReductionRule">
    <rdfs:label>ReductionRule</rdfs:label>
    <rdfs:comment>Guard-effect pair governing stage transitions in the reduction. The guard must be satisfied before the effect is applied.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/Epoch">
    <rdfs:label>Epoch</rdfs:label>
    <rdfs:comment>Temporal segment of reduction execution. Each epoch represents one complete pass through the reduction stages.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/EpochBoundary">
    <rdfs:label>EpochBoundary</rdfs:label>
    <rdfs:comment>Transition between epochs. Carries metadata about the epoch boundary crossing.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PredicateExpression">
    <rdfs:label>PredicateExpression</rdfs:label>
    <rdfs:comment>A Boolean expression over the reduction state. The atomic guard unit.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/GuardExpression">
    <rdfs:label>GuardExpression</rdfs:label>
    <rdfs:comment>A conjunction of PredicateExpressions that must hold for a transition to fire.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/TransitionEffect">
    <rdfs:label>TransitionEffect</rdfs:label>
    <rdfs:comment>State changes applied when a transition fires. Contains PropertyBind steps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PropertyBind">
    <rdfs:label>PropertyBind</rdfs:label>
    <rdfs:comment>A single site pinning: target site + value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ReductionAdvance">
    <rdfs:label>ReductionAdvance</rdfs:label>
    <rdfs:comment>Advancement from one ReductionStep to the next.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ServiceWindow">
    <rdfs:label>ServiceWindow</rdfs:label>
    <rdfs:comment>A sliding window over recent epochs providing BaseContext.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ReductionTransaction">
    <rdfs:label>ReductionTransaction</rdfs:label>
    <rdfs:comment>An atomic group of state changes within the reduction.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PipelineSuccess">
    <rdfs:label>PipelineSuccess</rdfs:label>
    <rdfs:comment>Successful termination (FullGrounding).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PipelineFailureReason">
    <rdfs:label>PipelineFailureReason</rdfs:label>
    <rdfs:comment>Typed failure: DispatchMiss, GroundingFailure, ConvergenceStall, etc.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/PreflightCheck">
    <rdfs:label>PreflightCheck</rdfs:label>
    <rdfs:comment>A pre-execution validation: feasibility, dispatch coverage, coherence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/FeasibilityResult">
    <rdfs:label>FeasibilityResult</rdfs:label>
    <rdfs:comment>Result of a preflight check: feasibility witness or infeasibility witness.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/LeaseState">
    <rdfs:label>LeaseState</rdfs:label>
    <rdfs:comment>Lifecycle of a partitioned context lease: Pending → Active → Released/Expired/Suspended.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ManagedLease">
    <rdfs:label>ManagedLease</rdfs:label>
    <rdfs:comment>A context lease with lifecycle tracking.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/LeaseCheckpoint">
    <rdfs:label>LeaseCheckpoint</rdfs:label>
    <rdfs:comment>Snapshot of lease state at a point in time.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/BackPressureSignal">
    <rdfs:label>BackPressureSignal</rdfs:label>
    <rdfs:comment>Flow control when reduction produces faster than downstream can consume.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/DeferredQuerySet">
    <rdfs:label>DeferredQuerySet</rdfs:label>
    <rdfs:comment>Queries postponed to a future epoch.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/SubleaseTransfer">
    <rdfs:label>SubleaseTransfer</rdfs:label>
    <rdfs:comment>Transfer of a lease from one computation to another.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ComparisonPredicate">
    <rdfs:label>ComparisonPredicate</rdfs:label>
    <rdfs:comment>Predicate comparing a state field against a value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/ConjunctionPredicate">
    <rdfs:label>ConjunctionPredicate</rdfs:label>
    <rdfs:comment>Conjunction (AND) of multiple predicates.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/DisjunctionPredicate">
    <rdfs:label>DisjunctionPredicate</rdfs:label>
    <rdfs:comment>Disjunction (OR) of multiple predicates.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/NegationPredicate">
    <rdfs:label>NegationPredicate</rdfs:label>
    <rdfs:comment>Negation (NOT) of a single predicate.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/MembershipPredicate">
    <rdfs:label>MembershipPredicate</rdfs:label>
    <rdfs:comment>Predicate testing membership of an element in a set.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/GroundingPredicate">
    <rdfs:label>GroundingPredicate</rdfs:label>
    <rdfs:comment>Predicate testing whether grounding exceeds a threshold.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/SiteCoveragePredicate">
    <rdfs:label>SiteCoveragePredicate</rdfs:label>
    <rdfs:comment>Predicate testing whether a site coverage target is met.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/EqualsPredicate">
    <rdfs:label>EqualsPredicate</rdfs:label>
    <rdfs:comment>Predicate testing equality of two expressions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/NonNullPredicate">
    <rdfs:label>NonNullPredicate</rdfs:label>
    <rdfs:comment>Predicate testing that a field is non-null.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/QuerySubtypePredicate">
    <rdfs:label>QuerySubtypePredicate</rdfs:label>
    <rdfs:comment>Predicate testing whether a query is a subtype of a given type.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/CompileUnit">
    <rdfs:label>CompileUnit</rdfs:label>
    <rdfs:comment>The typed input graph submitted to the reduction pipeline. Packages a root Term, target quantum level, verification domains, and thermodynamic budget. Stage 0 accepts exactly one CompileUnit and initializes the reduction state vector from it.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/FailureField">
    <rdfs:label>FailureField</rdfs:label>
    <rdfs:comment>An ontology fact describing a single field on a reduction:PipelineFailureReason variant. The v0.2.1 Rust codegen walks FailureField individuals filtered by ofFailure to assemble the PipelineFailure enum&apos;s variant fields. Adding a new field to a failure variant requires only adding a new FailureField individual.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/SatBound">
    <rdfs:label>SatBound</rdfs:label>
    <rdfs:comment>Declarative bound for SAT-fragment deciders. The v0.2.1 pipeline driver reads these individuals at codegen time to emit the bounded iterative Tarjan SCC (2-SAT) and unit propagation (Horn-SAT) implementations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/reduction/TimingBound">
    <rdfs:label>TimingBound</rdfs:label>
    <rdfs:comment>Declarative timing bound for reduction pipeline stages. Values in nanoseconds at the v0.2.1 reference hardware.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/phaseParameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseParameter</rdfs:label>
    <rdfs:comment>The base phase parameter Ω for this reduction (e.g., e^{iπ/6}).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/stageCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stageCount</rdfs:label>
    <rdfs:comment>The number of stages in this reduction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/convergenceAngle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>convergenceAngle</rdfs:label>
    <rdfs:comment>The cumulative phase angle at which the reduction converges.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/composedOfMaps">
    <rdfs:label>composedOfMaps</rdfs:label>
    <rdfs:comment>The ordered list of ψ-maps that compose this reduction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/rotationSchedule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rotationSchedule</rdfs:label>
    <rdfs:comment>String representation of the rotation schedule Ω⁰, Ω¹, …, Ω⁵.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PhaseRotationScheduler"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/baseAngle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseAngle</rdfs:label>
    <rdfs:comment>The base angle π/6 from which the schedule is derived.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PhaseRotationScheduler"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/targetAngle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetAngle</rdfs:label>
    <rdfs:comment>The target convergence angle (default: π).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/TargetConvergenceAngle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/gateStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>gateStage</rdfs:label>
    <rdfs:comment>The reduction stage at which this gate is applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/gateExpectedPhase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>gateExpectedPhase</rdfs:label>
    <rdfs:comment>The expected phase angle Ω^k at this gate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/gateResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>gateResult</rdfs:label>
    <rdfs:comment>Whether the phase gate check passed or failed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/rollbackTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rollbackTarget</rdfs:label>
    <rdfs:comment>The reduction stage to which execution rolls back on gate failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ComplexConjugateRollback"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/stageIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stageIndex</rdfs:label>
    <rdfs:comment>Zero-based index of this stage in the reduction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/stageName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stageName</rdfs:label>
    <rdfs:comment>Human-readable name of this reduction stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/expectedPhase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>expectedPhase</rdfs:label>
    <rdfs:comment>The expected phase angle Ω^k at this stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/entryGuard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>entryGuard</rdfs:label>
    <rdfs:comment>A typed predicate evaluated on the current ReductionState. Must be satisfied to enter this stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/exitGuard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exitGuard</rdfs:label>
    <rdfs:comment>A typed predicate that must be satisfied before the reduction advances past this stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/stageEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stageEffect</rdfs:label>
    <rdfs:comment>The effect applied by this stage upon successful exit.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/currentStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>currentStage</rdfs:label>
    <rdfs:comment>The reduction stage at which execution is currently positioned.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/phaseAngle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseAngle</rdfs:label>
    <rdfs:comment>The accumulated phase angle at the current point.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/pinnedMask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pinnedMask</rdfs:label>
    <rdfs:comment>Bit mask of sites that are pinned (resolved) at this point.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/freeRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>freeRank</rdfs:label>
    <rdfs:comment>The number of free (unresolved) sites at this point.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/transitionGuard">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transitionGuard</rdfs:label>
    <rdfs:comment>A typed GuardedTransition from predicate/ governing the stage transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionRule"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/GuardedTransition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/transitionEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transitionEffect</rdfs:label>
    <rdfs:comment>The effect applied when this transition fires.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionRule"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/transitionAdvance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transitionAdvance</rdfs:label>
    <rdfs:comment>Whether this transition advances to the next stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionRule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/epochIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochIndex</rdfs:label>
    <rdfs:comment>Zero-based index of this epoch in the reduction execution.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/Epoch"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/epochDatum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochDatum</rdfs:label>
    <rdfs:comment>Metadata or summary datum for this epoch.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/Epoch"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/epochBoundaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochBoundaryType</rdfs:label>
    <rdfs:comment>The type of epoch boundary crossing (e.g., normal, forced, timeout).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EpochBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/predicateField">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>predicateField</rdfs:label>
    <rdfs:comment>The state field this predicate tests.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/predicateOperator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>predicateOperator</rdfs:label>
    <rdfs:comment>The comparison operator (e.g., &apos;=&apos;, &apos;&lt;&apos;, &apos;&gt;=&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/predicateValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>predicateValue</rdfs:label>
    <rdfs:comment>The value against which the field is compared.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/guardPredicates">
    <rdfs:label>guardPredicates</rdfs:label>
    <rdfs:comment>The predicate expressions that compose this guard.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/GuardExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/effectBindings">
    <rdfs:label>effectBindings</rdfs:label>
    <rdfs:comment>The property bind steps applied by this effect.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/TransitionEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/PropertyBind"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/bindTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bindTarget</rdfs:label>
    <rdfs:comment>The target site identifier for this binding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PropertyBind"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/bindValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bindValue</rdfs:label>
    <rdfs:comment>The value to pin the target site to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PropertyBind"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/advanceFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>advanceFrom</rdfs:label>
    <rdfs:comment>The source stage of the advancement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionAdvance"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/advanceTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>advanceTo</rdfs:label>
    <rdfs:comment>The target stage of the advancement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionAdvance"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/windowSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>windowSize</rdfs:label>
    <rdfs:comment>The number of recent epochs in this service window.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ServiceWindow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/windowOffset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>windowOffset</rdfs:label>
    <rdfs:comment>The starting epoch offset of this service window.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ServiceWindow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/transactionPolicy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transactionPolicy</rdfs:label>
    <rdfs:comment>The execution policy for this transaction (e.g., AllOrNothing, BestEffort).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionTransaction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/transactionOutcome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transactionOutcome</rdfs:label>
    <rdfs:comment>The outcome of this transaction (e.g., committed, rolled back).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionTransaction"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/failureKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureKind</rdfs:label>
    <rdfs:comment>The kind of pipeline failure (e.g., DispatchMiss, ConvergenceStall).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/preflightKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preflightKind</rdfs:label>
    <rdfs:comment>The kind of preflight check (e.g., feasibility, dispatch coverage).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/preflightResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preflightResult</rdfs:label>
    <rdfs:comment>The result of the preflight check (e.g., pass, fail).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/groundingReached">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingReached</rdfs:label>
    <rdfs:comment>Whether full grounding was achieved.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PipelineSuccess"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/feasibilityKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>feasibilityKind</rdfs:label>
    <rdfs:comment>The kind of feasibility result (e.g., Feasible, Infeasible).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FeasibilityResult"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/feasibilityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>feasibilityWitness</rdfs:label>
    <rdfs:comment>The witness justifying the feasibility or infeasibility result.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FeasibilityResult"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/leasePhase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leasePhase</rdfs:label>
    <rdfs:comment>The lifecycle phase of a lease (e.g., Pending, Active, Released).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/managedLeaseId">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>managedLeaseId</rdfs:label>
    <rdfs:comment>Unique identifier for this managed lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ManagedLease"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/leaseLifecycle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseLifecycle</rdfs:label>
    <rdfs:comment>The current lifecycle state of this managed lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ManagedLease"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/LeaseState"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/checkpointEpoch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>checkpointEpoch</rdfs:label>
    <rdfs:comment>The epoch index at which this checkpoint was taken.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/LeaseCheckpoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/checkpointState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>checkpointState</rdfs:label>
    <rdfs:comment>The reduction state captured at this checkpoint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/LeaseCheckpoint"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionState"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/pressureLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pressureLevel</rdfs:label>
    <rdfs:comment>The current back-pressure level (e.g., Low, Medium, High).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/BackPressureSignal"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/pressureThreshold">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pressureThreshold</rdfs:label>
    <rdfs:comment>The threshold at which back-pressure activates.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/BackPressureSignal"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/deferredCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>deferredCount</rdfs:label>
    <rdfs:comment>The number of queries in this deferred set.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/DeferredQuerySet"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/deferralEpoch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>deferralEpoch</rdfs:label>
    <rdfs:comment>The epoch in which these queries were deferred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/DeferredQuerySet"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/sourceLeaseRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceLeaseRef</rdfs:label>
    <rdfs:comment>The lease being transferred from.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SubleaseTransfer"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/targetLeaseRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetLeaseRef</rdfs:label>
    <rdfs:comment>The lease being transferred to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SubleaseTransfer"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/transferredBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transferredBudget</rdfs:label>
    <rdfs:comment>The site budget transferred between leases.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SubleaseTransfer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/transferCompleted">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transferCompleted</rdfs:label>
    <rdfs:comment>Whether the sublease transfer has been completed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SubleaseTransfer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/comparisonField">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>comparisonField</rdfs:label>
    <rdfs:comment>The state field tested by this comparison predicate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ComparisonPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/comparisonOperator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>comparisonOperator</rdfs:label>
    <rdfs:comment>The comparison operator (e.g., &apos;=&apos;, &apos;&lt;&apos;, &apos;&gt;=&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ComparisonPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/comparisonValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>comparisonValue</rdfs:label>
    <rdfs:comment>The value against which the comparison is made.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ComparisonPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/conjuncts">
    <rdfs:label>conjuncts</rdfs:label>
    <rdfs:comment>A conjunct predicate in a conjunction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ConjunctionPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/disjuncts">
    <rdfs:label>disjuncts</rdfs:label>
    <rdfs:comment>A disjunct predicate in a disjunction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/DisjunctionPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/negatedPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>negatedPredicate</rdfs:label>
    <rdfs:comment>The predicate being negated.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/NegationPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/membershipSet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>membershipSet</rdfs:label>
    <rdfs:comment>The set against which membership is tested.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/MembershipPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/membershipElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>membershipElement</rdfs:label>
    <rdfs:comment>The element being tested for set membership.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/MembershipPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/groundingThreshold">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingThreshold</rdfs:label>
    <rdfs:comment>The grounding threshold above which the predicate holds.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/GroundingPredicate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/coverageTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>coverageTarget</rdfs:label>
    <rdfs:comment>The site coverage target expression.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SiteCoveragePredicate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/equalityLeft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>equalityLeft</rdfs:label>
    <rdfs:comment>The left-hand side of an equality test.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EqualsPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/equalityRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>equalityRight</rdfs:label>
    <rdfs:comment>The right-hand side of an equality test.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EqualsPredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/nonNullField">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nonNullField</rdfs:label>
    <rdfs:comment>The field that must be non-null.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/NonNullPredicate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/queryTypeRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>queryTypeRef</rdfs:label>
    <rdfs:comment>The query type reference for subtype testing.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/QuerySubtypePredicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/siteState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteState</rdfs:label>
    <rdfs:comment>The site state descriptor within a reduction state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/transactionScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transactionScope</rdfs:label>
    <rdfs:comment>The scope of sites affected by this transaction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionTransaction"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/transactionStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>transactionStatus</rdfs:label>
    <rdfs:comment>Current status of this transaction (e.g., pending, committed).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ReductionTransaction"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/baseContextRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseContextRef</rdfs:label>
    <rdfs:comment>Reference to the base context provided by this service window.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ServiceWindow"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/leaseRemainingBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseRemainingBudget</rdfs:label>
    <rdfs:comment>The remaining site budget at this checkpoint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/LeaseCheckpoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/expiryEpoch">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>expiryEpoch</rdfs:label>
    <rdfs:comment>The epoch at which this managed lease expires.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ManagedLease"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/leaseBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseBudget</rdfs:label>
    <rdfs:comment>The total site budget allocated to this managed lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/ManagedLease"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/sourceStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceStage</rdfs:label>
    <rdfs:comment>The source stage emitting back-pressure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/BackPressureSignal"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/targetStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetStage</rdfs:label>
    <rdfs:comment>The target stage receiving back-pressure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/BackPressureSignal"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/deferralReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>deferralReason</rdfs:label>
    <rdfs:comment>The reason for deferring these queries.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/DeferredQuerySet"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/infeasibilityKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>infeasibilityKind</rdfs:label>
    <rdfs:comment>The kind of infeasibility detected.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FeasibilityResult"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/failureStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureStage</rdfs:label>
    <rdfs:comment>The reduction stage at which the pipeline failure occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/finalGrounding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>finalGrounding</rdfs:label>
    <rdfs:comment>The final grounding level achieved on pipeline success.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PipelineSuccess"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/preservedGrounding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preservedGrounding</rdfs:label>
    <rdfs:comment>Whether grounding was preserved across the epoch boundary.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/EpochBoundary"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/rootTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rootTerm</rdfs:label>
    <rdfs:comment>The root term expression of a CompileUnit — the top-level syntactic node from which all sub-expressions descend.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/unitWittLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unitWittLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this CompileUnit operates.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/thermodynamicBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>thermodynamicBudget</rdfs:label>
    <rdfs:comment>The Landauer-bounded energy budget for this CompileUnit&apos;s resolution, measured in k_B T ln 2 units.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/targetDomains">
    <rdfs:label>targetDomains</rdfs:label>
    <rdfs:comment>The verification domain(s) targeted by this CompileUnit.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/VerificationDomain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/unitAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unitAddress</rdfs:label>
    <rdfs:comment>Content-addressable identifier computed as the u:Element of the root term’s transitive closure. Computed by stage_initialization, not declared by the submitter. Excludes budget, domains, and quantum level to enable memoization.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/preflightOrder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preflightOrder</rdfs:label>
    <rdfs:comment>Zero-based execution order for preflight checks. Lower indices execute first. BudgetSolvencyCheck (order 0) must precede all others.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/reduction/ofFailure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ofFailure</rdfs:label>
    <rdfs:comment>The PipelineFailureReason (or class) this field belongs to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/fieldName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fieldName</rdfs:label>
    <rdfs:comment>Snake_case name of the Rust field on the generated PipelineFailure variant.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/fieldType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fieldType</rdfs:label>
    <rdfs:comment>Rust type for the field, expressed as a literal type string the codegen emits verbatim (e.g., &quot;&amp;&apos;static str&quot;, &quot;usize&quot;, &quot;ReductionStep&quot;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/maxVarCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxVarCount</rdfs:label>
    <rdfs:comment>Maximum variable count the SAT decider supports.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SatBound"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/maxClauseCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxClauseCount</rdfs:label>
    <rdfs:comment>Maximum clause count the SAT decider supports.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SatBound"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/maxLiteralsPerClause">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxLiteralsPerClause</rdfs:label>
    <rdfs:comment>Maximum literals per clause (2 for 2-SAT, higher for Horn).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/SatBound"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/preflightBudgetNs">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preflightBudgetNs</rdfs:label>
    <rdfs:comment>Preflight-stage time budget in nanoseconds at the v0.2.1 reference hardware.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/TimingBound"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/reduction/runtimeBudgetNs">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>runtimeBudgetNs</rdfs:label>
    <rdfs:comment>Runtime-stage time budget in nanoseconds at the v0.2.1 reference hardware.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/reduction/TimingBound"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_initialization">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Initialization</rdfs:label>
    <rdfs:comment>Stage 0: initialize state vector to identity.</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:reduction/stageIndex>
    <uor:reduction/stageName>Initialization</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω⁰</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_declare">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Declare</rdfs:label>
    <rdfs:comment>Stage 1: dispatch resolver (δ selects).</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:reduction/stageIndex>
    <uor:reduction/stageName>Declare</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω¹</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_factorize">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Factorize</rdfs:label>
    <rdfs:comment>Stage 2: produce valid ring address (G grounds).</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:reduction/stageIndex>
    <uor:reduction/stageName>Factorize</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω²</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_resolve">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Resolve</rdfs:label>
    <rdfs:comment>Stage 3: resolve constraints (Π terminates).</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</uor:reduction/stageIndex>
    <uor:reduction/stageName>Resolve</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω³</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_attest">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Attest</rdfs:label>
    <rdfs:comment>Stage 4: accumulate without contradiction (α consistent).</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</uor:reduction/stageIndex>
    <uor:reduction/stageName>Attest</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω⁴</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_extract">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Extract</rdfs:label>
    <rdfs:comment>Stage 5: extract coherent output (P projects).</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</uor:reduction/stageIndex>
    <uor:reduction/stageName>Extract</uor:reduction/stageName>
    <uor:reduction/expectedPhase>Ω⁵</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/stage_convergence">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
    <rdfs:label>Convergence</rdfs:label>
    <rdfs:comment>Terminal stage: reduction has reached the convergence angle π.</rdfs:comment>
    <uor:reduction/stageIndex rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</uor:reduction/stageIndex>
    <uor:reduction/stageName>Convergence</uor:reduction/stageName>
    <uor:reduction/expectedPhase>π</uor:reduction/expectedPhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_initialization">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_initialization</rdfs:label>
    <rdfs:comment>Phase gate at stage 0 boundary: checks Ω⁰ = 1.</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_initialization"/>
    <uor:reduction/gateExpectedPhase>Ω⁰</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_declare">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_declare</rdfs:label>
    <rdfs:comment>Phase gate at stage 1 boundary: checks Ω¹.</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_declare"/>
    <uor:reduction/gateExpectedPhase>Ω¹</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_factorize">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_factorize</rdfs:label>
    <rdfs:comment>Phase gate at stage 2 boundary: checks Ω².</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_factorize"/>
    <uor:reduction/gateExpectedPhase>Ω²</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_resolve">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_resolve</rdfs:label>
    <rdfs:comment>Phase gate at stage 3 boundary: checks Ω³.</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_resolve"/>
    <uor:reduction/gateExpectedPhase>Ω³</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_attest">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_attest</rdfs:label>
    <rdfs:comment>Phase gate at stage 4 boundary: checks Ω⁴.</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_attest"/>
    <uor:reduction/gateExpectedPhase>Ω⁴</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/gate_extract">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseGateAttestation"/>
    <rdfs:label>gate_extract</rdfs:label>
    <rdfs:comment>Phase gate at stage 5 boundary: checks Ω⁵.</rdfs:comment>
    <uor:reduction/gateStage rdf:resource="https://uor.foundation/reduction/stage_extract"/>
    <uor:reduction/gateExpectedPhase>Ω⁵</uor:reduction/gateExpectedPhase>
    <uor:reduction/gateResult rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/gateResult>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/euler_reduction_instance">
    <rdf:type rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
    <rdfs:label>euler_reduction_instance</rdfs:label>
    <rdfs:comment>The canonical Euler reduction instance with Ω = e^{iπ/6} and 6 stages.</rdfs:comment>
    <uor:reduction/phaseParameter>e^{iπ/6}</uor:reduction/phaseParameter>
    <uor:reduction/stageCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</uor:reduction/stageCount>
    <uor:reduction/convergenceAngle>π</uor:reduction/convergenceAngle>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/phase_schedule">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PhaseRotationScheduler"/>
    <rdfs:label>phase_schedule</rdfs:label>
    <rdfs:comment>The canonical phase rotation schedule for the 6-stage reduction.</rdfs:comment>
    <uor:reduction/rotationSchedule>Ω⁰, Ω¹, Ω², Ω³, Ω⁴, Ω⁵</uor:reduction/rotationSchedule>
    <uor:reduction/baseAngle>π/6</uor:reduction/baseAngle>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/convergence_target">
    <rdf:type rdf:resource="https://uor.foundation/reduction/TargetConvergenceAngle"/>
    <rdfs:label>convergence_target</rdfs:label>
    <rdfs:comment>The default convergence target angle π.</rdfs:comment>
    <uor:reduction/targetAngle>π</uor:reduction/targetAngle>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/conjugate_rollback">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ComplexConjugateRollback"/>
    <rdfs:label>conjugate_rollback</rdfs:label>
    <rdfs:comment>The canonical complex conjugate rollback operation: z → z̄.</rdfs:comment>
    <uor:reduction/rollbackTarget rdf:resource="https://uor.foundation/reduction/stage_initialization"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/DispatchMiss">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>DispatchMiss</rdfs:label>
    <rdfs:comment>Failure: no resolver matched the dispatch query.</rdfs:comment>
    <uor:reduction/failureKind>DispatchMiss</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/GroundingFailure">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>GroundingFailure</rdfs:label>
    <rdfs:comment>Failure: grounding to a valid ring address failed.</rdfs:comment>
    <uor:reduction/failureKind>GroundingFailure</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/ConvergenceStall">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>ConvergenceStall</rdfs:label>
    <rdfs:comment>Failure: reduction stalled before reaching convergence angle.</rdfs:comment>
    <uor:reduction/failureKind>ConvergenceStall</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/ContradictionDetected">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>ContradictionDetected</rdfs:label>
    <rdfs:comment>Failure: accumulation detected a logical contradiction.</rdfs:comment>
    <uor:reduction/failureKind>ContradictionDetected</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/CoherenceViolation">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>CoherenceViolation</rdfs:label>
    <rdfs:comment>Failure: coherence constraint violated during extraction.</rdfs:comment>
    <uor:reduction/failureKind>CoherenceViolation</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/ShapeMismatch">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineFailureReason"/>
    <rdfs:label>ShapeMismatch</rdfs:label>
    <rdfs:comment>Failure: the CompileUnit&apos;s root term produced a value of a shape other than the caller-declared expected shape. Introduced in v0.2.2 W14 as part of the typed pipeline::run::&lt;T&gt; entry point.</rdfs:comment>
    <uor:reduction/failureKind>ShapeMismatch</uor:reduction/failureKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/FullGroundingSuccess">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PipelineSuccess"/>
    <rdfs:label>FullGroundingSuccess</rdfs:label>
    <rdfs:comment>Successful termination: all sites saturated.</rdfs:comment>
    <uor:reduction/groundingReached rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:reduction/groundingReached>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/FeasibilityCheck">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>FeasibilityCheck</rdfs:label>
    <rdfs:comment>Preflight: checks that the reduction can reach convergence.</rdfs:comment>
    <uor:reduction/preflightKind>Feasibility</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/DispatchCoverageCheck">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>DispatchCoverageCheck</rdfs:label>
    <rdfs:comment>Preflight: checks that every dispatch query has a resolver.</rdfs:comment>
    <uor:reduction/preflightKind>DispatchCoverage</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/PackageCoherenceCheck">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>PackageCoherenceCheck</rdfs:label>
    <rdfs:comment>Preflight: checks package-level coherence constraints.</rdfs:comment>
    <uor:reduction/preflightKind>PackageCoherence</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/default_service_window">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ServiceWindow"/>
    <rdfs:label>default_service_window</rdfs:label>
    <rdfs:comment>The default service window: 3 epochs, zero offset.</rdfs:comment>
    <uor:reduction/windowSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</uor:reduction/windowSize>
    <uor:reduction/windowOffset rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:reduction/windowOffset>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/advance_init_to_declare">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionAdvance"/>
    <rdfs:label>advance_init_to_declare</rdfs:label>
    <rdfs:comment>Advancement from Initialization to Declare.</rdfs:comment>
    <uor:reduction/advanceFrom rdf:resource="https://uor.foundation/reduction/stage_initialization"/>
    <uor:reduction/advanceTo rdf:resource="https://uor.foundation/reduction/stage_declare"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/atomic_transaction">
    <rdf:type rdf:resource="https://uor.foundation/reduction/ReductionTransaction"/>
    <rdfs:label>atomic_transaction</rdfs:label>
    <rdfs:comment>An all-or-nothing atomic reduction transaction.</rdfs:comment>
    <uor:reduction/transactionPolicy>AllOrNothing</uor:reduction/transactionPolicy>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/empty_guard">
    <rdf:type rdf:resource="https://uor.foundation/reduction/GuardExpression"/>
    <rdfs:label>empty_guard</rdfs:label>
    <rdfs:comment>A trivially satisfied guard with no predicates.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/identity_effect">
    <rdf:type rdf:resource="https://uor.foundation/reduction/TransitionEffect"/>
    <rdfs:label>identity_effect</rdfs:label>
    <rdfs:comment>The identity effect: no state changes.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/true_predicate">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
    <rdfs:label>true_predicate</rdfs:label>
    <rdfs:comment>A predicate that always evaluates to true.</rdfs:comment>
    <uor:reduction/predicateField>*</uor:reduction/predicateField>
    <uor:reduction/predicateOperator>true</uor:reduction/predicateOperator>
    <uor:reduction/predicateValue>*</uor:reduction/predicateValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/noop_bind">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PropertyBind"/>
    <rdfs:label>noop_bind</rdfs:label>
    <rdfs:comment>A no-op property binding that changes nothing.</rdfs:comment>
    <uor:reduction/bindTarget>none</uor:reduction/bindTarget>
    <uor:reduction/bindValue>unchanged</uor:reduction/bindValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/Pending">
    <rdf:type rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:label>Pending</rdfs:label>
    <rdfs:comment>Lease is pending activation.</rdfs:comment>
    <uor:reduction/leasePhase>Pending</uor:reduction/leasePhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/Active">
    <rdf:type rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:label>Active</rdfs:label>
    <rdfs:comment>Lease is active and resources are allocated.</rdfs:comment>
    <uor:reduction/leasePhase>Active</uor:reduction/leasePhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/Released">
    <rdf:type rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:label>Released</rdfs:label>
    <rdfs:comment>Lease has been explicitly released.</rdfs:comment>
    <uor:reduction/leasePhase>Released</uor:reduction/leasePhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/Expired">
    <rdf:type rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:label>Expired</rdfs:label>
    <rdfs:comment>Lease has expired due to timeout.</rdfs:comment>
    <uor:reduction/leasePhase>Expired</uor:reduction/leasePhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/Suspended">
    <rdf:type rdf:resource="https://uor.foundation/reduction/LeaseState"/>
    <rdfs:label>Suspended</rdfs:label>
    <rdfs:comment>Lease is temporarily suspended.</rdfs:comment>
    <uor:reduction/leasePhase>Suspended</uor:reduction/leasePhase>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/FeasibilityWitness">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FeasibilityResult"/>
    <rdfs:label>FeasibilityWitness</rdfs:label>
    <rdfs:comment>Preflight result: reduction is feasible.</rdfs:comment>
    <uor:reduction/feasibilityKind>Feasible</uor:reduction/feasibilityKind>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/InfeasibilityWitness">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FeasibilityResult"/>
    <rdfs:label>InfeasibilityWitness</rdfs:label>
    <rdfs:comment>Preflight result: reduction is infeasible.</rdfs:comment>
    <uor:reduction/feasibilityKind>Infeasible</uor:reduction/feasibilityKind>
    <uor:reduction/feasibilityWitness>obstruction detected</uor:reduction/feasibilityWitness>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/PreflightTiming">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>PreflightTiming</rdfs:label>
    <rdfs:comment>Preflight: timing feasibility check.</rdfs:comment>
    <uor:reduction/preflightKind>Timing</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/RuntimeTiming">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>RuntimeTiming</rdfs:label>
    <rdfs:comment>Preflight: runtime timing bounds check.</rdfs:comment>
    <uor:reduction/preflightKind>RuntimeTiming</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/BudgetSolvencyCheck">
    <rdf:type rdf:resource="https://uor.foundation/reduction/PreflightCheck"/>
    <rdfs:label>BudgetSolvencyCheck</rdfs:label>
    <rdfs:comment>Preflight: verifies thermodynamicBudget ≥ bitsWidth(unitWittLevel) × ln 2. Rejects the CompileUnit if the budget is absent or insufficient. Must execute before all other preflights (preflightOrder 0). Cost is O(1) per CS_4.</rdfs:comment>
    <uor:reduction/preflightKind>BudgetSolvency</uor:reduction/preflightKind>
    <uor:reduction/preflightOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:reduction/preflightOrder>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/BackPressureDefault">
    <rdf:type rdf:resource="https://uor.foundation/reduction/BackPressureSignal"/>
    <rdfs:label>BackPressureDefault</rdfs:label>
    <rdfs:comment>Default back-pressure signal with medium threshold.</rdfs:comment>
    <uor:reduction/pressureLevel>Medium</uor:reduction/pressureLevel>
    <uor:reduction/pressureThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.75</uor:reduction/pressureThreshold>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/dispatchMiss_queryIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>dispatchMiss_queryIri_field</rdfs:label>
    <rdfs:comment>DispatchMiss field carrying the query IRI that failed to dispatch.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/DispatchMiss"/>
    <uor:reduction/fieldName>query_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/dispatchMiss_tableIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>dispatchMiss_tableIri_field</rdfs:label>
    <rdfs:comment>DispatchMiss field carrying the dispatch table IRI that failed to find a matching rule.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/DispatchMiss"/>
    <uor:reduction/fieldName>table_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/groundingFailure_reasonIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>groundingFailure_reasonIri_field</rdfs:label>
    <rdfs:comment>GroundingFailure field carrying the morphism:GroundingMap IRI whose image missed the ring.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/GroundingFailure"/>
    <uor:reduction/fieldName>reason_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/convergenceStall_stage_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>convergenceStall_stage_field</rdfs:label>
    <rdfs:comment>ConvergenceStall field carrying the IRI of the ReductionStep at which the phase-rotation scheduler stopped advancing.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ConvergenceStall"/>
    <uor:reduction/fieldName>stage_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/convergenceStall_angle_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>convergenceStall_angle_field</rdfs:label>
    <rdfs:comment>ConvergenceStall field carrying the last reduction:convergenceAngle reached, encoded as a milli-radian integer to preserve `Eq` on PipelineFailure.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ConvergenceStall"/>
    <uor:reduction/fieldName>angle_milliradians</uor:reduction/fieldName>
    <uor:reduction/fieldType>i64</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/contradictionDetected_atStep_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>contradictionDetected_atStep_field</rdfs:label>
    <rdfs:comment>ContradictionDetected field carrying the derivation:stepIndex of the accumulation step.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ContradictionDetected"/>
    <uor:reduction/fieldName>at_step</uor:reduction/fieldName>
    <uor:reduction/fieldType>usize</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/contradictionDetected_traceIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>contradictionDetected_traceIri_field</rdfs:label>
    <rdfs:comment>ContradictionDetected field pointing to the trace:ComputationTrace record.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ContradictionDetected"/>
    <uor:reduction/fieldName>trace_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/coherenceViolation_sitePosition_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>coherenceViolation_sitePosition_field</rdfs:label>
    <rdfs:comment>CoherenceViolation field carrying the site position where the conformance:PackageCoherenceCheck failed.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/CoherenceViolation"/>
    <uor:reduction/fieldName>site_position</uor:reduction/fieldName>
    <uor:reduction/fieldType>usize</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/coherenceViolation_constraintIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>coherenceViolation_constraintIri_field</rdfs:label>
    <rdfs:comment>CoherenceViolation field carrying the failing constraint IRI.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/CoherenceViolation"/>
    <uor:reduction/fieldName>constraint_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/shapeMismatch_expected_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>shapeMismatch_expected_field</rdfs:label>
    <rdfs:comment>ShapeMismatch field carrying the expected shape IRI declared by the caller of pipeline::run::&lt;T&gt;.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ShapeMismatch"/>
    <uor:reduction/fieldName>expected</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/shapeMismatch_got_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>shapeMismatch_got_field</rdfs:label>
    <rdfs:comment>ShapeMismatch field carrying the actual shape IRI produced by the CompileUnit&apos;s root term.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/reduction/ShapeMismatch"/>
    <uor:reduction/fieldName>got</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/liftObstruction_sitePosition_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>liftObstruction_sitePosition_field</rdfs:label>
    <rdfs:comment>LiftObstructionFailure field carrying the site position from the resolver:LiftRefinementSuggestion.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/failure/LiftObstructionFailure"/>
    <uor:reduction/fieldName>site_position</uor:reduction/fieldName>
    <uor:reduction/fieldType>usize</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/liftObstruction_obstructionClassIri_field">
    <rdf:type rdf:resource="https://uor.foundation/reduction/FailureField"/>
    <rdfs:label>liftObstruction_obstructionClassIri_field</rdfs:label>
    <rdfs:comment>LiftObstructionFailure field carrying the obstruction class IRI from the LiftRefinementSuggestion.</rdfs:comment>
    <uor:reduction/ofFailure rdf:resource="https://uor.foundation/failure/LiftObstructionFailure"/>
    <uor:reduction/fieldName>obstruction_class_iri</uor:reduction/fieldName>
    <uor:reduction/fieldType>&amp;&apos;static str</uor:reduction/fieldType>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/TwoSatBound">
    <rdf:type rdf:resource="https://uor.foundation/reduction/SatBound"/>
    <rdfs:label>TwoSatBound</rdfs:label>
    <rdfs:comment>v0.2.1 2-SAT decider bounds. Drives TWO_SAT_MAX_VARS and the corresponding Lean fuel constant.</rdfs:comment>
    <uor:reduction/maxVarCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">256</uor:reduction/maxVarCount>
    <uor:reduction/maxClauseCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">512</uor:reduction/maxClauseCount>
    <uor:reduction/maxLiteralsPerClause rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:reduction/maxLiteralsPerClause>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/HornSatBound">
    <rdf:type rdf:resource="https://uor.foundation/reduction/SatBound"/>
    <rdfs:label>HornSatBound</rdfs:label>
    <rdfs:comment>v0.2.1 Horn-SAT decider bounds.</rdfs:comment>
    <uor:reduction/maxVarCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">256</uor:reduction/maxVarCount>
    <uor:reduction/maxClauseCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">512</uor:reduction/maxClauseCount>
    <uor:reduction/maxLiteralsPerClause rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</uor:reduction/maxLiteralsPerClause>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/PreflightTimingBound">
    <rdf:type rdf:resource="https://uor.foundation/reduction/TimingBound"/>
    <rdfs:label>PreflightTimingBound</rdfs:label>
    <rdfs:comment>v0.2.1 preflight-stage time budget.</rdfs:comment>
    <uor:reduction/preflightBudgetNs rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10000000</uor:reduction/preflightBudgetNs>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/reduction/RuntimeTimingBound">
    <rdf:type rdf:resource="https://uor.foundation/reduction/TimingBound"/>
    <rdfs:label>RuntimeTimingBound</rdfs:label>
    <rdfs:comment>v0.2.1 runtime-stage time budget.</rdfs:comment>
    <uor:reduction/runtimeBudgetNs rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10000000</uor:reduction/runtimeBudgetNs>
  </owl:NamedIndividual>

  <!-- Namespace: convergence -->
  <owl:Ontology rdf:about="https://uor.foundation/convergence/">
    <rdfs:label>UOR Convergence Tower</rdfs:label>
    <rdfs:comment>Hopf convergence tower: four levels R, C, H, O corresponding to the four normed division algebras of dimensions 1, 2, 4, 8. Each level carries a Hopf fibration fiber and Betti signature.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/reduction/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/homology/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/convergence/ConvergenceLevel">
    <rdfs:label>ConvergenceLevel</rdfs:label>
    <rdfs:comment>A level in the convergence tower. Four instances: R (dim 1), C (dim 2), H (dim 4), O (dim 8).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/convergence/HopfFiber">
    <rdfs:label>HopfFiber</rdfs:label>
    <rdfs:comment>The fiber of the Hopf fibration at a convergence level. Four instances: S⁰, S¹, S³, S⁷.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/convergence/ConvergenceResidual">
    <rdfs:label>ConvergenceResidual</rdfs:label>
    <rdfs:comment>The unresolved structure at a convergence level. The β_{2^k−1} = 1 Betti number that persists.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/convergence/CommutativeSubspace">
    <rdfs:label>CommutativeSubspace</rdfs:label>
    <rdfs:comment>The subspace U(1) ⊂ SU(2) selected when pairwise interaction converges.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/convergence/AssociativeSubalgebra">
    <rdfs:label>AssociativeSubalgebra</rdfs:label>
    <rdfs:comment>The subspace H ⊂ O selected when triple interaction converges.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/algebraDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>algebraDimension</rdfs:label>
    <rdfs:comment>The dimension of the division algebra at this level (1, 2, 4, or 8).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/bettiSignature">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bettiSignature</rdfs:label>
    <rdfs:comment>The Betti number signature at this convergence level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/convergence/fiberType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fiberType</rdfs:label>
    <rdfs:comment>The Hopf fiber associated with this convergence level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:range rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/characteristicIdentity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>characteristicIdentity</rdfs:label>
    <rdfs:comment>The characteristic identity at this convergence level (existence, feedback, choice, self-reference).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/levelName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>levelName</rdfs:label>
    <rdfs:comment>Human-readable name of this convergence level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/fiberDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fiberDimension</rdfs:label>
    <rdfs:comment>The dimension of the Hopf fiber sphere.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/totalSpace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>totalSpace</rdfs:label>
    <rdfs:comment>The total space of the Hopf fibration.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/baseSpace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseSpace</rdfs:label>
    <rdfs:comment>The base space of the Hopf fibration.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/fiberSphere">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fiberSphere</rdfs:label>
    <rdfs:comment>The fiber sphere designation (e.g. S⁰, S¹).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/residualBetti">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residualBetti</rdfs:label>
    <rdfs:comment>The persistent Betti number at this residual.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceResidual"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/convergence/residualDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residualDimension</rdfs:label>
    <rdfs:comment>The dimension at which the residual persists.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/ConvergenceResidual"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/convergence/subspaceRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>subspaceRef</rdfs:label>
    <rdfs:comment>The commutative subspace selected by pairwise convergence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/CommutativeSubspace"/>
    <rdfs:range rdf:resource="https://uor.foundation/convergence/CommutativeSubspace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/convergence/subalgebraRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>subalgebraRef</rdfs:label>
    <rdfs:comment>The associative subalgebra selected by triple convergence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/AssociativeSubalgebra"/>
    <rdfs:range rdf:resource="https://uor.foundation/convergence/AssociativeSubalgebra"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/convergence/commutatorRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>commutatorRef</rdfs:label>
    <rdfs:comment>Reference to the commutator pair for this convergence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/CommutativeSubspace"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/Commutator"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/convergence/associatorRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorRef</rdfs:label>
    <rdfs:comment>Reference to the associator triple for this convergence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/convergence/AssociativeSubalgebra"/>
    <rdfs:range rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/L0_State">
    <rdf:type rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:label>L0_State</rdfs:label>
    <rdfs:comment>Level 0: R (reals), dimension 1, existence.</rdfs:comment>
    <uor:convergence/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:convergence/algebraDimension>
    <uor:convergence/bettiSignature>[1]</uor:convergence/bettiSignature>
    <uor:convergence/fiberType rdf:resource="https://uor.foundation/convergence/hopf_S0"/>
    <uor:convergence/characteristicIdentity>existence</uor:convergence/characteristicIdentity>
    <uor:convergence/levelName>R</uor:convergence/levelName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/L1_Memory">
    <rdf:type rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:label>L1_Memory</rdfs:label>
    <rdfs:comment>Level 1: C (complex), dimension 2, feedback.</rdfs:comment>
    <uor:convergence/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:convergence/algebraDimension>
    <uor:convergence/bettiSignature>[1,1]</uor:convergence/bettiSignature>
    <uor:convergence/fiberType rdf:resource="https://uor.foundation/convergence/hopf_S1"/>
    <uor:convergence/characteristicIdentity>feedback</uor:convergence/characteristicIdentity>
    <uor:convergence/levelName>C</uor:convergence/levelName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/L2_Agency">
    <rdf:type rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:label>L2_Agency</rdfs:label>
    <rdfs:comment>Level 2: H (quaternions), dimension 4, choice.</rdfs:comment>
    <uor:convergence/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</uor:convergence/algebraDimension>
    <uor:convergence/bettiSignature>[1,0,0,1]</uor:convergence/bettiSignature>
    <uor:convergence/fiberType rdf:resource="https://uor.foundation/convergence/hopf_S3"/>
    <uor:convergence/characteristicIdentity>choice</uor:convergence/characteristicIdentity>
    <uor:convergence/levelName>H</uor:convergence/levelName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/L3_Self">
    <rdf:type rdf:resource="https://uor.foundation/convergence/ConvergenceLevel"/>
    <rdfs:label>L3_Self</rdfs:label>
    <rdfs:comment>Level 3: O (octonions), dimension 8, self-reference.</rdfs:comment>
    <uor:convergence/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</uor:convergence/algebraDimension>
    <uor:convergence/bettiSignature>[1,0,0,0,0,0,0,1]</uor:convergence/bettiSignature>
    <uor:convergence/fiberType rdf:resource="https://uor.foundation/convergence/hopf_S7"/>
    <uor:convergence/characteristicIdentity>self-reference</uor:convergence/characteristicIdentity>
    <uor:convergence/levelName>O</uor:convergence/levelName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/hopf_S0">
    <rdf:type rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:label>hopf_S0</rdfs:label>
    <rdfs:comment>Hopf fiber S⁰: dimension 0, total space S¹, base pt.</rdfs:comment>
    <uor:convergence/fiberDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:convergence/fiberDimension>
    <uor:convergence/totalSpace>S¹</uor:convergence/totalSpace>
    <uor:convergence/baseSpace>pt</uor:convergence/baseSpace>
    <uor:convergence/fiberSphere>S⁰</uor:convergence/fiberSphere>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/hopf_S1">
    <rdf:type rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:label>hopf_S1</rdfs:label>
    <rdfs:comment>Hopf fiber S¹: dimension 1, total space S³, base S².</rdfs:comment>
    <uor:convergence/fiberDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:convergence/fiberDimension>
    <uor:convergence/totalSpace>S³</uor:convergence/totalSpace>
    <uor:convergence/baseSpace>S²</uor:convergence/baseSpace>
    <uor:convergence/fiberSphere>S¹</uor:convergence/fiberSphere>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/hopf_S3">
    <rdf:type rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:label>hopf_S3</rdfs:label>
    <rdfs:comment>Hopf fiber S³: dimension 3, total space S⁷, base S⁴.</rdfs:comment>
    <uor:convergence/fiberDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</uor:convergence/fiberDimension>
    <uor:convergence/totalSpace>S⁷</uor:convergence/totalSpace>
    <uor:convergence/baseSpace>S⁴</uor:convergence/baseSpace>
    <uor:convergence/fiberSphere>S³</uor:convergence/fiberSphere>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/convergence/hopf_S7">
    <rdf:type rdf:resource="https://uor.foundation/convergence/HopfFiber"/>
    <rdfs:label>hopf_S7</rdfs:label>
    <rdfs:comment>Hopf fiber S⁷: dimension 7, total space S¹⁵, base S⁸.</rdfs:comment>
    <uor:convergence/fiberDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</uor:convergence/fiberDimension>
    <uor:convergence/totalSpace>S¹⁵</uor:convergence/totalSpace>
    <uor:convergence/baseSpace>S⁸</uor:convergence/baseSpace>
    <uor:convergence/fiberSphere>S⁷</uor:convergence/fiberSphere>
  </owl:NamedIndividual>

  <!-- Namespace: division -->
  <owl:Ontology rdf:about="https://uor.foundation/division/">
    <rdfs:label>UOR Division Algebras</rdfs:label>
    <rdfs:comment>The four normed division algebras R, C, H, O and the Cayley-Dickson construction.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/convergence/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/division/NormedDivisionAlgebra">
    <rdfs:label>NormedDivisionAlgebra</rdfs:label>
    <rdfs:comment>An algebra over R that is a division ring with multiplicative norm. Exactly four exist (Hurwitz theorem): R, C, H, O.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/division/CayleyDicksonConstruction">
    <rdfs:label>CayleyDicksonConstruction</rdfs:label>
    <rdfs:comment>The doubling construction that builds each division algebra from the previous: R → C → H → O.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/division/MultiplicationTable">
    <rdfs:label>MultiplicationTable</rdfs:label>
    <rdfs:comment>The explicit product rules for a division algebra’s basis elements.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/division/AlgebraCommutator">
    <rdfs:label>AlgebraCommutator</rdfs:label>
    <rdfs:comment>The commutator [a,b] = ab − ba. Zero for R and C; non-zero for H and O.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/division/AlgebraAssociator">
    <rdfs:label>AlgebraAssociator</rdfs:label>
    <rdfs:comment>The associator [a,b,c] = (ab)c − a(bc). Zero for R, C, H; non-zero for O.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/algebraDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>algebraDimension</rdfs:label>
    <rdfs:comment>The dimension of this division algebra (1, 2, 4, or 8).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/isCommutative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isCommutative</rdfs:label>
    <rdfs:comment>Whether multiplication in this algebra is commutative.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/isAssociative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isAssociative</rdfs:label>
    <rdfs:comment>Whether multiplication in this algebra is associative.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/basisElements">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>basisElements</rdfs:label>
    <rdfs:comment>The basis elements of this division algebra.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/division/algebraMultiplicationTable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>algebraMultiplicationTable</rdfs:label>
    <rdfs:comment>The multiplication table for this algebra.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:range rdf:resource="https://uor.foundation/division/MultiplicationTable"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/division/cayleyDicksonSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cayleyDicksonSource</rdfs:label>
    <rdfs:comment>The source algebra of the Cayley-Dickson doubling.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:range rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/division/cayleyDicksonTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cayleyDicksonTarget</rdfs:label>
    <rdfs:comment>The target algebra of the Cayley-Dickson doubling.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:range rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/adjoinedElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>adjoinedElement</rdfs:label>
    <rdfs:comment>The new basis element adjoined by this doubling step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/division/conjugationRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>conjugationRule</rdfs:label>
    <rdfs:comment>The conjugation and multiplication rule for the adjoined element.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/RealAlgebra">
    <rdf:type rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:label>RealAlgebra</rdfs:label>
    <rdfs:comment>The real numbers R: dimension 1, commutative, associative.</rdfs:comment>
    <uor:division/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:division/algebraDimension>
    <uor:division/isCommutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:division/isCommutative>
    <uor:division/isAssociative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:division/isAssociative>
    <uor:division/basisElements>{1}</uor:division/basisElements>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/ComplexAlgebra">
    <rdf:type rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:label>ComplexAlgebra</rdfs:label>
    <rdfs:comment>The complex numbers C: dimension 2, commutative, associative.</rdfs:comment>
    <uor:division/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:division/algebraDimension>
    <uor:division/isCommutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:division/isCommutative>
    <uor:division/isAssociative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:division/isAssociative>
    <uor:division/basisElements>{1, i}</uor:division/basisElements>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/QuaternionAlgebra">
    <rdf:type rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:label>QuaternionAlgebra</rdfs:label>
    <rdfs:comment>The quaternions H: dimension 4, non-commutative, associative.</rdfs:comment>
    <uor:division/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</uor:division/algebraDimension>
    <uor:division/isCommutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:division/isCommutative>
    <uor:division/isAssociative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:division/isAssociative>
    <uor:division/basisElements>{1, i, j, k}</uor:division/basisElements>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/OctonionAlgebra">
    <rdf:type rdf:resource="https://uor.foundation/division/NormedDivisionAlgebra"/>
    <rdfs:label>OctonionAlgebra</rdfs:label>
    <rdfs:comment>The octonions O: dimension 8, non-commutative, non-associative.</rdfs:comment>
    <uor:division/algebraDimension rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</uor:division/algebraDimension>
    <uor:division/isCommutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:division/isCommutative>
    <uor:division/isAssociative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:division/isAssociative>
    <uor:division/basisElements>{1, i, j, k, l, il, jl, kl}</uor:division/basisElements>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/cayleyDickson_R_to_C">
    <rdf:type rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:label>cayleyDickson_R_to_C</rdfs:label>
    <rdfs:comment>Cayley-Dickson doubling R → C: adjoin i with i² = −1.</rdfs:comment>
    <uor:division/cayleyDicksonSource rdf:resource="https://uor.foundation/division/RealAlgebra"/>
    <uor:division/cayleyDicksonTarget rdf:resource="https://uor.foundation/division/ComplexAlgebra"/>
    <uor:division/adjoinedElement>i</uor:division/adjoinedElement>
    <uor:division/conjugationRule>i² = −1</uor:division/conjugationRule>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/cayleyDickson_C_to_H">
    <rdf:type rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:label>cayleyDickson_C_to_H</rdfs:label>
    <rdfs:comment>Cayley-Dickson doubling C → H: adjoin j with j² = −1, ij = k, ji = −k.</rdfs:comment>
    <uor:division/cayleyDicksonSource rdf:resource="https://uor.foundation/division/ComplexAlgebra"/>
    <uor:division/cayleyDicksonTarget rdf:resource="https://uor.foundation/division/QuaternionAlgebra"/>
    <uor:division/adjoinedElement>j</uor:division/adjoinedElement>
    <uor:division/conjugationRule>ij = k, ji = −k</uor:division/conjugationRule>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/division/cayleyDickson_H_to_O">
    <rdf:type rdf:resource="https://uor.foundation/division/CayleyDicksonConstruction"/>
    <rdfs:label>cayleyDickson_H_to_O</rdfs:label>
    <rdfs:comment>Cayley-Dickson doubling H → O: adjoin l, non-associative Fano plane products.</rdfs:comment>
    <uor:division/cayleyDicksonSource rdf:resource="https://uor.foundation/division/QuaternionAlgebra"/>
    <uor:division/cayleyDicksonTarget rdf:resource="https://uor.foundation/division/OctonionAlgebra"/>
    <uor:division/adjoinedElement>l</uor:division/adjoinedElement>
    <uor:division/conjugationRule>non-associative Fano plane products</uor:division/conjugationRule>
  </owl:NamedIndividual>

  <!-- Namespace: interaction -->
  <owl:Ontology rdf:about="https://uor.foundation/interaction/">
    <rdfs:label>UOR Interaction Algebra</rdfs:label>
    <rdfs:comment>Multi-entity interaction: commutator states, associator triples, negotiation convergence.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/convergence/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/interaction/InteractionContext">
    <rdfs:label>InteractionContext</rdfs:label>
    <rdfs:comment>Two entities sharing sites through composed operations. Properties: entityA, entityB, sharedSiteMask, commutatorNorm.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/CommutatorState">
    <rdfs:label>CommutatorState</rdfs:label>
    <rdfs:comment>The norm ‖[δ_A, ι_B]‖ on shared sites. Zero iff operators commute on the shared domain.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/AssociatorState">
    <rdfs:label>AssociatorState</rdfs:label>
    <rdfs:comment>The norm of the three-way associator on shared sites.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/AssociatorTriple">
    <rdfs:label>AssociatorTriple</rdfs:label>
    <rdfs:comment>Three entities whose interaction exhibits non-associativity due to read-write interleaving.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/ThreeWaySite">
    <rdfs:label>ThreeWaySite</rdfs:label>
    <rdfs:comment>A site shared by all three entities in an AssociatorTriple.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/NegotiationTrace">
    <rdfs:label>NegotiationTrace</rdfs:label>
    <rdfs:comment>Sequence of CommutatorStates across interaction steps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/MutualModelTrace">
    <rdfs:label>MutualModelTrace</rdfs:label>
    <rdfs:comment>Sequence of AssociatorStates across interaction steps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/InteractionNerve">
    <rdfs:label>InteractionNerve</rdfs:label>
    <rdfs:comment>Simplicial complex of N-entity coupling.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/interaction/InteractionComposition">
    <rdfs:label>InteractionComposition</rdfs:label>
    <rdfs:comment>IC(A,B) = κ(session(A,B)). Combined interaction-composition operator.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/entityA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>entityA</rdfs:label>
    <rdfs:comment>First entity in the interaction context.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionContext"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/entityB">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>entityB</rdfs:label>
    <rdfs:comment>Second entity in the interaction context.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionContext"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/sharedSiteMask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sharedSiteMask</rdfs:label>
    <rdfs:comment>Bitmask identifying which sites are shared between the two entities.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionContext"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/commutatorNorm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>commutatorNorm</rdfs:label>
    <rdfs:comment>The norm of the commutator on shared sites. Zero iff the operators commute.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionContext"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/commutatorValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>commutatorValue</rdfs:label>
    <rdfs:comment>The computed commutator norm value.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/CommutatorState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/associatorNorm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorNorm</rdfs:label>
    <rdfs:comment>The norm of the three-way associator on shared sites.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/tripleComponentA">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tripleComponentA</rdfs:label>
    <rdfs:comment>First component datum in the associator triple.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/tripleComponentB">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tripleComponentB</rdfs:label>
    <rdfs:comment>Second component datum in the associator triple.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/tripleComponentC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tripleComponentC</rdfs:label>
    <rdfs:comment>Third component datum in the associator triple.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/sitePosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePosition</rdfs:label>
    <rdfs:comment>The position index of the shared site.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/ThreeWaySite"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/leftGroupingValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftGroupingValue</rdfs:label>
    <rdfs:comment>Value under left-associative grouping (AB)C.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/ThreeWaySite"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/rightGroupingValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightGroupingValue</rdfs:label>
    <rdfs:comment>Value under right-associative grouping A(BC).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/ThreeWaySite"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/isPinned">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isPinned</rdfs:label>
    <rdfs:comment>Whether this site is pinned by a lease constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/ThreeWaySite"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/pinningPair">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pinningPair</rdfs:label>
    <rdfs:comment>Identifier of the entity pair that pins this site.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/ThreeWaySite"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/negotiationSteps">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>negotiationSteps</rdfs:label>
    <rdfs:comment>Number of steps in the negotiation trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/NegotiationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/isConvergent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isConvergent</rdfs:label>
    <rdfs:comment>Whether the trace converges to zero commutator or zero associator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/NegotiationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/modelConvergent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>modelConvergent</rdfs:label>
    <rdfs:comment>Whether the mutual model trace converges.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/MutualModelTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/nerveDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nerveDimension</rdfs:label>
    <rdfs:comment>Maximum dimension of the interaction nerve simplicial complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionNerve"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/nerveBettiNumbers">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nerveBettiNumbers</rdfs:label>
    <rdfs:comment>Betti number sequence of the interaction nerve.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionNerve"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/reificationDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>reificationDepth</rdfs:label>
    <rdfs:comment>Depth of the interaction composition reification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/InteractionComposition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/traceLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>traceLength</rdfs:label>
    <rdfs:comment>The number of steps in a negotiation trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/NegotiationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/convergenceRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>convergenceRate</rdfs:label>
    <rdfs:comment>The rate at which the negotiation trace converges.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/NegotiationTrace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/terminalValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>terminalValue</rdfs:label>
    <rdfs:comment>The terminal value of the negotiation trace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/NegotiationTrace"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/interaction/associatorProfileRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorProfileRef</rdfs:label>
    <rdfs:comment>Reference to the observable describing the associativity profile.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/interaction/associatorNormValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorNormValue</rdfs:label>
    <rdfs:comment>The maximum norm of the associator for this triple.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/interaction/AssociatorTriple"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <!-- Namespace: monoidal -->
  <owl:Ontology rdf:about="https://uor.foundation/monoidal/">
    <rdfs:label>UOR Monoidal Composition</rdfs:label>
    <rdfs:comment>Sequential composition of computations via monoidal product A ⊗ B.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/reduction/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/monoidal/MonoidalProduct">
    <rdfs:label>MonoidalProduct</rdfs:label>
    <rdfs:comment>A ⊗ B: the sequential composition of two computations. Output of A feeds input of B.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/monoidal/MonoidalUnit">
    <rdfs:label>MonoidalUnit</rdfs:label>
    <rdfs:comment>The identity computation I: passes input through unchanged. I ⊗ A ≅ A ≅ A ⊗ I.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/monoidal/MonoidalAssociator">
    <rdfs:label>MonoidalAssociator</rdfs:label>
    <rdfs:comment>The witness that (A⊗B)⊗C ≅ A⊗(B⊗C). The associativity isomorphism.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/leftOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftOperand</rdfs:label>
    <rdfs:comment>The left operand in the monoidal product A ⊗ B.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/rightOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightOperand</rdfs:label>
    <rdfs:comment>The right operand in the monoidal product A ⊗ B.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/composedResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedResult</rdfs:label>
    <rdfs:comment>The result datum of the composed computation A ⊗ B.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/monoidal/saturationValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>saturationValue</rdfs:label>
    <rdfs:comment>σ(A⊗B) relationship: saturation of the sequential composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/unitWitnessRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unitWitnessRef</rdfs:label>
    <rdfs:comment>Certificate witnessing I ⊗ A ≅ A ≅ A ⊗ I.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalUnit"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/associatorLeft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorLeft</rdfs:label>
    <rdfs:comment>The left-grouped product (A⊗B)⊗C.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalAssociator"/>
    <rdfs:range rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/associatorRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorRight</rdfs:label>
    <rdfs:comment>The right-grouped product A⊗(B⊗C).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalAssociator"/>
    <rdfs:range rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/monoidal/associatorWitnessRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associatorWitnessRef</rdfs:label>
    <rdfs:comment>Certificate witnessing the associativity isomorphism (A⊗B)⊗C ≅ A⊗(B⊗C).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/monoidal/MonoidalAssociator"/>
    <rdfs:range rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:ObjectProperty>

  <!-- Namespace: operad -->
  <owl:Ontology rdf:about="https://uor.foundation/operad/">
    <rdfs:label>UOR Operad Composition</rdfs:label>
    <rdfs:comment>Structural type nesting via operad composition. Governs how types compose: Table(Tuple(Sequence(Symbol(...)))).</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/carry/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/operad/StructuralOperad">
    <rdfs:label>StructuralOperad</rdfs:label>
    <rdfs:comment>The composition structure on the eight structural types. Governs how types nest.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/operad/OperadComposition">
    <rdfs:label>OperadComposition</rdfs:label>
    <rdfs:comment>A specific nesting: outer type F applied to inner type G.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/operad/operadStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operadStructure</rdfs:label>
    <rdfs:comment>The structural operad defining this composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/StructuralOperad"/>
    <rdfs:range rdf:resource="https://uor.foundation/operad/StructuralOperad"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/operad/outerType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outerType</rdfs:label>
    <rdfs:comment>The outer type F in the nesting F(G).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/OperadComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/operad/innerType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>innerType</rdfs:label>
    <rdfs:comment>The inner type G in the nesting F(G).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/OperadComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/operad/composedType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedType</rdfs:label>
    <rdfs:comment>The resulting composed type F(G).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/OperadComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/operad/composedSiteCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedSiteCount</rdfs:label>
    <rdfs:comment>Site count of the composed type F(G).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/OperadComposition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/operad/composedGrounding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedGrounding</rdfs:label>
    <rdfs:comment>Grounding of the composed type F(G).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/OperadComposition"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
  </owl:ObjectProperty>

  <!-- Namespace: effect -->
  <owl:Ontology rdf:about="https://uor.foundation/effect/">
    <rdfs:label>UOR Effect Algebra</rdfs:label>
    <rdfs:comment>Typed endomorphisms on state:Context classified by site target. Formalizes what reduction guard-effect pairs do to the site budget.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/effect/Effect">
    <rdfs:label>Effect</rdfs:label>
    <rdfs:comment>A typed endomorphism on state:Context. Maps one site-budget configuration to another. The atomic unit of state mutation in the kernel.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/ReversibleEffect">
    <rdfs:label>ReversibleEffect</rdfs:label>
    <rdfs:comment>An effect that has a well-defined inverse. PinningEffect and PhaseEffect are reversible; ExternalEffect and CompositeEffect are not in general.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/PinningEffect">
    <rdfs:label>PinningEffect</rdfs:label>
    <rdfs:comment>Pins a single free site to a definite value. Decrements freeRank by exactly 1. The effect produced by constraint resolution.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/ReversibleEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/UnbindingEffect">
    <rdfs:label>UnbindingEffect</rdfs:label>
    <rdfs:comment>Releases a pinned site back to free state. Increments freeRank by exactly 1. The effect produced by session boundary reset.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/PhaseEffect">
    <rdfs:label>PhaseEffect</rdfs:label>
    <rdfs:comment>Rotates the reduction phase angle by Ω^k. Does not alter the site budget. The effect produced by reduction step transitions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/ReversibleEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/CompositeEffect">
    <rdfs:label>CompositeEffect</rdfs:label>
    <rdfs:comment>An ordered sequence of effects applied atomically. The composition E₁ ; E₂ applies E₁ then E₂.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/ExternalEffect">
    <rdfs:label>ExternalEffect</rdfs:label>
    <rdfs:comment>An opaque effect declared by a Prism implementation. The kernel treats it as a site-budget transformation satisfying the declared commutation contract. Must carry an effect:externalEffectShape linking to a conformance:EffectShape.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/EffectTarget">
    <rdfs:label>EffectTarget</rdfs:label>
    <rdfs:comment>The set of site coordinates that an effect reads or writes. Determines commutation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/effect/DisjointnessWitness">
    <rdfs:label>DisjointnessWitness</rdfs:label>
    <rdfs:comment>A certificate that two EffectTargets have empty intersection, enabling commutative reordering.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/effectTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>effectTarget</rdfs:label>
    <rdfs:comment>The site coordinates this effect touches.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/targetSites">
    <rdfs:label>targetSites</rdfs:label>
    <rdfs:comment>The individual site coordinates in this target set.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/EffectTarget"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/compositeHead">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositeHead</rdfs:label>
    <rdfs:comment>The first effect in the composite sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/CompositeEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/compositeTail">
    <rdfs:label>compositeTail</rdfs:label>
    <rdfs:comment>Subsequent effects in the composite sequence (ordered by effect:compositeIndex).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/CompositeEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/disjointnessLeft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessLeft</rdfs:label>
    <rdfs:comment>The left target in the disjointness claim.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/DisjointnessWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/disjointnessRight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessRight</rdfs:label>
    <rdfs:comment>The right target in the disjointness claim.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/DisjointnessWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/preContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>preContext</rdfs:label>
    <rdfs:comment>The context before effect application.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/postContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>postContext</rdfs:label>
    <rdfs:comment>The context after effect application.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/effect/externalEffectShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>externalEffectShape</rdfs:label>
    <rdfs:comment>The conformance shape that this external effect satisfies.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/ExternalEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/conformance/EffectShape"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/effect/freeRankDelta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>freeRankDelta</rdfs:label>
    <rdfs:comment>Change in freeRank: −1 for PinningEffect, +1 for UnbindingEffect, 0 for PhaseEffect.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/effect/phaseAngleDelta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseAngleDelta</rdfs:label>
    <rdfs:comment>The phase rotation applied, expressed as Ω^k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/PhaseEffect"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/effect/compositeIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositeIndex</rdfs:label>
    <rdfs:comment>Position within a CompositeEffect sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/effect/isCommutativeWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isCommutativeWith</rdfs:label>
    <rdfs:comment>Computed: true iff effectTargets are disjoint with the compared effect. Derived from DisjointnessWitness existence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/Effect"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/effect/targetCardinality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetCardinality</rdfs:label>
    <rdfs:comment>Number of site coordinates in this target set.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/effect/EffectTarget"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: predicate -->
  <owl:Ontology rdf:about="https://uor.foundation/predicate/">
    <rdfs:label>UOR Predicates and Dispatch</rdfs:label>
    <rdfs:comment>Boolean-valued functions on kernel objects. Formalizes resolver dispatch, reduction guard evaluation, and conditional resolution paths.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/predicate/Predicate">
    <rdfs:label>Predicate</rdfs:label>
    <rdfs:comment>A total, pure, boolean-valued function on a kernel object. Evaluation terminates for all inputs and produces no side effects.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/TypePredicate">
    <rdfs:label>TypePredicate</rdfs:label>
    <rdfs:comment>A predicate over type:TypeDefinition. Used for resolver dispatch.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/StatePredicate">
    <rdfs:label>StatePredicate</rdfs:label>
    <rdfs:comment>A predicate over state:Context or reduction:ReductionState. Used for reduction step guards.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/SitePredicate">
    <rdfs:label>SitePredicate</rdfs:label>
    <rdfs:comment>A predicate over partition:SiteIndex. Used for site-level selection in geodesic resolution.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/DispatchRule">
    <rdfs:label>DispatchRule</rdfs:label>
    <rdfs:comment>A pair (Predicate, Target) where Target is a resolver:Resolver class. The kernel evaluates the predicate; if true, the target resolver is selected.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/DispatchTable">
    <rdfs:label>DispatchTable</rdfs:label>
    <rdfs:comment>An ordered set of DispatchRules for a single dispatch point. Must satisfy exhaustiveness and mutual exclusion.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/GuardedTransition">
    <rdfs:label>GuardedTransition</rdfs:label>
    <rdfs:comment>A triple (StatePredicate, effect:Effect, reduction:ReductionStep). The guard is a StatePredicate; if true, the effect is applied and the reduction advances to the target step.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/MatchArm">
    <rdfs:label>MatchArm</rdfs:label>
    <rdfs:comment>A single case in a pattern match: a Predicate and a result Term. The match evaluates predicates in order and returns the result of the first matching arm.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/predicate/MatchExpression">
    <rdfs:label>MatchExpression</rdfs:label>
    <rdfs:comment>A term formed by evaluating a sequence of MatchArms. Extends the term language with deterministic conditional evaluation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/evaluatesOver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>evaluatesOver</rdfs:label>
    <rdfs:comment>The OWL class of objects this predicate accepts as input.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/dispatchPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchPredicate</rdfs:label>
    <rdfs:comment>The predicate that triggers this dispatch rule.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/dispatchTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchTarget</rdfs:label>
    <rdfs:comment>The resolver class selected when the predicate is satisfied. Range is the OWL class IRI of a resolver:Resolver subclass; v0.2.1 uses class IRIs so the codegen can construct façade structs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/dispatchRules">
    <rdfs:label>dispatchRules</rdfs:label>
    <rdfs:comment>The ordered set of rules in this table.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchTable"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/dispatchPriority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchPriority</rdfs:label>
    <rdfs:comment>Non-negative integer priority. Lower priority values are evaluated first; ties within a DispatchTable are resolved by declaration order.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/evaluatorTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>evaluatorTerm</rdfs:label>
    <rdfs:comment>The evaluator term that must reduce to a boolean-shaped datum on every input of the declared input type.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/terminationWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>terminationWitness</rdfs:label>
    <rdfs:comment>An IRI or identifier of the proof:Proof / proof:ComputationCertificate attesting that the evaluator halts on all inputs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/guardPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>guardPredicate</rdfs:label>
    <rdfs:comment>The guard predicate for this transition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/GuardedTransition"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/guardEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>guardEffect</rdfs:label>
    <rdfs:comment>The effect applied when the guard is satisfied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/GuardedTransition"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/guardTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>guardTarget</rdfs:label>
    <rdfs:comment>The reduction step to advance to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/GuardedTransition"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/matchArms">
    <rdfs:label>matchArms</rdfs:label>
    <rdfs:comment>The ordered arms of this match expression.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/MatchExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/MatchArm"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/armPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>armPredicate</rdfs:label>
    <rdfs:comment>The predicate guarding this arm.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/MatchArm"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/armResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>armResult</rdfs:label>
    <rdfs:comment>The result term if this arm matches.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/MatchArm"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/predicate/boundedEvaluator">
    <rdfs:label>boundedEvaluator</rdfs:label>
    <rdfs:comment>A termination witness for user-declared predicates. Kernel predicates are total by construction; user-declared predicates must carry a descent measure certifying termination.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/DescentMeasure"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/dispatchIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchIndex</rdfs:label>
    <rdfs:comment>Position in the dispatch table (evaluation order).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/isExhaustive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isExhaustive</rdfs:label>
    <rdfs:comment>True iff the disjunction of all dispatch predicates is a tautology over the input class.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchTable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/isMutuallyExclusive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isMutuallyExclusive</rdfs:label>
    <rdfs:comment>True iff no two dispatch predicates can be simultaneously true for any input.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/DispatchTable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/predicate/armIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>armIndex</rdfs:label>
    <rdfs:comment>Position in the match expression (evaluation order).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/predicate/MatchArm"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/always">
    <rdf:type rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:label>always</rdfs:label>
    <rdfs:comment>True on every Datum. Match-arm default catch-all.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/never">
    <rdf:type rdf:resource="https://uor.foundation/predicate/Predicate"/>
    <rdfs:label>never</rdfs:label>
    <rdfs:comment>False on every Datum. Disabled-arm marker.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/isZero">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>isZero</rdfs:label>
    <rdfs:comment>True iff the Datum is the additive identity of its ring.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/isUnit">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>isUnit</rdfs:label>
    <rdfs:comment>True iff the Datum is the multiplicative identity.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/isOdd">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>isOdd</rdfs:label>
    <rdfs:comment>True iff the Datum parity bit is 1.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/isEven">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>isEven</rdfs:label>
    <rdfs:comment>True iff the Datum parity bit is 0.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/isInvolution">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>isInvolution</rdfs:label>
    <rdfs:comment>True iff op(op(x)) = x for the bound op.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/sitePinned">
    <rdf:type rdf:resource="https://uor.foundation/predicate/SitePredicate"/>
    <rdfs:label>sitePinned</rdfs:label>
    <rdfs:comment>True iff the named site coordinate is currently pinned.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/siteFree">
    <rdf:type rdf:resource="https://uor.foundation/predicate/SitePredicate"/>
    <rdfs:label>siteFree</rdfs:label>
    <rdfs:comment>True iff the named site coordinate is currently free.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/contradictionReached">
    <rdf:type rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
    <rdfs:label>contradictionReached</rdfs:label>
    <rdfs:comment>True iff the resolver has entered a ContradictionBoundary.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/state/ContradictionBoundary"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/budgetExhausted">
    <rdf:type rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
    <rdfs:label>budgetExhausted</rdfs:label>
    <rdfs:comment>True iff the FreeRank deficit is zero.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/reductionConverged">
    <rdf:type rdf:resource="https://uor.foundation/predicate/StatePredicate"/>
    <rdfs:label>reductionConverged</rdfs:label>
    <rdfs:comment>True iff the reduction fixpoint has been reached.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/reduction/ReductionState"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/Is2SatShape">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>Is2SatShape</rdfs:label>
    <rdfs:comment>True on ConstrainedType instances whose constraint nerve contains only disjunctions of width ≤ 2.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/IsHornShape">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>IsHornShape</rdfs:label>
    <rdfs:comment>True on ConstrainedType instances whose disjunctions each contain at most one positive literal.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/IsResidualFragment">
    <rdf:type rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
    <rdfs:label>IsResidualFragment</rdfs:label>
    <rdfs:comment>Default (catch-all) predicate. True on ConstrainedType instances not classified by Is2SatShape or IsHornShape.</rdfs:comment>
    <uor:predicate/evaluatesOver rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/InhabitanceDispatchTable">
    <rdf:type rdf:resource="https://uor.foundation/predicate/DispatchTable"/>
    <rdfs:label>InhabitanceDispatchTable</rdfs:label>
    <rdfs:comment>The predicate:DispatchTable governing resolver:InhabitanceResolver. Three rules form a partition of type:ConstrainedType: Is2SatShape → TwoSatDecider (priority 0), IsHornShape → HornSatDecider (priority 1), IsResidualFragment → ResidualVerdictResolver (priority 2, catch-all). Total coverage is enforced by reduction:DispatchCoverageCheck; DispatchMiss is unreachable for this table.</rdfs:comment>
    <uor:predicate/isExhaustive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:predicate/isExhaustive>
    <uor:predicate/isMutuallyExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:predicate/isMutuallyExclusive>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/inhabitance_rule_2sat">
    <rdf:type rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:label>inhabitance_rule_2sat</rdfs:label>
    <rdfs:comment>Dispatch rule 1 of InhabitanceDispatchTable: Is2SatShape → TwoSatDecider at priority 0.</rdfs:comment>
    <uor:predicate/dispatchPredicate rdf:resource="https://uor.foundation/predicate/Is2SatShape"/>
    <uor:predicate/dispatchTarget rdf:resource="https://uor.foundation/resolver/TwoSatDecider"/>
    <uor:predicate/dispatchPriority rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:predicate/dispatchPriority>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/inhabitance_rule_horn">
    <rdf:type rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:label>inhabitance_rule_horn</rdfs:label>
    <rdfs:comment>Dispatch rule 2 of InhabitanceDispatchTable: IsHornShape → HornSatDecider at priority 1.</rdfs:comment>
    <uor:predicate/dispatchPredicate rdf:resource="https://uor.foundation/predicate/IsHornShape"/>
    <uor:predicate/dispatchTarget rdf:resource="https://uor.foundation/resolver/HornSatDecider"/>
    <uor:predicate/dispatchPriority rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:predicate/dispatchPriority>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/predicate/inhabitance_rule_residual">
    <rdf:type rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <rdfs:label>inhabitance_rule_residual</rdfs:label>
    <rdfs:comment>Dispatch rule 3 (catch-all) of InhabitanceDispatchTable: IsResidualFragment → ResidualVerdictResolver at priority 2. Ensures total coverage.</rdfs:comment>
    <uor:predicate/dispatchPredicate rdf:resource="https://uor.foundation/predicate/IsResidualFragment"/>
    <uor:predicate/dispatchTarget rdf:resource="https://uor.foundation/resolver/ResidualVerdictResolver"/>
    <uor:predicate/dispatchPriority rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:predicate/dispatchPriority>
  </owl:NamedIndividual>

  <!-- Namespace: parallel -->
  <owl:Ontology rdf:about="https://uor.foundation/parallel/">
    <rdfs:label>UOR Parallel Composition</rdfs:label>
    <rdfs:comment>Independent computations over provably disjoint site budgets. Formalizes when execution order is irrelevant.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/monoidal/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/parallel/ParallelProduct">
    <rdfs:label>ParallelProduct</rdfs:label>
    <rdfs:comment>A ∥ B: two computations with provably disjoint site targets. Execution order does not affect the result.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/parallel/DisjointnessCertificate">
    <rdfs:label>DisjointnessCertificate</rdfs:label>
    <rdfs:comment>A kernel-produced certificate attesting that the site targets of two computations are disjoint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cert/Certificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/parallel/SynchronizationPoint">
    <rdfs:label>SynchronizationPoint</rdfs:label>
    <rdfs:comment>A point where two parallel computations must agree on shared state before proceeding. Only applicable when parallelism is partial.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/parallel/ParallelTrace">
    <rdfs:label>ParallelTrace</rdfs:label>
    <rdfs:comment>A computation trace recording interleaved steps from two parallel computations. Valid iff every interleaving produces the same final context.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/parallel/SitePartitioning">
    <rdfs:label>SitePartitioning</rdfs:label>
    <rdfs:comment>A partition of the total site budget into disjoint subsets, one per parallel component. The sum of subset cardinalities equals the total site budget.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/leftComputation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftComputation</rdfs:label>
    <rdfs:comment>The left parallel component (itself a sequential computation).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/rightComputation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightComputation</rdfs:label>
    <rdfs:comment>The right parallel component.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/monoidal/MonoidalProduct"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/disjointnessCert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessCert</rdfs:label>
    <rdfs:comment>The certificate proving site disjointness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/parallel/DisjointnessCertificate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/certLeftTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certLeftTarget</rdfs:label>
    <rdfs:comment>The site target of the left computation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/DisjointnessCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/certRightTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>certRightTarget</rdfs:label>
    <rdfs:comment>The site target of the right computation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/DisjointnessCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/syncSites">
    <rdfs:label>syncSites</rdfs:label>
    <rdfs:comment>The shared sites requiring synchronization.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/SynchronizationPoint"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/partitionComponents">
    <rdfs:label>partitionComponents</rdfs:label>
    <rdfs:comment>The disjoint subsets composing the full site budget.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/SitePartitioning"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/EffectTarget"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/parallel/componentCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>componentCount</rdfs:label>
    <rdfs:comment>Number of parallel components.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/SitePartitioning"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/parallel/isFullyDisjoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isFullyDisjoint</rdfs:label>
    <rdfs:comment>True iff site targets have zero overlap (no SynchronizationPoints required).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/parallel/disjointnessCommutation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessCommutation</rdfs:label>
    <rdfs:comment>Declares whether this parallel product commutes with disjoint effects per FX_4.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/parallel/sitePartition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePartition</rdfs:label>
    <rdfs:comment>The partition:Partition this parallel product is over.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/parallel/disjointnessWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessWitness</rdfs:label>
    <rdfs:comment>IRI of a proof of pairwise disjointness of the partition components.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/parallel/ParallelProduct"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <!-- Namespace: stream -->
  <owl:Ontology rdf:about="https://uor.foundation/stream/">
    <rdfs:label>UOR Productive Streams</rdfs:label>
    <rdfs:comment>Coinductive sequences of reduction epochs. Each epoch terminates independently; the stream is the unbounded composition of terminating epochs.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/reduction/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/monoidal/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/stream/ProductiveStream">
    <rdfs:label>ProductiveStream</rdfs:label>
    <rdfs:comment>An unbounded sequence of reduction epochs where each epoch terminates and produces a well-typed output. The coinductive dual of a finite computation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/stream/Epoch">
    <rdfs:label>Epoch</rdfs:label>
    <rdfs:comment>A single bounded iteration within a productive stream. Each epoch is a complete reduction execution from Initialization through Convergence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/stream/EpochBoundary">
    <rdfs:label>EpochBoundary</rdfs:label>
    <rdfs:comment>The transition point between consecutive epochs. Carries the continuation context and the epoch output.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/stream/StreamPrefix">
    <rdfs:label>StreamPrefix</rdfs:label>
    <rdfs:comment>A finite prefix of a productive stream: the first k epochs and their outputs. Every finite prefix is computable in finite time.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/stream/StreamMorphism">
    <rdfs:label>StreamMorphism</rdfs:label>
    <rdfs:comment>A transform between productive streams: maps each epoch of the source to an epoch of the target while preserving the productive property.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/stream/Unfold">
    <rdfs:label>Unfold</rdfs:label>
    <rdfs:comment>The coinductive constructor: given an initial context and a step function (a morphism:ComputationDatum), produces a ProductiveStream. The step function must be certified to always reach reduction convergence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/epochReduction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochReduction</rdfs:label>
    <rdfs:comment>The reduction execution for this epoch.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Epoch"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/EulerReduction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/epochOutput">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochOutput</rdfs:label>
    <rdfs:comment>The output datum produced by this epoch.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Epoch"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/epochContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochContext</rdfs:label>
    <rdfs:comment>The context at the start of this epoch.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Epoch"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/boundaryFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundaryFrom</rdfs:label>
    <rdfs:comment>The epoch that just completed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/EpochBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/stream/Epoch"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/boundaryTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundaryTo</rdfs:label>
    <rdfs:comment>The epoch about to begin.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/EpochBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/stream/Epoch"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/continuationContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>continuationContext</rdfs:label>
    <rdfs:comment>The context carried across the boundary.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/EpochBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/prefixEpochs">
    <rdfs:label>prefixEpochs</rdfs:label>
    <rdfs:comment>The epochs in this prefix (ordered by stream:epochIndex).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/StreamPrefix"/>
    <rdfs:range rdf:resource="https://uor.foundation/stream/Epoch"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/unfoldSeed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unfoldSeed</rdfs:label>
    <rdfs:comment>The initial context for the stream.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Unfold"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/unfoldStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unfoldStep</rdfs:label>
    <rdfs:comment>The certified step function producing each epoch.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Unfold"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/unfoldResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unfoldResult</rdfs:label>
    <rdfs:comment>The stream produced by this unfold.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Unfold"/>
    <rdfs:range rdf:resource="https://uor.foundation/stream/ProductiveStream"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/stream/epochIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>epochIndex</rdfs:label>
    <rdfs:comment>Zero-based index of this epoch in the stream.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/Epoch"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/stream/prefixLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>prefixLength</rdfs:label>
    <rdfs:comment>Number of epochs in this prefix.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/StreamPrefix"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/stream/isProductive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isProductive</rdfs:label>
    <rdfs:comment>Always true by construction: every epoch terminates. Invariant, not computed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/ProductiveStream"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/stream/stepTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepTerm</rdfs:label>
    <rdfs:comment>A term denoting a function from the current seed value to a pair (head, next_seed).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/ProductiveStream"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/stream/productivityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>productivityWitness</rdfs:label>
    <rdfs:comment>IRI of a proof of stream productivity (coinductive well-foundedness).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/stream/ProductiveStream"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <!-- Namespace: failure -->
  <owl:Ontology rdf:about="https://uor.foundation/failure/">
    <rdfs:label>UOR Failure Algebra</rdfs:label>
    <rdfs:comment>Partial computations, typed failure propagation, and recovery. Formalizes how computations that cannot reach convergence are represented, composed, and recovered from within the ring substrate.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/reduction/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
    <owl:imports rdf:resource="https://uor.foundation/proof/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/failure/ComputationResult">
    <rdfs:label>ComputationResult</rdfs:label>
    <rdfs:comment>The outcome of a computation that may fail: either a Success carrying a datum, or a Failure carrying a typed reason. The coproduct of the success and failure cases.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/Success">
    <rdfs:label>Success</rdfs:label>
    <rdfs:comment>A computation that reached convergence and produced a valid datum. Carries the output datum and the computation certificate.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/ComputationResult"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/Failure">
    <rdfs:label>Failure</rdfs:label>
    <rdfs:comment>A computation that could not reach convergence. Carries a typed FailureReason and the reduction state at the point of failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/ComputationResult"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/FailureReason">
    <rdfs:label>FailureReason</rdfs:label>
    <rdfs:comment>A typed classification of why a computation failed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/GuardFailure">
    <rdfs:label>GuardFailure</rdfs:label>
    <rdfs:comment>A reduction step guard evaluated to false and no alternative transition exists.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/ConstraintContradiction">
    <rdfs:label>ConstraintContradiction</rdfs:label>
    <rdfs:comment>Two constraints in the type’s constraint set are jointly unsatisfiable.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/SiteExhaustion">
    <rdfs:label>SiteExhaustion</rdfs:label>
    <rdfs:comment>The linear budget was exhausted before resolution completed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/LiftObstructionFailure">
    <rdfs:label>LiftObstructionFailure</rdfs:label>
    <rdfs:comment>A WittLift encountered a non-trivial obstruction that could not be resolved.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/PartialComputation">
    <rdfs:label>PartialComputation</rdfs:label>
    <rdfs:comment>A computation that produces a ComputationResult rather than a guaranteed datum. The general case of all computations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/TotalComputation">
    <rdfs:label>TotalComputation</rdfs:label>
    <rdfs:comment>A computation where the FailureReason type is empty — failure is structurally impossible.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/failure/PartialComputation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/Recovery">
    <rdfs:label>Recovery</rdfs:label>
    <rdfs:comment>A strategy for converting a Failure into a Success by modifying the computation path.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/failure/FailurePropagation">
    <rdfs:label>FailurePropagation</rdfs:label>
    <rdfs:comment>The rule for how failures compose under monoidal and parallel products.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/resultDatum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>resultDatum</rdfs:label>
    <rdfs:comment>The output datum of a successful computation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Success"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/resultCertificate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>resultCertificate</rdfs:label>
    <rdfs:comment>The certificate attesting the computation’s correctness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Success"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/failureReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureReason</rdfs:label>
    <rdfs:comment>The typed reason for failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Failure"/>
    <rdfs:range rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/failureState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureState</rdfs:label>
    <rdfs:comment>The reduction state at the point of failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Failure"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionState"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/failureStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureStage</rdfs:label>
    <rdfs:comment>The reduction step where failure occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Failure"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/recoveryStrategy">
    <rdfs:label>recoveryStrategy</rdfs:label>
    <rdfs:comment>Available recovery strategies for this failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Failure"/>
    <rdfs:range rdf:resource="https://uor.foundation/failure/Recovery"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/recoveryEffect">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>recoveryEffect</rdfs:label>
    <rdfs:comment>The effect applied to recover from failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Recovery"/>
    <rdfs:range rdf:resource="https://uor.foundation/effect/Effect"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/recoveryTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>recoveryTarget</rdfs:label>
    <rdfs:comment>The reduction step to retry after recovery.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Recovery"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/failure/propagationRule">
    <rdfs:label>propagationRule</rdfs:label>
    <rdfs:comment>Which failure reasons propagate through this composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/FailurePropagation"/>
    <rdfs:range rdf:resource="https://uor.foundation/failure/FailureReason"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/failure/isTotal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isTotal</rdfs:label>
    <rdfs:comment>True iff the computation is a TotalComputation (no possible failure path).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/PartialComputation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/failure/failureDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>failureDepth</rdfs:label>
    <rdfs:comment>The reduction step index at which failure occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/failure/Failure"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: linear -->
  <owl:Ontology rdf:about="https://uor.foundation/linear/">
    <rdfs:label>UOR Linear Resources</rdfs:label>
    <rdfs:comment>Linear discipline on site consumption. Formalizes that each site in a complete resolution path is targeted by exactly one effect.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/linear/LinearSite">
    <rdfs:label>LinearSite</rdfs:label>
    <rdfs:comment>A site index annotated with a linearity constraint: must be pinned exactly once in any complete resolution path.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/linear/LinearEffect">
    <rdfs:label>LinearEffect</rdfs:label>
    <rdfs:comment>A PinningEffect that consumes its target LinearSite. After application, the site is no longer available for pinning by any subsequent effect.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/PinningEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/linear/LinearTrace">
    <rdfs:label>LinearTrace</rdfs:label>
    <rdfs:comment>A computation trace where every site in the budget is targeted by exactly one LinearEffect.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/linear/LinearBudget">
    <rdfs:label>LinearBudget</rdfs:label>
    <rdfs:comment>The multiset of LinearSites available at a given point in resolution. Starts as the full site budget; each LinearEffect removes exactly one element.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/linear/LeaseAllocation">
    <rdfs:label>LeaseAllocation</rdfs:label>
    <rdfs:comment>A binding between a state:ContextLease and a subset of LinearSites. Formalizes what resources a lease claims.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/linear/AffineSite">
    <rdfs:label>AffineSite</rdfs:label>
    <rdfs:comment>A site that may be pinned at most once (but need not be pinned). Relaxation of LinearSite for incomplete resolution paths.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/linearTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>linearTarget</rdfs:label>
    <rdfs:comment>The single site consumed by this effect.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LinearEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/linear/LinearSite"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/budgetSites">
    <rdfs:label>budgetSites</rdfs:label>
    <rdfs:comment>The sites remaining in the budget.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LinearBudget"/>
    <rdfs:range rdf:resource="https://uor.foundation/linear/LinearSite"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/budgetContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>budgetContext</rdfs:label>
    <rdfs:comment>The context associated with this budget state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LinearBudget"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/leaseTarget">
    <rdfs:label>leaseTarget</rdfs:label>
    <rdfs:comment>The sites claimed by this lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LeaseAllocation"/>
    <rdfs:range rdf:resource="https://uor.foundation/linear/LinearSite"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/leaseSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseSource</rdfs:label>
    <rdfs:comment>The ContextLease individual that owns this allocation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LeaseAllocation"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/ContextLease"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/linear/leaseAllocation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseAllocation</rdfs:label>
    <rdfs:comment>Links a state:ContextLease to its LinearSite allocation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/state/ContextLease"/>
    <rdfs:range rdf:resource="https://uor.foundation/linear/LeaseAllocation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/linear/remainingCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>remainingCount</rdfs:label>
    <rdfs:comment>Number of unconsumed sites. Equals freeRank on the associated context.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LinearBudget"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/linear/leaseCardinality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseCardinality</rdfs:label>
    <rdfs:comment>Number of sites claimed by this lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LeaseAllocation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/linear/stackBudgetBytes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stackBudgetBytes</rdfs:label>
    <rdfs:comment>The stack budget available at the call site in bytes. On embedded targets this is compile-time-known; on std targets it is computed from the thread-local stack frame. Consumed by the MultiplicationResolver to bound the admissible Toom-Cook splitting factor R: deeper recursion requires more stack, so R is capped where stack would overflow.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/linear/LinearBudget"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: recursion -->
  <owl:Ontology rdf:about="https://uor.foundation/recursion/">
    <rdfs:label>UOR Bounded Recursion</rdfs:label>
    <rdfs:comment>Self-referential computations with well-founded descent measures guaranteeing termination.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/predicate/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/failure/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/recursion/BoundedRecursion">
    <rdfs:label>BoundedRecursion</rdfs:label>
    <rdfs:comment>A self-referential computation parameterized by a descent measure. Each recursive step strictly decreases the measure; the computation terminates when the base case predicate is satisfied.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/DescentMeasure">
    <rdfs:label>DescentMeasure</rdfs:label>
    <rdfs:comment>A well-founded function from computation state to xsd:nonNegativeInteger. Strictly decreases on every recursive step.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/BaseCase">
    <rdfs:label>BaseCase</rdfs:label>
    <rdfs:comment>The match arm selected when the descent measure reaches zero or the base predicate is satisfied. Produces a direct result without further recursion.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/predicate/MatchArm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/RecursiveCase">
    <rdfs:label>RecursiveCase</rdfs:label>
    <rdfs:comment>The match arm selected when the descent measure is positive. Applies a decomposition step, decreases the measure, and invokes the recursion.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/predicate/MatchArm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/RecursiveStep">
    <rdfs:label>RecursiveStep</rdfs:label>
    <rdfs:comment>A single step in a bounded recursion: the decomposition applied before the recursive invocation. Must strictly decrease the DescentMeasure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/RecursionTrace">
    <rdfs:label>RecursionTrace</rdfs:label>
    <rdfs:comment>A computation trace recording the sequence of recursive steps, measure values, and the base case result. The trace length is bounded by the initial measure value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/trace/ComputationTrace"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/recursion/StructuralRecursion">
    <rdfs:label>StructuralRecursion</rdfs:label>
    <rdfs:comment>A bounded recursion where the descent measure is the structural size of the input type (site count, constraint count, or operad nesting depth).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/measure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>measure</rdfs:label>
    <rdfs:comment>The descent measure guaranteeing termination.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/DescentMeasure"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/baseCase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseCase</rdfs:label>
    <rdfs:comment>The base case match arm.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/BaseCase"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/recursiveCase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>recursiveCase</rdfs:label>
    <rdfs:comment>The recursive case match arm.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/RecursiveCase"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/stepDecomposition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepDecomposition</rdfs:label>
    <rdfs:comment>The transform applied to decompose the input before recursion.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/RecursiveStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/stepMeasurePre">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepMeasurePre</rdfs:label>
    <rdfs:comment>The measure value before this step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/RecursiveStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/DescentMeasure"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/stepMeasurePost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepMeasurePost</rdfs:label>
    <rdfs:comment>The measure value after this step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/RecursiveStep"/>
    <rdfs:range rdf:resource="https://uor.foundation/recursion/DescentMeasure"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/basePredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>basePredicate</rdfs:label>
    <rdfs:comment>The predicate that identifies the base case.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/Predicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/recursion/recursionBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>recursionBody</rdfs:label>
    <rdfs:comment>The computation applied at each recursive step (may reference itself via its content address).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ComputationDatum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/recursion/initialMeasure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>initialMeasure</rdfs:label>
    <rdfs:comment>The measure value at the start of recursion. Bounds the maximum recursion depth.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/BoundedRecursion"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/recursion/measureValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>measureValue</rdfs:label>
    <rdfs:comment>The current value of the descent measure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/recursion/DescentMeasure"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: region -->
  <owl:Ontology rdf:about="https://uor.foundation/region/">
    <rdfs:label>UOR Address Regions</rdfs:label>
    <rdfs:comment>Spatial locality of content-addressed ring elements. Defines computable working sets for resolver stages, independent of physical memory layout.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/region/AddressRegion">
    <rdfs:label>AddressRegion</rdfs:label>
    <rdfs:comment>A contiguous range of u:Element values accessible during a single reduction step. Defines the resolver’s working set.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/region/RegionBound">
    <rdfs:label>RegionBound</rdfs:label>
    <rdfs:comment>The boundary of an AddressRegion: a pair (lowerAddress, upperAddress) in the content-address ordering.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/region/LocalityMetric">
    <rdfs:label>LocalityMetric</rdfs:label>
    <rdfs:comment>A metric on u:Element values determining which addresses are near each other for resolution purposes.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/region/WorkingSet">
    <rdfs:label>WorkingSet</rdfs:label>
    <rdfs:comment>The set of AddressRegions needed by a resolver at a specific reduction step for a specific type. Computable from the type’s constraint nerve.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/region/RegionAllocation">
    <rdfs:label>RegionAllocation</rdfs:label>
    <rdfs:comment>An assignment of AddressRegions to reduction steps for a given computation. Enables Prism to pre-compute memory layout.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/regionLower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>regionLower</rdfs:label>
    <rdfs:comment>The lower bound of the address range.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/RegionBound"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/regionUpper">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>regionUpper</rdfs:label>
    <rdfs:comment>The upper bound of the address range.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/RegionBound"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/regionBound">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>regionBound</rdfs:label>
    <rdfs:comment>The boundary of this region.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/AddressRegion"/>
    <rdfs:range rdf:resource="https://uor.foundation/region/RegionBound"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/localityMetric">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>localityMetric</rdfs:label>
    <rdfs:comment>The metric defining contiguity for this region.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/AddressRegion"/>
    <rdfs:range rdf:resource="https://uor.foundation/region/LocalityMetric"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/workingSetRegions">
    <rdfs:label>workingSetRegions</rdfs:label>
    <rdfs:comment>The address regions composing this working set.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/WorkingSet"/>
    <rdfs:range rdf:resource="https://uor.foundation/region/AddressRegion"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/workingSetStage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>workingSetStage</rdfs:label>
    <rdfs:comment>The reduction step this working set applies to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/WorkingSet"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/workingSetType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>workingSetType</rdfs:label>
    <rdfs:comment>The type being resolved.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/WorkingSet"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/allocationStage">
    <rdfs:label>allocationStage</rdfs:label>
    <rdfs:comment>Reduction steps in this allocation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/RegionAllocation"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/ReductionStep"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/region/allocationWorkingSet">
    <rdfs:label>allocationWorkingSet</rdfs:label>
    <rdfs:comment>The working sets assigned to each stage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/RegionAllocation"/>
    <rdfs:range rdf:resource="https://uor.foundation/region/WorkingSet"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/region/regionCardinality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>regionCardinality</rdfs:label>
    <rdfs:comment>Number of addresses in this region.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/AddressRegion"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/region/workingSetSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>workingSetSize</rdfs:label>
    <rdfs:comment>Total addresses across all regions in the working set.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/region/WorkingSet"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: boundary -->
  <owl:Ontology rdf:about="https://uor.foundation/boundary/">
    <rdfs:label>UOR IO Boundary</rdfs:label>
    <rdfs:comment>Typed interface between kernel computation and the external world. Formalizes how data enters and exits the ring substrate.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/boundary/IOBoundary">
    <rdfs:label>IOBoundary</rdfs:label>
    <rdfs:comment>A typed interface point between the kernel and the external world. Every data flow into or out of the ring crosses exactly one IOBoundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/Source">
    <rdfs:label>Source</rdfs:label>
    <rdfs:comment>A typed source of external data entering the ring. Carries an expected TypeDefinition describing the shape of incoming data.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/boundary/IOBoundary"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/Sink">
    <rdfs:label>Sink</rdfs:label>
    <rdfs:comment>A typed destination for data leaving the ring. Carries an expected TypeDefinition describing the shape of outgoing data.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/boundary/IOBoundary"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/BoundaryEffect">
    <rdfs:label>BoundaryEffect</rdfs:label>
    <rdfs:comment>An effect that crosses the kernel/external boundary. Specializes effect:ExternalEffect with explicit source or sink binding.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/effect/ExternalEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/IngestEffect">
    <rdfs:label>IngestEffect</rdfs:label>
    <rdfs:comment>A BoundaryEffect that reads from a Source and produces a datum in the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/boundary/BoundaryEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/EmitEffect">
    <rdfs:label>EmitEffect</rdfs:label>
    <rdfs:comment>A BoundaryEffect that writes a ring datum to a Sink.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/boundary/BoundaryEffect"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/BoundaryProtocol">
    <rdfs:label>BoundaryProtocol</rdfs:label>
    <rdfs:comment>A specification of the data shape, ordering, and framing constraints for data crossing a boundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/boundary/BoundarySession">
    <rdfs:label>BoundarySession</rdfs:label>
    <rdfs:comment>A Session that includes BoundaryEffects. Extends the session model to track which boundaries were crossed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/state/Session"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/sourceType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceType</rdfs:label>
    <rdfs:comment>The expected type of data arriving from this source.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/Source"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/sinkType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sinkType</rdfs:label>
    <rdfs:comment>The expected type of data departing through this sink.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/Sink"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/effectBoundary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>effectBoundary</rdfs:label>
    <rdfs:comment>The boundary this effect crosses.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundaryEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/boundary/IOBoundary"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/ingestSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ingestSource</rdfs:label>
    <rdfs:comment>The source being read.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/IngestEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/boundary/Source"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/emitSink">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>emitSink</rdfs:label>
    <rdfs:comment>The sink being written to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/EmitEffect"/>
    <rdfs:range rdf:resource="https://uor.foundation/boundary/Sink"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/protocolType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>protocolType</rdfs:label>
    <rdfs:comment>The type specification for boundary data.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundaryProtocol"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/protocolOrdering">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>protocolOrdering</rdfs:label>
    <rdfs:comment>Sequencing constraints on boundary data.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundaryProtocol"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Conjunction"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/boundary/sessionBoundaries">
    <rdfs:label>sessionBoundaries</rdfs:label>
    <rdfs:comment>The boundaries crossed during this session.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundarySession"/>
    <rdfs:range rdf:resource="https://uor.foundation/boundary/IOBoundary"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/boundary/isIdempotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isIdempotent</rdfs:label>
    <rdfs:comment>True iff applying the boundary effect twice produces the same result as applying it once.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundaryEffect"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/boundary/crossingCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>crossingCount</rdfs:label>
    <rdfs:comment>Total number of boundary crossings in this session.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/boundary/BoundarySession"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: conformance -->
  <owl:Ontology rdf:about="https://uor.foundation/conformance/">
    <rdfs:label>UOR Conformance Shapes</rdfs:label>
    <rdfs:comment>SHACL-equivalent constraint shapes defining what a Prism implementation must provide at each extension point. Machine-verifiable contracts.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/effect/"/>
    <owl:imports rdf:resource="https://uor.foundation/predicate/"/>
    <owl:imports rdf:resource="https://uor.foundation/parallel/"/>
    <owl:imports rdf:resource="https://uor.foundation/stream/"/>
    <owl:imports rdf:resource="https://uor.foundation/linear/"/>
    <owl:imports rdf:resource="https://uor.foundation/region/"/>
    <owl:imports rdf:resource="https://uor.foundation/failure/"/>
    <owl:imports rdf:resource="https://uor.foundation/recursion/"/>
    <owl:imports rdf:resource="https://uor.foundation/boundary/"/>
    <owl:imports rdf:resource="https://uor.foundation/reduction/"/>
    <owl:imports rdf:resource="https://uor.foundation/cert/"/>
    <owl:imports rdf:resource="https://uor.foundation/trace/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/conformance/Shape">
    <rdfs:label>Shape</rdfs:label>
    <rdfs:comment>A constraint shape that a Prism-declared extension must satisfy. Analogous to sh:NodeShape in SHACL.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/PropertyConstraint">
    <rdfs:label>PropertyConstraint</rdfs:label>
    <rdfs:comment>A single required property within a shape: the property URI, its expected range, minimum and maximum cardinality.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/WittLevelShape">
    <rdfs:label>WittLevelShape</rdfs:label>
    <rdfs:comment>Shape for declaring a new WittLevel beyond Q3.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/EffectShape">
    <rdfs:label>EffectShape</rdfs:label>
    <rdfs:comment>Shape for declaring an ExternalEffect.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ParallelShape">
    <rdfs:label>ParallelShape</rdfs:label>
    <rdfs:comment>Shape for declaring a ParallelProduct.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/StreamShape">
    <rdfs:label>StreamShape</rdfs:label>
    <rdfs:comment>Shape for declaring a ProductiveStream (targets stream:Unfold, the coinductive constructor).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/DispatchShape">
    <rdfs:label>DispatchShape</rdfs:label>
    <rdfs:comment>Shape for declaring a new DispatchRule in a DispatchTable.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/LeaseShape">
    <rdfs:label>LeaseShape</rdfs:label>
    <rdfs:comment>Shape for declaring a Lease with LinearSite allocation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/GroundingShape">
    <rdfs:label>GroundingShape</rdfs:label>
    <rdfs:comment>Shape for declaring a GroundingMap from surface data to the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ValidationResult">
    <rdfs:label>ValidationResult</rdfs:label>
    <rdfs:comment>The result of validating an extension against a shape: conforms (boolean), and violation details if non-conformant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/PredicateShape">
    <rdfs:label>PredicateShape</rdfs:label>
    <rdfs:comment>Shape for user-declared predicates. Requires a bounded evaluator (termination witness) and input type declaration.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/InteractionShape">
    <rdfs:label>InteractionShape</rdfs:label>
    <rdfs:comment>Shape describing the required surface of an InteractionDeclaration consumed by the foundation&apos;s InteractionDeclarationBuilder: peer protocol, convergence predicate, and commutator state class. Rejects builders missing any of the three.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/WitnessDatum">
    <rdfs:label>WitnessDatum</rdfs:label>
    <rdfs:comment>Opaque ring element witness. Cannot be constructed outside the foundation crate — only produced by reduction evaluation or the two-phase minting boundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/GroundedCoordinate">
    <rdfs:label>GroundedCoordinate</rdfs:label>
    <rdfs:comment>Boundary crossing intermediate for a single grounded coordinate value. Not a WitnessDatum — must be validated and minted by the foundation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/GroundedTuple">
    <rdfs:label>GroundedTuple</rdfs:label>
    <rdfs:comment>Boundary crossing intermediate for a fixed-size array of GroundedCoordinate values. Stack-resident, no heap allocation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/GroundedValueMarker">
    <rdfs:label>GroundedValueMarker</rdfs:label>
    <rdfs:comment>Sealed marker trait class. Implemented only for GroundedCoordinate and GroundedTuple. Prevents downstream crates from substituting arbitrary types.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ValidatedWrapper">
    <rdfs:label>ValidatedWrapper</rdfs:label>
    <rdfs:comment>Generic validation-proof wrapper. Proves that the inner value was produced by the conformance checker, not fabricated by Prism code.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/WitnessDerivation">
    <rdfs:label>WitnessDerivation</rdfs:label>
    <rdfs:comment>Opaque derivation trace that can only be extended by the rewrite engine. Records rewrite step count and root term content address.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/WitnessSiteBudget">
    <rdfs:label>WitnessSiteBudget</rdfs:label>
    <rdfs:comment>Opaque site budget that can only be decremented by PinningEffect and incremented by UnbindingEffect — never by direct mutation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ShapeViolationReport">
    <rdfs:label>ShapeViolationReport</rdfs:label>
    <rdfs:comment>Structured violation diagnostic carrying the shape IRI, constraint IRI, property IRI, expected range, cardinality bounds, and violation kind.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ViolationKind">
    <rdfs:label>ViolationKind</rdfs:label>
    <rdfs:comment>The kind of shape violation: Missing, TypeMismatch, CardinalityViolation, ValueCheck, or LevelMismatch.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/CompileUnitBuilder">
    <rdfs:label>CompileUnitBuilder</rdfs:label>
    <rdfs:comment>Builder for CompileUnit admission. Collects rootTerm, quantumLevelCeiling, thermodynamicBudget, and targetDomains. Validates against CompileUnitShape.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/EffectDeclaration">
    <rdfs:label>EffectDeclaration</rdfs:label>
    <rdfs:comment>Builder for EffectShape. Collects effect name, target sites, budget delta, and commutation flag.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/GroundingDeclaration">
    <rdfs:label>GroundingDeclaration</rdfs:label>
    <rdfs:comment>Builder for GroundingShape. Collects source type, ring mapping, and invertibility contract.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/DispatchDeclaration">
    <rdfs:label>DispatchDeclaration</rdfs:label>
    <rdfs:comment>Builder for DispatchShape. Collects predicate, target resolver, and dispatch priority.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/LeaseDeclaration">
    <rdfs:label>LeaseDeclaration</rdfs:label>
    <rdfs:comment>Builder for LeaseShape. Collects linear site and lease scope.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/StreamDeclaration">
    <rdfs:label>StreamDeclaration</rdfs:label>
    <rdfs:comment>Builder for StreamShape. Collects unfold seed, step term, and productivity witness.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/PredicateDeclaration">
    <rdfs:label>PredicateDeclaration</rdfs:label>
    <rdfs:comment>Builder for PredicateShape. Collects input type, evaluator term, and termination witness.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/ParallelDeclaration">
    <rdfs:label>ParallelDeclaration</rdfs:label>
    <rdfs:comment>Builder for ParallelShape. Collects site partition and disjointness witness.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/WittLevelDeclaration">
    <rdfs:label>WittLevelDeclaration</rdfs:label>
    <rdfs:comment>Builder for WittLevelShape. Collects declared bit width, cycle size, and predecessor level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/MintingSession">
    <rdfs:label>MintingSession</rdfs:label>
    <rdfs:comment>Boundary session state tracker. Records crossing count and idempotency flag for the two-phase minting boundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/conformance/PreludeExport">
    <rdfs:label>PreludeExport</rdfs:label>
    <rdfs:comment>An ontology fact recording that a particular OWL class should appear in the foundation crate&apos;s `prelude` module re-exports. The v0.2.1 Rust codegen walks PreludeExport individuals filtered by exportsClass to assemble the prelude membership list.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/targetClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetClass</rdfs:label>
    <rdfs:comment>The OWL class that instances of this shape must belong to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/requiredProperty">
    <rdfs:label>requiredProperty</rdfs:label>
    <rdfs:comment>A required property in this shape.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:range rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/constraintProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>constraintProperty</rdfs:label>
    <rdfs:comment>The property URI that must be present.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/constraintRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>constraintRange</rdfs:label>
    <rdfs:comment>The expected range of the required property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/validationShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validationShape</rdfs:label>
    <rdfs:comment>The shape that was validated against.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ValidationResult"/>
    <rdfs:range rdf:resource="https://uor.foundation/conformance/Shape"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/validationTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validationTarget</rdfs:label>
    <rdfs:comment>The instance that was validated.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ValidationResult"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/minCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>minCount</rdfs:label>
    <rdfs:comment>Minimum cardinality of the required property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/maxCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxCount</rdfs:label>
    <rdfs:comment>Maximum cardinality (0 = unbounded).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/conforms">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>conforms</rdfs:label>
    <rdfs:comment>True iff the target satisfies all constraints of the shape.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ValidationResult"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/witnessLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>witnessLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this witness datum was minted.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/WitnessDatum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/witnessBytes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>witnessBytes</rdfs:label>
    <rdfs:comment>The raw byte representation of this witness datum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/WitnessDatum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/coordinateLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>coordinateLevel</rdfs:label>
    <rdfs:comment>The quantum level tag of this grounded coordinate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/GroundedCoordinate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/validatedInner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validatedInner</rdfs:label>
    <rdfs:comment>The validated inner value wrapped by this proof.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ValidatedWrapper"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/shapeIri">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>shapeIri</rdfs:label>
    <rdfs:comment>IRI of the conformance:Shape that was validated against.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/constraintIri">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>constraintIri</rdfs:label>
    <rdfs:comment>IRI of the specific PropertyConstraint that failed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/propertyIri">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>propertyIri</rdfs:label>
    <rdfs:comment>IRI of the property that was missing or invalid.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/expectedRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>expectedRange</rdfs:label>
    <rdfs:comment>The expected range class IRI for the violated property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/violationMinCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>violationMinCount</rdfs:label>
    <rdfs:comment>The minimum cardinality from the violated constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/violationMaxCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>violationMaxCount</rdfs:label>
    <rdfs:comment>The maximum cardinality from the violated constraint (0 = unbounded).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/violationKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>violationKind</rdfs:label>
    <rdfs:comment>The kind of violation that occurred.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ShapeViolationReport"/>
    <rdfs:range rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/builderRootTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>builderRootTerm</rdfs:label>
    <rdfs:comment>The root term expression for the CompileUnit.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/CompileUnitBuilder"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/builderWittLevelCeiling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>builderWittLevelCeiling</rdfs:label>
    <rdfs:comment>The widest quantum level the computation may reference.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/CompileUnitBuilder"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/builderThermodynamicBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>builderThermodynamicBudget</rdfs:label>
    <rdfs:comment>Landauer-bounded energy budget in kBT ln 2 units.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/CompileUnitBuilder"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/builderTargetDomains">
    <rdfs:label>builderTargetDomains</rdfs:label>
    <rdfs:comment>Verification domains targeted by the CompileUnit.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/CompileUnitBuilder"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/VerificationDomain"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/effectName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>effectName</rdfs:label>
    <rdfs:comment>The name of the declared effect.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/EffectDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/targetSites">
    <rdfs:label>targetSites</rdfs:label>
    <rdfs:comment>Site coordinates this effect reads or writes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/EffectDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/budgetDelta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>budgetDelta</rdfs:label>
    <rdfs:comment>The site budget delta (positive = increment, negative = decrement).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/EffectDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/commutationFlag">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>commutationFlag</rdfs:label>
    <rdfs:comment>Whether this effect commutes with effects on disjoint sites.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/EffectDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/groundingSourceType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingSourceType</rdfs:label>
    <rdfs:comment>The source type of incoming external data.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/GroundingDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/ringMapping">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ringMapping</rdfs:label>
    <rdfs:comment>Description of the mapping from surface data to ring.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/GroundingDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/invertibilityContract">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>invertibilityContract</rdfs:label>
    <rdfs:comment>Whether the grounding map is invertible.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/GroundingDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/dispatchPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchPredicate</rdfs:label>
    <rdfs:comment>The predicate expression guarding this dispatch rule.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/DispatchDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/reduction/PredicateExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/targetResolver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetResolver</rdfs:label>
    <rdfs:comment>The resolver to dispatch to when the predicate holds.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/DispatchDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/dispatchPriority">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchPriority</rdfs:label>
    <rdfs:comment>Priority ordering for this dispatch rule (lower = first).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/DispatchDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/linearSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>linearSite</rdfs:label>
    <rdfs:comment>The site coordinate allocated linearly by this lease.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/LeaseDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/leaseScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseScope</rdfs:label>
    <rdfs:comment>The scope within which this lease is valid.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/LeaseDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/unfoldSeed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>unfoldSeed</rdfs:label>
    <rdfs:comment>The seed term for the stream unfold constructor.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/StreamDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/stepTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stepTerm</rdfs:label>
    <rdfs:comment>The step function term for the stream unfold.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/StreamDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/productivityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>productivityWitness</rdfs:label>
    <rdfs:comment>Evidence that the stream is productive (always produces a next element).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/StreamDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/predicateInputType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>predicateInputType</rdfs:label>
    <rdfs:comment>The input type for the declared predicate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PredicateDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/evaluatorTerm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>evaluatorTerm</rdfs:label>
    <rdfs:comment>The evaluator term for the declared predicate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PredicateDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/terminationWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>terminationWitness</rdfs:label>
    <rdfs:comment>Evidence that the predicate evaluator terminates on all inputs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PredicateDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/sitePartition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePartition</rdfs:label>
    <rdfs:comment>The site partition for the parallel composition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ParallelDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/disjointnessWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>disjointnessWitness</rdfs:label>
    <rdfs:comment>Evidence that the site partition components are pairwise disjoint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/ParallelDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/declaredBitWidth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>declaredBitWidth</rdfs:label>
    <rdfs:comment>The declared bit width for this quantum level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/WittLevelDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/declaredCycleSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>declaredCycleSize</rdfs:label>
    <rdfs:comment>The declared number of ring states at this level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/WittLevelDeclaration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/predecessorLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>predecessorLevel</rdfs:label>
    <rdfs:comment>The predecessor quantum level in the chain.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/WittLevelDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/sessionCrossingCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionCrossingCount</rdfs:label>
    <rdfs:comment>Total boundary crossings in this minting session.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/MintingSession"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/sessionIsIdempotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionIsIdempotent</rdfs:label>
    <rdfs:comment>Whether applying this session&apos;s boundary effect twice equals applying it once.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/MintingSession"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/surfaceForm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>surfaceForm</rdfs:label>
    <rdfs:comment>Top-level EBNF non-terminal name this Shape generates (e.g., &quot;compile-unit-decl&quot; for CompileUnitShape).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/surfaceKeyword">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>surfaceKeyword</rdfs:label>
    <rdfs:comment>Literal surface keyword used in the conformance grammar for this property constraint (e.g., &quot;root_term&quot;, &quot;witt_level_ceiling&quot;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/surfaceProduction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>surfaceProduction</rdfs:label>
    <rdfs:comment>EBNF non-terminal that the value at this constraint slot must match (e.g., &quot;program&quot; for Term ranges, &quot;name&quot; for WittLevel ranges, &quot;decimal-literal&quot; for xsd:decimal, &quot;domain-set&quot; for non-functional IRI lists).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/conformance/exportsClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exportsClass</rdfs:label>
    <rdfs:comment>The OWL class IRI that the foundation crate&apos;s prelude module should re-export.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PreludeExport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/conformance/exportRustName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exportRustName</rdfs:label>
    <rdfs:comment>The Rust identifier under which the prelude exposes this symbol. Codegen uses this when the class&apos;s generated Rust name differs from a desired prelude alias.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/conformance/PreludeExport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/CompileUnitShape">
    <rdf:type rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:label>CompileUnitShape</rdfs:label>
    <rdfs:comment>Shape validating that a CompileUnit carries all required properties before reduction admission. The unitAddress property is NOT required — it is computed by stage_initialization after shape validation passes.</rdfs:comment>
    <uor:conformance/targetClass rdf:resource="https://uor.foundation/reduction/CompileUnit"/>
    <uor:conformance/surfaceForm>compile-unit-decl</uor:conformance/surfaceForm>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/compileUnit_rootTerm_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/compileUnit_unitWittLevel_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/compileUnit_thermodynamicBudget_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/compileUnit_targetDomains_constraint"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/compileUnit_rootTerm_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>compileUnit_rootTerm_constraint</rdfs:label>
    <rdfs:comment>Exactly one root term is required. Range is schema:Term.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/reduction/rootTerm"/>
    <uor:conformance/constraintRange rdf:resource="https://uor.foundation/schema/Term"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>root_term</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>program</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/compileUnit_unitWittLevel_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>compileUnit_unitWittLevel_constraint</rdfs:label>
    <rdfs:comment>Exactly one quantum level is required. Range is schema:WittLevel.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/reduction/unitWittLevel"/>
    <uor:conformance/constraintRange rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>witt_level_ceiling</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>name</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/compileUnit_thermodynamicBudget_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>compileUnit_thermodynamicBudget_constraint</rdfs:label>
    <rdfs:comment>Exactly one thermodynamic budget is required. Shape validates presence and type; the BudgetSolvencyCheck preflight validates the value against the Landauer bound.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/reduction/thermodynamicBudget"/>
    <uor:conformance/constraintRange rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>thermodynamic_budget</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>decimal-literal</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/compileUnit_targetDomains_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>compileUnit_targetDomains_constraint</rdfs:label>
    <rdfs:comment>At least one target verification domain is required. maxCount 0 means unbounded.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/reduction/targetDomains"/>
    <uor:conformance/constraintRange rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>target_domains</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>domain-set</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/Missing">
    <rdf:type rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
    <rdfs:label>Missing</rdfs:label>
    <rdfs:comment>Required property was not set on the builder.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/TypeMismatch">
    <rdf:type rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
    <rdfs:label>TypeMismatch</rdfs:label>
    <rdfs:comment>Property was set but its value is not an instance of the constraintRange.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/CardinalityViolation">
    <rdf:type rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
    <rdfs:label>CardinalityViolation</rdfs:label>
    <rdfs:comment>Cardinality violated: too few or too many values provided.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/ValueCheck">
    <rdf:type rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
    <rdfs:label>ValueCheck</rdfs:label>
    <rdfs:comment>Value-dependent check failed (Tier 2). For example, thermodynamic budget insufficient for Landauer bound.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/LevelMismatch">
    <rdf:type rdf:resource="https://uor.foundation/conformance/ViolationKind"/>
    <rdfs:label>LevelMismatch</rdfs:label>
    <rdfs:comment>A term&apos;s quantum level annotation exceeds the CompileUnit ceiling, or binary operation operands are at different levels without an intervening lift or project.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/DispatchShapeInstance">
    <rdf:type rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:label>DispatchShapeInstance</rdfs:label>
    <rdfs:comment>Shape instance validating predicate:DispatchRule declarations against the dispatch-rule-decl grammar.</rdfs:comment>
    <uor:conformance/targetClass rdf:resource="https://uor.foundation/predicate/DispatchRule"/>
    <uor:conformance/surfaceForm>dispatch-rule-decl</uor:conformance/surfaceForm>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/dispatch_predicate_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/dispatch_target_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/dispatch_priority_constraint"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/dispatch_predicate_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>dispatch_predicate_constraint</rdfs:label>
    <rdfs:comment>Exactly one predicate term selecting this dispatch rule.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/predicate/dispatchPredicate"/>
    <uor:conformance/constraintRange rdf:resource="https://uor.foundation/schema/Term"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>predicate</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>term</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/dispatch_target_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>dispatch_target_constraint</rdfs:label>
    <rdfs:comment>The resolver class invoked when the predicate holds.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/predicate/dispatchTarget"/>
    <uor:conformance/constraintRange rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>target_resolver</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>name</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/dispatch_priority_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>dispatch_priority_constraint</rdfs:label>
    <rdfs:comment>Non-negative integer evaluation order; lower values evaluate first.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/predicate/dispatchPriority"/>
    <uor:conformance/constraintRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>priority</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>integer-literal</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/WittLevelShapeInstance">
    <rdf:type rdf:resource="https://uor.foundation/conformance/Shape"/>
    <rdfs:label>WittLevelShapeInstance</rdfs:label>
    <rdfs:comment>Shape instance validating schema:WittLevel declarations against the witt-level-decl grammar.</rdfs:comment>
    <uor:conformance/targetClass rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <uor:conformance/surfaceForm>witt-level-decl</uor:conformance/surfaceForm>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/wittLevel_bitWidth_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/wittLevel_cycleSize_constraint"/>
    <uor:conformance/requiredProperty rdf:resource="https://uor.foundation/conformance/wittLevel_predecessorLevel_constraint"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/wittLevel_bitWidth_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>wittLevel_bitWidth_constraint</rdfs:label>
    <rdfs:comment>Bit width must equal 8·(k+1) for some non-negative integer k.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/schema/bitsWidth"/>
    <uor:conformance/constraintRange rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>bit_width</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>integer-literal</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/conformance/wittLevel_cycleSize_constraint">
    <rdf:type rdf:resource="https://uor.foundation/conformance/PropertyConstraint"/>
    <rdfs:label>wittLevel_cycleSize_constraint</rdfs:label>
    <rdfs:comment>Cycle size must equal 2^bit_width.</rdfs:comment>
    <uor:conformance/constraintProperty rdf:resource="https://uor.foundation/schema/cycleSize"/>
    <uor:conformance/constraintRange rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
    <uor:conformance/minCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/minCount>
    <uor:conformance/maxCount rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:conformance/maxCount>
    <uor:conformance/surfaceKeyword>cycle_size</uor:conformance/surfaceKeyword>
    <uor:conformance/surfaceProduction>integer-literal</uor:conformance/surfaceProduction>
  </owl:NamedIndividual>

