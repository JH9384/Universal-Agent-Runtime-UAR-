  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_3</rdfs:label>
    <rdfs:comment>Phase effects preserve site budget.</rdfs:comment>
