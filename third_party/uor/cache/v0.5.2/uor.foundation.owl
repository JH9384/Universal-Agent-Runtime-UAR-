  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CL_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CL_3</rdfs:label>
    <rdfs:comment>Lattice meet pins the intersection of component pins.</rdfs:comment>
