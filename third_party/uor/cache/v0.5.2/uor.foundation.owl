    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PAR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PAR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PAR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PAR_2</rdfs:label>
    <rdfs:comment>Parallel free-count deltas are additive.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PAR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PAR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PAR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PAR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PAR_3</rdfs:label>
    <rdfs:comment>Partitioning is exhaustive: component cardinalities sum to total site budget.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PAR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PAR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PAR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PAR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PAR_4</rdfs:label>
    <rdfs:comment>All interleavings of disjoint parallel computations yield the same final context.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PAR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PAR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PAR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PAR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PAR_5</rdfs:label>
    <rdfs:comment>Parallel certificate is the conjunction of component certificates plus disjointness.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PAR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PAR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PAR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HO_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HO_1</rdfs:label>
    <rdfs:comment>A ComputationDatum’s ring value is the content hash of its certificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HO_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HO_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HO_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HO_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HO_2</rdfs:label>
    <rdfs:comment>Application preserves certification.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HO_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HO_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HO_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HO_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HO_3</rdfs:label>
    <rdfs:comment>Composition certification requires both components certified and type-compatible.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HO_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HO_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HO_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HO_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HO_4</rdfs:label>
    <rdfs:comment>Fully saturated partial application equals direct application.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HO_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HO_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HO_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_1</rdfs:label>
    <rdfs:comment>Every epoch terminates: the reduction within each epoch reaches convergence angle π.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_2</rdfs:label>
    <rdfs:comment>Grounding preservation across epoch boundaries.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_3</rdfs:label>
    <rdfs:comment>Every finite prefix computes in finite time.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_4</rdfs:label>
    <rdfs:comment>The first epoch starts from the unfold seed context.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_5</rdfs:label>
    <rdfs:comment>Each subsequent epoch starts from the previous boundary’s continuation context.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/STR_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>STR_6</rdfs:label>
    <rdfs:comment>Lease expiry at an epoch boundary returns claimed sites to the next epoch’s linear budget.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_STR_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_STR_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_STR_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_1</rdfs:label>
    <rdfs:comment>Every partial computation produces exactly one of Success or Failure.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_2</rdfs:label>
    <rdfs:comment>A total computation always succeeds.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_3</rdfs:label>
    <rdfs:comment>Sequential failure propagation: if A fails, B is not evaluated.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_4</rdfs:label>
    <rdfs:comment>Parallel failure independence: one component’s failure does not prevent the other’s success.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_5</rdfs:label>
    <rdfs:comment>Recovery produces a new ComputationResult.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FLR_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FLR_6</rdfs:label>
    <rdfs:comment>The reduction’s existing rollback mechanism is a Recovery whose effect is the conjugate phase rotation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FLR_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FLR_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FLR_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_1</rdfs:label>
    <rdfs:comment>In a linear trace, every site is targeted exactly once. Total effect count equals site budget.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_2</rdfs:label>
    <rdfs:comment>After a LinearEffect, the target site is pinned.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_3</rdfs:label>
    <rdfs:comment>A consumed LinearSite cannot be targeted again.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_4</rdfs:label>
    <rdfs:comment>Lease allocation decrements the linear budget by the lease cardinality.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_5</rdfs:label>
    <rdfs:comment>Lease expiry returns claimed sites to the budget.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LN_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>LN_6</rdfs:label>
    <rdfs:comment>Every geodesic trace is a linear trace.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_LN_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_LN_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_LN_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_1</rdfs:label>
    <rdfs:comment>Subtyping is constraint superset: more constraints = more specific.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_2</rdfs:label>
    <rdfs:comment>Subtype has fewer valid resolutions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_3</rdfs:label>
    <rdfs:comment>The constraint nerve of the supertype is a sub-complex of the subtype’s nerve.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_4</rdfs:label>
    <rdfs:comment>Covariance preserves inclusion.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_5</rdfs:label>
    <rdfs:comment>Contravariance reverses inclusion.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SB_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SB_6</rdfs:label>
    <rdfs:comment>Lattice depth equals site budget.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SB_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SB_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SB_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BR_1</rdfs:label>
    <rdfs:comment>Every recursive step strictly decreases the descent measure.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BR_2</rdfs:label>
    <rdfs:comment>Recursion depth is bounded by the initial measure value.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BR_3</rdfs:label>
    <rdfs:comment>Every bounded recursion terminates.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BR_4</rdfs:label>
    <rdfs:comment>Structural recursion’s measure is the input type’s structural size.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/BR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>BR_5</rdfs:label>
    <rdfs:comment>The base predicate is satisfied exactly when the measure reaches zero.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_BR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_BR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_BR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RG_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RG_1</rdfs:label>
    <rdfs:comment>The working set is determined by the constraint nerve and the stage’s site targets.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RG_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RG_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RG_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RG_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RG_2</rdfs:label>
    <rdfs:comment>All addresses within a region are within the region’s diameter under the chosen metric.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RG_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RG_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RG_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RG_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RG_3</rdfs:label>
    <rdfs:comment>Total working set size is bounded by the addressable space at the quantum level.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RG_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RG_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RG_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RG_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RG_4</rdfs:label>
    <rdfs:comment>The resolver at stage k accesses only addresses within its working set.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RG_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RG_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RG_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IO_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IO_1</rdfs:label>
    <rdfs:comment>Ingested data conforms to the source’s declared type.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IO_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IO_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IO_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IO_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IO_2</rdfs:label>
    <rdfs:comment>Emitted data conforms to the sink’s declared type.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IO_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IO_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IO_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IO_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IO_3</rdfs:label>
    <rdfs:comment>Every ingestion through a source produces a valid ring datum via grounding.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IO_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IO_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IO_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IO_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IO_4</rdfs:label>
    <rdfs:comment>Every emission through a sink produces a valid surface symbol via projection.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IO_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IO_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IO_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IO_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IO_5</rdfs:label>
    <rdfs:comment>Every boundary effect touches at least one site.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IO_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IO_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IO_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IH_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IH_1</rdfs:label>
    <rdfs:comment>Inhabitance soundness (bidirectional). For any type:ConstrainedType T, cert:InhabitanceCertificate(T) .verified is true iff the carrier of T is non-empty. Discharge: the verdict reified by cert:InhabitanceCertificate agrees with the denotational carrier-non-emptiness predicate, by direct unfolding of cert:verified against the predicate semantics.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IH_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IH_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IH_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IH_2a">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IH_2a</rdfs:label>
    <rdfs:comment>Inhabitance cost (2-SAT restriction). For instances T satisfying predicate:Is2SatShape, the cost of resolver:TwoSatDecider on T is inherited from the classical 2-SAT decision procedure: O(n+m) where n is the variable count and m the clause count. Unrestricted IH_2 would be equivalent to P = NP and is not adopted.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IH_2a_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IH_2a_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IH_2a_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IH_2b">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IH_2b</rdfs:label>
    <rdfs:comment>Inhabitance cost (Horn-SAT restriction). For instances T satisfying predicate:IsHornShape, the cost of resolver:HornSatDecider on T is inherited from the classical Horn-SAT decision procedure via unit propagation: O(n+m).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IH_2b_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IH_2b_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IH_2b_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IH_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IH_3</rdfs:label>
    <rdfs:comment>Carrier preservation under basis reduction. The constraint-nerve reduction performed during inhabitance search preserves the carrier of the input ConstrainedType. Discharged against resolver:JacobianGuidedResolver and resolver:guidingJacobian vocabulary.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IH_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IH_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IH_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <!-- Namespace: query -->
  <owl:Ontology rdf:about="https://uor.foundation/query/">
    <rdfs:label>UOR Queries</rdfs:label>
    <rdfs:comment>Information extraction queries. Users initiate queries; the kernel resolves them against the ring substrate.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/morphism/"/>
    <owl:imports rdf:resource="https://uor.foundation/state/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/query/Query">
    <rdfs:label>Query</rdfs:label>
    <rdfs:comment>A request for information from the UOR kernel. The root abstraction for all query types.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/CoordinateQuery">
    <rdfs:label>CoordinateQuery</rdfs:label>
    <rdfs:comment>A query for the ring-coordinate position of a datum: its stratum, spectrum, and address within the ring geometry.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/query/Query"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/MetricQuery">
    <rdfs:label>MetricQuery</rdfs:label>
    <rdfs:comment>A query for a metric value between two datums: ring distance, Hamming distance, or their divergence (curvature).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/query/Query"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/RepresentationQuery">
    <rdfs:label>RepresentationQuery</rdfs:label>
    <rdfs:comment>A query for the canonical representation of a datum or term: its normal form under the active resolver strategy.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/query/Query"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/RelationQuery">
    <rdfs:label>RelationQuery</rdfs:label>
    <rdfs:comment>A Query with a known source address, a typed relation constraint, and an open target partition:FreeRank. Represents any question of the form: given this source symbol and relation type, what is the target? The relation type is read from the observable coordinate triple (d_R, d_H, d_I) — not externally supplied. Applies across NLP, ARC-AGI grids, music, images, sensor streams, and logical formulae.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/query/Query"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/TriadProjection">
    <rdfs:label>TriadProjection</rdfs:label>
    <rdfs:comment>A classification of coordinate types that a CoordinateQuery can extract. Each TriadProjection individual names a specific coordinate system (stratum, spectrum, address) replacing the string-valued query:coordinate property.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/query/SessionQuery">
    <rdfs:label>SessionQuery</rdfs:label>
    <rdfs:comment>A RelationQuery that explicitly declares its session membership, allowing the conformance suite to validate session-scoped site reduction across multi-turn Prism deployments.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/query/RelationQuery"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/inputType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inputType</rdfs:label>
    <rdfs:comment>The type of input the query accepts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/Query"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/outputType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outputType</rdfs:label>
    <rdfs:comment>The type of output the query produces.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/Query"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/hasTriadProjection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hasTriadProjection</rdfs:label>
    <rdfs:comment>The typed coordinate kind this query extracts. Replaces the string-valued query:coordinate property with a typed reference to a TriadProjection individual.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/CoordinateQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/query/TriadProjection"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/sourceAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceAddress</rdfs:label>
    <rdfs:comment>The ring address of the grounded source symbol.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/relationType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>relationType</rdfs:label>
    <rdfs:comment>The transformation type, expressed as a type:Conjunction composed from the primitive BoundConstraint basis. At inference time this is the output of an observable coordinate read on example pairs — computed from (d_R, d_H, d_I). Not an externally supplied input; read from the representation space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/targetSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetSite</rdfs:label>
    <rdfs:comment>The open site budget for the unknown target. Begins fully free; closes to isClosed = true upon resolution.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/groundingMap">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingMap</rdfs:label>
    <rdfs:comment>The GroundingMap that resolved the source symbol to its ring address.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/projectionMap">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>projectionMap</rdfs:label>
    <rdfs:comment>The ProjectionMap that will render the resolved address neighbourhood back to surface symbols.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/ProjectionMap"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/sessionContext">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionContext</rdfs:label>
    <rdfs:comment>Accumulated session state carrying all state:Binding instances produced by prior queries. Each binding records a resolved address, its datum, and the type under which it was resolved. Prior bindings monotonically reduce the free site space for subsequent queries.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/RelationQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Context"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/query/sessionMembership">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionMembership</rdfs:label>
    <rdfs:comment>The session this query belongs to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/query/SessionQuery"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/Session"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/query/TwoAdicValuation">
    <rdf:type rdf:resource="https://uor.foundation/query/TriadProjection"/>
    <rdfs:label>TwoAdicValuation</rdfs:label>
    <rdfs:comment>The stratum coordinate: the layer position of a datum within the ring&apos;s stratification.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/query/WalshHadamardImage">
    <rdf:type rdf:resource="https://uor.foundation/query/TriadProjection"/>
    <rdfs:label>WalshHadamardImage</rdfs:label>
    <rdfs:comment>The spectrum coordinate: the spectral decomposition of a datum under the ring&apos;s Fourier analysis.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/query/Address">
    <rdf:type rdf:resource="https://uor.foundation/query/TriadProjection"/>
    <rdfs:label>Address</rdfs:label>
    <rdfs:comment>The address coordinate: the content-addressable position of a datum in the Braille glyph encoding. Renamed from RingElement in v0.2.2 W8 to unify vocabulary with the schema:Triad bundling properties.</rdfs:comment>
  </owl:NamedIndividual>

  <!-- Namespace: resolver -->
  <owl:Ontology rdf:about="https://uor.foundation/resolver/">
    <rdfs:label>UOR Resolvers</rdfs:label>
    <rdfs:comment>Type resolution strategies implementing the partition map Π : T_n → Part(R_n). Resolvers transform type declarations into ring partitions.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/query/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/predicate/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/resolver/Resolver">
    <rdfs:label>Resolver</rdfs:label>
    <rdfs:comment>A strategy for resolving a type declaration into a partition of the ring. The kernel dispatches to a specific resolver based on the type&apos;s structure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/DihedralFactorizationResolver">
    <rdfs:label>DihedralFactorizationResolver</rdfs:label>
    <rdfs:comment>Resolves types by factoring the ring under dihedral group action. Identifies orbits under D_{2^n} to determine irreducibility boundaries.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/CanonicalFormResolver">
    <rdfs:label>CanonicalFormResolver</rdfs:label>
    <rdfs:comment>Resolves types by computing canonical forms via term rewriting. Applies the critical identity and normalization rules to reduce terms to unique canonical representatives.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/EvaluationResolver">
    <rdfs:label>EvaluationResolver</rdfs:label>
    <rdfs:comment>Resolves types by direct evaluation: applies operations to enumerate ring elements and classify them as irreducible, reducible, unit, or exterior.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ResolutionState">
    <rdfs:label>ResolutionState</rdfs:label>
    <rdfs:comment>The current state of an iterative resolution: tracks how many iterations have been performed, whether the resolution is complete, and the current site deficit.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/RefinementSuggestion">
    <rdfs:label>RefinementSuggestion</rdfs:label>
    <rdfs:comment>A suggestion from the resolver for how to refine an incomplete resolution: which metric axis to explore, which class to narrow to, and which sites to target.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ComplexityClass">
    <rdfs:label>ComplexityClass</rdfs:label>
    <rdfs:comment>A computational complexity classification for resolvers. Each resolver&apos;s asymptotic runtime is typed as a named ComplexityClass individual rather than a free string.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/CechNerve">
    <rdfs:label>CechNerve</rdfs:label>
    <rdfs:comment>The simplicial complex whose vertices are constraints and where a k-simplex exists iff the corresponding k+1 constraints have nonempty intersection. The nerve&apos;s topology governs resolution convergence: trivial homology ↔ smooth convergence, non-trivial homology ↔ potential stalls.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/homology/KanComplex"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/CompletenessResolver">
    <rdfs:label>CompletenessResolver</rdfs:label>
    <rdfs:comment>A specialisation of Resolver driving the completeness certification loop. Accepts a CompletenessCandidate, runs the ψ-pipeline (reading nerveEulerCharacteristic from ResolutionState), and either issues a CompletenessCertificate or produces a RefinementSuggestion.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/WittLevelResolver">
    <rdfs:label>WittLevelResolver</rdfs:label>
    <rdfs:comment>A Resolver parameterised by quantum level. The same resolver strategy runs at any quantum level n ≥ 1 by substituting the appropriate R_n ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/SessionResolver">
    <rdfs:label>SessionResolver</rdfs:label>
    <rdfs:comment>A Resolver that maintains a BindingAccumulator across multiple RelationQuery evaluations. The top-level resolver for multi-turn Prism deployments.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/TypeSynthesisResolver">
    <rdfs:label>TypeSynthesisResolver</rdfs:label>
    <rdfs:comment>A Resolver that runs the ψ-pipeline in inverse mode. Accepts a TypeSynthesisGoal and returns a TypeSynthesisResult. Internally maintains a ConstraintSearchState tracking which constraint combinations have been explored and which Betti profiles they realise.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ConstraintSearchState">
    <rdfs:label>ConstraintSearchState</rdfs:label>
    <rdfs:comment>Internal resolver state tracking the boundary of explored constraint combinations during synthesis. Carries exploredCount, currentCandidate, and a link to the best SynthesisSignature achieved so far.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/IncrementalCompletenessResolver">
    <rdfs:label>IncrementalCompletenessResolver</rdfs:label>
    <rdfs:comment>A Resolver that determines whether a CompleteType T at Q_n lifts to a CompleteType at Q_{n+1} without re-running the full ψ-pipeline from scratch. It computes the SpectralSequencePage sequence, reads the LiftObstruction, and either confirms the lift or returns a LiftRefinementSuggestion.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/LiftRefinementSuggestion">
    <rdfs:label>LiftRefinementSuggestion</rdfs:label>
    <rdfs:comment>A RefinementSuggestion produced when a WittLift has a non-trivial LiftObstruction. Specialises RefinementSuggestion with liftSitePosition (the new bit position n+1) and obstructionClass.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/MonodromyResolver">
    <rdfs:label>MonodromyResolver</rdfs:label>
    <rdfs:comment>A Resolver that computes the HolonomyGroup of a ConstrainedType by enumerating closed paths in the constraint nerve and accumulating DihedralElement values. Outputs a MonodromyClass and classifies the type as FlatType or TwistedType.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/JacobianGuidedResolver">
    <rdfs:label>JacobianGuidedResolver</rdfs:label>
    <rdfs:comment>A resolver that uses the Jacobian matrix to guide constraint selection, implementing DC_10: select the constraint that maximises total curvature reduction.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/SuperpositionResolver">
    <rdfs:label>SuperpositionResolver</rdfs:label>
    <rdfs:comment>A resolver that handles superposed site states, computing amplitudes and determining when superposition collapses to a classical site assignment (Amendment 32).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/GroundingAwareResolver">
    <rdfs:label>GroundingAwareResolver</rdfs:label>
    <rdfs:comment>A resolver that exploits accumulated session bindings at full saturation (σ = 1) to provide O(1) resolution via direct coordinate reads (SC_5).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/GeodesicValidator">
    <rdfs:label>GeodesicValidator</rdfs:label>
    <rdfs:comment>A resolver that validates whether a ComputationTrace satisfies the dual geodesic condition (AR_1-ordered and DC_10-selected). Produces GeodesicViolation individuals on failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/MeasurementResolver">
    <rdfs:label>MeasurementResolver</rdfs:label>
    <rdfs:comment>A resolver that handles projective collapse of SuperposedSiteState components. Issues MeasurementCertificate upon successful collapse with QM_1 verification.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/TowerCompletenessResolver">
    <rdfs:label>TowerCompletenessResolver</rdfs:label>
    <rdfs:comment>A Resolver that constructs a LiftChain from liftSourceLevel to an arbitrary liftTargetLevel Q_k by iterating IncrementalCompletenessResolver step by step.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/InhabitanceResolver">
    <rdfs:label>InhabitanceResolver</rdfs:label>
    <rdfs:comment>A Resolver whose dispatch is governed by a new predicate:InhabitanceDispatchTable. Returns either a cert:InhabitanceCertificate (verified true with witness) or a proof:InhabitanceImpossibilityWitness (verified false with contradiction proof). Inherits the dual-output termination discipline from resolver:TypeSynthesisResolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/TwoSatDecider">
    <rdfs:label>TwoSatDecider</rdfs:label>
    <rdfs:comment>A Resolver target that decides carrier non-emptiness on ConstrainedType instances whose constraint nerve contains only disjunctions of width ≤ 2, via classical 2-SAT in O(n+m). Dispatch rule 1 of the InhabitanceDispatchTable.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/HornSatDecider">
    <rdfs:label>HornSatDecider</rdfs:label>
    <rdfs:comment>A Resolver target that decides carrier non-emptiness on ConstrainedType instances whose disjunctions each contain at most one positive literal, via classical Horn-SAT unit propagation in O(n+m). Dispatch rule 2 of the InhabitanceDispatchTable.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ResidualVerdictResolver">
    <rdfs:label>ResidualVerdictResolver</rdfs:label>
    <rdfs:comment>A Resolver target for the catch-all default dispatch rule. Returns the residual-hard verdict without promising a polynomial bound; the verdict is well-formed but the cost identity is unbounded. Dispatch rule 3 of the InhabitanceDispatchTable ensuring total coverage (reduction:DispatchMiss is unreachable for this table).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/MultiplicationResolver">
    <rdfs:label>MultiplicationResolver</rdfs:label>
    <rdfs:comment>A Resolver target that decides the cost-optimal Toom-Cook splitting factor R for a Datum&lt;L&gt; × Datum&lt;L&gt; multiplication at a given call-site context (stack budget linear:stackBudgetBytes, const-eval regime). The decision procedure is a pure derivation over a closed-form Landauer cost function grounded in op:OA_5: for each admissible R, the cost is (2R - 1) · (N/R)² · 64 · ln 2 nats (R &gt; 1) or N² · 64 · ln 2 nats (R = 1). The resolver picks the cost-minimum R subject to stack-budget and const-eval constraints and returns a cert:MultiplicationCertificate recording the choice.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/CertifyMapping">
    <rdfs:label>CertifyMapping</rdfs:label>
    <rdfs:comment>An ontology fact recording that a resolver:Resolver subclass produces a specific cert:Certificate subclass on success and a specific proof:ImpossibilityWitness subclass on failure. The v0.2.1 Rust codegen reads CertifyMapping individuals to emit foundation::Certify trait impls for each resolver class, keeping the mapping data-driven rather than hand-tabulated in source.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ExecutionPolicy">
    <rdfs:label>ExecutionPolicy</rdfs:label>
    <rdfs:comment>A strategy class that defines how a SessionResolver orders pending RelationQuery instances for dispatch. The policy reads the targetSite.freeRank of each pending query and applies an ordering function.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ExecutionPolicyKind">
    <rdfs:label>ExecutionPolicyKind</rdfs:label>
    <rdfs:comment>A typed controlled vocabulary for ExecutionPolicy individuals. Follows the SessionBoundaryType pattern: a single class with named individuals rather than a subclass hierarchy.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/HomotopyResolver">
    <rdfs:label>HomotopyResolver</rdfs:label>
    <rdfs:comment>A resolver that runs the extended ψ-pipeline (ψ_7–ψ_9) to compute the full homotopy type of a CechNerve. Returns HomotopyGroup observables and PostnikovTruncation records.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/resolver/ModuliResolver">
    <rdfs:label>ModuliResolver</rdfs:label>
    <rdfs:comment>A resolver that computes the local structure of the moduli space at a given CompleteType: constructs the DeformationComplex, determines the HolonomyStratum, and computes tangent/obstruction dimensions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/resolver/Resolver"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/inputType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inputType</rdfs:label>
    <rdfs:comment>The type of input this resolver accepts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/outputType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>outputType</rdfs:label>
    <rdfs:comment>The type of output this resolver produces. For all UOR resolvers, the output is a partition:Partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/strategy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>strategy</rdfs:label>
    <rdfs:comment>A human-readable description of the resolution strategy this resolver implements.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/resolutionState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>resolutionState</rdfs:label>
    <rdfs:comment>The current resolution state of this resolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/isComplete">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isComplete</rdfs:label>
    <rdfs:comment>Whether this resolution is complete: all sites are pinned and the partition is fully determined.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/iterationCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>iterationCount</rdfs:label>
    <rdfs:comment>The number of refinement iterations performed so far.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/siteDeficit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteDeficit</rdfs:label>
    <rdfs:comment>The site budget showing the remaining unpinned sites. When all sites are pinned, the deficit is zero and resolution is complete.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/suggestion">
    <rdfs:label>suggestion</rdfs:label>
    <rdfs:comment>A refinement suggestion for advancing this resolution.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/suggestedAxis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>suggestedAxis</rdfs:label>
    <rdfs:comment>The metric axis this suggestion recommends exploring.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/MetricAxis"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/suggestedClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>suggestedClass</rdfs:label>
    <rdfs:comment>The constraint class this suggestion recommends applying.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/targetSites">
    <rdfs:label>targetSites</rdfs:label>
    <rdfs:comment>The site coordinates this suggestion targets for pinning.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/convergenceRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>convergenceRate</rdfs:label>
    <rdfs:comment>The rate at which sites are being pinned per iteration. A higher rate indicates faster convergence toward a complete resolution.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/hasComplexityClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hasComplexityClass</rdfs:label>
    <rdfs:comment>The computational complexity class of this resolver. Replaces the string-valued resolver:complexity property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ComplexityClass"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/cechNerve">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cechNerve</rdfs:label>
    <rdfs:comment>The constraint nerve associated with this resolution state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/CechNerve"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/residualEntropy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residualEntropy</rdfs:label>
    <rdfs:comment>The residual Shannon entropy of the resolution state: S = freeRank × ln 2. Measures remaining uncertainty.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/topologicallyComplete">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>topologicallyComplete</rdfs:label>
    <rdfs:comment>Whether all Betti numbers of the constraint nerve are zero, indicating no topological obstructions to resolution.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/nerveEulerCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nerveEulerCharacteristic</rdfs:label>
    <rdfs:comment>The Euler characteristic χ(N(C)) of the active constraint nerve at this resolution state. IT_7d requires this value to equal n (the quantum level) for resolution to be complete. Cached here to avoid recomputing the full ψ pipeline on each iteration check.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/completenessTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>completenessTarget</rdfs:label>
    <rdfs:comment>The CompletenessCandidate this resolver is certifying.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/CompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompletenessCandidate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/quantumLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>quantumLevel</rdfs:label>
    <rdfs:comment>The quantum level this resolver instance is configured for.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/WittLevelResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/sessionAccumulator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sessionAccumulator</rdfs:label>
    <rdfs:comment>The BindingAccumulator this session resolver maintains across multiple RelationQuery evaluations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/SessionResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/state/BindingAccumulator"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/synthesisGoal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>synthesisGoal</rdfs:label>
    <rdfs:comment>The goal this type synthesis resolver is working to achieve.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TypeSynthesisResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeSynthesisGoal"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/exploredCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exploredCount</rdfs:label>
    <rdfs:comment>Number of constraint combinations evaluated so far during synthesis.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ConstraintSearchState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/currentCandidate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>currentCandidate</rdfs:label>
    <rdfs:comment>The type candidate currently being evaluated during synthesis.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ConstraintSearchState"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/liftTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftTarget</rdfs:label>
    <rdfs:comment>The WittLift this incremental completeness resolver is evaluating.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/IncrementalCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/WittLift"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/liftSitePosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftSitePosition</rdfs:label>
    <rdfs:comment>The new site position at Q_{n+1} that the lift refinement suggestion targets.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/LiftRefinementSuggestion"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/obstructionClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionClass</rdfs:label>
    <rdfs:comment>The obstruction class this lift refinement suggestion is designed to kill.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/LiftRefinementSuggestion"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/LiftObstructionClass"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/monodromyTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>monodromyTarget</rdfs:label>
    <rdfs:comment>The type whose holonomy this monodromy resolver is computing.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MonodromyResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/holonomyResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>holonomyResult</rdfs:label>
    <rdfs:comment>The HolonomyGroup produced by this monodromy resolver run.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MonodromyResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/HolonomyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/guidingJacobian">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>guidingJacobian</rdfs:label>
    <rdfs:comment>The Jacobian observable guiding constraint selection at this resolution state (DC_10).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/Jacobian"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/usedGrounding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>usedGrounding</rdfs:label>
    <rdfs:comment>Whether this resolver used the saturation shortcut (SC_5) to bypass the ψ-pipeline and return a direct coordinate read.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/GroundingAwareResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/validateGeodesic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validateGeodesic</rdfs:label>
    <rdfs:comment>The GeodesicTrace being validated by this GeodesicValidator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/GeodesicValidator"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/GeodesicTrace"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/collapseAmplitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>collapseAmplitude</rdfs:label>
    <rdfs:comment>The amplitude of the SuperposedSiteState prior to projective collapse by this MeasurementResolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MeasurementResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/collapsedSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>collapsedSite</rdfs:label>
    <rdfs:comment>The site index that was collapsed (pinned to a classical value) by the projective measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MeasurementResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/measurementOutcome">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>measurementOutcome</rdfs:label>
    <rdfs:comment>The classical value obtained from the projective collapse. Either 0 or 1 for a single-site measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MeasurementResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/amplitudeVector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>amplitudeVector</rdfs:label>
    <rdfs:comment>The amplitude vector of all branches maintained by this SuperpositionResolver during ψ-pipeline traversal. Encoded as a comma-separated list of decimal amplitudes. Must satisfy Σ|αᵢ|² = 1 (QM_5) after normalization.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/SuperpositionResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/resolver/priorAmplitudeVector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>priorAmplitudeVector</rdfs:label>
    <rdfs:comment>The full vector of all branch amplitudes before projective collapse. Recorded by the MeasurementResolver to enable Born rule verification (QM_5): P(outcome k) = |α_k|².</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/MeasurementResolver"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/towerSourceLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>towerSourceLevel</rdfs:label>
    <rdfs:comment>The level at which the tower starts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/towerTargetLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>towerTargetLevel</rdfs:label>
    <rdfs:comment>The level to which the tower is being built.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/currentChain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>currentChain</rdfs:label>
    <rdfs:comment>The LiftChain under construction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/LiftChain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/towerStepResolver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>towerStepResolver</rdfs:label>
    <rdfs:comment>The IncrementalCompletenessResolver used for each single-step lift.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/IncrementalCompletenessResolver"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/executionPolicy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>executionPolicy</rdfs:label>
    <rdfs:comment>The ordering strategy this resolver applies to pending queries. Defaults to FifoPolicy if unset.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/SessionResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/ExecutionPolicy"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/homotopyTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homotopyTarget</rdfs:label>
    <rdfs:comment>The CechNerve whose homotopy type this resolver computes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/HomotopyResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/CechNerve"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/homotopyResult">
    <rdfs:label>homotopyResult</rdfs:label>
    <rdfs:comment>A HomotopyGroup observable produced by this resolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/HomotopyResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/HomotopyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/moduliTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>moduliTarget</rdfs:label>
    <rdfs:comment>The CompleteType whose local moduli structure this resolver computes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ModuliResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/moduliDeformation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>moduliDeformation</rdfs:label>
    <rdfs:comment>The DeformationComplex constructed by this resolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ModuliResolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/DeformationComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/dispatchTable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchTable</rdfs:label>
    <rdfs:comment>The dispatch table governing resolver selection for this resolver class.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/DispatchTable"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/resolverPredicate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>resolverPredicate</rdfs:label>
    <rdfs:comment>The predicate that selects this specific resolver. When the predicate evaluates to true on an input type, this resolver is chosen.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/Resolver"/>
    <rdfs:range rdf:resource="https://uor.foundation/predicate/TypePredicate"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/forResolver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>forResolver</rdfs:label>
    <rdfs:comment>The resolver:Resolver subclass this CertifyMapping describes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/producesCertificate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>producesCertificate</rdfs:label>
    <rdfs:comment>The cert:Certificate (or proof:ComputationCertificate) subclass this resolver produces on success.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/resolver/producesWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>producesWitness</rdfs:label>
    <rdfs:comment>The proof:ImpossibilityWitness subclass this resolver produces on failure.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/ConstantTime">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ComplexityClass"/>
    <rdfs:label>ConstantTime</rdfs:label>
    <rdfs:comment>O(1) complexity — the resolver runs in constant time regardless of ring size.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/LogarithmicTime">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ComplexityClass"/>
    <rdfs:label>LogarithmicTime</rdfs:label>
    <rdfs:comment>O(log n) complexity — the resolver runs in logarithmic time in the quantum level.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/LinearTime">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ComplexityClass"/>
    <rdfs:label>LinearTime</rdfs:label>
    <rdfs:comment>O(n) complexity — the resolver runs in time linear in the quantum level.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/ExponentialTime">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ComplexityClass"/>
    <rdfs:label>ExponentialTime</rdfs:label>
    <rdfs:comment>O(2^n) complexity — the resolver runs in time exponential in the quantum level.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/FifoPolicy">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ExecutionPolicyKind"/>
    <rdfs:label>FifoPolicy</rdfs:label>
    <rdfs:comment>Process queries in arrival order. The implicit pre-Amendment 48 behavior.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/MinFreeCountFirst">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ExecutionPolicyKind"/>
    <rdfs:label>MinFreeCountFirst</rdfs:label>
    <rdfs:comment>Process the query with the smallest targetSite.freeRank first. Favors cheapest resolutions, accelerating early grounding gain.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/MaxFreeCountFirst">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ExecutionPolicyKind"/>
    <rdfs:label>MaxFreeCountFirst</rdfs:label>
    <rdfs:comment>Process the query with the largest targetSite.freeRank first. Favors hardest resolutions, maximizing information gain per step.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/DisjointFirst">
    <rdf:type rdf:resource="https://uor.foundation/resolver/ExecutionPolicyKind"/>
    <rdfs:label>DisjointFirst</rdfs:label>
    <rdfs:comment>Process queries whose targetSite is disjoint from all other pending queries&apos; site sets first. Minimizes contention when operating against a SharedContext.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/towerCertifyMapping">
    <rdf:type rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:label>towerCertifyMapping</rdfs:label>
    <rdfs:comment>TowerCompletenessResolver produces LiftChainCertificate on success and ImpossibilityWitness on failure.</rdfs:comment>
    <uor:resolver/forResolver rdf:resource="https://uor.foundation/resolver/TowerCompletenessResolver"/>
    <uor:resolver/producesCertificate rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <uor:resolver/producesWitness rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/incrementalCertifyMapping">
    <rdf:type rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:label>incrementalCertifyMapping</rdfs:label>
    <rdfs:comment>IncrementalCompletenessResolver produces LiftChainCertificate (single-step) on success and ImpossibilityWitness on failure.</rdfs:comment>
    <uor:resolver/forResolver rdf:resource="https://uor.foundation/resolver/IncrementalCompletenessResolver"/>
    <uor:resolver/producesCertificate rdf:resource="https://uor.foundation/cert/LiftChainCertificate"/>
    <uor:resolver/producesWitness rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/groundingAwareCertifyMapping">
    <rdf:type rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:label>groundingAwareCertifyMapping</rdfs:label>
    <rdfs:comment>GroundingAwareResolver produces GroundingCertificate on success and ImpossibilityWitness on failure.</rdfs:comment>
    <uor:resolver/forResolver rdf:resource="https://uor.foundation/resolver/GroundingAwareResolver"/>
    <uor:resolver/producesCertificate rdf:resource="https://uor.foundation/cert/GroundingCertificate"/>
    <uor:resolver/producesWitness rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/inhabitanceCertifyMapping">
    <rdf:type rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:label>inhabitanceCertifyMapping</rdfs:label>
    <rdfs:comment>InhabitanceResolver produces InhabitanceCertificate on success and InhabitanceImpossibilityWitness on failure.</rdfs:comment>
    <uor:resolver/forResolver rdf:resource="https://uor.foundation/resolver/InhabitanceResolver"/>
    <uor:resolver/producesCertificate rdf:resource="https://uor.foundation/cert/InhabitanceCertificate"/>
    <uor:resolver/producesWitness rdf:resource="https://uor.foundation/proof/InhabitanceImpossibilityWitness"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/resolver/multiplicationCertifyMapping">
    <rdf:type rdf:resource="https://uor.foundation/resolver/CertifyMapping"/>
    <rdfs:label>multiplicationCertifyMapping</rdfs:label>
    <rdfs:comment>MultiplicationResolver produces MultiplicationCertificate on success and ImpossibilityWitness on failure. The resolver is total over admissible call-site contexts (stack_budget_bytes &gt; 0), so failure is unreachable for well-formed inputs.</rdfs:comment>
    <uor:resolver/forResolver rdf:resource="https://uor.foundation/resolver/MultiplicationResolver"/>
    <uor:resolver/producesCertificate rdf:resource="https://uor.foundation/cert/MultiplicationCertificate"/>
    <uor:resolver/producesWitness rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
  </owl:NamedIndividual>

  <!-- Namespace: type -->
  <owl:Ontology rdf:about="https://uor.foundation/type/">
    <rdfs:label>UOR Type System</rdfs:label>
    <rdfs:comment>Runtime type declarations that parameterize the resolution pipeline. Types are declared by Prism applications and resolved to partitions of the ring.</rdfs:comment>
    <uor:space>user</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/type/TypeDefinition">
    <rdfs:label>TypeDefinition</rdfs:label>
    <rdfs:comment>A runtime type declaration. The root class for all UOR types. Each TypeDefinition, when resolved, produces a partition of the ring at the specified quantum level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/Constraint"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/MetricAxis"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/PrimitiveType">
    <rdfs:label>PrimitiveType</rdfs:label>
    <rdfs:comment>A primitive type defined by a fixed bit width. The carrier is the entire ring Z/(2^n)Z at the specified quantum level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ProductType">
    <rdfs:label>ProductType</rdfs:label>
    <rdfs:comment>A product (Cartesian) type formed from multiple component types. The carrier is the product of the component carriers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/SumType">
    <rdfs:label>SumType</rdfs:label>
    <rdfs:comment>A sum (disjoint union) type formed from multiple variant types. The carrier is the disjoint union of the variant carriers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ConstrainedType">
    <rdfs:label>ConstrainedType</rdfs:label>
    <rdfs:comment>A type formed by constraining a base type with a predicate. The carrier is the subset of the base carrier satisfying the constraint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/Constraint">
    <rdfs:label>Constraint</rdfs:label>
    <rdfs:comment>A composable predicate that refines a type by pinning one or more site coordinates. Constraints are the parameterization mechanism for ConstrainedType.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/TypeDefinition"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/MetricAxis"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/MetricAxis">
    <rdfs:label>MetricAxis</rdfs:label>
    <rdfs:comment>A classification axis for constraints by their geometric effect. The three axes — vertical (ring/additive), horizontal (Hamming/bitwise), diagonal (incompatibility) — form the tri-metric coordinate system of UOR.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/TypeDefinition"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/CompleteType">
    <rdfs:label>CompleteType</rdfs:label>
    <rdfs:comment>A TypeDefinition certified to satisfy the UOR completeness criterion (IT_7d): its constraint nerve N(C) has Euler characteristic χ = n and all Betti numbers β_k = 0. A CompleteType guarantees that resolution closes the site budget in O(1) — no iterative refinement is required. Completeness is attested by a cert:CompletenessCertificate linked via cert:certifiedType. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/CompletenessCandidate">
    <rdfs:label>CompletenessCandidate</rdfs:label>
    <rdfs:comment>A ConstrainedType actively undergoing the completeness certification pipeline. Links to the resolver:ResolutionState tracking the current iteration and to the resolver:CechNerve being computed. Disjoint from CompleteType (which is already certified). This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/CompletenessWitness">
    <rdfs:label>CompletenessWitness</rdfs:label>
    <rdfs:comment>A record of a single site-closing event: one constraint application that reduced the FreeRank deficit. Carries the applied constraint and the sitesClosed count. Forms the ordered audit trail between ConstrainedType and CompleteType.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/TypeSynthesisGoal">
    <rdfs:label>TypeSynthesisGoal</rdfs:label>
    <rdfs:comment>A specification of the desired topological properties of a type to be synthesised. Carries a target Euler characteristic (targetEulerCharacteristic) and a target Betti profile (zero or more targetBettiNumber assertions). The minimal goal for O(1) resolution is: targetEulerCharacteristic = n and all targetBettiNumber = 0 — the IT_7d profile.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/TypeSynthesisResult">
    <rdfs:label>TypeSynthesisResult</rdfs:label>
    <rdfs:comment>The output of a TypeSynthesisResolver run. Contains the SynthesizedType, the realised topological signature (as a SynthesisSignature), and the SynthesisTrace recording the construction steps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/SynthesizedType">
    <rdfs:label>SynthesizedType</rdfs:label>
    <rdfs:comment>A ConstrainedType produced by the TypeSynthesisResolver. Distinguished from a hand-authored ConstrainedType by the presence of a type:synthesisResult link. May or may not be a CompleteType, depending on the synthesis goal. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/MinimalConstraintBasis">
    <rdfs:label>MinimalConstraintBasis</rdfs:label>
    <rdfs:comment>The minimal set of constraints in the SynthesizedType&apos;s constraint set that is sufficient to realise the target topological signature. The minimality criterion is that removing any single member changes the realised signature.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/WittLift">
    <rdfs:label>WittLift</rdfs:label>
    <rdfs:comment>A ConstrainedType T&apos; over R_{n+1} obtained by extending a ConstrainedType T over R_n. Carries a link to the base type (liftBase), the quantum level it lifts to (liftTargetLevel), and the LiftObstruction (if the lift fails to transfer completeness). A WittLift is a CompleteType iff its LiftObstruction is trivial.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/LiftObstruction">
    <rdfs:label>LiftObstruction</rdfs:label>
    <rdfs:comment>The algebraic obstruction to a WittLift inheriting the completeness of its base type. Computed as the image of the spectral sequence differential d_2. If trivial (zero), the base type&apos;s completeness lifts. If non-trivial, at least one additional constraint is needed at the new quantum level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/TwistedType">
    <rdfs:label>TwistedType</rdfs:label>
    <rdfs:comment>A ConstrainedType whose HolonomyGroup is non-trivial — at least one closed constraint path produces a non-identity dihedral element. A TwistedType may still be a CompleteType (IT_7d is a homological, not holonomic, criterion), but its resolution paths require tracking dihedral accumulation. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/FlatType"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/FlatType">
    <rdfs:label>FlatType</rdfs:label>
    <rdfs:comment>A ConstrainedType whose HolonomyGroup is trivial — all closed constraint paths have identity monodromy. The constraint configuration is topologically flat: resolution is path-independent. This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/type/TwistedType"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/SuperposedSiteState">
    <rdfs:label>SuperposedSiteState</rdfs:label>
    <rdfs:comment>A type representing a superposition of site states where sites carry complex amplitudes rather than binary pinned/free assignments. Ontological realisation of RC_5 (Amendment 32). This class is not addressable from a type-expr position in the term language; references from term-language positions are rejected by the resolver.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ForbiddenSignature">
    <rdfs:label>ForbiddenSignature</rdfs:label>
    <rdfs:comment>A topological signature (χ, β_k) that is formally impossible to achieve for any ConstrainedType. Witnessed by an ImpossibilityWitness in proof/.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/CollapsedSiteState">
    <rdfs:label>CollapsedSiteState</rdfs:label>
    <rdfs:comment>A site state that has undergone projective collapse from a SuperposedSiteState to a definitive classical value. Topologically equivalent to a classically pinned site (QM_2).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/LiftChain">
    <rdfs:label>LiftChain</rdfs:label>
    <rdfs:comment>An ordered composition of WittLift steps from liftSourceLevel (Q_j) to liftTargetLevel (Q_k) for any j &lt; k. The canonical object certifying type completeness at arbitrary Q_k.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ObstructionChain">
    <rdfs:label>ObstructionChain</rdfs:label>
    <rdfs:comment>The complete ordered sequence of LiftObstruction records encountered and resolved along a LiftChain. An empty ObstructionChain means the tower is flat.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ModuliSpace">
    <rdfs:label>ModuliSpace</rdfs:label>
    <rdfs:comment>The space of all CompleteTypes over R_n at a given quantum level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/HolonomyStratum">
    <rdfs:label>HolonomyStratum</rdfs:label>
    <rdfs:comment>A stratum indexed by a conjugacy class of subgroups of D_{2^n}.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/DeformationFamily">
    <rdfs:label>DeformationFamily</rdfs:label>
    <rdfs:comment>A one-parameter family of constraint configurations parameterizing a path.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/VersalDeformation">
    <rdfs:label>VersalDeformation</rdfs:label>
    <rdfs:comment>The versal deformation of a CompleteType T.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ModuliTowerMap">
    <rdfs:label>ModuliTowerMap</rdfs:label>
    <rdfs:comment>The map induced by WittLift from one moduli space to the next.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/GaloisConnection">
    <rdfs:label>GaloisConnection</rdfs:label>
    <rdfs:comment>The adjunction between the type lattice and the site lattice. The upper adjoint is type closure; the lower adjoint is site interior. σ = lower adjoint evaluation; r = complement of upper adjoint image.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/TypeInclusion">
    <rdfs:label>TypeInclusion</rdfs:label>
    <rdfs:comment>A morphism T₁ → T₂ witnessing that T₁ is a subtype of T₂: the constraint set of T₁ is a superset of the constraint set of T₂.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Transform"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/VarianceAnnotation">
    <rdfs:label>VarianceAnnotation</rdfs:label>
    <rdfs:comment>The variance of a structural type position under operad composition. One of Covariant, Contravariant, Invariant, or Bivariant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/SubtypingLattice">
    <rdfs:label>SubtypingLattice</rdfs:label>
    <rdfs:comment>The partial order on types induced by TypeInclusion. The top element is PrimitiveType (no constraints); the bottom elements are CompleteTypes (all sites pinned).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/ConstraintDefaults">
    <rdfs:label>ConstraintDefaults</rdfs:label>
    <rdfs:comment>Declarative defaults for type:Constraint subclasses, consumed by #[derive(ConstrainedType)] at macro-crate build time.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/BoundConstraint">
    <rdfs:label>BoundConstraint</rdfs:label>
    <rdfs:comment>Parametric constraint carrier consumed by the codegen to emit `BoundConstraint&lt;O: Observable, B: BoundShape&gt;` in the Rust foundation. The (observable, bound_shape) pair picks the predicate form; the typed datatype properties (modulus, residue, hammingBound, ...) carry the parameters for that specific kind. Replaces the seven v0.2.1 enumerated Constraint subclasses with a parametric form; the legacy names survive as Rust type aliases (ResidueConstraint, HammingConstraint, ...).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/BoundShape">
    <rdfs:label>BoundShape</rdfs:label>
    <rdfs:comment>The predicate form a BoundConstraint imposes on its bound observable. Closed enumeration with exactly six named individuals (EqualBound, LessEqBound, GreaterEqBound, RangeContainBound, ResidueClassBound, AffineEqualBound). Adding a new bound shape is an ontology+grammar+codegen edit on the same protocol as adding a Witt level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/type/Conjunction">
    <rdfs:label>Conjunction</rdfs:label>
    <rdfs:comment>A conjunction of BoundConstraint instances. The conjuncts property is ordered. Replaces the v0.2.1 CompositeConstraint enumeration; the legacy name survives as a Rust type alias (CompositeConstraint&lt;const N: usize&gt; = Conjunction&lt;N&gt;).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/bitWidth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bitWidth</rdfs:label>
    <rdfs:comment>The bit width of a primitive type (the quantum level n). The carrier is Z/(2^n)Z.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/PrimitiveType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/component">
    <rdfs:label>component</rdfs:label>
    <rdfs:comment>A component type in a product type.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ProductType"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/variant">
    <rdfs:label>variant</rdfs:label>
    <rdfs:comment>A variant type in a sum type. Ordering contract: variants are returned in canonical content-fingerprint order (ascending), matching the canonicalization used by coproduct_shape! and the content-address hashing pipeline, so introspection via variant() and the algebra_id derived from the same type agree on which variant is &apos;left&apos; and which is &apos;right&apos;. Author-order is not preserved.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SumType"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/tagSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tagSite</rdfs:label>
    <rdfs:comment>The tag site distinguishing variants of this sum type at runtime (ST_6). Stored at the physical layout position max(SITE_COUNT(A), SITE_COUNT(B)) so the tag cannot collide with any inherited bookkeeping site when either operand is itself a coproduct.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SumType"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/TagSite"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/baseType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseType</rdfs:label>
    <rdfs:comment>The base type that a constrained type restricts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/contentAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>contentAddress</rdfs:label>
    <rdfs:comment>The content-derived address of this type definition, uniquely identifying the type in the UOR address space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeDefinition"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/hasConstraint">
    <rdfs:label>hasConstraint</rdfs:label>
    <rdfs:comment>A typed constraint object applied to this constrained type. Replaces the deprecated string-based type:constraint property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/modulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>modulus</rdfs:label>
    <rdfs:comment>The modulus m of a residue constraint: x ≡ r (mod m).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/residue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>residue</rdfs:label>
    <rdfs:comment>The residue value r of a residue constraint: x ≡ r (mod m).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/carryPattern">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>carryPattern</rdfs:label>
    <rdfs:comment>The carry propagation pattern of a carry constraint, expressed as a Datum at the appropriate quantum level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/minDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>minDepth</rdfs:label>
    <rdfs:comment>The minimum factorization depth required by a depth constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/maxDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxDepth</rdfs:label>
    <rdfs:comment>The maximum factorization depth allowed by a depth constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/composedFrom">
    <rdfs:label>composedFrom</rdfs:label>
    <rdfs:comment>A component constraint of this composite constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/Conjunction"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/hammingBound">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hammingBound</rdfs:label>
    <rdfs:comment>Upper bound on the Hamming weight of the Datum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/siteIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteIndex</rdfs:label>
    <rdfs:comment>Zero-based index of the pinned site coordinate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/siteValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteValue</rdfs:label>
    <rdfs:comment>The value the pinned site coordinate must equal (a Datum in the set {0, 1}).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/affineOffset">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>affineOffset</rdfs:label>
    <rdfs:comment>Constant offset defining the affine subspace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/affineGenerator">
    <rdfs:label>affineGenerator</rdfs:label>
    <rdfs:comment>A generator of the affine subspace. Non-functional: multiple generators span the subspace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/metricAxis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricAxis</rdfs:label>
    <rdfs:comment>The metric axis along which this constraint operates: vertical (ring), horizontal (Hamming), or diagonal (incompatibility).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/Constraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/MetricAxis"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/pinsSites">
    <rdfs:label>pinsSites</rdfs:label>
    <rdfs:comment>A site coordinate that this constraint pins when applied.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/Constraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/affectsAxis">
    <rdfs:label>affectsAxis</rdfs:label>
    <rdfs:comment>The metric axis that this operation affects. Replaces the string-valued type:axisSignature property with a typed reference to MetricAxis individuals. Non-functional: an operation may affect multiple axes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/MetricAxis"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/crossingCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>crossingCost</rdfs:label>
    <rdfs:comment>The cost of applying this constraint in terms of axis crossings: the number of metric boundaries that must be traversed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/Constraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/completenessCandidate">
    <rdfs:label>completenessCandidate</rdfs:label>
    <rdfs:comment>The ConstrainedType being evaluated for completeness by this CompletenessCandidate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CompletenessCandidate"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/candidateNerve">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>candidateNerve</rdfs:label>
    <rdfs:comment>The constraint nerve being computed for this candidate. The CompletenessResolver reads χ(N(C)) from this nerve at each iteration via resolver:nerveEulerCharacteristic.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CompletenessCandidate"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/CechNerve"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/witnessConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>witnessConstraint</rdfs:label>
    <rdfs:comment>The constraint applied in this witness step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CompletenessWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/sitesClosed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitesClosed</rdfs:label>
    <rdfs:comment>Number of sites closed by this witness step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CompletenessWitness"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/targetEulerCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetEulerCharacteristic</rdfs:label>
    <rdfs:comment>The target χ(N(C)) value. For O(1) resolution: set equal to n (the quantum level).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeSynthesisGoal"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/targetBettiNumber">
    <rdfs:label>targetBettiNumber</rdfs:label>
    <rdfs:comment>Non-functional. Each assertion specifies a target Betti number value for a given homological degree. Multiple assertions permitted, one per degree.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeSynthesisGoal"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/synthesisResult">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>synthesisResult</rdfs:label>
    <rdfs:comment>Links a SynthesizedType back to the synthesis run that produced it.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SynthesizedType"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeSynthesisResult"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/basisConstraint">
    <rdfs:label>basisConstraint</rdfs:label>
    <rdfs:comment>Non-functional. One assertion per constraint in the minimal basis.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/MinimalConstraintBasis"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/basisSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>basisSize</rdfs:label>
    <rdfs:comment>The cardinality of the minimal basis. The theoretical lower bound is n (one constraint per site).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/MinimalConstraintBasis"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/liftBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftBase</rdfs:label>
    <rdfs:comment>The base type being lifted to the next quantum level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/WittLift"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/liftTargetLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftTargetLevel</rdfs:label>
    <rdfs:comment>The quantum level this lift targets.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/WittLift"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/liftObstruction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftObstruction</rdfs:label>
    <rdfs:comment>The LiftObstruction for this lift. Trivial (zero class) iff the lift inherits completeness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/WittLift"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/LiftObstruction"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/obstructionTrivial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionTrivial</rdfs:label>
    <rdfs:comment>True iff the obstruction class is zero — the base type&apos;s completeness transfers to the lifted quantum level without additional constraints.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftObstruction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/obstructionSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionSite</rdfs:label>
    <rdfs:comment>The site at the new quantum level where the obstruction is located. Ranges over the new bit position introduced at Q_{n+1}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftObstruction"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/holonomyGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>holonomyGroup</rdfs:label>
    <rdfs:comment>The HolonomyGroup of this type. Computed by the MonodromyResolver.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/HolonomyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/monodromyClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>monodromyClass</rdfs:label>
    <rdfs:comment>The MonodromyClass classifying this type as flat or twisted.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/MonodromyClass"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/amplitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>amplitude</rdfs:label>
    <rdfs:comment>The amplitude coefficient for this superposed site state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SuperposedSiteState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/targetForbidden">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetForbidden</rdfs:label>
    <rdfs:comment>Whether the target signature of this TypeSynthesisGoal is a ForbiddenSignature. If true, synthesis is provably impossible.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeSynthesisGoal"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/collapsedFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>collapsedFrom</rdfs:label>
    <rdfs:comment>The SuperposedSiteState from which this CollapsedSiteState was produced by projective measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CollapsedSiteState"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/SuperposedSiteState"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/survivingAmplitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>survivingAmplitude</rdfs:label>
    <rdfs:comment>The amplitude of the surviving branch after projective collapse. |α|² is the probability of this outcome under the Born rule.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/CollapsedSiteState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/normalizationVerified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>normalizationVerified</rdfs:label>
    <rdfs:comment>Whether the amplitude vector of this SuperposedSiteState satisfies the normalization condition Σ|αᵢ|² = 1 (QM_5). Set by the SuperpositionResolver after verification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SuperposedSiteState"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/holonomyClassified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>holonomyClassified</rdfs:label>
    <rdfs:comment>Whether this ConstrainedType has been classified as FlatType or TwistedType by the MonodromyResolver. The MN_8 identity guarantees this is a bivalent classification: holonomyClassified(T) iff isFlatType(T) xor isTwistedType(T).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/liftSourceLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>liftSourceLevel</rdfs:label>
    <rdfs:comment>The quantum level at the base of the chain.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftChain"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/chainLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>chainLength</rdfs:label>
    <rdfs:comment>The number of WittLift steps in the chain (k - j).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/chainStep">
    <rdfs:label>chainStep</rdfs:label>
    <rdfs:comment>A WittLift step in this chain. Non-functional: one per step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftChain"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/WittLift"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/chainObstructionProfile">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>chainObstructionProfile</rdfs:label>
    <rdfs:comment>The full obstruction history of this chain.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftChain"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ObstructionChain"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/resolvedBasisSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>resolvedBasisSize</rdfs:label>
    <rdfs:comment>The basis size of the CompleteType at the chain target level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/LiftChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/obstructionAt">
    <rdfs:label>obstructionAt</rdfs:label>
    <rdfs:comment>A non-trivial LiftObstruction in this chain. Non-functional.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ObstructionChain"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/LiftObstruction"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/obstructionCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionCount</rdfs:label>
    <rdfs:comment>Total number of non-trivial LiftObstruction records.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ObstructionChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/isFlat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isFlat</rdfs:label>
    <rdfs:comment>True iff obstructionCount = 0 (flat tower).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ObstructionChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/moduliWittLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>moduliWittLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this moduli space is defined.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ModuliSpace"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/moduliPoint">
    <rdfs:label>moduliPoint</rdfs:label>
    <rdfs:comment>A CompleteType that is a point of this moduli space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ModuliSpace"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/moduliDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>moduliDimension</rdfs:label>
    <rdfs:comment>The dimension of this moduli space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ModuliSpace"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/stratumHolonomyClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stratumHolonomyClass</rdfs:label>
    <rdfs:comment>The MonodromyClass indexing this stratum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/HolonomyStratum"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/MonodromyClass"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/stratumCodimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stratumCodimension</rdfs:label>
    <rdfs:comment>The codimension of this stratum within the moduli space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/HolonomyStratum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/stratumModuli">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stratumModuli</rdfs:label>
    <rdfs:comment>The moduli space containing this stratum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/HolonomyStratum"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ModuliSpace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/familyParameter">
    <rdfs:label>familyParameter</rdfs:label>
    <rdfs:comment>A CompleteType along the deformation path.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/DeformationFamily"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/familyPreservesCompleteness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>familyPreservesCompleteness</rdfs:label>
    <rdfs:comment>Whether every member of this deformation family remains a CompleteType.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/DeformationFamily"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/versalBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>versalBase</rdfs:label>
    <rdfs:comment>The CompleteType at the base of this versal deformation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/VersalDeformation"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/versalDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>versalDimension</rdfs:label>
    <rdfs:comment>The dimension of the versal deformation space.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/VersalDeformation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/towerMapSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>towerMapSource</rdfs:label>
    <rdfs:comment>The source moduli space of this tower map.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ModuliTowerMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ModuliSpace"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/upperAdjoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>upperAdjoint</rdfs:label>
    <rdfs:comment>The upper adjoint (type closure) of the Galois connection, expressed as a symbolic formula string.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/lowerAdjoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>lowerAdjoint</rdfs:label>
    <rdfs:comment>The lower adjoint (site interior) of the Galois connection, expressed as a symbolic formula string.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/fixpointCondition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fixpointCondition</rdfs:label>
    <rdfs:comment>The fixpoint condition for the Galois connection: when upper(lower(T)) = T, the type is complete.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/refinementDirection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>refinementDirection</rdfs:label>
    <rdfs:comment>Description of the refinement direction: ascending in type lattice corresponds to descending in site freedom.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/type/structuralSiteCount">
    <rdfs:label>structuralSiteCount</rdfs:label>
    <rdfs:comment>Formula or description of the site count for a structural type individual.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/type/structuralGrounding">
    <rdfs:label>structuralGrounding</rdfs:label>
    <rdfs:comment>Description of the grounding rule that maps values of this structural type onto the UOR ring.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/type/structuralConstraint">
    <rdfs:label>structuralConstraint</rdfs:label>
    <rdfs:comment>Description of the constraint characterizing this structural type, if applicable.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/galoisClosureProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>galoisClosureProperty</rdfs:label>
    <rdfs:comment>The closure property of a Galois connection.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/galoisInteriorProperty">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>galoisInteriorProperty</rdfs:label>
    <rdfs:comment>The interior property of a Galois connection.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/GaloisConnection"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/groundingMapRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundingMapRef</rdfs:label>
    <rdfs:comment>Reference to the grounding map used for this type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/morphism/GroundingMap"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/compositionLaw">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionLaw</rdfs:label>
    <rdfs:comment>The algebraic composition law governing this type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/siteOrderingConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteOrderingConstraint</rdfs:label>
    <rdfs:comment>Constraint on the ordering of sites for this type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/backboneThreshold">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>backboneThreshold</rdfs:label>
    <rdfs:comment>The threshold for backbone inclusion in the type lattice.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/permutationGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>permutationGroup</rdfs:label>
    <rdfs:comment>The permutation group acting on sites of this type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/op/Group"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/acyclicityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>acyclicityWitness</rdfs:label>
    <rdfs:comment>Witness certifying acyclicity of the type dependency graph.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/connectivityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>connectivityWitness</rdfs:label>
    <rdfs:comment>Witness certifying connectivity of the type graph.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/schemaConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>schemaConstraint</rdfs:label>
    <rdfs:comment>Constraint imposed by the schema on this type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/type/alphabetSize">
    <rdfs:label>alphabetSize</rdfs:label>
    <rdfs:comment>The size of the alphabet for symbol-based types.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:AnnotationProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/quantizationRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>quantizationRange</rdfs:label>
    <rdfs:comment>The range specification for quantized types.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/elementTypeRef">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>elementTypeRef</rdfs:label>
    <rdfs:comment>Reference to the element type within a composite type.</rdfs:comment>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/inclusionSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inclusionSource</rdfs:label>
    <rdfs:comment>The subtype (more constraints).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeInclusion"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/inclusionTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inclusionTarget</rdfs:label>
    <rdfs:comment>The supertype (fewer constraints).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeInclusion"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/positionVariance">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>positionVariance</rdfs:label>
    <rdfs:comment>The variance of each operand position.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/operad/StructuralOperad"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/VarianceAnnotation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/inclusionWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inclusionWitness</rdfs:label>
    <rdfs:comment>True iff constraints(source) ⊇ constraints(target). Computed, not asserted.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/TypeInclusion"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/latticeDepth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>latticeDepth</rdfs:label>
    <rdfs:comment>Maximum chain length from PrimitiveType (top) to any CompleteType (bottom). Equals the site budget n at quantum level Q_k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/SubtypingLattice"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/defaultValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>defaultValue</rdfs:label>
    <rdfs:comment>Default integer value for the named constraint default.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/ConstraintDefaults"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/boundObservable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundObservable</rdfs:label>
    <rdfs:comment>The observable:Observable whose values this BoundConstraint bounds. Picks which datum projection is being constrained.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/boundShape">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundShape</rdfs:label>
    <rdfs:comment>The predicate form this BoundConstraint imposes on its bound observable. Closed enumeration with exactly six named individuals (EqualBound, LessEqBound, GreaterEqBound, RangeContainBound, ResidueClassBound, AffineEqualBound).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/BoundShape"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/type/boundArguments">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundArguments</rdfs:label>
    <rdfs:comment>The BoundConstraint&apos;s parameters in canonical string form (e.g., &apos;modulus=256;residue=255&apos; for a residue class bound). Non-functional — the string-form encoding is the canonical serialization; typed accessors on the Rust side unpack it via the per-type-alias constructors.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/type/conjuncts">
    <rdfs:label>conjuncts</rdfs:label>
    <rdfs:comment>An ordered list of BoundConstraint individuals that this Conjunction composes. Non-functional — multiple conjuncts span the conjunction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/type/Conjunction"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/BoundConstraint"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/verticalAxis">
    <rdf:type rdf:resource="https://uor.foundation/type/MetricAxis"/>
    <rdfs:label>verticalAxis</rdfs:label>
    <rdfs:comment>The vertical (ring/additive) metric axis. Constraints on this axis operate through ring arithmetic: residue classes, divisibility, and additive structure.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/horizontalAxis">
    <rdf:type rdf:resource="https://uor.foundation/type/MetricAxis"/>
    <rdfs:label>horizontalAxis</rdfs:label>
    <rdfs:comment>The horizontal (Hamming/bitwise) metric axis. Constraints on this axis operate through bitwise structure: carry patterns, bit positions, and Hamming distance.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/diagonalAxis">
    <rdf:type rdf:resource="https://uor.foundation/type/MetricAxis"/>
    <rdfs:label>diagonalAxis</rdfs:label>
    <rdfs:comment>The diagonal (incompatibility) metric axis. Constraints on this axis measure the gap between ring and Hamming metrics — the curvature of UOR geometry.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/ScalarType">
    <rdf:type rdf:resource="https://uor.foundation/type/PrimitiveType"/>
    <rdfs:label>ScalarType</rdfs:label>
    <rdfs:comment>A single value from an ordered domain. siteCount = n (quantization bits).</rdfs:comment>
    <uor:type/structuralSiteCount>n (quantization bits)</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>quantize(value, range, bits) produces ring element where d_R reflects value proximity</uor:type/structuralGrounding>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/SymbolType">
    <rdf:type rdf:resource="https://uor.foundation/type/PrimitiveType"/>
    <rdfs:label>SymbolType</rdfs:label>
    <rdfs:comment>A value from a finite unordered set. siteCount = ceil(log2(|alphabet|)).</rdfs:comment>
    <uor:type/structuralSiteCount>ceil(log2(|alphabet|))</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>argmin_{encoding} sum d_delta over observed pairs (CY_5)</uor:type/structuralGrounding>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/SequenceType">
    <rdf:type rdf:resource="https://uor.foundation/type/ProductType"/>
    <rdfs:label>SequenceType</rdfs:label>
    <rdfs:comment>An ordered list of elements with backbone constraint. The free monoid on the element type.</rdfs:comment>
    <uor:type/structuralSiteCount>sum of element site counts</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>free monoid on element type, backbone constraint</uor:type/structuralGrounding>
    <uor:type/structuralConstraint>backbone ordering: elements indexed by position</uor:type/structuralConstraint>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/TupleType">
    <rdf:type rdf:resource="https://uor.foundation/type/ProductType"/>
    <rdfs:label>TupleType</rdfs:label>
    <rdfs:comment>A fixed collection of named fields.</rdfs:comment>
    <uor:type/structuralSiteCount>sum of field site counts</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>site ordering follows CY_6 (optimal site ordering)</uor:type/structuralGrounding>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/GraphType">
    <rdf:type rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:label>GraphType</rdfs:label>
    <rdfs:comment>Nodes with edge constraints. Constraint nerve = graph topology.</rdfs:comment>
    <uor:type/structuralSiteCount>sum of node site counts + edge overhead</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>constraint nerve = graph nerve, beta_k equality</uor:type/structuralGrounding>
    <uor:type/structuralConstraint>edge constraints: adjacency preserved under grounding</uor:type/structuralConstraint>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/SetType">
    <rdf:type rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:label>SetType</rdfs:label>
    <rdfs:comment>Unordered collection. d_delta is permutation-invariant.</rdfs:comment>
    <uor:type/structuralSiteCount>sum of element site counts</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>d_delta invariant under element permutation, D_{2n} symmetry</uor:type/structuralGrounding>
    <uor:type/structuralConstraint>permutation invariance: encoding is order-independent</uor:type/structuralConstraint>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/TreeType">
    <rdf:type rdf:resource="https://uor.foundation/type/ConstrainedType"/>
    <rdfs:label>TreeType</rdfs:label>
    <rdfs:comment>Hierarchical structure. beta_1=0 (acyclic), beta_0=1 (connected).</rdfs:comment>
    <uor:type/structuralSiteCount>sum of node site counts</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>parent-child encoding with acyclicity constraint</uor:type/structuralGrounding>
    <uor:type/structuralConstraint>beta_1=0 (acyclic), beta_0=1 (connected)</uor:type/structuralConstraint>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/TableType">
    <rdf:type rdf:resource="https://uor.foundation/type/ProductType"/>
    <rdfs:label>TableType</rdfs:label>
    <rdfs:comment>Collection of tuples sharing a schema = Sequence(Tuple(S)). Functorial decomposition.</rdfs:comment>
    <uor:type/structuralSiteCount>row_count * tuple_site_count</uor:type/structuralSiteCount>
    <uor:type/structuralGrounding>Sequence(Tuple(S)), functorial decomposition</uor:type/structuralGrounding>
    <uor:type/structuralConstraint>shared schema: all rows conform to tuple type S</uor:type/structuralConstraint>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/Covariant">
    <rdf:type rdf:resource="https://uor.foundation/type/VarianceAnnotation"/>
    <rdfs:label>Covariant</rdfs:label>
    <rdfs:comment>The structural position preserves TypeInclusion: if T₁ ≤ T₂, then F(T₁) ≤ F(T₂).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/type/Covariant"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/Contravariant">
    <rdf:type rdf:resource="https://uor.foundation/type/VarianceAnnotation"/>
    <rdfs:label>Contravariant</rdfs:label>
    <rdfs:comment>The structural position reverses TypeInclusion: if T₁ ≤ T₂, then F(T₂) ≤ F(T₁).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/type/Contravariant"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/Invariant">
    <rdf:type rdf:resource="https://uor.foundation/type/VarianceAnnotation"/>
    <rdfs:label>Invariant</rdfs:label>
    <rdfs:comment>The structural position requires exact type equality: F(T₁) ≤ F(T₂) only if T₁ = T₂.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/type/Invariant"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/Bivariant">
    <rdf:type rdf:resource="https://uor.foundation/type/VarianceAnnotation"/>
    <rdfs:label>Bivariant</rdfs:label>
    <rdfs:comment>The structural position ignores the type parameter: F(T₁) ≤ F(T₂) for all T₁, T₂.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/type/Bivariant"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/EitherType">
    <rdf:type rdf:resource="https://uor.foundation/type/SumType"/>
    <rdfs:label>EitherType</rdfs:label>
    <rdfs:comment>The canonical binary disjoint union type whose carrier is L + R.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/OptionType">
    <rdf:type rdf:resource="https://uor.foundation/type/SumType"/>
    <rdfs:label>OptionType</rdfs:label>
    <rdfs:comment>The canonical A + Unit idiom for optional values.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/ResidueDefaultModulus">
    <rdf:type rdf:resource="https://uor.foundation/type/ConstraintDefaults"/>
    <rdfs:label>ResidueDefaultModulus</rdfs:label>
    <rdfs:comment>Default modulus for ResidueConstraint when the #[uor(residue = X)] attribute omits the explicit modulus. 256 matches the v0.2.1 reference ring Z/(2^8)Z.</rdfs:comment>
    <uor:type/defaultValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">256</uor:type/defaultValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/EqualBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>EqualBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) == target`. Used by BoundConstraint instances asserting strict equality of a datum&apos;s observable projection to a target value.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/LessEqBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>LessEqBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) &lt;= bound`. Used by hamming, depth, carry, and site-rank bound constraints.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/GreaterEqBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>GreaterEqBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) &gt;= bound`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/RangeContainBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>RangeContainBound</rdfs:label>
    <rdfs:comment>Predicate form: `lo &lt;= observable(datum) &lt;= hi`. The datum&apos;s observable projection must lie within the inclusive range `[lo, hi]`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/ResidueClassBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>ResidueClassBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) ≡ residue (mod modulus)`. Used by BoundConstraint instances asserting residue-class membership.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/AffineEqualBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>AffineEqualBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) == offset + Σ αᵢ·generatorᵢ`. The datum&apos;s observable projection must equal an affine combination of the BoundConstraint&apos;s affine generators.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/LexicographicLessEqBound">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundShape"/>
    <rdfs:label>LexicographicLessEqBound</rdfs:label>
    <rdfs:comment>Predicate form: `observable(datum) &lt;= bound` over byte-sequence-valued observables under canonical big-endian unsigned ordering. Fixed-length: lexicographic byte-wise comparison. Variable-length: lexicographic with shorter-prefix-rule (the shorter sequence is less than the longer when bytes match through the shorter&apos;s length). Wiki ADR-040 + ADR-038: this is the BoundShape primitive for byte-sequence-valued AxisProjectionObservable instances (e.g. axis-realized hash projections) — LessEqBound is the integer-valued primitive (HammingMetric, DerivationDepthObservable, etc.).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/residueConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>residueConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 ResidueConstraint class: (observable:ValueModObservable, type:ResidueClassBound). The Rust foundation exposes this kind via the `ResidueConstraint` type alias with `pub const fn new(modulus, residue)`.</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/observable/ValueModObservable"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/ResidueClassBound"/>
    <uor:type/boundArguments>modulus=256;residue=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/hammingConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>hammingConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 HammingConstraint class: (observable:HammingMetric, type:LessEqBound). The Rust foundation exposes this kind via the `HammingConstraint` type alias with `pub const fn new(bound)`.</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/observable/HammingMetric"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/LessEqBound"/>
    <uor:type/boundArguments>bound=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/depthConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>depthConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 DepthConstraint class: (derivation:DerivationDepthObservable, type:LessEqBound).</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/derivation/DerivationDepthObservable"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/LessEqBound"/>
    <uor:type/boundArguments>min_depth=0;max_depth=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/carryConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>carryConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 CarryConstraint class: (carry:CarryDepthObservable, type:LessEqBound).</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/carry/CarryDepthObservable"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/LessEqBound"/>
    <uor:type/boundArguments>bound=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/siteConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>siteConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 SiteConstraint class: (partition:FreeRankObservable, type:LessEqBound).</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/partition/FreeRankObservable"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/LessEqBound"/>
    <uor:type/boundArguments>site_index=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/type/affineConstraintKind">
    <rdf:type rdf:resource="https://uor.foundation/type/BoundConstraint"/>
    <rdfs:label>affineConstraintKind</rdfs:label>
    <rdfs:comment>Parametric replacement for the v0.2.1 AffineConstraint class: (observable:ValueModObservable, type:AffineEqualBound).</rdfs:comment>
    <uor:type/boundObservable rdf:resource="https://uor.foundation/observable/ValueModObservable"/>
    <uor:type/boundShape rdf:resource="https://uor.foundation/type/AffineEqualBound"/>
    <uor:type/boundArguments>offset=0</uor:type/boundArguments>
  </owl:NamedIndividual>

  <!-- Namespace: partition -->
  <owl:Ontology rdf:about="https://uor.foundation/partition/">
    <rdfs:label>UOR Partitions</rdfs:label>
    <rdfs:comment>Irreducibility partitions produced by type resolution. A partition divides the ring into four disjoint components: Irreducible, Reducible, Units, and Exterior.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/partition/Partition">
    <rdfs:label>Partition</rdfs:label>
    <rdfs:comment>A four-component partition of R_n produced by resolving a type declaration. The four components — Irreducible, Reducible, Units, Exterior — are mutually disjoint and exhaustive over the carrier.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/Component">
    <rdfs:label>Component</rdfs:label>
    <rdfs:comment>A single component of a partition: a set of datum values belonging to one of the four categories.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/SiteIndex"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/IrreducibleSet">
    <rdfs:label>IrreducibleSet</rdfs:label>
    <rdfs:comment>The set of irreducible elements under the active type: elements whose only factorizations involve units or themselves. Analogous to prime elements in a ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/Component"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/ReducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/UnitGroup"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/Complement"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/ReducibleSet">
    <rdfs:label>ReducibleSet</rdfs:label>
    <rdfs:comment>The set of reducible non-unit elements: elements that can be expressed as a product of two or more non-unit elements.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/Component"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/IrreducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/UnitGroup"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/Complement"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/UnitGroup">
    <rdfs:label>UnitGroup</rdfs:label>
    <rdfs:comment>The set of invertible elements (units) in the carrier: elements with a multiplicative inverse. In Z/(2^n)Z, the units are the odd integers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/Component"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/IrreducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/ReducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/Complement"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/Complement">
    <rdfs:label>Complement</rdfs:label>
    <rdfs:comment>Elements of R_n that fall outside the active carrier — i.e., outside the type&apos;s domain. These are ring elements that do not participate in the current type resolution.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/Component"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/IrreducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/ReducibleSet"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/UnitGroup"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/SiteIndex">
    <rdfs:label>SiteIndex</rdfs:label>
    <rdfs:comment>A single site coordinate in the iterated Z/2Z fibration. Each site represents one binary degree of freedom in the ring&apos;s structure. The total number of sites equals the quantum level n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/Component"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/FreeRank">
    <rdfs:label>FreeRank</rdfs:label>
    <rdfs:comment>The site budget for a partition: an accounting of how many sites are pinned (determined by constraints) versus free (still available for further refinement). A closed budget means all sites are pinned and the type is fully resolved.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/SiteIndex"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/Component"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/SiteBinding">
    <rdfs:label>SiteBinding</rdfs:label>
    <rdfs:comment>A record of a single site being pinned by a constraint. Links a specific site coordinate to the constraint that determined its value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/PartitionProduct">
    <rdfs:label>PartitionProduct</rdfs:label>
    <rdfs:comment>The tensor product of two partitions: partition(A × B) = partition(A) ⊗ partition(B). The four-component structure combines component-wise under the product type construction (PT_2a). Carries leftFactor and rightFactor links to the operand partitions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/PartitionCoproduct"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/CartesianPartitionProduct"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/PartitionCoproduct">
    <rdfs:label>PartitionCoproduct</rdfs:label>
    <rdfs:comment>The coproduct (disjoint union) of two partitions: partition(A + B) = partition(A) ⊕ partition(B). The four-component structure combines via disjoint union under the sum type construction (PT_2b). Carries leftSummand and rightSummand links to the operand partitions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/PartitionProduct"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/CartesianPartitionProduct"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/CartesianPartitionProduct">
    <rdfs:label>CartesianPartitionProduct</rdfs:label>
    <rdfs:comment>The Cartesian product of partitions. Classifies the nerve topology of A ⊠ B as a simplicial product (χ multiplicative per CPT_3, Betti by Künneth per CPT_4) rather than a site-disjoint union (χ additive — PartitionProduct). Site budget is |S_A| + |S_B| per CPT_1 — the bit width of the product state space. Partition-ness is asserted via leftCartesianFactor / rightCartesianFactor (both ranged at Partition), matching the sibling pattern for PartitionProduct and PartitionCoproduct. Satisfies CPT_1–CPT_6 per this amendment.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/PartitionProduct"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/partition/PartitionCoproduct"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/TagSite">
    <rdfs:label>TagSite</rdfs:label>
    <rdfs:comment>The distinguishing site in a PartitionCoproduct whose value (0 or 1) selects the variant. Logically, the tag is not a data site of either operand (ST_6) and carries exactly the ln 2 entropy quantum (ST_2). Its physical placement in a flat constraint layout follows the foundation layout convention: layoutTagSite = max(SITE_COUNT(A), SITE_COUNT(B)), so the tag does not collide with any inherited bookkeeping sites when operands are themselves coproducts.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/FreeRankObservable">
    <rdfs:label>FreeRankObservable</rdfs:label>
    <rdfs:comment>Observes the free-rank of the partition associated with a Datum&apos;s site context, recording the count of unbound sites at the moment of observation. Used as the bound observable for the siteConstraintKind BoundConstraint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/partition/PartitionComponent">
    <rdfs:label>PartitionComponent</rdfs:label>
    <rdfs:comment>Closed enumeration of partition component kinds: Irreducible (non-factorizable), Reducible (factorizable into non-trivial parts), Units (invertible), Exterior (outside the factorization domain). Codegen treats this as an enum class with exactly 4 individuals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/irreducibles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>irreducibles</rdfs:label>
    <rdfs:comment>The irreducible component of this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/IrreducibleSet"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/reducibles">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>reducibles</rdfs:label>
    <rdfs:comment>The reducible component of this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/ReducibleSet"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/units">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>units</rdfs:label>
    <rdfs:comment>The units component of this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/UnitGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/exterior">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exterior</rdfs:label>
    <rdfs:comment>The exterior component of this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Complement"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/member">
    <rdfs:label>member</rdfs:label>
    <rdfs:comment>A datum value belonging to this partition component.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Component"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/cardinality">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cardinality</rdfs:label>
    <rdfs:comment>The number of elements in this partition component. The cardinalities of the four components must sum to 2^n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/density">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>density</rdfs:label>
    <rdfs:comment>The irreducible density of this partition: |Irr| / |A|, where A is the active carrier.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/sourceType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceType</rdfs:label>
    <rdfs:comment>The type declaration that was resolved to produce this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/wittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLength</rdfs:label>
    <rdfs:comment>The Witt level n at which this partition was computed. The ring has 2^n elements at this level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/sitePosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePosition</rdfs:label>
    <rdfs:comment>The zero-based position of this site coordinate within the iterated fibration. Position 0 is the least significant bit; position n-1 is the most significant.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/SiteIndex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/siteState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteState</rdfs:label>
    <rdfs:comment>The current state of this site coordinate: &apos;pinned&apos; if determined by a constraint, &apos;free&apos; if still available for refinement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/SiteIndex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/siteBudget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>siteBudget</rdfs:label>
    <rdfs:comment>The site budget associated with this partition.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/FreeRank"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/totalSites">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>totalSites</rdfs:label>
    <rdfs:comment>The total number of site coordinates in this budget, equal to the quantum level n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/pinnedCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pinnedCount</rdfs:label>
    <rdfs:comment>The number of site coordinates currently pinned by constraints.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/freeRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>freeRank</rdfs:label>
    <rdfs:comment>The number of site coordinates still free (not yet pinned). Equals totalSites - pinnedCount.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/isClosed">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isClosed</rdfs:label>
    <rdfs:comment>Whether all sites in this budget are pinned. A closed budget means the type is fully resolved and the partition is complete.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/hasSite">
    <rdfs:label>hasSite</rdfs:label>
    <rdfs:comment>A site coordinate belonging to this budget.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/pinnedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pinnedBy</rdfs:label>
    <rdfs:comment>The constraint that pins this site coordinate.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/SiteBinding"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/pinsCoordinate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pinsCoordinate</rdfs:label>
    <rdfs:comment>The site coordinate that this pinning determines.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/SiteBinding"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/hasBinding">
    <rdfs:label>hasBinding</rdfs:label>
    <rdfs:comment>A site pinning record in this budget.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteBinding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/ancillaSite">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ancillaSite</rdfs:label>
    <rdfs:comment>An ancilla site coordinate paired with this site for reversible computation (RC_1–RC_4 ancilla model).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/SiteIndex"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/reversibleStrategy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>reversibleStrategy</rdfs:label>
    <rdfs:comment>True when this site budget uses a reversible computation strategy preserving information through ancilla sites.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/FreeRank"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/exteriorCriteria">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>exteriorCriteria</rdfs:label>
    <rdfs:comment>The formal membership criterion for this Complement: x ∈ Ext(T) iff x ∉ carrier(T). The Complement is context-dependent on the active type T (FPM_9).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Complement"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/isExhaustive">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isExhaustive</rdfs:label>
    <rdfs:comment>Whether the four components of this partition are exhaustive over R_n: |Irr| + |Red| + |Unit| + |Ext| = 2^n (FPM_8). Set by the kernel after verification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/leftFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftFactor</rdfs:label>
    <rdfs:comment>The left operand partition of this tensor product.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/PartitionProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/rightFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightFactor</rdfs:label>
    <rdfs:comment>The right operand partition of this tensor product.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/PartitionProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/leftSummand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftSummand</rdfs:label>
    <rdfs:comment>The left operand partition of this coproduct.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/PartitionCoproduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/rightSummand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightSummand</rdfs:label>
    <rdfs:comment>The right operand partition of this coproduct.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/PartitionCoproduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/leftCartesianFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftCartesianFactor</rdfs:label>
    <rdfs:comment>The left operand partition of this Cartesian partition product.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/CartesianPartitionProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/rightCartesianFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightCartesianFactor</rdfs:label>
    <rdfs:comment>The right operand partition of this Cartesian partition product.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/CartesianPartitionProduct"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/Partition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/partition/tagSiteOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tagSiteOf</rdfs:label>
    <rdfs:comment>The tag site distinguishing the variants of a PartitionCoproduct. Logically distinct from every data site of either operand (ST_6) and carries the ln 2 entropy quantum of ST_2.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/TagSite"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/tagValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tagValue</rdfs:label>
    <rdfs:comment>The boolean value (false = 0, true = 1) assigned to a tag site. false selects the left variant of the PartitionCoproduct; true selects the right variant.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/TagSite"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/partition/productCategoryLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>productCategoryLevel</rdfs:label>
    <rdfs:comment>The categorical level at which this construction is a product / coproduct. Values: &apos;partition_classification&apos; (PartitionProduct, PartitionCoproduct), or &apos;nerve_topology&apos; (CartesianPartitionProduct). Prevents misreading the product vs coproduct distinction across levels.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/partition/Partition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/partition/Irreducible">
    <rdf:type rdf:resource="https://uor.foundation/partition/PartitionComponent"/>
    <rdfs:label>Irreducible</rdfs:label>
    <rdfs:comment>The irreducible component: elements that admit no non-trivial factorization within the ring.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/partition/Reducible">
    <rdf:type rdf:resource="https://uor.foundation/partition/PartitionComponent"/>
    <rdfs:label>Reducible</rdfs:label>
    <rdfs:comment>The reducible component: elements that factor into non-trivial parts.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/partition/Units">
    <rdf:type rdf:resource="https://uor.foundation/partition/PartitionComponent"/>
    <rdfs:label>Units</rdfs:label>
    <rdfs:comment>The unit component: invertible elements of the ring.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/partition/Exterior">
    <rdf:type rdf:resource="https://uor.foundation/partition/PartitionComponent"/>
    <rdfs:label>Exterior</rdfs:label>
    <rdfs:comment>The exterior component: elements outside the factorization domain (e.g., zero or ring-boundary values).</rdfs:comment>
  </owl:NamedIndividual>

  <!-- Namespace: foundation -->
  <owl:Ontology rdf:about="https://uor.foundation/foundation/">
    <rdfs:label>UOR Foundation Layout Invariants</rdfs:label>
    <rdfs:comment>Foundation-level layout invariants complementing op-namespace theorems. Quantifies over foundation-defined SITE_COUNT arithmetic and ConstraintRef byte patterns, not over ontology-level siteBudget.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/foundation/LayoutInvariant">
    <rdfs:label>LayoutInvariant</rdfs:label>
    <rdfs:comment>A foundation-level layout invariant. Each instance describes an arithmetic or encoding identity that the foundation&apos;s mint primitives and validate_const() pass enforce at compile time, distinct from the ontology-level theorem individuals carried by the op namespace. Violations produce GenericImpossibilityWitness citations against the specific LayoutInvariant IRI, letting consumers distinguish a layout-level failure from a theorem-level failure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/foundation/layoutRule">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>layoutRule</rdfs:label>
    <rdfs:comment>The arithmetic or encoding identity this LayoutInvariant asserts, expressed as a human-readable string for inspection in documentation and debugging output.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/foundation/LayoutInvariant"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/foundation/ProductLayoutWidth">
    <rdf:type rdf:resource="https://uor.foundation/foundation/LayoutInvariant"/>
    <rdfs:label>ProductLayoutWidth</rdfs:label>
    <rdfs:comment>PartitionProduct layout-width invariant: products introduce no bookkeeping of their own, so layout widths add. Cited by primitive_partition_product when the caller-supplied combined SITE_COUNT differs from the sum of operand SITE_COUNTs.</rdfs:comment>
    <uor:foundation/layoutRule>SITE_COUNT(A × B) = SITE_COUNT(A) + SITE_COUNT(B)</uor:foundation/layoutRule>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/foundation/CartesianLayoutWidth">
    <rdf:type rdf:resource="https://uor.foundation/foundation/LayoutInvariant"/>
    <rdfs:label>CartesianLayoutWidth</rdfs:label>
    <rdfs:comment>CartesianPartitionProduct layout-width invariant: cartesian products introduce no bookkeeping either, so layout widths add the same way PartitionProduct does. The distinction between these two constructions lives at the nerve-topology level (χ multiplicative vs additive), not the layout level.</rdfs:comment>
    <uor:foundation/layoutRule>SITE_COUNT(A ⊠ B) = SITE_COUNT(A) + SITE_COUNT(B)</uor:foundation/layoutRule>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/foundation/CoproductLayoutWidth">
    <rdf:type rdf:resource="https://uor.foundation/foundation/LayoutInvariant"/>
    <rdfs:label>CoproductLayoutWidth</rdfs:label>
    <rdfs:comment>PartitionCoproduct layout-width invariant: coproducts add exactly one tag site beyond the widest operand&apos;s full layout. Uses SITE_COUNT (not siteBudget) so nested coproducts whose operands carry inherited bookkeeping do not collide their outer tag with an inner tag site.</rdfs:comment>
    <uor:foundation/layoutRule>SITE_COUNT(A + B) = max(SITE_COUNT(A), SITE_COUNT(B)) + 1</uor:foundation/layoutRule>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/foundation/CoproductTagEncoding">
    <rdf:type rdf:resource="https://uor.foundation/foundation/LayoutInvariant"/>
    <rdfs:label>CoproductTagEncoding</rdfs:label>
    <rdfs:comment>PartitionCoproduct canonical tag-pinner encoding: each variant&apos;s tag-pinning constraint is the canonical Affine form with all-zero coefficients except a single 1 at tag_site, with bias 0 for the left variant and bias −1 for the right. Semantically equivalent but non-normalized encodings (coefficient ≠ 1, or alternative biases, etc.) are rejected at mint time because content-addressing depends on the normalized byte pattern, not the semantic equivalence class.</rdfs:comment>
    <uor:foundation/layoutRule>Affine { coefficients: [0,…,0, 1 at tag_site], bias: 0 (left) | −1 (right) }</uor:foundation/layoutRule>
  </owl:NamedIndividual>

  <!-- Namespace: observable -->
  <owl:Ontology rdf:about="https://uor.foundation/observable/">
    <rdfs:label>UOR Observables</rdfs:label>
    <rdfs:comment>Observable quantities and metrics computed by the UOR kernel. Includes ring-metric, Hamming-metric, curvature, holonomy, and catastrophe-theoretic observables.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/observable/Observable">
    <rdfs:label>Observable</rdfs:label>
    <rdfs:comment>A measurable quantity in the UOR Framework. All observables are kernel-computed and user-consumed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/StratumObservable">
    <rdfs:label>StratumObservable</rdfs:label>
    <rdfs:comment>An observable measuring stratum-level properties: position within the ring&apos;s layer structure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/MetricObservable">
    <rdfs:label>MetricObservable</rdfs:label>
    <rdfs:comment>An observable measuring geometric distance between ring elements under a specific metric.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/PathObservable">
    <rdfs:label>PathObservable</rdfs:label>
    <rdfs:comment>An observable measuring properties of paths through the ring: path length, total variation, winding number.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ReductionObservable">
    <rdfs:label>ReductionObservable</rdfs:label>
    <rdfs:comment>An observable measuring reduction properties: the length and count of operation sequences.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/CatastropheObservable">
    <rdfs:label>CatastropheObservable</rdfs:label>
    <rdfs:comment>An observable measuring catastrophe-theoretic properties: thresholds at which qualitative changes occur in the partition.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/CurvatureObservable">
    <rdfs:label>CurvatureObservable</rdfs:label>
    <rdfs:comment>An observable measuring the curvature of the UOR geometry: the gap between ring-isometry and Hamming-isometry for a given transform.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/HolonomyObservable">
    <rdfs:label>HolonomyObservable</rdfs:label>
    <rdfs:comment>An observable measuring holonomy: the accumulated transformation when traversing a closed path in the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/SpectralObservable">
    <rdfs:label>SpectralObservable</rdfs:label>
    <rdfs:comment>ADR-049: an observable whose value is a structural reading of a digest&apos;s frequency-domain spectrum. Distinct from the seven internally-derived Observable categories (Stratum / Metric / Path / Reduction / Catastrophe / Curvature / Holonomy) — its values are Walsh–Hadamard parities at specific frequencies, not derivable from the framework&apos;s internal algebraic/topological structure. Foundation&apos;s typed observable `WalshHadamardParity` per ADR-049 falls under this subclass; predicates over its values enter the typed-commitment surface per ADR-048 as `SingletonCommitment&lt;WalshHadamardParity&gt;` operands.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ValueThresholdObservable">
    <rdfs:label>ValueThresholdObservable</rdfs:label>
    <rdfs:comment>ADR-040 + ADR-049: an observable whose value is a byte-sequence threshold comparison reading of a digest. Distinct from the seven internally-derived Observable categories (Stratum / Metric / Path / Reduction / Catastrophe / Curvature / Holonomy) and from SpectralObservable / AxisProjectionObservable — its values carry from `(digest as big-endian unsigned integer) &lt;= (target as big-endian unsigned integer)`, the predicate form ADR-040 named when it committed `type:LexicographicLessEqBound`. Foundation&apos;s typed observable `LexicographicLessEqThreshold` per ADR-049 falls under this subclass; the canonical search-cost commitment alias `TargetCommitment = SingletonCommitment&lt;LexicographicLessEqThreshold&gt;` per ADR-048 consumes it. The ConstraintRef::Bound.args_repr canonical-string-form encoding for ValueThresholdObservable arguments carries the target byte sequence as the bound&apos;s argument directly.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/AxisProjectionObservable">
    <rdfs:label>AxisProjectionObservable</rdfs:label>
    <rdfs:comment>ADR-038: an observable whose value is the axis-realized projection of typed sites through an application-declared AxisTuple kernel per ADR-030. Distinct from the seven internally-derived Observable categories (Stratum, Metric, Path, Reduction, Catastrophe, Curvature, Holonomy) — its values carry from the substrate-extension surface (axis kernels), not from the framework&apos;s internal algebraic / topological structure. The closed-catalog discipline holds: foundation owns the subclass; applications consume catalog variants through canonical-string-form `args_repr` on `ConstraintRef::Bound`. The args_repr encoding (per ADR-038) is `axis_address=&lt;hex&gt;;kernel=&lt;symbolic&gt;;sites=&lt;site-list&gt;[;target=&lt;target-spec&gt;]` — axis identification by content-address (AXIS_ADDRESS per ADR-030), not by tuple position, so the encoding is application-invariant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/RingMetric">
    <rdfs:label>RingMetric</rdfs:label>
    <rdfs:comment>Distance between two ring elements under the ring metric: d_R(x, y) = |x - y| mod 2^n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/HammingMetric">
    <rdfs:label>HammingMetric</rdfs:label>
    <rdfs:comment>Distance between two ring elements under the Hamming metric: the number of bit positions where they differ.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/IncompatibilityMetric">
    <rdfs:label>IncompatibilityMetric</rdfs:label>
    <rdfs:comment>The metric incompatibility between two ring elements: the divergence between their ring-metric and Hamming-metric distances, measuring geometric curvature.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ValueModObservable">
    <rdfs:label>ValueModObservable</rdfs:label>
    <rdfs:comment>Observes a Datum&apos;s value modulo a configurable modulus. Used as the bound observable for BoundConstraint instances representing residue and affine constraint kinds (residueConstraintKind, affineConstraintKind).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/MetricObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/GroundingSigma">
    <rdfs:label>GroundingSigma</rdfs:label>
    <rdfs:comment>Observes the grounding completion ratio σ ∈ [0, 1] of a context, where σ = 1 indicates the ground state (state:GroundedContext). Backs the sigma_metric BaseMetric accessor on Grounded&lt;T&gt;.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/JacobianObservable">
    <rdfs:label>JacobianObservable</rdfs:label>
    <rdfs:comment>Observes the per-site Jacobian row of a Datum at a particular WittLevel, computed as the sequence of partial derivatives of the ring operation with respect to each site coordinate. Backs the jacobian_metric BaseMetric accessor on Grounded&lt;T&gt;; the Rust-side JacobianMetric&lt;L&gt; is parametric over the level marker.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/StratumValue">
    <rdfs:label>StratumValue</rdfs:label>
    <rdfs:comment>The stratum index of a ring element.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/StratumObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/StratumDelta">
    <rdfs:label>StratumDelta</rdfs:label>
    <rdfs:comment>The difference in stratum between two ring elements.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/StratumObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/StratumTrajectory">
    <rdfs:label>StratumTrajectory</rdfs:label>
    <rdfs:comment>The sequence of strata traversed by a path through the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/StratumObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/PathLength">
    <rdfs:label>PathLength</rdfs:label>
    <rdfs:comment>The length of a path through the ring, measured in operation steps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/PathObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/TotalVariation">
    <rdfs:label>TotalVariation</rdfs:label>
    <rdfs:comment>The total variation of a path: the sum of metric distances between consecutive elements.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/PathObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/WindingNumber">
    <rdfs:label>WindingNumber</rdfs:label>
    <rdfs:comment>The winding number of a closed path: the number of times the path wraps around the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/PathObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ReductionLength">
    <rdfs:label>ReductionLength</rdfs:label>
    <rdfs:comment>The number of operation applications in a reduction sequence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ReductionObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ReductionCount">
    <rdfs:label>ReductionCount</rdfs:label>
    <rdfs:comment>The number of distinct reduction sequences in a computation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ReductionObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/CatastropheThreshold">
    <rdfs:label>CatastropheThreshold</rdfs:label>
    <rdfs:comment>A critical value at which a qualitative change occurs in the partition structure.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/CatastropheCount">
    <rdfs:label>CatastropheCount</rdfs:label>
    <rdfs:comment>The number of catastrophe events (qualitative partition changes) in a computation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/Commutator">
    <rdfs:label>Commutator</rdfs:label>
    <rdfs:comment>The commutator [f, g](x) = f(g(x)) - g(f(x)) of two operations, measuring their non-commutativity.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/CurvatureObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/CurvatureFlux">
    <rdfs:label>CurvatureFlux</rdfs:label>
    <rdfs:comment>The integrated curvature over a region of type space: the total metric incompatibility accumulated.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/CurvatureObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/Monodromy">
    <rdfs:label>Monodromy</rdfs:label>
    <rdfs:comment>The monodromy of a closed path: the net transformation accumulated when traversing a loop in the type space.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/HolonomyObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ParallelTransport">
    <rdfs:label>ParallelTransport</rdfs:label>
    <rdfs:comment>The parallel transport of a vector along a path: the canonical lift of the path to the tangent bundle of the ring.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/HolonomyObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/DihedralElement">
    <rdfs:label>DihedralElement</rdfs:label>
    <rdfs:comment>An element of the dihedral group D_{2^n} acting on the type space. Each dihedral element induces an isometry of 𝒯_n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/HolonomyObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/MeasurementUnit">
    <rdfs:label>MeasurementUnit</rdfs:label>
    <rdfs:comment>A unit of measurement for observable quantities. Each MeasurementUnit individual names a specific unit (bits, ring steps, dimensionless) replacing the string-valued observable:unit property.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/Jacobian">
    <rdfs:label>Jacobian</rdfs:label>
    <rdfs:comment>Site-by-site curvature decomposition. J_k measures the discrete derivative of the incompatibility metric at site position k: J_k = |d_R(x, succ(x)) - d_H(x, succ(x))| restricted to position k.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/CurvatureObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/TopologicalObservable">
    <rdfs:label>TopologicalObservable</rdfs:label>
    <rdfs:comment>An observable measuring a topological invariant of the resolution space. Topological observables are invariant under continuous deformations of the constraint configuration.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/BettiNumber">
    <rdfs:label>BettiNumber</rdfs:label>
    <rdfs:comment>The rank of a homology group of the constraint nerve. β_k = rank(H_k(N(C))) counts the k-dimensional holes in the constraint configuration.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/TopologicalObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/SpectralGap">
    <rdfs:label>SpectralGap</rdfs:label>
    <rdfs:comment>The smallest positive eigenvalue of the constraint nerve Laplacian. Controls the convergence rate of iterative resolution: larger gap = faster convergence.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/TopologicalObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ThermoObservable">
    <rdfs:label>ThermoObservable</rdfs:label>
    <rdfs:comment>An observable measuring thermodynamic properties of the resolution process: residual entropy, Landauer cost, and reduction distribution statistics.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ResidualEntropy">
    <rdfs:label>ResidualEntropy</rdfs:label>
    <rdfs:comment>S_residual: the residual Shannon entropy of the site distribution after partial resolution. Computed as S = (Σ κ_k − χ(N(C))) × ln 2 (IT_7b). Unit: Nats.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ThermoObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/LandauerCost">
    <rdfs:label>LandauerCost</rdfs:label>
    <rdfs:comment>The minimum thermodynamic cost (in units of k_B T ln 2) of erasing one bit of site uncertainty. The UOR ring operates at β* = ln 2 — the Landauer temperature.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ThermoObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/LandauerBudget">
    <rdfs:label>LandauerBudget</rdfs:label>
    <rdfs:comment>A sealed observable carrier for accumulated Landauer cost in nats. Monotonic within a single pipeline invocation. The UOR ring operates at the Landauer temperature (β* = ln 2), so this observable is a direct measure of irreversible bit-erasure performed by the computation up to the witness it accompanies.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ThermoObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ReductionEntropy">
    <rdfs:label>ReductionEntropy</rdfs:label>
    <rdfs:comment>The Shannon entropy of the reduction distribution P(j) = 2^{−j}. At the Landauer temperature, this equals ln 2 per reduction step — each step erases exactly one bit of site uncertainty.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/ThermoObservable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/SynthesisSignature">
    <rdfs:label>SynthesisSignature</rdfs:label>
    <rdfs:comment>A named topological signature: a pair (realised Euler characteristic, realised Betti profile). Linked from TypeSynthesisResult. Allows comparison between the goal signature and the actually achieved signature.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/SpectralSequencePage">
    <rdfs:label>SpectralSequencePage</rdfs:label>
    <rdfs:comment>A single page E_r of the quantum level spectral sequence. Carries the page index r and the differential d_r. The sequence converges when all differentials vanish — typically by E_3 for simple constraint configurations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/LiftObstructionClass">
    <rdfs:label>LiftObstructionClass</rdfs:label>
    <rdfs:comment>The cohomology class in H^2(N(C(T))) representing the LiftObstruction for a specific WittLift. The class is zero iff the obstruction is trivial. When non-zero, it indexes the specific site pair at Q_{n+1} that cannot be closed by the lifted constraint set alone.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/MonodromyClass">
    <rdfs:label>MonodromyClass</rdfs:label>
    <rdfs:comment>A classification of a type&apos;s holonomy: the subgroup of D_{2^n} generated by all Monodromy observables computed over closed paths in the type&apos;s constraint nerve. Trivial iff every closed constraint path returns to its starting site assignment without net dihedral transformation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/HolonomyGroup">
    <rdfs:label>HolonomyGroup</rdfs:label>
    <rdfs:comment>The holonomy group of a ConstrainedType: the group of all Monodromy elements achievable by closed paths in the constraint nerve. Always a subgroup of D_{2^n}. Trivial iff the type has trivial monodromy everywhere; equals D_{2^n} iff paths involving both neg and bnot involutions are present.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/ClosedConstraintPath">
    <rdfs:label>ClosedConstraintPath</rdfs:label>
    <rdfs:comment>A sequence of constraint applications forming a closed loop in the constraint nerve — beginning and ending at the same site assignment. The Monodromy of the loop is the net DihedralElement accumulated when traversing it.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/PhaseBoundaryType">
    <rdfs:label>PhaseBoundaryType</rdfs:label>
    <rdfs:comment>A classification of phase boundary in the catastrophe diagram: period boundary (g divides 2^n − 1) or power-of-two boundary (g = 2^k).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/AchievabilityStatus">
    <rdfs:label>AchievabilityStatus</rdfs:label>
    <rdfs:comment>The achievability classification of a topological signature in the morphospace. Either Achievable or Forbidden (witnessed by ImpossibilityWitness).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/HomotopyGroup">
    <rdfs:label>HomotopyGroup</rdfs:label>
    <rdfs:comment>The k-th homotopy group πk(N(C), v) of the constraint nerve based at vertex v.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/HigherMonodromy">
    <rdfs:label>HigherMonodromy</rdfs:label>
    <rdfs:comment>The image of πk(N(C)) → Aut(sitek) for k &gt; 1. Generalises the MN_6 monodromy homomorphism.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/WhiteheadProduct">
    <rdfs:label>WhiteheadProduct</rdfs:label>
    <rdfs:comment>The Whitehead product [α, β] ∈ πp+q−1 for α ∈ πp, β ∈ πq.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/StratificationRecord">
    <rdfs:label>StratificationRecord</rdfs:label>
    <rdfs:comment>A record of the holonomy stratification of the moduli space at a given quantum level: the list of HolonomyStrata, their codimensions, and their relationship to the MorphospaceBoundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/BaseMetric">
    <rdfs:label>BaseMetric</rdfs:label>
    <rdfs:comment>Superclass for the six universal measurements. Every computation on the ring produces these six quantities: d_Δ, σ, J_k, β_k, χ, r.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/GroundingObservable">
    <rdfs:label>GroundingObservable</rdfs:label>
    <rdfs:comment>The grounding metric σ = pinned sites / total sites. Ranges from 0 (no sites pinned) to 1 (fully grounded).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/observable/EulerCharacteristicObservable">
    <rdfs:label>EulerCharacteristicObservable</rdfs:label>
    <rdfs:comment>The Euler characteristic χ = Σ(−1)^k β_k of the constraint nerve. An integer-valued topological invariant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/value">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>value</rdfs:label>
    <rdfs:comment>The numeric value of an observable measurement.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Observable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/source">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>source</rdfs:label>
    <rdfs:comment>The source object of this measurement (datum, partition, or path start point).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Observable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/target">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>target</rdfs:label>
    <rdfs:comment>The target object of this measurement (for metrics and path-end measurements).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Observable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/hasUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hasUnit</rdfs:label>
    <rdfs:comment>The measurement unit of this observable. Replaces the string-valued observable:unit property with a typed reference to a MeasurementUnit individual.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Observable"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/sitePosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePosition</rdfs:label>
    <rdfs:comment>The site position k at which this Jacobian entry is measured.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Jacobian"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/derivativeValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>derivativeValue</rdfs:label>
    <rdfs:comment>The discrete derivative value at this site position.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Jacobian"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/dimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dimension</rdfs:label>
    <rdfs:comment>The dimension k of the topological observable (e.g., the degree of the Betti number or the dimension of the spectral gap).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/TopologicalObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/realisedEuler">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>realisedEuler</rdfs:label>
    <rdfs:comment>The Euler characteristic actually achieved by this synthesis signature.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/realisedBetti">
    <rdfs:label>realisedBetti</rdfs:label>
    <rdfs:comment>Non-functional. Realised Betti number values, one assertion per homological degree.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/pageIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pageIndex</rdfs:label>
    <rdfs:comment>The page r of this spectral sequence page. r=1 is the initial page; convergence is declared when all d_r are zero.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SpectralSequencePage"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/differentialIsZero">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>differentialIsZero</rdfs:label>
    <rdfs:comment>True iff d_r = 0 on this page — no further corrections to the lifted homology.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SpectralSequencePage"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/convergedAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>convergedAt</rdfs:label>
    <rdfs:comment>The page index r at which the spectral sequence converged (all subsequent differentials zero).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SpectralSequencePage"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/obstructionClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionClass</rdfs:label>
    <rdfs:comment>The cohomology class in H^2(N(C(T))) representing this obstruction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/LiftObstructionClass"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CohomologyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/monodromyLoop">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>monodromyLoop</rdfs:label>
    <rdfs:comment>The closed path that generates this monodromy value.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Monodromy"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/ClosedConstraintPath"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/monodromyElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>monodromyElement</rdfs:label>
    <rdfs:comment>The dihedral element g in D_{2^n} accumulated when traversing the loop. The monodromy is trivial iff this element is the group identity.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Monodromy"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/DihedralElement"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/isTrivialMonodromy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isTrivialMonodromy</rdfs:label>
    <rdfs:comment>True iff the monodromyElement is the identity in D_{2^n}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/Monodromy"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/holonomyGroup">
    <rdfs:label>holonomyGroup</rdfs:label>
    <rdfs:comment>Non-functional. The generators of the holonomy group: one DihedralElement per generating monodromy.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HolonomyGroup"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/DihedralElement"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/holonomyGroupOrder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>holonomyGroupOrder</rdfs:label>
    <rdfs:comment>The order of the holonomy group as a subgroup of D_{2^n}. For a FlatType: 1. For full dihedral holonomy: 2^{n+1}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HolonomyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/pathLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>pathLength</rdfs:label>
    <rdfs:comment>The number of constraint application steps in this closed path.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/ClosedConstraintPath"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/pathConstraints">
    <rdfs:label>pathConstraints</rdfs:label>
    <rdfs:comment>Non-functional. The ordered sequence of constraints traversed. One assertion per step.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/ClosedConstraintPath"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/dihedralElementValue">
    <rdfs:label>dihedralElementValue</rdfs:label>
    <rdfs:comment>Non-functional. One assertion per generator in the normal form of the element — the sequence of neg and/or bnot operations that realises this dihedral element when composed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/DihedralElement"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/isIdentityElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isIdentityElement</rdfs:label>
    <rdfs:comment>True iff this element is the group identity (the trivial monodromy value).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/DihedralElement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/elementOrder">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>elementOrder</rdfs:label>
    <rdfs:comment>The order of this element in D_{2^n}: the smallest k &gt;= 1 such that g^k = id. For neg and bnot: order 2.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/DihedralElement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/hardnessEstimate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hardnessEstimate</rdfs:label>
    <rdfs:comment>An estimated computational hardness for a ThermoObservable, connecting thermodynamic cost to complexity (TH_9 realisation).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/ThermoObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/phaseN">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseN</rdfs:label>
    <rdfs:comment>The ring dimension coordinate n in the (n, g) catastrophe phase diagram (PD_1 n-coordinate).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/phaseG">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseG</rdfs:label>
    <rdfs:comment>The group-order coordinate g in the (n, g) catastrophe phase diagram (PD_1 g-coordinate).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/onResonanceLine">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>onResonanceLine</rdfs:label>
    <rdfs:comment>True when g divides 2^n − 1, placing this observable on a resonance line in the phase diagram (PD_4).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/phaseBoundaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>phaseBoundaryType</rdfs:label>
    <rdfs:comment>The type of phase boundary at this point in the catastrophe diagram: PeriodBoundary or PowerOfTwoBoundary (PD_2).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/CatastropheObservable"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/PhaseBoundaryType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/achievabilityStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>achievabilityStatus</rdfs:label>
    <rdfs:comment>The achievability classification of this observable&apos;s topological signature in the morphospace.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/AchievabilityStatus"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/isAchievable">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isAchievable</rdfs:label>
    <rdfs:comment>Whether this signature has been empirically verified as achievable at some quantum level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/isForbidden">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isForbidden</rdfs:label>
    <rdfs:comment>Whether this signature has been formally proven impossible by an ImpossibilityWitness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/achievabilityWitness">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>achievabilityWitness</rdfs:label>
    <rdfs:comment>The proof individual (ImpossibilityWitness or AxiomaticDerivation) that grounds this signature&apos;s achievability classification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SynthesisSignature"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/rotationExponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rotationExponent</rdfs:label>
    <rdfs:comment>The rotation exponent k ∈ \[0, 2^n) of this dihedral element in the standard representation r^k s^s. Together with reflectionBit, uniquely identifies the element within D_\{2^n\}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/DihedralElement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/reflectionBit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>reflectionBit</rdfs:label>
    <rdfs:comment>The reflection flag s ∈ \{0,1\} of this dihedral element. False = pure rotation (r^k), true = reflection (r^k·s). D_7 defines composition: (r^a s^p)(r^b s^q) = r^(a + (-1)^p b) s^(p XOR q).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/DihedralElement"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/homotopyDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homotopyDimension</rdfs:label>
    <rdfs:comment>The dimension k of this homotopy group πk.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HomotopyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/homotopyRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homotopyRank</rdfs:label>
    <rdfs:comment>The rank of this homotopy group (number of free generators).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HomotopyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/homotopyBasepoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homotopyBasepoint</rdfs:label>
    <rdfs:comment>The basepoint vertex v at which this homotopy group is computed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HomotopyGroup"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/higherMonodromyDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>higherMonodromyDimension</rdfs:label>
    <rdfs:comment>The dimension k &gt; 1 at which this higher monodromy acts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/HigherMonodromy"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/whiteheadTrivial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>whiteheadTrivial</rdfs:label>
    <rdfs:comment>True iff this Whitehead product is trivial (zero in πp+q−1).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/WhiteheadProduct"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/postnikovTruncation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>postnikovTruncation</rdfs:label>
    <rdfs:comment>The Postnikov truncation associated with this spectral sequence page.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SpectralSequencePage"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/PostnikovTruncation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/stratificationLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stratificationLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this stratification is computed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/StratificationRecord"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/stratificationStratum">
    <rdfs:label>stratificationStratum</rdfs:label>
    <rdfs:comment>A HolonomyStratum in this stratification record.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/StratificationRecord"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/HolonomyStratum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/metricDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricDomain</rdfs:label>
    <rdfs:comment>The mathematical domain of this base metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/metricRange">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricRange</rdfs:label>
    <rdfs:comment>The mathematical range (codomain) of this base metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricComposition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricComposition</rdfs:label>
    <rdfs:comment>How this metric composes with others in the measurement tower.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/observable/referencesClass">
    <rdfs:label>referencesClass</rdfs:label>
    <rdfs:comment>IRI of the existing observable class that this base metric references. Annotation-valued (not ObjectProperty) because the assertion is a class-level reference, not an instance-level one: the metric describes a class of Observable phenomena, not a specific individual.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/referencesIdentity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>referencesIdentity</rdfs:label>
    <rdfs:comment>The existing identity that defines this base metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/saturationNumerator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>saturationNumerator</rdfs:label>
    <rdfs:comment>The count of pinned sites (numerator of σ).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/GroundingObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/saturationDenominator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>saturationDenominator</rdfs:label>
    <rdfs:comment>The total site count (denominator of σ).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/GroundingObservable"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/alternatingSum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>alternatingSum</rdfs:label>
    <rdfs:comment>The alternating sum formula for Euler characteristic.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/EulerCharacteristicObservable"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricUnit</rdfs:label>
    <rdfs:comment>The unit of measurement for this base metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/metricPrecision">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricPrecision</rdfs:label>
    <rdfs:comment>The precision or resolution of this base metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricMonotonicity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricMonotonicity</rdfs:label>
    <rdfs:comment>Monotonicity property of this metric (e.g., non-decreasing).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricDecomposition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricDecomposition</rdfs:label>
    <rdfs:comment>The decomposition rule for this metric into sub-metrics.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/metricTowerPosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricTowerPosition</rdfs:label>
    <rdfs:comment>The position of this metric in the metric tower.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricComputationCost">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricComputationCost</rdfs:label>
    <rdfs:comment>The computational cost of evaluating this metric.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/observable/metricBound">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>metricBound</rdfs:label>
    <rdfs:comment>Upper or lower bound on the metric value.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/observable/landauerNats">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>landauerNats</rdfs:label>
    <rdfs:comment>The accumulated Landauer cost carried by a LandauerBudget instance, measured in nats. Monotonic within a pipeline invocation. The unit is observable:Nats — every increment corresponds to a number of irreversible bit-erasures times ln 2 (op:OA_5).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/LandauerBudget"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/Bits">
    <rdf:type rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
    <rdfs:label>Bits</rdfs:label>
    <rdfs:comment>Information-theoretic unit: the measurement is in bits (e.g., Hamming weight, entropy).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/RingSteps">
    <rdf:type rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
    <rdfs:label>RingSteps</rdfs:label>
    <rdfs:comment>Ring-arithmetic unit: the measurement is in ring distance steps (|x - y| mod 2^n).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/Dimensionless">
    <rdf:type rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
    <rdfs:label>Dimensionless</rdfs:label>
    <rdfs:comment>Dimensionless unit: the measurement is a pure number (e.g., winding number, Betti number, spectral gap).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/Nats">
    <rdf:type rdf:resource="https://uor.foundation/observable/MeasurementUnit"/>
    <rdfs:label>Nats</rdfs:label>
    <rdfs:comment>Natural information unit: entropy measured in nats (using natural logarithm). S_residual is expressed in nats when computed as (Σ κ_k − χ) × ln 2.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/PeriodBoundary">
    <rdf:type rdf:resource="https://uor.foundation/observable/PhaseBoundaryType"/>
    <rdfs:label>PeriodBoundary</rdfs:label>
    <rdfs:comment>A phase boundary where g divides 2^n − 1, meaning g is a period of the multiplicative structure of R_n.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/PowerOfTwoBoundary">
    <rdf:type rdf:resource="https://uor.foundation/observable/PhaseBoundaryType"/>
    <rdfs:label>PowerOfTwoBoundary</rdfs:label>
    <rdfs:comment>A phase boundary where g = 2^k, meaning g aligns with the binary stratification of R_n.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/Achievable">
    <rdf:type rdf:resource="https://uor.foundation/observable/AchievabilityStatus"/>
    <rdfs:label>Achievable</rdfs:label>
    <rdfs:comment>The signature has been verified as achievable at some quantum level by an AxiomaticDerivation proof.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/Forbidden">
    <rdf:type rdf:resource="https://uor.foundation/observable/AchievabilityStatus"/>
    <rdfs:label>Forbidden</rdfs:label>
    <rdfs:comment>The signature has been formally proven impossible by an ImpossibilityWitness deriving from MS_1, MS_2, or other impossibility theorems.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/d_delta_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>d_delta_metric</rdfs:label>
    <rdfs:comment>d_Δ: the incompatibility metric |d_R − d_H| per site pair.</rdfs:comment>
    <uor:observable/metricDomain>pair of ring elements</uor:observable/metricDomain>
    <uor:observable/metricRange>non-negative integer</uor:observable/metricRange>
    <uor:observable/referencesClass rdf:resource="https://uor.foundation/observable/IncompatibilityMetric"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/sigma_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>sigma_metric</rdfs:label>
    <rdfs:comment>σ: the grounding metric, pinned sites / total sites.</rdfs:comment>
    <uor:observable/metricDomain>computation state</uor:observable/metricDomain>
    <uor:observable/metricRange>decimal in [0, 1]</uor:observable/metricRange>
    <uor:observable/referencesIdentity rdf:resource="https://uor.foundation/op/GS_2"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/jacobian_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>jacobian_metric</rdfs:label>
    <rdfs:comment>J_k: per-site curvature, ∂_R f_k.</rdfs:comment>
    <uor:observable/metricDomain>computation state × site index</uor:observable/metricDomain>
    <uor:observable/metricRange>decimal</uor:observable/metricRange>
    <uor:observable/referencesClass rdf:resource="https://uor.foundation/observable/Jacobian"/>
    <uor:observable/referencesIdentity rdf:resource="https://uor.foundation/op/DC_6"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/betti_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>betti_metric</rdfs:label>
    <rdfs:comment>β_k: per-dimension Betti number of the constraint nerve.</rdfs:comment>
    <uor:observable/metricDomain>simplicial complex × dimension</uor:observable/metricDomain>
    <uor:observable/metricRange>non-negative integer</uor:observable/metricRange>
    <uor:observable/referencesClass rdf:resource="https://uor.foundation/observable/BettiNumber"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/euler_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>euler_metric</rdfs:label>
    <rdfs:comment>χ: Euler characteristic, Σ(−1)^k β_k.</rdfs:comment>
    <uor:observable/metricDomain>simplicial complex</uor:observable/metricDomain>
    <uor:observable/metricRange>integer</uor:observable/metricRange>
    <uor:observable/referencesIdentity rdf:resource="https://uor.foundation/op/IT_2"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/observable/residual_metric">
    <rdf:type rdf:resource="https://uor.foundation/observable/BaseMetric"/>
    <rdfs:label>residual_metric</rdfs:label>
    <rdfs:comment>r: count of free (unpinned) sites, the residual entropy.</rdfs:comment>
    <uor:observable/metricDomain>computation state</uor:observable/metricDomain>
    <uor:observable/metricRange>non-negative integer</uor:observable/metricRange>
    <uor:observable/referencesClass rdf:resource="https://uor.foundation/observable/ResidualEntropy"/>
  </owl:NamedIndividual>

  <!-- Namespace: carry -->
  <owl:Ontology rdf:about="https://uor.foundation/carry/">
    <rdfs:label>UOR Carry Algebra</rdfs:label>
    <rdfs:comment>Carry chain algebra: generate/propagate/kill event classification, carry profiles, encoding configurations, and encoding quality metrics for d_Δ optimization.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/carry/CarryChain">
    <rdfs:label>CarryChain</rdfs:label>
    <rdfs:comment>The Boolean function chain c_{k+1} = or(and(x_k, y_k), and(xor(x_k, y_k), c_k)). The carry chain is the algebraic mechanism behind the incompatibility metric d_Δ.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/carry/CarryEvent">
    <rdfs:label>CarryEvent</rdfs:label>
    <rdfs:comment>A single carry event at site k. Three kinds: Generate (and(x_k, y_k) = 1), Propagate (xor(x_k, y_k) = 1 and c_k = 1), Kill (neither generate nor propagate).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/carry/CarryProfile">
    <rdfs:label>CarryProfile</rdfs:label>
    <rdfs:comment>The complete carry pattern for an addition x + y. Aggregates carry events across all sites into counts and position masks.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/carry/EncodingConfiguration">
    <rdfs:label>EncodingConfiguration</rdfs:label>
    <rdfs:comment>A mapping from a finite symbol set S to Z/(2^k)Z where 2^k ≥ |S|. Determines how domain values are represented as ring elements.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/carry/EncodingQuality">
    <rdfs:label>EncodingQuality</rdfs:label>
    <rdfs:comment>The d_Δ quality metric for an encoding over observed data. Measures how well an encoding minimizes carry-induced metric incompatibility.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/carry/CarryDepthObservable">
    <rdfs:label>CarryDepthObservable</rdfs:label>
    <rdfs:comment>Observes the carry depth of a Datum in the W₂ tower, computed as the maximum carry-chain length in any operation producing it. Used as the bound observable for the carryConstraintKind BoundConstraint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/observable/Observable"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/chainLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>chainLength</rdfs:label>
    <rdfs:comment>The number of sites in this carry chain.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/generateMask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>generateMask</rdfs:label>
    <rdfs:comment>Bit mask of site positions where carry is generated: and(x_k, y_k) = 1.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/propagateMask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>propagateMask</rdfs:label>
    <rdfs:comment>Bit mask of site positions where carry propagates: xor(x_k, y_k) = 1.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/killMask">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>killMask</rdfs:label>
    <rdfs:comment>Bit mask of site positions where carry is killed: neither generated nor propagated.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryChain"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/eventKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>eventKind</rdfs:label>
    <rdfs:comment>The kind of carry event: Generate, Propagate, or Kill.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/sitePosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sitePosition</rdfs:label>
    <rdfs:comment>The site index k at which this carry event occurs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryEvent"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/carryCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>carryCount</rdfs:label>
    <rdfs:comment>The total number of carry events in this profile.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/maxPropagationLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxPropagationLength</rdfs:label>
    <rdfs:comment>The longest consecutive propagation run in this profile.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryProfile"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/carry/profileChain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>profileChain</rdfs:label>
    <rdfs:comment>The carry chain that this profile summarizes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/CarryProfile"/>
    <rdfs:range rdf:resource="https://uor.foundation/carry/CarryChain"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/symbolSetSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>symbolSetSize</rdfs:label>
    <rdfs:comment>The cardinality of the symbol set S being encoded.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingConfiguration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/quantizationBits">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>quantizationBits</rdfs:label>
    <rdfs:comment>The number of bits k used for encoding (2^k ≥ |S|).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingConfiguration"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/carry/encodingMap">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>encodingMap</rdfs:label>
    <rdfs:comment>String representation of the mapping from symbols to ring elements.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingConfiguration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/meanDelta">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>meanDelta</rdfs:label>
    <rdfs:comment>The mean d_Δ over observed pairs for this encoding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingQuality"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/discriminationRatio">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>discriminationRatio</rdfs:label>
    <rdfs:comment>The ratio of distinguishable pairs to total pairs under this encoding.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingQuality"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/carry/isOptimalEncoding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isOptimalEncoding</rdfs:label>
    <rdfs:comment>Whether this encoding minimizes Σ d_Δ over observed pairs.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/carry/EncodingQuality"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <!-- Namespace: homology -->
  <owl:Ontology rdf:about="https://uor.foundation/homology/">
    <rdfs:label>UOR Homology</rdfs:label>
    <rdfs:comment>Simplicial complexes, chain complexes, boundary operators, and homology groups for structural reasoning.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/type/"/>
    <owl:imports rdf:resource="https://uor.foundation/resolver/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/homology/Simplex">
    <rdfs:label>Simplex</rdfs:label>
    <rdfs:comment>A k-simplex: a finite set of k+1 vertices drawn from constraint objects.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/SimplicialComplex">
    <rdfs:label>SimplicialComplex</rdfs:label>
    <rdfs:comment>A simplicial complex: a set of simplices closed under taking faces.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/FaceMap">
    <rdfs:label>FaceMap</rdfs:label>
    <rdfs:comment>A face map d_i: removes vertex i from a simplex, producing a face.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/ChainGroup">
    <rdfs:label>ChainGroup</rdfs:label>
    <rdfs:comment>A free abelian group generated by k-simplices (the k-th chain group C_k).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/BoundaryOperator">
    <rdfs:label>BoundaryOperator</rdfs:label>
    <rdfs:comment>The boundary operator ∂_k: C_k → C_{k-1}. Satisfies ∂² = 0.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/ChainComplex">
    <rdfs:label>ChainComplex</rdfs:label>
    <rdfs:comment>A chain complex: a sequence of chain groups connected by boundary operators.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/HomologyGroup">
    <rdfs:label>HomologyGroup</rdfs:label>
    <rdfs:comment>The k-th homology group H_k = ker(∂_k) / im(∂_{k+1}). Measures k-dimensional holes.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/NerveFunctor">
    <rdfs:label>NerveFunctor</rdfs:label>
    <rdfs:comment>The nerve functor N: maps a set of constraints to a simplicial complex.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/ChainFunctor">
    <rdfs:label>ChainFunctor</rdfs:label>
    <rdfs:comment>The chain functor C: maps a simplicial complex to a chain complex.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/KanComplex">
    <rdfs:label>KanComplex</rdfs:label>
    <rdfs:comment>A simplicial set satisfying the Kan extension condition. The constraint nerve, when promoted from a SimplicialComplex to a KanComplex, carries a full homotopy type — not just its homology groups.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/HornFiller">
    <rdfs:label>HornFiller</rdfs:label>
    <rdfs:comment>A witness that a given horn (an incomplete simplex boundary) can be filled, certifying the Kan condition at a specific dimension and position.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/PostnikovTruncation">
    <rdfs:label>PostnikovTruncation</rdfs:label>
    <rdfs:comment>The k-th Postnikov truncation τ≤k of the constraint nerve: a KanComplex whose homotopy groups πj vanish for j &gt; k.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/KInvariant">
    <rdfs:label>KInvariant</rdfs:label>
    <rdfs:comment>The k-invariant κk that classifies the extension from the (k−1)-truncation to the k-truncation of the Postnikov tower. Trivial κk means the truncation splits as a product.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/homology/DeformationComplex">
    <rdfs:label>DeformationComplex</rdfs:label>
    <rdfs:comment>The deformation complex of a CompleteType T: a chain complex whose H⁰ = automorphisms, H¹ = first-order deformations, H² = obstructions to extending deformations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/homology/ChainComplex"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/dimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dimension</rdfs:label>
    <rdfs:comment>The dimension k of a simplex (number of vertices minus one).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/Simplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/vertex">
    <rdfs:label>vertex</rdfs:label>
    <rdfs:comment>A vertex of this simplex, drawn from the set of constraint objects.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/Simplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/Constraint"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/vertexCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>vertexCount</rdfs:label>
    <rdfs:comment>The number of vertices in this simplex (dimension + 1).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/Simplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/isFaceOf">
    <rdfs:label>isFaceOf</rdfs:label>
    <rdfs:comment>Indicates that this simplex is a face of another simplex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/Simplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/pinIntersection">
    <rdfs:label>pinIntersection</rdfs:label>
    <rdfs:comment>A site coordinate in the partition whose intersection pins this simplex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/Simplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/partition/SiteIndex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/hasSimplex">
    <rdfs:label>hasSimplex</rdfs:label>
    <rdfs:comment>A simplex belonging to this simplicial complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/maxDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>maxDimension</rdfs:label>
    <rdfs:comment>The maximum dimension of any simplex in this simplicial complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/eulerCharacteristic">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>eulerCharacteristic</rdfs:label>
    <rdfs:comment>The Euler characteristic of this simplicial complex: the alternating sum of simplex counts by dimension.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/simplicialVertexCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>simplicialVertexCount</rdfs:label>
    <rdfs:comment>The total number of vertices (0-simplices) in this simplicial complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/removesVertex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>removesVertex</rdfs:label>
    <rdfs:comment>The index i of the vertex removed by this face map d_i.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/FaceMap"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/sourceSimplex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceSimplex</rdfs:label>
    <rdfs:comment>The source simplex of this face map.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/FaceMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/targetFace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetFace</rdfs:label>
    <rdfs:comment>The target face (result simplex) of this face map.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/FaceMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/degree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>degree</rdfs:label>
    <rdfs:comment>The degree k of this chain group (the dimension of its generating simplices).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/ChainGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/rank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rank</rdfs:label>
    <rdfs:comment>The rank of a free abelian group (number of generators).</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/generatedBy">
    <rdfs:label>generatedBy</rdfs:label>
    <rdfs:comment>A simplex that generates this chain group.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/ChainGroup"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/sourceGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sourceGroup</rdfs:label>
    <rdfs:comment>The source chain group C_k of this boundary operator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/BoundaryOperator"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/targetGroup">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>targetGroup</rdfs:label>
    <rdfs:comment>The target chain group C_{k-1} of this boundary operator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/BoundaryOperator"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainGroup"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/satisfiesBoundarySquaredZero">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>satisfiesBoundarySquaredZero</rdfs:label>
    <rdfs:comment>Whether this boundary operator satisfies the fundamental property ∂² = 0.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/BoundaryOperator"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/hasChainGroup">
    <rdfs:label>hasChainGroup</rdfs:label>
    <rdfs:comment>A chain group belonging to this chain complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/ChainComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/hasBoundary">
    <rdfs:label>hasBoundary</rdfs:label>
    <rdfs:comment>A boundary operator belonging to this chain complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/ChainComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/BoundaryOperator"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/homologyDegree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homologyDegree</rdfs:label>
    <rdfs:comment>The degree k of this homology group H_k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/HomologyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/bettiNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bettiNumber</rdfs:label>
    <rdfs:comment>The Betti number β_k = rank(H_k): the rank of this homology group.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/HomologyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/kanWitness">
    <rdfs:label>kanWitness</rdfs:label>
    <rdfs:comment>A horn filler witnessing the Kan condition for this complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/KanComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/HornFiller"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/hornDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hornDimension</rdfs:label>
    <rdfs:comment>The dimension of the horn that this filler completes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/HornFiller"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/hornPosition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hornPosition</rdfs:label>
    <rdfs:comment>The position (missing face index) of the horn that this filler completes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/HornFiller"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/truncationLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>truncationLevel</rdfs:label>
    <rdfs:comment>The truncation level k of this Postnikov truncation τ≤k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/PostnikovTruncation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/truncationSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>truncationSource</rdfs:label>
    <rdfs:comment>The KanComplex from which this Postnikov truncation is derived.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/PostnikovTruncation"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/KanComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/kInvariant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>kInvariant</rdfs:label>
    <rdfs:comment>The k-invariant classifying the extension at this truncation level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/PostnikovTruncation"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/KInvariant"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/kInvariantTrivial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>kInvariantTrivial</rdfs:label>
    <rdfs:comment>True iff this k-invariant is trivial, meaning the Postnikov truncation splits as a product.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/KInvariant"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/deformationBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>deformationBase</rdfs:label>
    <rdfs:comment>The CompleteType whose deformation complex this is.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/DeformationComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/CompleteType"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/tangentDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>tangentDimension</rdfs:label>
    <rdfs:comment>The dimension of the tangent space H¹(Def(T)): the number of first-order deformations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/DeformationComplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/homology/obstructionDimension">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionDimension</rdfs:label>
    <rdfs:comment>The dimension of the obstruction space H²(Def(T)): the number of independent obstructions to extending deformations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/homology/DeformationComplex"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/groundedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>groundedIn</rdfs:label>
    <rdfs:comment>The homology group that grounds this Betti number observable.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/BettiNumber"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/HomologyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/laplacianOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>laplacianOf</rdfs:label>
    <rdfs:comment>The chain complex whose Laplacian determines this spectral gap.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/observable/SpectralGap"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/homology/homologicalAnalysis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>homologicalAnalysis</rdfs:label>
    <rdfs:comment>The chain complex used for homological analysis of a resolution state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainComplex"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/homology/boundarySquaredZero">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>boundarySquaredZero</rdfs:label>
    <rdfs:comment>∂² = 0: the boundary of a boundary is zero.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_boundarySquaredZero_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_boundarySquaredZero_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_boundarySquaredZero_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/homology/nerveFunctorN">
    <rdf:type rdf:resource="https://uor.foundation/homology/NerveFunctor"/>
    <rdfs:label>nerveFunctorN</rdfs:label>
    <rdfs:comment>The nerve functor N: constraints → simplicial complex.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/homology/chainFunctorC">
    <rdf:type rdf:resource="https://uor.foundation/homology/ChainFunctor"/>
    <rdfs:label>chainFunctorC</rdfs:label>
    <rdfs:comment>The chain functor C: simplicial complex → chain complex.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/homology/psi_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_4</rdfs:label>
    <rdfs:comment>ψ_4: HomologyGroups → BettiNumbers (extraction functor).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/homology/indexBridge">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>indexBridge</rdfs:label>
    <rdfs:comment>Index bridge: connects Euler characteristic to alternating Betti sum.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_indexBridge_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_indexBridge_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_indexBridge_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <!-- Namespace: cohomology -->
  <owl:Ontology rdf:about="https://uor.foundation/cohomology/">
    <rdfs:label>UOR Cohomology</rdfs:label>
    <rdfs:comment>Cochain complexes, sheaf cohomology, and local-to-global obstruction detection.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/homology/"/>
    <owl:imports rdf:resource="https://uor.foundation/resolver/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
    <owl:imports rdf:resource="https://uor.foundation/partition/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/cohomology/CochainGroup">
    <rdfs:label>CochainGroup</rdfs:label>
    <rdfs:comment>A cochain group: the dual of a chain group, maps chains to coefficients.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/CoboundaryOperator">
    <rdfs:label>CoboundaryOperator</rdfs:label>
    <rdfs:comment>The coboundary operator δ^k: C^k → C^{k+1}. Satisfies δ² = 0.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/CochainComplex">
    <rdfs:label>CochainComplex</rdfs:label>
    <rdfs:comment>A cochain complex: a sequence of cochain groups connected by coboundary operators.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/CohomologyGroup">
    <rdfs:label>CohomologyGroup</rdfs:label>
    <rdfs:comment>The k-th cohomology group H^k = ker(δ^k) / im(δ^{k-1}). Measures k-dimensional obstructions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/Sheaf">
    <rdfs:label>Sheaf</rdfs:label>
    <rdfs:comment>A sheaf F over a simplicial complex: assigns data to each simplex with restriction maps.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/Stalk">
    <rdfs:label>Stalk</rdfs:label>
    <rdfs:comment>A stalk F_σ: the local data of a sheaf at a simplex σ.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/Section">
    <rdfs:label>Section</rdfs:label>
    <rdfs:comment>A global section of a sheaf: a consistent choice of local data across all simplices.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/LocalSection">
    <rdfs:label>LocalSection</rdfs:label>
    <rdfs:comment>A local section: a consistent choice of data over a subcomplex.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/cohomology/Section"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/RestrictionMap">
    <rdfs:label>RestrictionMap</rdfs:label>
    <rdfs:comment>A restriction map ρ_{σ,τ}: maps data from a simplex to a face.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/cohomology/GluingObstruction">
    <rdfs:label>GluingObstruction</rdfs:label>
    <rdfs:comment>A gluing obstruction: a cohomology class that detects when local sections fail to glue.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cohomology/cochainDegree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cochainDegree</rdfs:label>
    <rdfs:comment>The degree k of this cochain group C^k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cohomology/cochainRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cochainRank</rdfs:label>
    <rdfs:comment>The rank (dimension) of this cochain group.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/dualOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dualOf</rdfs:label>
    <rdfs:comment>The chain group that this cochain group is dual to.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/ChainGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/coboundarySource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>coboundarySource</rdfs:label>
    <rdfs:comment>The source cochain group of this coboundary operator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CoboundaryOperator"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/coboundaryTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>coboundaryTarget</rdfs:label>
    <rdfs:comment>The target cochain group of this coboundary operator.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CoboundaryOperator"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cohomology/satisfiesCoboundarySquaredZero">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>satisfiesCoboundarySquaredZero</rdfs:label>
    <rdfs:comment>Whether this coboundary operator satisfies δ² = 0.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CoboundaryOperator"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/hasCochainGroup">
    <rdfs:label>hasCochainGroup</rdfs:label>
    <rdfs:comment>A cochain group belonging to this cochain complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CochainComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CochainGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/hasCoboundary">
    <rdfs:label>hasCoboundary</rdfs:label>
    <rdfs:comment>A coboundary operator belonging to this cochain complex.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CochainComplex"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CoboundaryOperator"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cohomology/cohomologyDegree">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cohomologyDegree</rdfs:label>
    <rdfs:comment>The degree k of this cohomology group H^k.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CohomologyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/cohomology/cohomologyRank">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cohomologyRank</rdfs:label>
    <rdfs:comment>The rank (dimension) of this cohomology group.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/CohomologyGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/sheafOver">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sheafOver</rdfs:label>
    <rdfs:comment>The simplicial complex that this sheaf is defined over.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/Sheaf"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/SimplicialComplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/coefficientIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>coefficientIn</rdfs:label>
    <rdfs:comment>The coefficient ring of this sheaf.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/Sheaf"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Ring"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/hasStalks">
    <rdfs:label>hasStalks</rdfs:label>
    <rdfs:comment>A stalk belonging to this sheaf.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/Sheaf"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/Stalk"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/stalkAt">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stalkAt</rdfs:label>
    <rdfs:comment>The simplex at which this stalk is located.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/Stalk"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/restrictsFrom">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>restrictsFrom</rdfs:label>
    <rdfs:comment>The source simplex of this restriction map.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/RestrictionMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/restrictsTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>restrictsTo</rdfs:label>
    <rdfs:comment>The target simplex (face) of this restriction map.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/RestrictionMap"/>
    <rdfs:range rdf:resource="https://uor.foundation/homology/Simplex"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/hasGlobalSection">
    <rdfs:label>hasGlobalSection</rdfs:label>
    <rdfs:comment>A global section of this sheaf.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/Sheaf"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/Section"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/obstructionClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>obstructionClass</rdfs:label>
    <rdfs:comment>The cohomology class that this gluing obstruction represents.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/GluingObstruction"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/CohomologyGroup"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/addressesSuggestion">
    <rdfs:label>addressesSuggestion</rdfs:label>
    <rdfs:comment>The refinement suggestion that, if applied, would resolve this gluing obstruction. Computed by the kernel when ψ₆ detects H^1 ≠ 0: the obstruction class indexes the site pair that is incompatible, and the suggestion targets that pair with a new bridging constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/cohomology/GluingObstruction"/>
    <rdfs:range rdf:resource="https://uor.foundation/resolver/RefinementSuggestion"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/cohomology/sheafAnalysis">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>sheafAnalysis</rdfs:label>
    <rdfs:comment>The sheaf analysis associated with a resolution state.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/resolver/ResolutionState"/>
    <rdfs:range rdf:resource="https://uor.foundation/cohomology/Sheaf"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/cohomology/coboundarySquaredZero">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>coboundarySquaredZero</rdfs:label>
    <rdfs:comment>δ² = 0: the coboundary of a coboundary is zero.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_coboundarySquaredZero_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_coboundarySquaredZero_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_coboundarySquaredZero_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/cohomology/deRhamDuality">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>deRhamDuality</rdfs:label>
    <rdfs:comment>Discrete de Rham duality: H^k ≅ Hom(H_k, R).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_deRhamDuality_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_deRhamDuality_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_deRhamDuality_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/cohomology/sheafCohomologyBridge">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>sheafCohomologyBridge</rdfs:label>
    <rdfs:comment>Sheaf cohomology equals simplicial cohomology for constant sheaves.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_sheafCohomologyBridge_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_sheafCohomologyBridge_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_sheafCohomologyBridge_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/cohomology/localGlobalPrinciple">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>localGlobalPrinciple</rdfs:label>
    <rdfs:comment>Local-global principle: H^1(K; F) = 0 implies all local sections glue to global sections.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_localGlobalPrinciple_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_localGlobalPrinciple_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_localGlobalPrinciple_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <!-- Namespace: proof -->
  <owl:Ontology rdf:about="https://uor.foundation/proof/">
    <rdfs:label>UOR Proofs</rdfs:label>
    <rdfs:comment>Kernel-produced verification proofs attesting to algebraic properties of UOR objects and operations.</rdfs:comment>
    <uor:space>bridge</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
    <owl:imports rdf:resource="https://uor.foundation/op/"/>
    <owl:imports rdf:resource="https://uor.foundation/derivation/"/>
    <owl:imports rdf:resource="https://uor.foundation/observable/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/proof/Proof">
    <rdfs:label>Proof</rdfs:label>
    <rdfs:comment>A kernel-produced attestation that a given algebraic property holds. The root class for all proof types.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/CoherenceProof">
    <rdfs:label>CoherenceProof</rdfs:label>
    <rdfs:comment>A proof of coherence: the type system and ring structure are mutually consistent at a given quantum level.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/ComputationCertificate">
    <rdfs:label>ComputationCertificate</rdfs:label>
    <rdfs:comment>A proof confirmed by exhaustive execution over R_n at a specific quantum level. The kernel ran the identity against all 2^n inputs and observed that it holds. The proof:atWittLevel property records the level; proof:witness links to the WitnessData. CriticalIdentityProof is a subclass of ComputationCertificate.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/AxiomaticDerivation">
    <rdfs:label>AxiomaticDerivation</rdfs:label>
    <rdfs:comment>A proof that follows from previously established axioms or definitions by equational, structural, or topological reasoning. The proof:derivationWitness property links to a derivation:Derivation individual recording the rewrite chain. All pipeline, constraint, observable, and topological identities are AxiomaticDerivations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/CriticalIdentityProof">
    <rdfs:label>CriticalIdentityProof</rdfs:label>
    <rdfs:comment>A proof of the critical identity: neg(bnot(x)) = succ(x) for all x in R_n. This is the foundational theorem of the UOR kernel.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/WitnessData">
    <rdfs:label>WitnessData</rdfs:label>
    <rdfs:comment>Supporting data for a proof: specific examples, counter-examples checked, or intermediate computation results.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/ImpossibilityWitness">
    <rdfs:label>ImpossibilityWitness</rdfs:label>
    <rdfs:comment>A formal witness that a topological signature (χ, β_k) is impossible to achieve for any ConstrainedType. Carries the algebraic reason and the verification domain grounding the impossibility.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/MorphospaceRecord">
    <rdfs:label>MorphospaceRecord</rdfs:label>
    <rdfs:comment>A formal record of a morphospace boundary point — either an achievable or forbidden topological signature. Aggregated by MorphospaceBoundary to form the queryable morphospace map.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/MorphospaceBoundary">
    <rdfs:label>MorphospaceBoundary</rdfs:label>
    <rdfs:comment>An aggregate of ImpossibilityWitness instances forming the queryable morphospace map. SPARQL over this structure answers achievability queries in O(1).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/InductiveProof">
    <rdfs:label>InductiveProof</rdfs:label>
    <rdfs:comment>A proof by structural induction on the quantum level index k. Carries a base case proof, an inductive step proof, and the minimum k for which the induction holds.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/ProofStrategy">
    <rdfs:label>ProofStrategy</rdfs:label>
    <rdfs:comment>A controlled vocabulary of proof methods. Each proof individual carries exactly one strategy from this vocabulary, enabling compilation to verified theorem provers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/DerivationTerm">
    <rdfs:label>DerivationTerm</rdfs:label>
    <rdfs:comment>Root AST node for proof construction terms. Distinct from schema:TermExpression which represents mathematical terms; DerivationTerm represents proof constructions (tactic applications, lemma invocations, induction scaffolding).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/TacticApplication">
    <rdfs:label>TacticApplication</rdfs:label>
    <rdfs:comment>A proof step applying a named tactic (from ProofStrategy) with arguments. Maps to a Lean4 tactic invocation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/DerivationTerm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/LemmaInvocation">
    <rdfs:label>LemmaInvocation</rdfs:label>
    <rdfs:comment>A proof step invoking a previously proved identity as a lemma. References the identity via proof:dependsOn.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/DerivationTerm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/InductionStep">
    <rdfs:label>InductionStep</rdfs:label>
    <rdfs:comment>A proof step performing structural induction: base case derivation, inductive hypothesis, and step derivation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/DerivationTerm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/ComputationStep">
    <rdfs:label>ComputationStep</rdfs:label>
    <rdfs:comment>A proof step performing exhaustive computation at a specific quantum level as verification witness.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/DerivationTerm"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/proof/InhabitanceImpossibilityWitness">
    <rdfs:label>InhabitanceImpossibilityWitness</rdfs:label>
    <rdfs:comment>A specialisation of proof:ImpossibilityWitness produced when the inhabitance search determines that the carrier of a ConstrainedType is empty. Aggregates into the existing proof:MorphospaceBoundary alongside other impossibility witnesses, inheriting its O(1) amortised lookup discipline for previously resolved signatures.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/verified">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>verified</rdfs:label>
    <rdfs:comment>Whether this proof has been verified by the kernel.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/timestamp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>timestamp</rdfs:label>
    <rdfs:comment>The time at which this proof was produced.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/witness">
    <rdfs:label>witness</rdfs:label>
    <rdfs:comment>Supporting witness data for this proof.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/WitnessData"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/proof/criticalIdentity">
    <rdfs:label>criticalIdentity</rdfs:label>
    <rdfs:comment>Human-readable statement of the critical identity proven. E.g., &apos;neg(bnot(x)) = succ(x) for all x in R_n&apos;. Annotation only — proof:provesIdentity is the typed reference.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/CriticalIdentityProof"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/x">
    <rdfs:label>x</rdfs:label>
    <rdfs:comment>A specific input value used as a witness for the critical identity check.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/WitnessData"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/bnot_x">
    <rdfs:label>bnot_x</rdfs:label>
    <rdfs:comment>The value bnot(x) for a witness x.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/WitnessData"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/neg_bnot_x">
    <rdfs:label>neg_bnot_x</rdfs:label>
    <rdfs:comment>The value neg(bnot(x)) for a witness x.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/WitnessData"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/succ_x">
    <rdfs:label>succ_x</rdfs:label>
    <rdfs:comment>The value succ(x) for a witness x.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/WitnessData"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/holds">
    <rdfs:label>holds</rdfs:label>
    <rdfs:comment>Whether the identity neg(bnot(x)) = succ(x) holds for this specific witness.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/WitnessData"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/provesIdentity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>provesIdentity</rdfs:label>
    <rdfs:comment>The algebraic identity this proof establishes. Provides a canonical object reference alongside the existing proof:criticalIdentity string property, which remains for human readability.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/atWittLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>atWittLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this computation certificate was produced. A ComputationCertificate at schema:Q0 confirms the identity holds for all 256 inputs of R_8. A certificate at schema:Q1 confirms it for all 65,536 inputs of R_16.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/proof/wittNote">
    <rdfs:label>wittNote</rdfs:label>
    <rdfs:comment>Human-readable quantum level note, e.g. &apos;n=8, 256 inputs&apos;. Annotation only — proof:atWittLevel is the typed assertion.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/universalScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>universalScope</rdfs:label>
    <rdfs:comment>True when this axiomatic derivation holds for all quantum levels by the definition of Z/(2^n)Z. False when the derivation depends on a property specific to a particular ring size. All current AxiomaticDerivation individuals in the spec carry universalScope true.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/derivationWitness">
    <rdfs:label>derivationWitness</rdfs:label>
    <rdfs:comment>The derivation chain that witnesses this axiomatic derivation. Links a proof:AxiomaticDerivation to the derivation:Derivation individual recording the rewrite sequence. Optional at the spec level — the conformance suite requires only that the proof individual exists; full derivation chains live in generated artifacts.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:range rdf:resource="https://uor.foundation/derivation/Derivation"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/proof/forbidsSignature">
    <rdfs:label>forbidsSignature</rdfs:label>
    <rdfs:comment>The topological signature (χ, β_k) that this ImpossibilityWitness formally forbids, expressed as a symbolic notation string (e.g., &apos;β₀ = 0&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/impossibilityReason">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>impossibilityReason</rdfs:label>
    <rdfs:comment>Human-readable statement of the algebraic reason the signature is impossible (e.g., &apos;β₀ = 0 violates MS_1&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/impossibilityDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>impossibilityDomain</rdfs:label>
    <rdfs:comment>The verification domain grounding the impossibility (e.g., Pipeline for β₀ = 0, Algebraic for χ &gt; n).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/VerificationDomain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/achievabilityStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>achievabilityStatus</rdfs:label>
    <rdfs:comment>The achievability classification of a proof-linked observable signature: Achievable or Forbidden.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/AchievabilityStatus"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/verifiedAtLevel">
    <rdfs:label>verifiedAtLevel</rdfs:label>
    <rdfs:comment>The specific quantum level at which an empirical verification or impossibility witness was established.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/morphospaceRecord">
    <rdfs:label>morphospaceRecord</rdfs:label>
    <rdfs:comment>Links a MorphospaceBoundary to one of its constituent MorphospaceRecord individuals.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/MorphospaceBoundary"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/MorphospaceRecord"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/boundaryType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>boundaryType</rdfs:label>
    <rdfs:comment>Whether this MorphospaceRecord represents an impossibility boundary (from below) or an achievability boundary (from above).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/MorphospaceRecord"/>
    <rdfs:range rdf:resource="https://uor.foundation/observable/AchievabilityStatus"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/baseCase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>baseCase</rdfs:label>
    <rdfs:comment>The proof that the claim holds at the base level k_0.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InductiveProof"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/inductiveStep">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inductiveStep</rdfs:label>
    <rdfs:comment>The proof that if the claim holds at Q_k, it holds at Q_{k+1}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InductiveProof"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/Proof"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/validForKAtLeast">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validForKAtLeast</rdfs:label>
    <rdfs:comment>The minimum k for which the induction is valid.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InductiveProof"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/strategy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>strategy</rdfs:label>
    <rdfs:comment>The proof method from the ProofStrategy controlled vocabulary. Determines the compilation target (e.g., `by ring`, `by simp`, `by induction`).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/dependsOn">
    <rdfs:label>dependsOn</rdfs:label>
    <rdfs:comment>An identity that this proof depends on as a lemma. Forms the proof dependency DAG. Leaf proofs (provable from definitions alone) have no dependsOn assertions.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Identity"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/formalDerivation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>formalDerivation</rdfs:label>
    <rdfs:comment>The formal proof construction term: a DerivationTerm AST node encoding the tactic script, lemma chain, or induction scaffold that constitutes the proof.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/Proof"/>
    <rdfs:range rdf:resource="https://uor.foundation/proof/DerivationTerm"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/proof/contradictionProof">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>contradictionProof</rdfs:label>
    <rdfs:comment>The Lean 4 by-contradiction derivation over the predicate vocabulary attesting that no value tuple satisfies the constraint system.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InhabitanceImpossibilityWitness"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/grounded">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>grounded</rdfs:label>
    <rdfs:comment>The type:ConstrainedType whose carrier this witness certifies as empty.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InhabitanceImpossibilityWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/ConstrainedType"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/proof/searchTrace">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>searchTrace</rdfs:label>
    <rdfs:comment>The audit trail of the inhabitance search up to the contradiction.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/proof/InhabitanceImpossibilityWitness"/>
    <rdfs:range rdf:resource="https://uor.foundation/trace/InhabitanceSearchTrace"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/RingAxiom">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>RingAxiom</rdfs:label>
    <rdfs:comment>Follows from ZMod ring axioms. Lean4 tactic: `by ring`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/DecideQ0">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>DecideQ0</rdfs:label>
    <rdfs:comment>Decidable at Q0 by exhaustive evaluation. Lean4: `by native_decide`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/BitwiseInduction">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>BitwiseInduction</rdfs:label>
    <rdfs:comment>Induction on bit width n. Lean4: `by induction n`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/GroupPresentation">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>GroupPresentation</rdfs:label>
    <rdfs:comment>From dihedral group presentation. Lean4: `by group`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/Simplification">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>Simplification</rdfs:label>
    <rdfs:comment>By simplification with cited lemmas. Lean4: `by simp [lemmalist]`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/ChineseRemainder">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>ChineseRemainder</rdfs:label>
    <rdfs:comment>By Chinese Remainder Theorem. Lean4: `by exact ZMod.chineseRemainder ...`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/EulerPoincare">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>EulerPoincare</rdfs:label>
    <rdfs:comment>By Euler-Poincare formula applied to the constraint nerve.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/ProductFormula">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>ProductFormula</rdfs:label>
    <rdfs:comment>By Ostrowski product formula or derived valuation arguments.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/Composition">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>Composition</rdfs:label>
    <rdfs:comment>By composing proofs of sub-identities. Lean4: `by exact ...`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/Contradiction">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>Contradiction</rdfs:label>
    <rdfs:comment>By deriving contradiction for impossibility witnesses. Lean4: `by contradiction`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/Computation">
    <rdf:type rdf:resource="https://uor.foundation/proof/ProofStrategy"/>
    <rdfs:label>Computation</rdfs:label>
    <rdfs:comment>By computation at a specified quantum level. Lean4: `by native_decide`.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_criticalIdentity">
    <rdf:type rdf:resource="https://uor.foundation/proof/CriticalIdentityProof"/>
    <rdfs:label>prf_criticalIdentity</rdfs:label>
    <rdfs:comment>Computation certificate for the critical identity neg(bnot(x)) = succ(x) at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/criticalIdentity"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_criticalIdentity_axiomatic">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_criticalIdentity_axiomatic</rdfs:label>
    <rdfs:comment>Axiomatic derivation of the critical identity neg(bnot(x)) = succ(x). Holds at all quantum levels.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/criticalIdentity"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/RingAxiom"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_1</rdfs:label>
    <rdfs:comment>Computation certificate for phi_1 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_1"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_2">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_2</rdfs:label>
    <rdfs:comment>Computation certificate for phi_2 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_2"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_3">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_3</rdfs:label>
    <rdfs:comment>Computation certificate for phi_3 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_3"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_4">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_4</rdfs:label>
    <rdfs:comment>Computation certificate for phi_4 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_4"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_5">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_5</rdfs:label>
    <rdfs:comment>Computation certificate for phi_5 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_5"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_phi_6">
    <rdf:type rdf:resource="https://uor.foundation/proof/ComputationCertificate"/>
    <rdfs:label>prf_phi_6</rdfs:label>
    <rdfs:comment>Computation certificate for phi_6 at Q0.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/phi_6"/>
    <uor:proof/atWittLevel rdf:resource="https://uor.foundation/schema/W8"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Computation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_AD_1">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_AD_1</rdfs:label>
    <rdfs:comment>Axiomatic derivation of AD_1. Holds at all quantum levels by definition of Z/(2^n)Z.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/op/AD_1"/>
