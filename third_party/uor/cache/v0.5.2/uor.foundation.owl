  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/iw_beta0_bound">
    <rdf:type rdf:resource="https://uor.foundation/proof/ImpossibilityWitness"/>
    <rdfs:label>iw_beta0_bound</rdfs:label>
    <rdfs:comment>Impossibility witness for MS_1: β₀ = 0 is forbidden for any non-empty ConstrainedType because the constraint nerve is always connected.</rdfs:comment>
    <uor:proof/forbidsSignature>β₀ = 0</uor:proof/forbidsSignature>
