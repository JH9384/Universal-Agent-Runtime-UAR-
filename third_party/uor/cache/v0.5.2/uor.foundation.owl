  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_CIC_7_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_CIC_7_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>MeasurementEvent with amplitude vector</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GC_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GC_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>shared-frame grounding of symbol s</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GC_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GC_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>∃ c: GroundingCertificate. certifies(c, map)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GC_1_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_GC_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>GroundingMap with valid ProjectionMap</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_8_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_8_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>compose(S_A, S_B) valid at Q_k</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_8_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_8_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>∀ j ≤ k: ∀ a ∈ pinnedSites(S_A, Q_j) ∩ pinnedSites(S_B, Q_j): datum(S_A, a, Q_j) = datum(S_B, a, Q_j)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_8_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_GR_8_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>S_A, S_B: Session at quantum level Q_k (k ≥ 0)</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_9_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_9_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>leasedSites(L_A) ∩ leasedSites(L_B)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_9_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_9_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= ∅</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_9_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_GR_9_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>L_A, L_B: ContextLease on SharedContext C, L_A ≠ L_B</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_10_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_10_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>finalState(R, P_1, Q)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_10_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_GR_10_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= finalState(R, P_2, Q) for any P_1, P_2: ExecutionPolicy</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_GR_10_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_GR_10_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SessionResolver R with ExecutionPolicy P, pending query set Q</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>Σᵢ freeRank(leasedSites(L_i))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= freeRank(C)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_1_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SharedContext C; leaseSet {L_1, …, L_k} covering all sites of C</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_2_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_2_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>freeRank(B_{i+1} |_L)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_2_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_2_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>≤ freeRank(B_i |_L)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_2_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_2_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>ContextLease L held by Session S; binding step i within S restricted to leasedSites(L)</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>freeRank(compose(S_A, S_B))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_3_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_3_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>freeRank(S_A) + freeRank(S_B) − |pinnedSites(S_A) ∩ pinnedSites(S_B)|</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_3_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>S_A, S_B: Session; compose(S_A, S_B) valid (SR_8 satisfied)</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>freeRank(compose(S_A, S_B))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= freeRank(S_A) + freeRank(S_B)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>S_A, S_B on ContextLeases L_A, L_B within SharedContext C; SR_9 holds</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_5_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_5_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>finalBindings(R, P_1, Q)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_5_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_5_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= finalBindings(R, P_2, Q)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_5_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_5_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SessionResolver R; pending query set Q; ExecutionPolicy P_1, P_2</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_6_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_6_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>σ(compose(S_1, …, S_k))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_6_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_6_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= 1 (FullGrounding)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_6_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_6_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SharedContext C; leases {L_1, …, L_k} pairwise disjoint (SR_9) and fully covering C; each S_i with freeRank = 0 within L_i</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_7_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_7_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>stepCount(q, C*)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_7_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_7_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>= 0</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_7_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_7_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>q: RelationQuery; C* = compose(S_1, …, S_k) with σ(C*) = 1 by MC_6</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_8_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_8_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>max_i stepCount(S_i to convergence within L_i)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_8_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_MC_8_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>≤ ⌈n/k⌉</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_MC_8_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_MC_8_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>SharedContext C with totalSites = n; uniform partition into k leases</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>a_k(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_1_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_1_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>x_k (k-th bit of x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_1_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_WC_1_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x ∈ R_n, 0 ≤ k &lt; n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_2_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_2_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>S_k − x_k − y_k (mod 2)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_2_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_2_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>c_k(x,y)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_2_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_WC_2_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x, y ∈ R_n, 0 ≤ k &lt; n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>CA_2 recurrence</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_3_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_3_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>S_{k+1} ghost equation at p=2</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_3_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_WC_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x, y ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>δ_k(x+y) correction</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_WC_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>c_{k+1}(x,y)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_WC_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
