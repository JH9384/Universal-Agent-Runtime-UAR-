    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CF_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CF_4</rdfs:label>
    <rdfs:comment>Total successor curvature flux over R_n equals 2^n − 2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CF_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CF_4_rhs"/>
