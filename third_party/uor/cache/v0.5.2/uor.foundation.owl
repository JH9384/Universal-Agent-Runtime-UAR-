<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:sh="http://www.w3.org/ns/shacl#"
    xmlns:uor="https://uor.foundation/"
    xmlns:u="https://uor.foundation/u/"
    xmlns:schema="https://uor.foundation/schema/"
    xmlns:op="https://uor.foundation/op/"
    xmlns:query="https://uor.foundation/query/"
    xmlns:resolver="https://uor.foundation/resolver/"
    xmlns:type="https://uor.foundation/type/"
    xmlns:partition="https://uor.foundation/partition/"
    xmlns:foundation="https://uor.foundation/foundation/"
    xmlns:observable="https://uor.foundation/observable/"
    xmlns:carry="https://uor.foundation/carry/"
    xmlns:homology="https://uor.foundation/homology/"
    xmlns:cohomology="https://uor.foundation/cohomology/"
    xmlns:proof="https://uor.foundation/proof/"
    xmlns:derivation="https://uor.foundation/derivation/"
    xmlns:trace="https://uor.foundation/trace/"
    xmlns:cert="https://uor.foundation/cert/"
    xmlns:morphism="https://uor.foundation/morphism/"
    xmlns:state="https://uor.foundation/state/"
    xmlns:reduction="https://uor.foundation/reduction/"
    xmlns:convergence="https://uor.foundation/convergence/"
    xmlns:division="https://uor.foundation/division/"
    xmlns:interaction="https://uor.foundation/interaction/"
    xmlns:monoidal="https://uor.foundation/monoidal/"
    xmlns:operad="https://uor.foundation/operad/"
    xmlns:effect="https://uor.foundation/effect/"
    xmlns:predicate="https://uor.foundation/predicate/"
    xmlns:parallel="https://uor.foundation/parallel/"
    xmlns:stream="https://uor.foundation/stream/"
    xmlns:failure="https://uor.foundation/failure/"
    xmlns:linear="https://uor.foundation/linear/"
    xmlns:recursion="https://uor.foundation/recursion/"
    xmlns:region="https://uor.foundation/region/"
    xmlns:boundary="https://uor.foundation/boundary/"
    xmlns:conformance="https://uor.foundation/conformance/"
>

  <owl:Ontology rdf:about="https://uor.foundation/">
    <rdfs:label>UOR Foundation</rdfs:label>
    <owl:versionInfo>0.5.2</owl:versionInfo>
  </owl:Ontology>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/space">
    <rdfs:label>space</rdfs:label>
    <rdfs:comment>Whether this module belongs to kernel-space (immutable, compiled), user-space (parameterizable, runtime), or bridge (kernel-computed, user-consumed). Values: &apos;kernel&apos;, &apos;user&apos;, &apos;bridge&apos;.</rdfs:comment>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <!-- Namespace: u -->
  <owl:Ontology rdf:about="https://uor.foundation/u/">
    <rdfs:label>UOR Content Addressing</rdfs:label>
    <rdfs:comment>Content-addressable identifiers for ring elements. Each element carries a unique content-derived identifier.</rdfs:comment>
    <uor:space>kernel</uor:space>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/u/Element">
    <rdfs:label>Element</rdfs:label>
    <rdfs:comment>A content-addressable ring element. Each Element uniquely identifies a piece of content via its hash-derived identifier.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/u/length">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>length</rdfs:label>
    <rdfs:comment>The number of Braille glyphs in an address string.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/u/addresses">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>addresses</rdfs:label>
    <rdfs:comment>The datum that this address references. Inverse of schema:glyph.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/u/digest">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>digest</rdfs:label>
    <rdfs:comment>The content hash of this address. Format: (blake3|sha256) colon followed by 64 lowercase hex characters. The algorithm prefix must match u:digestAlgorithm.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/u/digestAlgorithm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>digestAlgorithm</rdfs:label>
    <rdfs:comment>The hash algorithm used to produce u:digest. Allowed values: &apos;blake3&apos; (primary), &apos;sha256&apos; (secondary).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/u/canonicalBytes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>canonicalBytes</rdfs:label>
    <rdfs:comment>The canonical byte serialisation of the addressed datum, per Amendment 43 section 2: header(k) || le_bytes(x, k+1). This is the exact byte string hashed to produce u:digest.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#hexBinary"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/u/wittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLength</rdfs:label>
    <rdfs:comment>The Witt level n of this element. The element encodes a datum in R_n = Z/(2^n)Z.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/u/Element"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <!-- Namespace: schema -->
  <owl:Ontology rdf:about="https://uor.foundation/schema/">
    <rdfs:label>UOR Schema</rdfs:label>
    <rdfs:comment>Core value types and term language for the UOR ring substrate. Defines Datum (ring element), Term (syntactic expression), and the Ring container.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/u/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/schema/Datum">
    <rdfs:label>Datum</rdfs:label>
    <rdfs:comment>An element of the ring Z/(2^n)Z at a specific Witt level n. The primary semantic value type. Disjoint from Term: datums are values, terms are syntactic expressions that evaluate to datums.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/Term">
    <rdfs:label>Term</rdfs:label>
    <rdfs:comment>A syntactic expression in the UOR term language. Terms are evaluated to produce Datums. Disjoint from Datum.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/Triad">
    <rdfs:label>Triad</rdfs:label>
    <rdfs:comment>A three-component structure encoding an element&apos;s position in the UOR address space: stratum (ring layer), spectrum (bit pattern), and address (content-addressable position in the Braille glyph encoding). The three required functional properties schema:triadStratum, schema:triadSpectrum, and schema:triadAddress project a Triad onto its TwoAdicValuation, WalshHadamardImage, and Address coordinates respectively.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/Literal">
    <rdfs:label>Literal</rdfs:label>
    <rdfs:comment>A term that directly denotes a datum value. A Literal is a leaf node in the term language — it refers to a concrete Datum via schema:denotes without being a Datum itself.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/Term"/>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/SurfaceSymbol"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/Application">
    <rdfs:label>Application</rdfs:label>
    <rdfs:comment>A term formed by applying an operation to one or more argument terms. The application&apos;s value is the result of evaluating the operator on the evaluated arguments.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/Ring">
    <rdfs:label>Ring</rdfs:label>
    <rdfs:comment>The ambient ring Z/(2^n)Z at a specific Witt level n. The Ring is the primary data structure of the UOR kernel. Its two generators (negation and complement) produce the dihedral group D_{2^n} that governs the invariance frame.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/W16Ring">
    <rdfs:label>W16Ring</rdfs:label>
    <rdfs:comment>The concrete ring Z/(2^16)Z at Witt level 16. Subclass of schema:Ring. Carries 65,536 elements. W16Ring is the first extension of the default Q0 ring and is the target of Amendment 26&apos;s universality proofs.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/Ring"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/WittLevel">
    <rdfs:label>WittLevel</rdfs:label>
    <rdfs:comment>A named Witt level Q_k at which the UOR ring operates. Level Q_k uses 8*(k+1) bits, 2^(8*(k+1)) states, and modulus 2^(8*(k+1)). The named individuals Q0-Q3 are the spec-defined reference levels. The class is open: Prism implementations operating at higher levels declare their own WittLevel individuals. The nextWittLevel property forms an unbounded chain Q0 -&gt; Q1 -&gt; Q2 -&gt; ...</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/TermExpression">
    <rdfs:label>TermExpression</rdfs:label>
    <rdfs:comment>Root AST node for parsed EBNF term expressions. Identity lhs/rhs values are instances of TermExpression subtypes. Maps to the `term` production in the EBNF grammar.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/LiteralExpression">
    <rdfs:label>LiteralExpression</rdfs:label>
    <rdfs:comment>A leaf AST node: an integer literal, variable reference, or named constant.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/ApplicationExpression">
    <rdfs:label>ApplicationExpression</rdfs:label>
    <rdfs:comment>An AST node representing operator application: an operator applied to an argument list (e.g., add(x, y)).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/InfixExpression">
    <rdfs:label>InfixExpression</rdfs:label>
    <rdfs:comment>An AST node for infix relations and logical connectives (e.g., x &lt;= y, P -&gt; Q, a = b).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/SetExpression">
    <rdfs:label>SetExpression</rdfs:label>
    <rdfs:comment>An AST node for set-builder notation (e.g., {x : P(x)}).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/CompositionExpression">
    <rdfs:label>CompositionExpression</rdfs:label>
    <rdfs:comment>An AST node for function composition (f compose g).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/ForAllDeclaration">
    <rdfs:label>ForAllDeclaration</rdfs:label>
    <rdfs:comment>A structured quantifier binding: typed variable declarations with a domain and quantifier kind (universal or existential). Replaces the string-valued op:forAll property.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/VariableBinding">
    <rdfs:label>VariableBinding</rdfs:label>
    <rdfs:comment>A single variable binding: a variable name bound to a domain type (e.g., x in R_n).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/QuantifierKind">
    <rdfs:label>QuantifierKind</rdfs:label>
    <rdfs:comment>The kind of quantifier: Universal (forall) or Existential (exists). Controlled vocabulary with exactly 2 individuals.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/SurfaceSymbol">
    <rdfs:label>SurfaceSymbol</rdfs:label>
    <rdfs:comment>An abstract leaf value that a grounding map can accept as surface input. Has no direct instances: every SurfaceSymbol is either a Datum-denoting schema:Literal or an xsd-typed schema:HostValue, and the two cases are disjoint.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/HostValue">
    <rdfs:label>HostValue</rdfs:label>
    <rdfs:comment>An xsd-typed value that denotes a host datatype rather than a ring datum. Used in property-position slots whose range is xsd and as the host-side input of a grounding map.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/SurfaceSymbol"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/schema/Term"/>
    <owl:disjointWith rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/HostStringLiteral">
    <rdfs:label>HostStringLiteral</rdfs:label>
    <rdfs:comment>A host string literal carrying an xsd:string value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/HostValue"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/HostBooleanLiteral">
    <rdfs:label>HostBooleanLiteral</rdfs:label>
    <rdfs:comment>A host boolean literal carrying an xsd:boolean value.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/schema/HostValue"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/schema/ValueTuple">
    <rdfs:label>ValueTuple</rdfs:label>
    <rdfs:comment>An ordered tuple of values drawn from a type:ConstrainedType&apos;s carrier. Serves as the witness form for cert:InhabitanceCertificate when verified is true.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/value">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>value</rdfs:label>
    <rdfs:comment>The integer value of a datum element. For a Datum in Z/(2^n)Z, this is an integer in [0, 2^n).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/wittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLength</rdfs:label>
    <rdfs:comment>The Witt level n of a datum, where the datum&apos;s ring is Z/(2^n)Z. Determines the bit width and modulus of the datum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/stratum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>stratum</rdfs:label>
    <rdfs:comment>The ring-layer index of a datum, indicating its position in the stratification of Z/(2^n)Z.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/spectrum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>spectrum</rdfs:label>
    <rdfs:comment>The bit-pattern representation of a datum, encoding its position in the hypercube geometry of Z/(2^n)Z.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/element">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>element</rdfs:label>
    <rdfs:comment>The content-addressable element associated with this datum, linking the algebraic value to its identifier.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:range rdf:resource="https://uor.foundation/u/Element"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/operator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operator</rdfs:label>
    <rdfs:comment>The operation applied in an Application term.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Application"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/argument">
    <rdfs:label>argument</rdfs:label>
    <rdfs:comment>An argument term in an Application. The ordering of arguments follows rdf:List semantics.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Application"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Term"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/ringWittLength">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ringWittLength</rdfs:label>
    <rdfs:comment>The bit width n of the ring Z/(2^n)Z. Distinct from schema:wittLength on Datum — ringWittLength is the container&apos;s bit width; datum wittLength is a membership property.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/modulus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>modulus</rdfs:label>
    <rdfs:comment>The modulus 2^n of the ring. Equals 2 raised to the power of ringWittLength.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/generator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>generator</rdfs:label>
    <rdfs:comment>The generator element π₁ (value = 1) of the ring. Under iterated successor application, π₁ generates all ring elements.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/negation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>negation</rdfs:label>
    <rdfs:comment>The ring reflection involution: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Involution"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/complement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>complement</rdfs:label>
    <rdfs:comment>The hypercube reflection involution: bnot(x) = (2^n - 1) ⊕ x. The second generator of the dihedral group D_{2^n}.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Involution"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/denotes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>denotes</rdfs:label>
    <rdfs:comment>The datum value that a Literal term denotes. Bridges the Term/Datum disjointness: a Literal refers to a Datum without being one. Evaluation of a Literal produces its denoted Datum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Literal"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/Datum"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/bitsWidth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bitsWidth</rdfs:label>
    <rdfs:comment>The bit width 8*(k+1) of this Witt level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/cycleSize">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>cycleSize</rdfs:label>
    <rdfs:comment>The number of distinct states 2^(8*(k+1)) at this Witt level.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/nextWittLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>nextWittLevel</rdfs:label>
    <rdfs:comment>The next Witt level in the chain: Q_k -&gt; Q_(k+1). The chain is unbounded; Q3 points to Q4, which is not a named individual in the spec but may be declared by Prism implementations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/wittLevelPredecessor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>wittLevelPredecessor</rdfs:label>
    <rdfs:comment>The predecessor Witt level in the chain: Q_(k+1) -&gt; Q_k. Inverse of nextWittLevel. If nextWittLevel(Q_k) = Q_(k+1), then wittLevelPredecessor(Q_(k+1)) = Q_k. Formalizes the chain extension protocol (QL_8).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/atWittLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>atWittLevel</rdfs:label>
    <rdfs:comment>The Witt level at which this Ring instance operates. Links a concrete Ring individual to its WittLevel.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Ring"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/W16bitWidth">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>W16bitWidth</rdfs:label>
    <rdfs:comment>Bit width of the Q1 ring: 16.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/W16Ring"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/W16capacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>W16capacity</rdfs:label>
    <rdfs:comment>Carrier set size of the Q1 ring: 65,536 elements.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/W16Ring"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/boundVariables">
    <rdfs:label>boundVariables</rdfs:label>
    <rdfs:comment>The variable bindings in a quantifier declaration. Non-functional: a ForAllDeclaration may bind multiple variables.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/VariableBinding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/variableDomain">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>variableDomain</rdfs:label>
    <rdfs:comment>The domain type of a variable binding (e.g., schema:Ring, type:ConstrainedType).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/VariableBinding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/variableName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>variableName</rdfs:label>
    <rdfs:comment>The name of a bound variable (e.g., &apos;x&apos;, &apos;y&apos;, &apos;n&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/VariableBinding"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/quantifierKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>quantifierKind</rdfs:label>
    <rdfs:comment>The kind of quantifier: Universal or Existential.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/QuantifierKind"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/expressionOperator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>expressionOperator</rdfs:label>
    <rdfs:comment>The operator in an application expression (e.g., op:add, op:neg).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/ApplicationExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/leftOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leftOperand</rdfs:label>
    <rdfs:comment>The left operand of an infix expression.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/InfixExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/rightOperand">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rightOperand</rdfs:label>
    <rdfs:comment>The right operand of an infix expression.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/InfixExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/schema/arguments">
    <rdfs:label>arguments</rdfs:label>
    <rdfs:comment>The argument list of an application expression. Non-functional: an application may take multiple arguments.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/ApplicationExpression"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/literalValue">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>literalValue</rdfs:label>
    <rdfs:comment>The string representation of a literal expression value (e.g., &apos;42&apos;, &apos;x&apos;, &apos;pi1&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/infixOperator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>infixOperator</rdfs:label>
    <rdfs:comment>The operator symbol in an infix expression (e.g., &apos;=&apos;, &apos;\u{2264}&apos;, &apos;\u{2192}&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/InfixExpression"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/hostString">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hostString</rdfs:label>
    <rdfs:comment>The string value carried by a HostStringLiteral.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/HostStringLiteral"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/hostBoolean">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hostBoolean</rdfs:label>
    <rdfs:comment>The boolean value carried by a HostBooleanLiteral.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/HostBooleanLiteral"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/triadStratum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>triadStratum</rdfs:label>
    <rdfs:comment>The stratum component of a Triad: the datum&apos;s two-adic valuation, indexing its layer in the ring stratification. Semantically corresponds to query:TwoAdicValuation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Triad"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/triadSpectrum">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>triadSpectrum</rdfs:label>
    <rdfs:comment>The spectrum component of a Triad: the datum&apos;s Walsh-Hadamard transform image, indexing its position in the hypercube spectral decomposition. Semantically corresponds to query:WalshHadamardImage.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Triad"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/schema/triadAddress">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>triadAddress</rdfs:label>
    <rdfs:comment>The address component of a Triad: the datum&apos;s content-addressable position in the ring&apos;s Braille glyph encoding. Semantically corresponds to query:Address (renamed from RingElement in v0.2.2 W8).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/schema/Triad"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/Universal">
    <rdf:type rdf:resource="https://uor.foundation/schema/QuantifierKind"/>
    <rdfs:label>Universal</rdfs:label>
    <rdfs:comment>Universal quantification (forall).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/Existential">
    <rdf:type rdf:resource="https://uor.foundation/schema/QuantifierKind"/>
    <rdfs:label>Existential</rdfs:label>
    <rdfs:comment>Existential quantification (exists).</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/pi1">
    <rdf:type rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:label>π₁</rdfs:label>
    <rdfs:comment>The unique generator of R_n under successor. Value = 1 at every Witt level. Under iterated application of succ, π₁ generates every element of the ring.</rdfs:comment>
    <uor:schema/value rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:schema/value>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/zero">
    <rdf:type rdf:resource="https://uor.foundation/schema/Datum"/>
    <rdfs:label>zero</rdfs:label>
    <rdfs:comment>The additive identity of the ring. Value = 0 at every Witt level. op:add(x, zero) = x for all x in R_n.</rdfs:comment>
    <uor:schema/value rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:schema/value>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W8">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W8</rdfs:label>
    <rdfs:comment>Witt level 0: 8-bit ring Z/256Z, 256 states. The reference level for all ComputationCertificate proofs in the spec.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">256</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W16"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W16">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W16</rdfs:label>
    <rdfs:comment>Witt level 1: 16-bit ring Z/65536Z, 65,536 states.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">65536</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W24"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W8"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W24">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W24</rdfs:label>
    <rdfs:comment>Witt level 2: 24-bit ring Z/16777216Z, 16,777,216 states.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">24</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16777216</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W32"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W16"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W32">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W32</rdfs:label>
    <rdfs:comment>Witt level 3: 32-bit ring Z/4294967296Z, 4,294,967,296 states. The highest 32-bit-and-below named level in the v0.2.1 spec; v0.2.2 Phase C extends the tower with the dense and powers-of-two set.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">32</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4294967296</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W40"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W24"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W40">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W40</rdfs:label>
    <rdfs:comment>Witt level 4: 40-bit ring Z/2^40 Z. Backed by u64 with a 40-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">40</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1099511627776</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W48"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W32"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W48">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W48</rdfs:label>
    <rdfs:comment>Witt level 5: 48-bit ring Z/2^48 Z. Backed by u64 with a 48-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">48</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">281474976710656</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W56"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W40"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W56">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W56</rdfs:label>
    <rdfs:comment>Witt level 6: 56-bit ring Z/2^56 Z. Backed by u64 with a 56-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">56</uor:schema/bitsWidth>
    <uor:schema/cycleSize rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">72057594037927936</uor:schema/cycleSize>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W64"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W48"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W64">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W64</rdfs:label>
    <rdfs:comment>Witt level 7: 64-bit ring Z/2^64 Z. Backed by u64 directly (exact fit; no mask). v0.2.2 Phase C. cycle_size = 2^64 exceeds i64 representation and is omitted; codegen derives it from bit_width.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">64</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W72"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W56"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W72">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W72</rdfs:label>
    <rdfs:comment>Witt level 8: 72-bit ring Z/2^72 Z. Backed by u128 with a 72-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">72</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W80"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W64"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W80">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W80</rdfs:label>
    <rdfs:comment>Witt level 9: 80-bit ring Z/2^80 Z. Backed by u128 with an 80-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">80</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W88"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W72"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W88">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W88</rdfs:label>
    <rdfs:comment>Witt level 10: 88-bit ring Z/2^88 Z. Backed by u128 with an 88-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">88</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W96"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W80"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W96">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W96</rdfs:label>
    <rdfs:comment>Witt level 11: 96-bit ring Z/2^96 Z. Backed by u128 with a 96-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">96</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W104"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W88"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W104">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W104</rdfs:label>
    <rdfs:comment>Witt level 12: 104-bit ring Z/2^104 Z. Backed by u128 with a 104-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">104</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W112"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W96"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W112">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W112</rdfs:label>
    <rdfs:comment>Witt level 13: 112-bit ring Z/2^112 Z. Backed by u128 with a 112-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">112</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W120"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W104"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W120">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W120</rdfs:label>
    <rdfs:comment>Witt level 14: 120-bit ring Z/2^120 Z. Backed by u128 with a 120-bit mask at the arithmetic boundary. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W128"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W112"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W128">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W128</rdfs:label>
    <rdfs:comment>Witt level 15: 128-bit ring Z/2^128 Z. Backed by u128 directly (exact fit; no mask). The largest native-backed Witt level; levels above W128 use the Limbs&lt;N&gt; generic kernel emitted in Phase C.3. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">128</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W160"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W120"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W160">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W160</rdfs:label>
    <rdfs:comment>Witt level: 160-bit ring (SHA-1 digest carrier). Backed by Limbs&lt;3&gt; with a 160-bit mask. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">160</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W192"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W128"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W192">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W192</rdfs:label>
    <rdfs:comment>Witt level: 192-bit ring (P-192 carrier). Backed by Limbs&lt;3&gt;. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">192</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W224"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W160"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W224">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W224</rdfs:label>
    <rdfs:comment>Witt level: 224-bit ring (SHA-224 digest carrier). Backed by Limbs&lt;4&gt; with a 224-bit mask. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">224</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W256"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W192"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W256">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W256</rdfs:label>
    <rdfs:comment>Witt level: 256-bit ring (SHA-256, blake3, secp256k1, P-256 carrier). Backed by Limbs&lt;4&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">256</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W384"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W224"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W384">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W384</rdfs:label>
    <rdfs:comment>Witt level: 384-bit ring (SHA-384, P-384 carrier). Backed by Limbs&lt;6&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">384</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W448"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W256"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W448">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W448</rdfs:label>
    <rdfs:comment>Witt level: 448-bit ring (Curve448 carrier). Backed by Limbs&lt;7&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">448</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W512"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W384"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W512">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W512</rdfs:label>
    <rdfs:comment>Witt level: 512-bit ring (SHA-512 carrier). Backed by Limbs&lt;8&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">512</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W520"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W448"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W520">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W520</rdfs:label>
    <rdfs:comment>Witt level: 520-bit ring (P-521 prime carrier, lower-bound). Backed by Limbs&lt;9&gt; with a 520-bit mask. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">520</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W528"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W512"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W528">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W528</rdfs:label>
    <rdfs:comment>Witt level: 528-bit ring (P-521 prime carrier, upper-bound; P-521 elements are constrained by an additional residue check). Backed by Limbs&lt;9&gt; with a 528-bit mask. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">528</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W1024"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W520"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W1024">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W1024</rdfs:label>
    <rdfs:comment>Witt level: 1024-bit ring (RSA-1024 carrier). Backed by Limbs&lt;16&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1024</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W2048"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W528"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W2048">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W2048</rdfs:label>
    <rdfs:comment>Witt level: 2048-bit ring (RSA-2048 carrier). Backed by Limbs&lt;32&gt; directly (exact fit; no mask). v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2048</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W4096"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W1024"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W4096">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W4096</rdfs:label>
    <rdfs:comment>Witt level: 4096-bit ring (RSA-4096, BFV/CKKS HE ring dimension carrier). Backed by Limbs&lt;64&gt;. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4096</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W8192"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W2048"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W8192">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W8192</rdfs:label>
    <rdfs:comment>Witt level: 8192-bit ring (lattice-based crypto carrier). Backed by Limbs&lt;128&gt;. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8192</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W12288"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W4096"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W12288">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W12288</rdfs:label>
    <rdfs:comment>Witt level: 12288-bit ring (BFV/BGV HE ring dimension at n=12288). Backed by Limbs&lt;192&gt;. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12288</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W16384"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W8192"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W16384">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W16384</rdfs:label>
    <rdfs:comment>Witt level: 16384-bit ring (post-quantum lattice parameter). Backed by Limbs&lt;256&gt;. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16384</uor:schema/bitsWidth>
    <uor:schema/nextWittLevel rdf:resource="https://uor.foundation/schema/W32768"/>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W12288"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/W32768">
    <rdf:type rdf:resource="https://uor.foundation/schema/WittLevel"/>
    <rdfs:label>W32768</rdfs:label>
    <rdfs:comment>Witt level: 32768-bit ring (post-quantum / extreme-precision arithmetic carrier). Backed by Limbs&lt;512&gt;. The highest foundation-shipped level in v0.2.2; downstream Prism implementations may declare higher levels via the `witt_level` conformance declaration form. v0.2.2 Phase C.</rdfs:comment>
    <uor:schema/bitsWidth rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">32768</uor:schema/bitsWidth>
    <uor:schema/wittLevelPredecessor rdf:resource="https://uor.foundation/schema/W16384"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_criticalIdentity_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_criticalIdentity_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>neg(bnot(x))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_criticalIdentity_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_criticalIdentity_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>succ(x)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_criticalIdentity_forAll">
