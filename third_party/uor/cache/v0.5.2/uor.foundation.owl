    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_4</rdfs:label>
    <rdfs:comment>Certificate issuance: full saturation (σ = 1, freeRank = 0) admits a GroundingCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_4_rhs"/>
