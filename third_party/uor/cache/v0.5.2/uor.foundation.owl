  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HG_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HG_2</rdfs:label>
    <rdfs:comment>Dihedral generator holonomy group is D_{2^n}.</rdfs:comment>
