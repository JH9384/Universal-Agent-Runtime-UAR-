  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/COEFF_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>COEFF_1</rdfs:label>
    <rdfs:comment>Standard coefficient ring: the coefficient ring for all psi-pipeline cohomology computations in uor.foundation is Z/2Z, consistent with MN_7.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_COEFF_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_COEFF_1_rhs"/>
