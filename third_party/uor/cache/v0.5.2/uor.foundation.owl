  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_M4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_M4</rdfs:label>
    <rdfs:comment>Negation preserves ring metric.</rdfs:comment>
