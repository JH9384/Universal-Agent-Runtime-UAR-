    <uor:schema/literalValue>∃ c: GroundingCertificate. certifies(c, C)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_CIC_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_CIC_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
