  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PAR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PAR_1</rdfs:label>
    <rdfs:comment>Disjoint parallel computations commute: A ⊗ B = B ⊗ A when site targets are disjoint.</rdfs:comment>
