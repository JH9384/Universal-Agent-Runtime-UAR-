  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_CC_PINS_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_CC_PINS_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
