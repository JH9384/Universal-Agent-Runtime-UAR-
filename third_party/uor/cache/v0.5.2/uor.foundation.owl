    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_2</rdfs:label>
    <rdfs:comment>Unbinding increments free count by exactly 1.</rdfs:comment>
