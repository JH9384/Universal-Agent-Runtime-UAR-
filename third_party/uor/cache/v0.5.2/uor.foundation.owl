  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_5</rdfs:label>
    <rdfs:comment>Composite free-count delta is additive.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FX_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FX_5_rhs"/>
