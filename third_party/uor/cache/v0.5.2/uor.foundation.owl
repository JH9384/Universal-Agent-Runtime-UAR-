  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_localGlobalPrinciple">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_localGlobalPrinciple</rdfs:label>
    <rdfs:comment>Axiomatic derivation of cohomology:localGlobalPrinciple. Holds at all quantum levels by topological reasoning.</rdfs:comment>
    <uor:proof/provesIdentity rdf:resource="https://uor.foundation/cohomology/localGlobalPrinciple"/>
    <uor:proof/universalScope rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/universalScope>
