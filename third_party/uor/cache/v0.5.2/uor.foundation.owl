  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_P3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_P3</rdfs:label>
    <rdfs:comment>Reduction length is additive under sequential composition.</rdfs:comment>
