    <uor:schema/variableName>d ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_AD_2_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
