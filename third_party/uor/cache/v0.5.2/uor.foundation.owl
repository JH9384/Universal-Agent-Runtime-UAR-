  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CF_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CF_1</rdfs:label>
    <rdfs:comment>Curvature flux is the sum of incompatibility along a path.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CF_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CF_1_rhs"/>
