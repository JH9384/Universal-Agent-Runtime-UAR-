  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CT_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CT_1</rdfs:label>
