    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_7</rdfs:label>
    <rdfs:comment>ψ_7: KanComplex → PostnikovTower — compute the Postnikov truncations τ_{≤k} for k = 0, 1, …, dim(N(C)).</rdfs:comment>
