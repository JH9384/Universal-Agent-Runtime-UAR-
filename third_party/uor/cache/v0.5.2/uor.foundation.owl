  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CT_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CT_4</rdfs:label>
    <rdfs:comment>Composite catastrophe threshold is max of component thresholds.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CT_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CT_4_rhs"/>
