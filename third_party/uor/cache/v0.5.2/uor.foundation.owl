  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/prf_sheafCohomologyBridge">
    <rdf:type rdf:resource="https://uor.foundation/proof/AxiomaticDerivation"/>
    <rdfs:label>prf_sheafCohomologyBridge</rdfs:label>
