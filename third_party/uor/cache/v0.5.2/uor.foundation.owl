    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_3</rdfs:label>
    <rdfs:comment>Certificate issuance: every involutive operation f where f(f(x)) = x admits an InvolutionCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_3_rhs"/>
