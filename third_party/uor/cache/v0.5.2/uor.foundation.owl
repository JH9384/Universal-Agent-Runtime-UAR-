  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CL_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CL_5</rdfs:label>
    <rdfs:comment>Constraint lattice complement existence.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CL_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CL_5_rhs"/>
