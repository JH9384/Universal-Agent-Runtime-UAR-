    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_5</rdfs:label>
    <rdfs:comment>Certificate issuance: an AR_1-ordered and DC_10-selected trace admits a GeodesicCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CIC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
