    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SD_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SD_7</rdfs:label>
    <rdfs:comment>TreeType β_1=0, β_0=1 topological constraints.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SD_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SD_7_rhs"/>
