  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_6</rdfs:label>
    <rdfs:comment>Every ReversibleEffect has an inverse (PinningEffect⁻¹ = UnbindingEffect on same site, PhaseEffect⁻¹ = conjugate phase).</rdfs:comment>
