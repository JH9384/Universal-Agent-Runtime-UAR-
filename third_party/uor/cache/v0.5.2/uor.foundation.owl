    <rdfs:label>term_B_10_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>x, y, z ∈ R_n</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_B_11_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_B_11_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>bnot(and(x, y))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_B_11_rhs">
