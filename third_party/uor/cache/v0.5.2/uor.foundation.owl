  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PR_2</rdfs:label>
    <rdfs:comment>Every predicate is pure: evaluation does not modify state.</rdfs:comment>
