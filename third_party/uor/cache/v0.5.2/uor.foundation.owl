  <owl:NamedIndividual rdf:about="https://uor.foundation/op/T_A2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>T_A2</rdfs:label>
    <rdfs:comment>Dihedral group action on partitions permutes components.</rdfs:comment>
