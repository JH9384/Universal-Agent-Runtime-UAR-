  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_R_A3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_R_A3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
