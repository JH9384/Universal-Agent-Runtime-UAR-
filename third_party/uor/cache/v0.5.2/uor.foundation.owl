  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_M1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_M1</rdfs:label>
    <rdfs:comment>Ring metric triangle inequality.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OB_M1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OB_M1_rhs"/>
