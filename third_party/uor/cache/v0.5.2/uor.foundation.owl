  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CT_3</rdfs:label>
    <rdfs:comment>Catastrophe threshold is normalized step cost.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CT_3_rhs"/>
