  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_jsat_CR_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_jsat_CR_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
