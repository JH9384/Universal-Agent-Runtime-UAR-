    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CB_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CB_6</rdfs:label>
    <rdfs:comment>Iteration bound for k constraints: at most min(k, n) iterations.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CB_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CB_6_rhs"/>
