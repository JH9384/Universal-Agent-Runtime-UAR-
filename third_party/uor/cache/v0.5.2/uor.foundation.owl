  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CT_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CT_2</rdfs:label>
    <rdfs:comment>Odd prime catastrophe transitions visibility via residue constraints.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CT_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CT_2_rhs"/>
