    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>O(n + m)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_IH_2b_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_IH_2b_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>T : type:ConstrainedType | IsHornShape(T)</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_IH_3_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_IH_3_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>carrier(reduce(T))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_IH_3_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_IH_3_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>carrier(T)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_IH_3_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_IH_3_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>T : type:ConstrainedType</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_boundarySquaredZero_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_boundarySquaredZero_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>∂_k(∂_{k+1}(c))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_boundarySquaredZero_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_boundarySquaredZero_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>0</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_boundarySquaredZero_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_boundarySquaredZero_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>c ∈ C_{k+1}</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_psi_4_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_psi_4_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>β_k(K)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_psi_4_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_psi_4_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>rank(H_k(K))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_psi_4_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_psi_4_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>simplicial complex K</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_indexBridge_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_indexBridge_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>χ(K)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_indexBridge_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_indexBridge_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>Σ_k (-1)^k β_k</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_indexBridge_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_indexBridge_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>finite simplicial complex K</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_coboundarySquaredZero_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_coboundarySquaredZero_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>δ^{k+1}(δ^k(f))</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_coboundarySquaredZero_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_coboundarySquaredZero_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>0</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_coboundarySquaredZero_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_coboundarySquaredZero_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>f ∈ C^k</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_deRhamDuality_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_deRhamDuality_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>H^k(K; R)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_deRhamDuality_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_deRhamDuality_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>Hom(H_k(K), R)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_deRhamDuality_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_deRhamDuality_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>simplicial complex K, ring R</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_sheafCohomologyBridge_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_sheafCohomologyBridge_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>H^k(K; F_R)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_sheafCohomologyBridge_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_sheafCohomologyBridge_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>H^k(K; R)</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_sheafCohomologyBridge_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_sheafCohomologyBridge_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>constant sheaf F_R over K</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_localGlobalPrinciple_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_localGlobalPrinciple_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>H^1(K; F) = 0</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_localGlobalPrinciple_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_localGlobalPrinciple_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>all local sections glue</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_localGlobalPrinciple_forAll">
    <rdf:type rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
    <rdfs:label>term_localGlobalPrinciple_forAll</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>sheaf F over K</uor:schema/variableName>
  </owl:NamedIndividual>

  <!-- Namespace: op -->
  <owl:Ontology rdf:about="https://uor.foundation/op/">
    <rdfs:label>UOR Operations</rdfs:label>
    <rdfs:comment>Ring operations, involutions, algebraic identities, and the dihedral symmetry group D_{2^n} generated by neg and bnot.</rdfs:comment>
    <uor:space>kernel</uor:space>
    <owl:imports rdf:resource="https://uor.foundation/schema/"/>
  </owl:Ontology>

  <owl:Class rdf:about="https://uor.foundation/op/Operation">
    <rdfs:label>Operation</rdfs:label>
    <rdfs:comment>An operation on the ring Z/(2^n)Z. The root class for all UOR kernel operations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/UnaryOp">
    <rdfs:label>UnaryOp</rdfs:label>
    <rdfs:comment>A unary operation on the ring: takes one datum and produces one datum.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/BinaryOp">
    <rdfs:label>BinaryOp</rdfs:label>
    <rdfs:comment>A binary operation on the ring: takes two datums and produces one datum.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/Involution">
    <rdfs:label>Involution</rdfs:label>
    <rdfs:comment>A unary operation f such that f(f(x)) = x for all x in R_n. The two UOR involutions are neg (ring reflection) and bnot (hypercube reflection).</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/UnaryOp"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/Identity">
    <rdfs:label>Identity</rdfs:label>
    <rdfs:comment>An algebraic identity: a statement that two expressions are equal for all inputs. The critical identity is neg(bnot(x)) = succ(x) for all x in R_n.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/Group">
    <rdfs:label>Group</rdfs:label>
    <rdfs:comment>A group: a set with an associative binary operation, an identity element, and inverses for every element.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/DihedralGroup">
    <rdfs:label>DihedralGroup</rdfs:label>
    <rdfs:comment>The dihedral group D_{2^n} of order 2^(n+1), generated by the ring reflection (neg) and the hypercube reflection (bnot). This group governs the symmetry of the UOR type space.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/Group"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/VerificationDomain">
    <rdfs:label>VerificationDomain</rdfs:label>
    <rdfs:comment>A named mathematical discipline through which an algebraic identity is established and grounded. Every op:Identity individual references at least one VerificationDomain via op:verificationDomain. The nine canonical domain individuals are kernel-level constants defined in op/.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/GeometricCharacter">
    <rdfs:label>GeometricCharacter</rdfs:label>
    <rdfs:comment>The geometric role of a ring operation in the UOR dual-geometry (ring + hypercube). Every op:Operation individual references exactly one GeometricCharacter via op:hasGeometricCharacter. The nine canonical individuals correspond to the action types of the dihedral group D_{2^n}.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/WittLevelBinding">
    <rdfs:label>WittLevelBinding</rdfs:label>
    <rdfs:comment>A record linking an op:Identity individual to a specific quantum level at which it has been verified. Non-functional: one WittLevelBinding per (Identity, WittLevel) pair verified.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/QuantumThermodynamicDomain">
    <rdfs:label>QuantumThermodynamicDomain</rdfs:label>
    <rdfs:comment>A verification domain at the intersection of quantum superposition and classical thermodynamics. Identities in this domain require both SuperpositionDomain and Thermodynamic reasoning simultaneously.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/ValidityScopeKind">
    <rdfs:label>ValidityScopeKind</rdfs:label>
    <rdfs:comment>Root class for validity scope individuals. Instances are the four named scope kinds: Universal, ParametricLower, ParametricRange, and LevelSpecific.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/ComposedOperation">
    <rdfs:label>ComposedOperation</rdfs:label>
    <rdfs:comment>An operation formed by composing ring operations, witnessed by op:composedOf and morphism/CompositionLaw.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/morphism/Composition"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/DispatchOperation">
    <rdfs:label>DispatchOperation</rdfs:label>
    <rdfs:comment>δ: Query × ResolverRegistry → Resolver. Non-commutative, non-associative, arity 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/ComposedOperation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/InferenceOperation">
    <rdfs:label>InferenceOperation</rdfs:label>
    <rdfs:comment>ι = P ∘ Π ∘ G (the φ-pipeline composed). Non-commutative, non-associative, arity 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/ComposedOperation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/AccumulationOperation">
    <rdfs:label>AccumulationOperation</rdfs:label>
    <rdfs:comment>α: Binding × Context → Context. Non-commutative, associative at convergence (SR_10), arity 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/ComposedOperation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/LeasePartitionOperation">
    <rdfs:label>LeasePartitionOperation</rdfs:label>
    <rdfs:comment>λ: SharedContext × ℕ → ContextLease^k. Non-commutative, non-associative, arity 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/ComposedOperation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/SessionCompositionOperation">
    <rdfs:label>SessionCompositionOperation</rdfs:label>
    <rdfs:comment>κ: Session × Session → Session. Commutative (disjoint leases), associative (SR_8), arity 2.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://uor.foundation/op/ComposedOperation"/>
  </owl:Class>

  <owl:Class rdf:about="https://uor.foundation/op/GroupPresentation">
    <rdfs:label>GroupPresentation</rdfs:label>
    <rdfs:comment>A structured group presentation: generators and relations as typed data rather than prose strings.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </owl:Class>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/arity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>arity</rdfs:label>
    <rdfs:comment>The number of arguments this operation takes. 1 for unary operations, 2 for binary operations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/hasGeometricCharacter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>hasGeometricCharacter</rdfs:label>
    <rdfs:comment>The geometric role of this operation in the UOR ring and hypercube geometry. Functional: each operation has exactly one geometric character.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/commutative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>commutative</rdfs:label>
    <rdfs:comment>Whether this binary operation satisfies op(x,y) = op(y,x) for all x, y in R_n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/associative">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>associative</rdfs:label>
    <rdfs:comment>Whether this binary operation satisfies op(op(x,y),z) = op(x,op(y,z)) for all x, y, z in R_n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/identity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>identity</rdfs:label>
    <rdfs:comment>The identity element of this binary operation: the value e such that op(x, e) = op(e, x) = x for all x in R_n.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/inverse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inverse</rdfs:label>
    <rdfs:comment>The inverse operation: the operation inv_op such that op(x, inv_op(x)) = e for all x, where e is the identity.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/composedOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedOf</rdfs:label>
    <rdfs:comment>Ordered list of operations this operation is composed from. Uses rdf:List to preserve application order (first element applied innermost). E.g., succ = neg ∘ bnot is encoded as [op:neg, op:bnot] meaning neg applied to the result of bnot.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/lhs">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>lhs</rdfs:label>
    <rdfs:comment>The left-hand side of an algebraic identity as a typed AST node (schema:TermExpression).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/rhs">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>rhs</rdfs:label>
    <rdfs:comment>The right-hand side of an algebraic identity as a typed AST node (schema:TermExpression).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/forAll">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>forAll</rdfs:label>
    <rdfs:comment>The quantifier scope: a typed declaration of the variable(s) over which this identity holds.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/ForAllDeclaration"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/generatedBy">
    <rdfs:label>generatedBy</rdfs:label>
    <rdfs:comment>An operation that generates this group. The dihedral group D_{2^n} is generated by op:neg and op:bnot.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Group"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/order">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>order</rdfs:label>
    <rdfs:comment>The number of elements in the group. For D_{2^n}, the order is 2^(n+1).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Group"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#positiveInteger"/>
  </owl:DatatypeProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/op/presentation">
    <rdfs:label>presentation</rdfs:label>
    <rdfs:comment>The group presentation (generators and relations). Example: ⟨r, s | r^{2^n} = s² = e, srs = r⁻¹⟩</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Group"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/verificationDomain">
    <rdfs:label>verificationDomain</rdfs:label>
    <rdfs:comment>The mathematical discipline(s) through which this identity is established. Range is op:VerificationDomain. Non-functional: composite identities (e.g. IT_7a–IT_7d) reference multiple domain individuals.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/VerificationDomain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/verifiedAtLevel">
    <rdfs:label>verifiedAtLevel</rdfs:label>
    <rdfs:comment>Links an Identity individual to a WittLevelBinding attesting verification at a specific quantum level. Non-functional: one binding per (Identity, WittLevel) pair.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/WittLevelBinding"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/bindingLevel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>bindingLevel</rdfs:label>
    <rdfs:comment>The quantum level at which this WittLevelBinding was verified.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/WittLevelBinding"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/WittLevel"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/universallyValid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>universallyValid</rdfs:label>
    <rdfs:comment>True iff this identity holds for all n ≥ 1 (proved symbolically by induction on the ring axioms, not just exhaustively at Q0). Identities that reference 8-bit-specific constants receive universallyValid = false.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/enumVariant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>enumVariant</rdfs:label>
    <rdfs:comment>The canonical Rust enum variant name corresponding to this VerificationDomain individual. Provides formal alignment between the OWL individual and the generated Rust enum.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/VerificationDomain"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/validityKind">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validityKind</rdfs:label>
    <rdfs:comment>The structured validity scope of this identity, replacing the binary universallyValid flag. Required on all new Identity individuals.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/ValidityScopeKind"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/validKMin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validKMin</rdfs:label>
    <rdfs:comment>Minimum quantum level index k for ParametricLower and ParametricRange scopes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/validKMax">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>validKMax</rdfs:label>
    <rdfs:comment>Maximum quantum level index k (inclusive) for ParametricRange scope.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/composedOfOps">
    <rdfs:label>composedOfOps</rdfs:label>
    <rdfs:comment>References a constituent operation of a ComposedOperation. Non-functional: a composed operation may reference multiple constituent operations.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:AnnotationProperty rdf:about="https://uor.foundation/op/operatorSignature">
    <rdfs:label>operatorSignature</rdfs:label>
    <rdfs:comment>Human-readable type signature describing the domain and codomain of a composed operation (e.g., &apos;Query × Registry → Resolver&apos;).</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:AnnotationProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/dispatchSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchSource</rdfs:label>
    <rdfs:comment>The source selector for a dispatch operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/DispatchOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/dispatchTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>dispatchTarget</rdfs:label>
    <rdfs:comment>The target resolver for a dispatch operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/DispatchOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/inferenceSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inferenceSource</rdfs:label>
    <rdfs:comment>The source data for an inference operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/InferenceOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/inferenceTarget">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inferenceTarget</rdfs:label>
    <rdfs:comment>The target type for an inference operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/InferenceOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/inferencePipeline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>inferencePipeline</rdfs:label>
    <rdfs:comment>The pipeline through which inference is performed.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/InferenceOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/accumulationBase">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>accumulationBase</rdfs:label>
    <rdfs:comment>The base value for an accumulation operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/AccumulationOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/accumulationBinding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>accumulationBinding</rdfs:label>
    <rdfs:comment>The binding accumulator for an accumulation operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/AccumulationOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/leaseSource">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseSource</rdfs:label>
    <rdfs:comment>The source context for a lease partition operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/LeasePartitionOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/leaseFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leaseFactor</rdfs:label>
    <rdfs:comment>The partition factor for a lease partition operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/LeasePartitionOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/leasePartitionCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>leasePartitionCount</rdfs:label>
    <rdfs:comment>The number of partitions in a lease partition operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/LeasePartitionOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/compositionLeftSession">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionLeftSession</rdfs:label>
    <rdfs:comment>The left session in a session composition operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/SessionCompositionOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/compositionRightSession">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>compositionRightSession</rdfs:label>
    <rdfs:comment>The right session in a session composition operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/SessionCompositionOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/op/Operation"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/operatorDomainType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operatorDomainType</rdfs:label>
    <rdfs:comment>The domain type of a composed operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/operatorRangeType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operatorRangeType</rdfs:label>
    <rdfs:comment>The range type of a composed operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/type/TypeDefinition"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/operatorComplexity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operatorComplexity</rdfs:label>
    <rdfs:comment>The computational complexity class of a composed operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/operatorIdempotent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>operatorIdempotent</rdfs:label>
    <rdfs:comment>Whether this composed operation is idempotent.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/composedOperatorCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>composedOperatorCount</rdfs:label>
    <rdfs:comment>The number of constituent operations in a composed operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/isInvolutory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isInvolutory</rdfs:label>
    <rdfs:comment>Whether applying this operation twice yields the identity.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:ObjectProperty rdf:about="https://uor.foundation/op/convergenceGuarantee">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>convergenceGuarantee</rdfs:label>
    <rdfs:comment>Description of the convergence guarantee for this operation.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/ComposedOperation"/>
    <rdfs:range rdf:resource="https://uor.foundation/schema/TermExpression"/>
  </owl:ObjectProperty>

  <owl:DatatypeProperty rdf:about="https://uor.foundation/op/isRingOp">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>isRingOp</rdfs:label>
    <rdfs:comment>True iff this Operation participates in the Z/(2^n)Z ring-arithmetic vocabulary. Annotation drives the Lean RingOp class generation in UOR/Enforcement.lean.</rdfs:comment>
    <rdfs:domain rdf:resource="https://uor.foundation/op/Operation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </owl:DatatypeProperty>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Enumerative">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Enumerative</rdfs:label>
    <rdfs:comment>Established by exhaustive traversal of R_n. Valid for all identities where the ring is finite.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Enumerative"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Algebraic">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Algebraic</rdfs:label>
    <rdfs:comment>Established by equational reasoning from ring or group axioms. Covers derivations via associativity, commutativity, inverse laws, and group presentations.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Geometric">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Geometric</rdfs:label>
    <rdfs:comment>Established by isometry, symmetry, or GeometricCharacter arguments. Covers dihedral actions, fixed-point analysis, automorphism groups, and affine embeddings.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Geometric"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Analytical">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Analytical</rdfs:label>
    <rdfs:comment>Established via discrete differential calculus or metric analysis. Covers ring/Hamming derivatives (DC_), metric divergence (AM_), and adiabatic scheduling (AR_).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Thermodynamic">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Thermodynamic</rdfs:label>
    <rdfs:comment>Established via entropy, Landauer bounds, or Boltzmann distributions. Covers site entropy (TH_), reversible computation (RC_), and phase transitions.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Topological">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Topological</rdfs:label>
    <rdfs:comment>Established via simplicial homology, cohomology, or constraint nerve analysis. Covers homological algebra (HA_) and the ψ-pipeline base chain ψ_1..ψ_6 (constraint nerve construction, chain functor, homology, Betti extraction, dualization, cohomology).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Pipeline">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>Pipeline</rdfs:label>
    <rdfs:comment>Established by the inter-algebra map structure of the resolution pipeline. Covers φ-maps (phi_1–phi_6) and the ψ-pipeline tower ψ_7..ψ_9 (Postnikov truncation, homotopy group extraction, k-invariant computation). The earlier ψ_1..ψ_6 chain (constraint nerve → simplicial homology) is established under op:Topological.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IndexTheoretic">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>IndexTheoretic</rdfs:label>
    <rdfs:comment>Established by the composition of Analytical and Topological reasoning. The only domain requiring multiple op:verificationDomain assertions. Covers the UOR Index Theorem (IT_7a–IT_7d).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SuperpositionDomain">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>SuperpositionDomain</rdfs:label>
    <rdfs:comment>Established by superposition analysis of site states. Covers identities involving superposed (non-classical) site assignments where sites carry complex amplitudes.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/SuperpositionDomain"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QuantumThermodynamic">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>QuantumThermodynamic</rdfs:label>
    <rdfs:comment>Established by the intersection of quantum superposition analysis and classical thermodynamic reasoning. Covers identities relating von Neumann entropy of superposed states to Landauer costs of projective collapse (QM_).</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ArithmeticValuation">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>ArithmeticValuation</rdfs:label>
    <rdfs:comment>Established by number-theoretic valuation arguments including p-adic absolute values, the Ostrowski product formula, and the arithmetic of global fields. Covers identities grounded in the product formula |x|_p · |x|_∞ = 1 and the Witt–Ostrowski derivation chain.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ComposedAlgebraic">
    <rdf:type rdf:resource="https://uor.foundation/op/VerificationDomain"/>
    <rdfs:label>ComposedAlgebraic</rdfs:label>
    <rdfs:comment>Verification domain for composed operation identities — algebraic properties of operator compositions including dispatch, inference, accumulation, lease, and session composition operations.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/ComposedAlgebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Universal">
    <rdf:type rdf:resource="https://uor.foundation/op/ValidityScopeKind"/>
    <rdfs:label>Universal</rdfs:label>
    <rdfs:comment>Holds for all k in N. No minimum k constraint.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ParametricLower">
    <rdf:type rdf:resource="https://uor.foundation/op/ValidityScopeKind"/>
    <rdfs:label>ParametricLower</rdfs:label>
    <rdfs:comment>Holds for all k &gt;= k_min, where k_min is given by validKMin.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/ParametricLower"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ParametricRange">
    <rdf:type rdf:resource="https://uor.foundation/op/ValidityScopeKind"/>
    <rdfs:label>ParametricRange</rdfs:label>
    <rdfs:comment>Holds for k_min &lt;= k &lt;= k_max. Both validKMin and validKMax required.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/ParametricRange"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/LevelSpecific">
    <rdf:type rdf:resource="https://uor.foundation/op/ValidityScopeKind"/>
    <rdfs:label>LevelSpecific</rdfs:label>
    <rdfs:comment>Holds only at exactly one level, given by a WittLevelBinding.</rdfs:comment>
    <uor:op/enumVariant rdf:resource="https://uor.foundation/op/LevelSpecific"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RingReflection">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>RingReflection</rdfs:label>
    <rdfs:comment>Reflection through the origin of the additive ring: neg(x) = -x mod 2^n. One of the two generators of D_{2^n}.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HypercubeReflection">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>HypercubeReflection</rdfs:label>
    <rdfs:comment>Reflection through the centre of the hypercube: bnot(x) = (2^n-1) ⊕ x. The second generator of D_{2^n}.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Rotation">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>Rotation</rdfs:label>
    <rdfs:comment>Rotation by one step: succ(x) = (x+1) mod 2^n. The composition of the two reflections.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RotationInverse">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>RotationInverse</rdfs:label>
    <rdfs:comment>Rotation by one step in the reverse direction: pred(x) = (x-1) mod 2^n.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Translation">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>Translation</rdfs:label>
    <rdfs:comment>Translation along the ring axis: add(x,y), sub(x,y). Preserves Hamming distance locally.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Scaling">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>Scaling</rdfs:label>
    <rdfs:comment>Scaling along the ring axis: mul(x,y) = (x×y) mod 2^n.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HypercubeTranslation">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>HypercubeTranslation</rdfs:label>
    <rdfs:comment>Translation along the hypercube axis: xor(x,y) = x ⊕ y. Preserves ring distance locally.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HypercubeProjection">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>HypercubeProjection</rdfs:label>
    <rdfs:comment>Projection onto a hypercube face: and(x,y) = x ∧ y. Idempotent; collapses dimensions.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HypercubeJoin">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>HypercubeJoin</rdfs:label>
    <rdfs:comment>Join on the hypercube lattice: or(x,y) = x ∨ y. Idempotent; dual to projection.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Quotient">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>Quotient</rdfs:label>
    <rdfs:comment>Euclidean quotient along the ring axis: div(a,b) — the structural dual of Scaling. Geometric character of `op:div` per ADR-053.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/Remainder">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>Remainder</rdfs:label>
    <rdfs:comment>Euclidean remainder along the ring axis: mod(a,b). Complement of Quotient — together they realize the divmod fold-rule. Geometric character of `op:mod` per ADR-053.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IteratedScaling">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>IteratedScaling</rdfs:label>
    <rdfs:comment>Iterated multiplicative scaling along the ring axis: pow(base, exp) = base^exp mod 2^n. Extends the multiplicative Scaling axis via square-and-multiply iteration. Geometric character of `op:pow` per ADR-053.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ConstraintSelection">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>ConstraintSelection</rdfs:label>
    <rdfs:comment>Geometric character of dispatch: constraint-guided selection over the resolver registry lattice.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ResolutionTraversal">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>ResolutionTraversal</rdfs:label>
    <rdfs:comment>Geometric character of inference: traversal through the φ-pipeline resolution graph P ∘ Π ∘ G.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SiteBinding">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>SiteBinding</rdfs:label>
    <rdfs:comment>Geometric character of accumulation: progressive pinning of site states in the context lattice.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SitePartition">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>SitePartition</rdfs:label>
    <rdfs:comment>Geometric character of lease partition: splitting a shared context into disjoint site-set leases.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SessionMerge">
    <rdf:type rdf:resource="https://uor.foundation/op/GeometricCharacter"/>
    <rdfs:label>SessionMerge</rdfs:label>
    <rdfs:comment>Geometric character of session composition: merging disjoint lease sessions into a unified resolution context.</rdfs:comment>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/neg">
    <rdf:type rdf:resource="https://uor.foundation/op/Involution"/>
    <rdfs:label>neg</rdfs:label>
    <rdfs:comment>Ring reflection: neg(x) = (-x) mod 2^n. One of the two generators of the dihedral group D_{2^n}. neg(neg(x)) = x (involution property).</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/RingReflection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/bnot">
    <rdf:type rdf:resource="https://uor.foundation/op/Involution"/>
    <rdfs:label>bnot</rdfs:label>
    <rdfs:comment>Hypercube reflection: bnot(x) = (2^n - 1) ⊕ x (bitwise complement). The second generator of D_{2^n}. bnot(bnot(x)) = x.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/HypercubeReflection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/succ">
    <rdf:type rdf:resource="https://uor.foundation/op/UnaryOp"/>
    <rdfs:label>succ</rdfs:label>
    <rdfs:comment>Successor: succ(x) = neg(bnot(x)) = (x + 1) mod 2^n. The critical identity: succ is the composition neg ∘ bnot.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Rotation"/>
    <uor:op/composedOf rdf:parseType="Collection">
      <rdf:Description rdf:about="https://uor.foundation/op/neg"/>
      <rdf:Description rdf:about="https://uor.foundation/op/bnot"/>
    </uor:op/composedOf>
    <uor:op/inverse rdf:resource="https://uor.foundation/op/pred"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/pred">
    <rdf:type rdf:resource="https://uor.foundation/op/UnaryOp"/>
    <rdfs:label>pred</rdfs:label>
    <rdfs:comment>Predecessor: pred(x) = bnot(neg(x)) = (x - 1) mod 2^n. The inverse of succ. pred is the composition bnot ∘ neg.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/RotationInverse"/>
    <uor:op/composedOf rdf:parseType="Collection">
      <rdf:Description rdf:about="https://uor.foundation/op/bnot"/>
      <rdf:Description rdf:about="https://uor.foundation/op/neg"/>
    </uor:op/composedOf>
    <uor:op/inverse rdf:resource="https://uor.foundation/op/succ"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/add">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>add</rdfs:label>
    <rdfs:comment>Ring addition: add(x, y) = (x + y) mod 2^n. Commutative, associative; identity element is 0.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Translation"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
    <uor:op/identity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:op/identity>
    <uor:op/inverse rdf:resource="https://uor.foundation/op/sub"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/sub">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>sub</rdfs:label>
    <rdfs:comment>Ring subtraction: sub(x, y) = (x - y) mod 2^n. Not commutative, not associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Translation"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/mul">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>mul</rdfs:label>
    <rdfs:comment>Ring multiplication: mul(x, y) = (x × y) mod 2^n. Commutative, associative; identity element is 1.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Scaling"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
    <uor:op/identity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</uor:op/identity>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/xor">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>xor</rdfs:label>
    <rdfs:comment>Bitwise exclusive or: xor(x, y) = x ⊕ y. Commutative, associative; identity element is 0.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/HypercubeTranslation"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
    <uor:op/identity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:op/identity>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/and">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>and</rdfs:label>
    <rdfs:comment>Bitwise and: and(x, y) = x ∧ y. Commutative, associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/HypercubeProjection"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/or">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>or</rdfs:label>
    <rdfs:comment>Bitwise or: or(x, y) = x ∨ y. Commutative, associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/HypercubeJoin"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/le">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>le</rdfs:label>
    <rdfs:comment>Byte-level less-than-or-equal: le(x, y) = 1 if x ≤ y else 0. Operands compared as big-endian unsigned byte sequences. The catamorphism fold-rule emits Literal(1) on true, Literal(0) on false.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ConstraintSelection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/lt">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>lt</rdfs:label>
    <rdfs:comment>Byte-level less-than: lt(x, y) = 1 if x &lt; y else 0. Operands compared as big-endian unsigned byte sequences.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ConstraintSelection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ge">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>ge</rdfs:label>
    <rdfs:comment>Byte-level greater-than-or-equal: ge(x, y) = 1 if x ≥ y else 0. Operands compared as big-endian unsigned byte sequences.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ConstraintSelection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/gt">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>gt</rdfs:label>
    <rdfs:comment>Byte-level greater-than: gt(x, y) = 1 if x &gt; y else 0. Operands compared as big-endian unsigned byte sequences.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ConstraintSelection"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/concat">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>concat</rdfs:label>
    <rdfs:comment>Byte-sequence concatenation: concat(x, y) = x ⧺ y. The substrate&apos;s byte-packing primitive — admits header serialization and other byte-array construction patterns. Result length is len(x) + len(y), carried by the source-polymorphic TermValue (inline up to the application&apos;s carrier width, else borrowed or streamed — no fixed ceiling).</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/HypercubeJoin"/>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/div">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>div</rdfs:label>
    <rdfs:comment>Euclidean quotient: div(a, b) = q where a = q·b + r, 0 ⇐ r &lt; b. Total on the ring for b &gt; 0; b = 0 emits a ShapeViolation. Operands read as unsigned big-endian integers at the operand width.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Quotient"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/mod">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>mod</rdfs:label>
    <rdfs:comment>Euclidean remainder: mod(a, b) = r where a = q·b + r, 0 ⇐ r &lt; b. Total on the ring for b &gt; 0; b = 0 emits a ShapeViolation. Operands read as unsigned big-endian integers at the operand width.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/Remainder"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/pow">
    <rdf:type rdf:resource="https://uor.foundation/op/BinaryOp"/>
    <rdfs:label>pow</rdfs:label>
    <rdfs:comment>Modular exponentiation: pow(base, exp) = base^exp mod 2^n. Fold-rule: square-and-multiply over exp bits. pow(_, 0) = 1; pow(0, b &gt; 0) = 0.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/isRingOp rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/isRingOp>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/IteratedScaling"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/dispatch">
    <rdf:type rdf:resource="https://uor.foundation/op/DispatchOperation"/>
    <rdfs:label>dispatch</rdfs:label>
    <rdfs:comment>δ(q, R) = R(q): dispatches a query to the matching resolver in the registry. Non-commutative, non-associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ConstraintSelection"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
    <uor:op/operatorSignature>Query × ResolverRegistry → Resolver</uor:op/operatorSignature>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/infer">
    <rdf:type rdf:resource="https://uor.foundation/op/InferenceOperation"/>
    <rdfs:label>infer</rdfs:label>
    <rdfs:comment>ι(s, C) = P(Π(G(s, C))): the φ-pipeline composed into a single inference step. Non-commutative, non-associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/ResolutionTraversal"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
    <uor:op/operatorSignature>Symbol × Context → ResolvedType</uor:op/operatorSignature>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/accumulate">
    <rdf:type rdf:resource="https://uor.foundation/op/AccumulationOperation"/>
    <rdfs:label>accumulate</rdfs:label>
    <rdfs:comment>α(b, C) = C&apos;: accumulates a binding into a resolution context, pinning a site. Non-commutative, associative at convergence (SR_10).</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/SiteBinding"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
    <uor:op/operatorSignature>Binding × Context → Context</uor:op/operatorSignature>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/partition_op">
    <rdf:type rdf:resource="https://uor.foundation/op/LeasePartitionOperation"/>
    <rdfs:label>partition_op</rdfs:label>
    <rdfs:comment>λ(S, k) = (L₁, …, Lₖ): partitions a shared context into k disjoint leases. Non-commutative, non-associative.</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/SitePartition"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/associative>
    <uor:op/operatorSignature>SharedContext × ℕ → ContextLease^k</uor:op/operatorSignature>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/compose_op">
    <rdf:type rdf:resource="https://uor.foundation/op/SessionCompositionOperation"/>
    <rdfs:label>compose_op</rdfs:label>
    <rdfs:comment>κ(S₁, S₂) = S₁ ∪ S₂: composes two sessions with disjoint leases into one. Commutative, associative (SR_8).</rdfs:comment>
    <uor:op/arity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</uor:op/arity>
    <uor:op/hasGeometricCharacter rdf:resource="https://uor.foundation/op/SessionMerge"/>
    <uor:op/commutative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/commutative>
    <uor:op/associative rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/associative>
    <uor:op/operatorSignature>Session × Session → Session</uor:op/operatorSignature>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/criticalIdentity">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>Critical Identity</rdfs:label>
    <rdfs:comment>The foundational theorem of the UOR kernel: neg(bnot(x)) = succ(x) for all x in R_n. This identity links the two involutions (neg and bnot) to the successor operation, making succ derivable from neg and bnot.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_criticalIdentity_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_criticalIdentity_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_criticalIdentity_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AD_1</rdfs:label>
    <rdfs:comment>Addressing bijection: addresses(glyph(d)) = d. Round-trip from datum through glyph and back is identity.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AD_2</rdfs:label>
    <rdfs:comment>Embedding coherence: glyph(ι(addresses(a))) = ι_addr(a). The addressing diagram commutes through embeddings.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A1</rdfs:label>
    <rdfs:comment>Additive associativity: add(x, add(y, z)) = add(add(x, y), z).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A2</rdfs:label>
    <rdfs:comment>Additive identity: add(x, 0) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A3</rdfs:label>
    <rdfs:comment>Additive inverse: add(x, neg(x)) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A4</rdfs:label>
    <rdfs:comment>Additive commutativity: add(x, y) = add(y, x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A5</rdfs:label>
    <rdfs:comment>Subtraction definition: sub(x, y) = add(x, neg(y)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_A6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_A6</rdfs:label>
    <rdfs:comment>Negation involution: neg(neg(x)) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_A6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_A6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_A6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_M1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_M1</rdfs:label>
    <rdfs:comment>Multiplicative associativity: mul(x, mul(y, z)) = mul(mul(x, y), z).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_M1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_M1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_M1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_M2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_M2</rdfs:label>
    <rdfs:comment>Multiplicative identity: mul(x, 1) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_M2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_M2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_M2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_M3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_M3</rdfs:label>
    <rdfs:comment>Multiplicative commutativity: mul(x, y) = mul(y, x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_M3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_M3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_M3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_M4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_M4</rdfs:label>
    <rdfs:comment>Distributivity: mul(x, add(y, z)) = add(mul(x, y), mul(x, z)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_M4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_M4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_M4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/R_M5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>R_M5</rdfs:label>
    <rdfs:comment>Annihilation: mul(x, 0) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_R_M5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_R_M5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_R_M5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DV_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DV_1</rdfs:label>
    <rdfs:comment>Division right-identity: div(a, 1) = a.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DV_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DV_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DV_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DV_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DV_2</rdfs:label>
    <rdfs:comment>Division left-absorbing: div(0, b) = 0 for b ≠ 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DV_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DV_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DV_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DV_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DV_3</rdfs:label>
    <rdfs:comment>Division-of-multiplication recovery: div(mul(a, b), b) = a for b ≠ 0 in the unit cone.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DV_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DV_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DV_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DV_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DV_4</rdfs:label>
    <rdfs:comment>Euclidean compatibility: a = add(mul(div(a, b), b), mod(a, b)) for b ≠ 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DV_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DV_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DV_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PW_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PW_1</rdfs:label>
    <rdfs:comment>Zero exponent identity: pow(a, 0) = 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PW_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PW_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PW_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PW_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PW_2</rdfs:label>
    <rdfs:comment>Unit exponent identity: pow(a, 1) = a.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PW_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PW_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PW_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PW_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PW_3</rdfs:label>
    <rdfs:comment>Additive exponent decomposition: pow(a, add(b, c)) = mul(pow(a, b), pow(a, c)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PW_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PW_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PW_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_1</rdfs:label>
    <rdfs:comment>XOR associativity: xor(x, xor(y, z)) = xor(xor(x, y), z).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_2</rdfs:label>
    <rdfs:comment>XOR identity: xor(x, 0) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_3</rdfs:label>
    <rdfs:comment>XOR self-inverse: xor(x, x) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_4</rdfs:label>
    <rdfs:comment>AND associativity: and(x, and(y, z)) = and(and(x, y), z).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_5</rdfs:label>
    <rdfs:comment>AND identity: and(x, 2^n - 1) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_6</rdfs:label>
    <rdfs:comment>AND annihilation: and(x, 0) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_7</rdfs:label>
    <rdfs:comment>OR associativity: or(x, or(y, z)) = or(or(x, y), z).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_8</rdfs:label>
    <rdfs:comment>OR identity: or(x, 0) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_9</rdfs:label>
    <rdfs:comment>Absorption: and(x, or(x, y)) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_10</rdfs:label>
    <rdfs:comment>AND distributes over OR: and(x, or(y, z)) = or(and(x, y), and(x, z)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_11">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_11</rdfs:label>
    <rdfs:comment>De Morgan 1: bnot(and(x, y)) = or(bnot(x), bnot(y)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_11_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_11_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_11_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_12">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_12</rdfs:label>
    <rdfs:comment>De Morgan 2: bnot(or(x, y)) = and(bnot(x), bnot(y)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_12_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_12_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_12_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/B_13">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>B_13</rdfs:label>
    <rdfs:comment>Bnot involution: bnot(bnot(x)) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_B_13_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_B_13_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_B_13_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_1</rdfs:label>
    <rdfs:comment>Neg via subtraction: neg(x) = sub(0, x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_2</rdfs:label>
    <rdfs:comment>Complement via XOR: bnot(x) = xor(x, 2^n - 1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_3</rdfs:label>
    <rdfs:comment>Succ via addition: succ(x) = add(x, 1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_4</rdfs:label>
    <rdfs:comment>Pred via subtraction: pred(x) = sub(x, 1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_5</rdfs:label>
    <rdfs:comment>Neg-bnot bridge: neg(x) = add(bnot(x), 1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_6</rdfs:label>
    <rdfs:comment>Complement predecessor: bnot(x) = pred(neg(x)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/X_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>X_7</rdfs:label>
    <rdfs:comment>XOR-add bridge: xor(x, y) = add(x, y) - 2 * and(x, y) (in Z before mod).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_X_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_X_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_X_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_1</rdfs:label>
    <rdfs:comment>Rotation order: succ^[2^n](x) = x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_3</rdfs:label>
    <rdfs:comment>Conjugation: neg(succ(neg(x))) = pred(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_4</rdfs:label>
    <rdfs:comment>Reverse composition: bnot(neg(x)) = pred(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_5</rdfs:label>
    <rdfs:comment>Group closure: D_[2^n] = [succ^k, neg ∘ succ^k : 0 ≤ k &lt; 2^n].</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/U_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>U_1</rdfs:label>
    <rdfs:comment>Unit group decomposition: R_n× ≅ Z/2 × Z/2^[n-2] for n ≥ 3.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_U_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_U_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_U_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/U_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>U_2</rdfs:label>
    <rdfs:comment>Unit group special cases: R_1× ≅ [1]; R_2× ≅ Z/2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_U_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_U_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_U_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/U_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>U_3</rdfs:label>
    <rdfs:comment>Multiplicative order: ord(u) = lcm(ord((-1)^a), ord(3^b)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_U_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_U_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_U_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/U_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>U_4</rdfs:label>
    <rdfs:comment>Resonance period: ord_g(2) divides φ(g).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_U_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_U_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_U_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/U_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>U_5</rdfs:label>
    <rdfs:comment>Step formula derivation: step_g = 2 * ((g - (2^n mod g)) mod g) + 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_U_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_U_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_U_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AG_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AG_1</rdfs:label>
    <rdfs:comment>Scaling not dihedral: μ_u ∉ D_[2^n] for u ≠ ±1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AG_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AG_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AG_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AG_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AG_2</rdfs:label>
    <rdfs:comment>Affine group: Aff(R_n) = R_n× ⋉ R_n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AG_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AG_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AG_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AG_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AG_3</rdfs:label>
    <rdfs:comment>Affine group order: |Aff(R_n)| = 2^[2n-1].</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AG_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AG_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AG_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AG_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AG_4</rdfs:label>
    <rdfs:comment>Subgroup inclusion: D_[2^n] ⊂ Aff(R_n) with u ∈ [±1].</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AG_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AG_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AG_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_1</rdfs:label>
    <rdfs:comment>Addition decomposition: add(x,y)_k = xor(x_k, xor(y_k, c_k(x,y))).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_2</rdfs:label>
    <rdfs:comment>Carry recurrence: c_[k+1](x,y) = or(and(x_k,y_k), and(xor(x_k,y_k), c_k)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_3</rdfs:label>
    <rdfs:comment>Carry commutativity: c(x, y) = c(y, x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_4</rdfs:label>
    <rdfs:comment>Zero carry: c(x, 0) = 0 at all positions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_5</rdfs:label>
    <rdfs:comment>Negation carry: c(x, neg(x))_k = 1 for k &gt; v_2(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CA_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CA_6</rdfs:label>
    <rdfs:comment>Carry-incompatibility link: d_Δ(x, y) &gt; 0 iff ∃ k : c_k(x,y) = 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CA_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CA_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CA_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/C_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>C_1</rdfs:label>
    <rdfs:comment>Constraint pin union: pins of a composite constraint equal the union of component pins.</rdfs:comment>
