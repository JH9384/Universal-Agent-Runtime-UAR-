  <owl:NamedIndividual rdf:about="https://uor.foundation/op/T_A3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>T_A3</rdfs:label>
    <rdfs:comment>Dihedral orbits determine irreducibility boundaries.</rdfs:comment>
