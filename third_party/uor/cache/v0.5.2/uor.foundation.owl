  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_P2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_P2</rdfs:label>
    <rdfs:comment>Total variation is subadditive under concatenation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OB_P2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OB_P2_rhs"/>
