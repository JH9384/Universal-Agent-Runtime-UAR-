  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CG_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CG_1</rdfs:label>
    <rdfs:comment>Entry guard must be satisfied to enter a stage.</rdfs:comment>
