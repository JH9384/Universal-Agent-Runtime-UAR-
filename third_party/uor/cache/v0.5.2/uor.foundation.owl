    <rdfs:comment></rdfs:comment>
    <uor:schema/variableName>a ∈ Addr(R_n), ι : R_n → R_{n&apos;}</uor:schema/variableName>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_R_A1_lhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_R_A1_lhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>add(x, add(y, z))</uor:schema/literalValue>
