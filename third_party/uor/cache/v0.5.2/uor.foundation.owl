  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_4</rdfs:label>
    <rdfs:comment>Disjoint effects commute.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FX_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FX_4_rhs"/>
