  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CF_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CF_2</rdfs:label>
    <rdfs:comment>Resolution cost is bounded below by curvature flux of optimal path.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CF_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CF_2_rhs"/>
