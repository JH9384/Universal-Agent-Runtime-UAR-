    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_8</rdfs:label>
    <rdfs:comment>Hurewicz isomorphism for first non-vanishing group: π_k(N(C)) ⊗ Z ≅ H_k(N(C); Z) for the smallest k with π_k ≠ 0, linking homotopy invariants to homology.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_8_rhs"/>
