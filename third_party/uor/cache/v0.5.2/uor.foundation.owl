    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_3</rdfs:label>
    <rdfs:comment>Zero entropy: fully resolved state has S = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_4</rdfs:label>
    <rdfs:comment>Landauer bound on total resolution cost.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_5</rdfs:label>
    <rdfs:comment>Critical inverse temperature for UOR site system.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_6</rdfs:label>
    <rdfs:comment>Constraint application removes entropy; convergence rate equals cooling rate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_7</rdfs:label>
    <rdfs:comment>CatastropheThreshold is the temperature of a partition phase transition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_8</rdfs:label>
    <rdfs:comment>Step formula as free-energy cost of a constraint boundary.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_9</rdfs:label>
    <rdfs:comment>Computational hardness maps to type incompleteness (high temperature).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TH_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TH_10</rdfs:label>
    <rdfs:comment>Type resolution is measurement; cost ≥ entropy removed.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TH_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TH_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TH_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AR_1</rdfs:label>
    <rdfs:comment>Adiabatic schedule: decreasing freeRank, cost-per-site ordering.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AR_2</rdfs:label>
    <rdfs:comment>Adiabatic cost is sum of constraint costs in optimal order.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AR_3</rdfs:label>
    <rdfs:comment>Adiabatic cost satisfies Landauer bound.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AR_4</rdfs:label>
    <rdfs:comment>Adiabatic efficiency η ≤ 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/AR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>AR_5</rdfs:label>
    <rdfs:comment>Greedy vs adiabatic cost difference: ≤ 5% for n ≤ 16.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_AR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_AR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_AR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PD_1</rdfs:label>
    <rdfs:comment>Phase space definition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PD_2</rdfs:label>
    <rdfs:comment>Phase boundaries occur where g divides 2^n − 1 or g is a power of 2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PD_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PD_3</rdfs:label>
    <rdfs:comment>Parity boundary divides R_n into equal halves.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PD_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PD_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PD_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PD_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PD_4</rdfs:label>
    <rdfs:comment>Resonance lines in the phase diagram.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PD_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PD_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PD_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PD_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PD_5</rdfs:label>
    <rdfs:comment>Phase count at level n is at most 2^n (typically O(n)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PD_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PD_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PD_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_1</rdfs:label>
    <rdfs:comment>Reversible pinning stores prior state in ancilla site.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_2</rdfs:label>
    <rdfs:comment>Reversible pinning has zero total entropy change.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_3</rdfs:label>
    <rdfs:comment>Deferred Landauer cost at ancilla erasure.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_4</rdfs:label>
    <rdfs:comment>Reversible total cost equals irreversible total cost (redistributed).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_5</rdfs:label>
    <rdfs:comment>Quantum UOR: superposed sites, cost proportional to winning path.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_1</rdfs:label>
    <rdfs:comment>Ring derivative: ∂_R f(x) = f(succ(x)) - f(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_2</rdfs:label>
    <rdfs:comment>Hamming derivative: ∂_H f(x) = f(bnot(x)) - f(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_3</rdfs:label>
    <rdfs:comment>Hamming derivative of identity: ∂_H id(x) = -(2x + 1) mod 2^n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_4</rdfs:label>
    <rdfs:comment>Commutator from derivatives: [neg, bnot](x) = ∂_R neg(x) - ∂_H neg(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_5</rdfs:label>
    <rdfs:comment>Carry dependence: the difference ∂_R f - ∂_H f decomposes into carry contributions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_6</rdfs:label>
    <rdfs:comment>Jacobian definition: J_k(x) = ∂_R f_k(x) where f_k = site_k.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_7</rdfs:label>
    <rdfs:comment>Top-site anomaly: J_{n-1}(x) may differ from lower sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_8</rdfs:label>
    <rdfs:comment>Rank-curvature identity: rank(J(x)) = d_H(x, succ(x)) - 1 for generic x.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_9</rdfs:label>
    <rdfs:comment>Total curvature from Jacobian: κ(x) = Σ_k J_k(x).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_10</rdfs:label>
    <rdfs:comment>Curvature-weighted ordering: optimal next constraint maximizes J_k over free sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/DC_11">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>DC_11</rdfs:label>
    <rdfs:comment>Curvature equipartition: Σ_{x} J_k(x) ≈ (2^n - 2)/n for each k.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_DC_11_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_DC_11_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_DC_11_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HA_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HA_1</rdfs:label>
    <rdfs:comment>Constraint nerve: N(C) is the simplicial complex on constraints.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HA_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HA_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HA_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HA_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HA_2</rdfs:label>
    <rdfs:comment>Stall iff non-trivial homology: resolution stalls ⟺ H_k(N(C)) ≠ 0 for some k &gt; 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HA_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HA_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HA_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HA_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HA_3</rdfs:label>
    <rdfs:comment>Betti-entropy theorem: S_residual ≥ Σ_k β_k × ln 2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HA_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HA_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HA_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_2</rdfs:label>
    <rdfs:comment>Euler-Poincaré formula for constraint nerve.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_3</rdfs:label>
    <rdfs:comment>Spectral Euler characteristic.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_6</rdfs:label>
    <rdfs:comment>Spectral gap bounds convergence rate from below.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_7a">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_7a</rdfs:label>
    <rdfs:comment>UOR index theorem (topological form): total curvature minus Euler characteristic equals residual entropy in bits.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_7a_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_7a_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_7a_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_7b">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_7b</rdfs:label>
    <rdfs:comment>UOR index theorem (entropy-topology duality).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_7b_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_7b_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_7b_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_7c">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_7c</rdfs:label>
    <rdfs:comment>UOR index theorem (spectral cost bound): resolution cost ≥ n - χ(N(C)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_7c_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_7c_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_7c_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/IT_7d">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>IT_7d</rdfs:label>
    <rdfs:comment>UOR index theorem (completeness criterion): resolution is complete iff χ(N(C)) = n and all Betti numbers vanish.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_IT_7d_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_IT_7d_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_IT_7d_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_1</rdfs:label>
    <rdfs:comment>Ring → Constraints map: negation transforms a residue constraint.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_2</rdfs:label>
    <rdfs:comment>Constraints → Sites map: composition maps to union of site pinnings.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_3</rdfs:label>
    <rdfs:comment>Sites → Partition map: a closed site state determines a unique 4-component partition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_4</rdfs:label>
    <rdfs:comment>Resolution pipeline: φ₄ = φ₃ ∘ φ₂ ∘ φ₁ is the composite resolution map.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_5</rdfs:label>
    <rdfs:comment>Operations → Observables map: negation preserves d_R, may change d_H.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/phi_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>phi_6</rdfs:label>
    <rdfs:comment>Observables → Refinement map: observables on a state yield a refinement suggestion.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_phi_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_phi_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_phi_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_1</rdfs:label>
    <rdfs:comment>ψ_1: Constraints → SimplicialComplex (nerve construction). Maps a set of constraints to its nerve simplicial complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_2</rdfs:label>
    <rdfs:comment>ψ_2: SimplicialComplex → ChainComplex (chain functor). Maps a simplicial complex to its chain complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_3</rdfs:label>
    <rdfs:comment>ψ_3: ChainComplex → HomologyGroups (homology functor). Computes homology groups from a chain complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_5</rdfs:label>
    <rdfs:comment>ψ_5: ChainComplex → CochainComplex (dualization functor). Dualizes a chain complex to obtain a cochain complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/psi_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>psi_6</rdfs:label>
    <rdfs:comment>ψ_6: CochainComplex → CohomologyGroups (cohomology functor). Computes cohomology groups from a cochain complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_psi_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_psi_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_psi_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D2n">
    <rdf:type rdf:resource="https://uor.foundation/op/DihedralGroup"/>
    <rdfs:label>D_{2^n}</rdfs:label>
    <rdfs:comment>The dihedral group of order 2^(n+1), generated by neg (ring reflection) and bnot (hypercube reflection). Every element of this group acts as an isometry on the type space 𝒯_n.</rdfs:comment>
    <uor:op/generatedBy rdf:resource="https://uor.foundation/op/neg"/>
    <uor:op/generatedBy rdf:resource="https://uor.foundation/op/bnot"/>
    <uor:op/presentation>⟨r, s | r^{2^n} = s² = e, srs = r⁻¹⟩</uor:op/presentation>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/surfaceSymmetry">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>Surface Symmetry</rdfs:label>
    <rdfs:comment>The Surface Symmetry Theorem: the composite P∘Π∘G is a well-typed morphism iff G and P share the same state:Frame F. When the shared-frame condition holds, the output lands in the type-equivalent neighbourhood of the source symbol.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_surfaceSymmetry_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_surfaceSymmetry_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_surfaceSymmetry_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_1</rdfs:label>
    <rdfs:comment>Completeness implies O(1) resolution: a CompleteType T satisfies ∀ x ∈ R_n, resolution(x, T) terminates in O(1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_2</rdfs:label>
    <rdfs:comment>Completeness is monotone: if T ⊆ T&apos; (T&apos; has more constraints), then completeness(T) implies completeness(T&apos;).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_3</rdfs:label>
    <rdfs:comment>Witness composition: concat(W₁, W₂) is a valid audit trail iff W₁.sitesClosed + W₂.sitesClosed = n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_4</rdfs:label>
    <rdfs:comment>The CompletenessResolver is the unique fixed point of the ψ-pipeline applied to a CompletenessCandidate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_5</rdfs:label>
    <rdfs:comment>CompletenessCertificate soundness: cert.verified = true implies χ(N(C)) = n and for all k: β_k = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_1</rdfs:label>
    <rdfs:comment>neg(bnot(x)) = succ(x) holds in Z/(2ⁿ)Z for all n ≥ 1. Universal form of the Critical Identity across all quantum levels.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_2</rdfs:label>
    <rdfs:comment>The dihedral group D_{2ⁿ} generated by neg and bnot has order 2ⁿ⁺¹ for all n ≥ 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_3</rdfs:label>
    <rdfs:comment>The reduction distribution P(j) = 2^{-j} is the Boltzmann distribution at β* = ln 2 for all n ≥ 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_4</rdfs:label>
    <rdfs:comment>The site budget of a PrimitiveType at quantum level n is exactly n (one site per bit).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_5</rdfs:label>
    <rdfs:comment>Resolution complexity for a CompleteType is O(1) for all n ≥ 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_6</rdfs:label>
    <rdfs:comment>Content addressing is a bijection for all n ≥ 1 (AD_1/AD_2 universality).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_7</rdfs:label>
    <rdfs:comment>The ψ-pipeline produces a valid ChainComplex for any ConstrainedType at any quantum level n ≥ 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_1</rdfs:label>
    <rdfs:comment>Binding monotonicity: freeRank(B_{i+1}) ≤ freeRank(B_i) for all i in a Session.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_2</rdfs:label>
    <rdfs:comment>Binding soundness: a Binding b is sound iff b.datum resolves under b.constraint in O(1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_3</rdfs:label>
    <rdfs:comment>Session convergence: a Session S converges iff there exists i such that freeRank(B_i) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_4</rdfs:label>
    <rdfs:comment>Context reset isolation: bindings in C_fresh are independent of bindings in C_prior after a SessionBoundary.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_5</rdfs:label>
    <rdfs:comment>Contradiction detection: ContradictionBoundary fires iff there exist bindings b, b&apos; with the same address, different datum, under the same constraint.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_1</rdfs:label>
    <rdfs:comment>Nerve realisability: for any target (χ*, β₀* = 1, β_k* = 0 for k ≥ 1) with χ* ≤ n, there exists a ConstrainedType T over R_n whose constraint nerve realises the target.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_2</rdfs:label>
    <rdfs:comment>Minimal basis bound: for the IT_7d target (χ* = n, all β* = 0), the MinimalConstraintBasis has size exactly n (one constraint per site position). No redundant constraints exist in the minimal basis.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_3</rdfs:label>
    <rdfs:comment>Synthesis monotonicity: adding a constraint to a synthesis candidate never decreases the Euler characteristic of the resulting nerve (χ is monotone non-decreasing under constraint addition).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_4</rdfs:label>
    <rdfs:comment>Synthesis convergence: the TypeSynthesisResolver terminates for any realisable target in at most n constraint additions (for n-site types).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_5</rdfs:label>
    <rdfs:comment>Synthesis–certification duality: a SynthesizedType T achieves the IT_7d target if and only if the CompletenessResolver certifies T as a CompleteType. The forward ψ-pipeline and the inverse TypeSynthesisResolver are dual computations.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_6</rdfs:label>
    <rdfs:comment>Jacobian-guided synthesis efficiency: using the Jacobian (DC_10) to select the next constraint reduces the expected number of synthesis steps from O(n²) (uninformed) to O(n log n) (Jacobian-guided).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_7</rdfs:label>
    <rdfs:comment>Unreachable signatures: a Betti profile with β₀ = 0 is unreachable by any non-empty ConstrainedType — the nerve of a non-empty constraint set is always connected (β₀ ≥ 1).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_1</rdfs:label>
    <rdfs:comment>Lift unobstructedness criterion: WittLift T&apos; is a CompleteType iff the spectral sequence E_r^{p,q} collapses at E_2 (d_2 = 0 and all higher differentials zero).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_2</rdfs:label>
    <rdfs:comment>Obstruction localisation: a non-trivial LiftObstruction is localised to a specific site at bit position n+1. The obstruction class lives in H²(N(C(T))) and is killed by adding one constraint involving the new site.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_3</rdfs:label>
    <rdfs:comment>Monotone lifting for trivially obstructed types: if T is a CompleteType at Q_n and its constraint set is closed under the Q_{n+1} extension map, then T&apos; is a CompleteType at Q_{n+1} with basisSize(T&apos;) = basisSize(T) + 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_4</rdfs:label>
    <rdfs:comment>Spectral sequence convergence bound: for constraint configurations of homological depth d (H_k(N(C(T))) = 0 for k &gt; d), the spectral sequence converges by page E_{d+2}.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_5</rdfs:label>
    <rdfs:comment>Universal identity preservation: every op:universallyValid identity holds in ℤ/(2^{n+1})ℤ with the lifted constraint set. The lift does not invalidate any certified universal identity.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WLS_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WLS_6</rdfs:label>
    <rdfs:comment>ψ-pipeline universality for quantum lifts: the ψ-pipeline produces a valid ChainComplex for any WittLift T&apos; — the chain complex of T&apos; restricts to the chain complex of T on the base nerve, and the extension is well-formed by construction.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WLS_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WLS_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WLS_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_1</rdfs:label>
    <rdfs:comment>Holonomy group containment: HolonomyGroup(T) ≤ D_{2^n} for all ConstrainedTypes T over R_n. The holonomy group is always a subgroup of the full dihedral group.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_2</rdfs:label>
    <rdfs:comment>Additive flatness (extends OB_H1): if all constraints in T are additive (ResidueConstraint or DepthConstraint type), then HolonomyGroup(T) = {id} — T is a FlatType.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_3</rdfs:label>
    <rdfs:comment>Dihedral generation: if T contains both a neg-related and a bnot-related constraint in a common closed path, then HolonomyGroup(T) = D_{2^n} — T has full dihedral holonomy.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_4</rdfs:label>
    <rdfs:comment>Holonomy-Betti implication: HolonomyGroup(T) ≠ {id} ⟹ β₁(N(C(T))) ≥ 1. Non-trivial monodromy requires a topological loop. (Converse is false: β₁ ≥ 1 does not imply non-trivial holonomy.)</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_5</rdfs:label>
    <rdfs:comment>CompleteType holonomy: a CompleteType (IT_7d: χ = n, all β = 0) has trivial holonomy. IT_7d implies FlatType because IT_7d requires β₁ = 0, which by MN_4 implies trivial monodromy.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_6</rdfs:label>
    <rdfs:comment>Monodromy composition: if p₁ and p₂ are closed constraint paths, then monodromy(p₁ · p₂) = monodromy(p₁) · monodromy(p₂) in D_{2^n} (group homomorphism from loops to dihedral elements).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_7</rdfs:label>
    <rdfs:comment>TwistedType obstruction class: the monodromy of a TwistedType contributes a non-zero class to H²(N(C(T&apos;)); ℤ/2ℤ) where T&apos; is any WittLift of T. TwistedTypes always have non-trivial lift obstructions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_1</rdfs:label>
    <rdfs:comment>Product type site additivity: siteBudget(A × B) = siteBudget(A) + siteBudget(B).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_2</rdfs:label>
    <rdfs:comment>Product type partition product: partition(A × B) = partition(A) ⊗ partition(B). v0.2.2 T1.3: grounds cert:PartitionCertificate — every PartitionCertificate attests the PartitionComponent classification (Irreducible / Reducible / Units / Exterior) derived from this partition-map identity.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_3</rdfs:label>
    <rdfs:comment>Product type Euler additivity: χ(N(C(A × B))) = χ(N(C(A))) + χ(N(C(B))).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_4</rdfs:label>
    <rdfs:comment>Product type entropy additivity: S(A × B) = S(A) + S(B).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_1</rdfs:label>
    <rdfs:comment>Sum type site budget: siteBudget(A + B) = max(siteBudget(A), siteBudget(B)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_2</rdfs:label>
    <rdfs:comment>Sum type entropy: S(A + B) = ln 2 + max(S(A), S(B)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_1</rdfs:label>
    <rdfs:comment>Context temperature: T_ctx(C) = freeRank(C) × ln 2 / n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_2</rdfs:label>
    <rdfs:comment>Grounding degree: σ(C) = (n − freeRank(C)) / n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_3</rdfs:label>
    <rdfs:comment>Grounding monotonicity: σ(B_{i+1}) ≥ σ(B_i) for all i in a Session.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_4</rdfs:label>
    <rdfs:comment>Ground state equivalence: σ(C) = 1 ↔ freeRank(C) = 0 ↔ S(C) = 0 ↔ T_ctx(C) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_5</rdfs:label>
    <rdfs:comment>O(1) resolution guarantee: freeRank(C) = 0 ∧ q.address ∈ bindings(C) → stepCount(q, C) = 0.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_6</rdfs:label>
    <rdfs:comment>Pre-reduction of effective budget: effectiveBudget(q, C) = max(0, siteBudget(q.type) − |pinnedSites(C) ∩ q.siteSet|).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GS_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GS_7</rdfs:label>
    <rdfs:comment>Thermodynamic cooling cost: Cost_saturation(C) = n × k_B T × ln 2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GS_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GS_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GS_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MS_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MS_1</rdfs:label>
    <rdfs:comment>Connectivity lower bound: β₀(N(C)) ≥ 1 for all non-empty C.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MS_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MS_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MS_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MS_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MS_2</rdfs:label>
    <rdfs:comment>Euler capacity ceiling: χ(N(C)) ≤ n for all C at quantum level n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MS_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MS_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MS_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MS_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MS_3</rdfs:label>
    <rdfs:comment>Betti monotonicity under addition: χ(N(C + c)) ≥ χ(N(C)) for any constraint c added to C.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MS_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MS_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MS_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MS_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MS_4</rdfs:label>
    <rdfs:comment>Level-relative achievability: a signature achievable at quantum level n remains achievable at level n+1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MS_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MS_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MS_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MS_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MS_5</rdfs:label>
    <rdfs:comment>Empirical completeness convergence: verified SynthesisSignature individuals converge to the exact morphospace boundary.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MS_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MS_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MS_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_1</rdfs:label>
    <rdfs:comment>Geodesic condition: a ComputationTrace is a geodesic iff its steps are AR_1-ordered and each step selects the constraint maximising J_k over free sites (DC_10).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_2</rdfs:label>
    <rdfs:comment>Geodesic entropy bound: ΔS_step(i) = ln 2 for every step i of a geodesic trace.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_3</rdfs:label>
    <rdfs:comment>Total geodesic cost: Cost_geodesic(T) = freeRank_initial × k_B T ln 2 = TH_4.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_4</rdfs:label>
    <rdfs:comment>Geodesic uniqueness up to step-order equivalence: all geodesics for the same ConstrainedType share stepCount and constraint set.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_5</rdfs:label>
    <rdfs:comment>Subgeodesic detectability: a trace is sub-geodesic iff ∃ step i where J_k(step_i) &lt; max_{free sites} J_k(state_i).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QM_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QM_1</rdfs:label>
    <rdfs:comment>Von Neumann–Landauer bridge: S_vonNeumann(ψ) = Cost_Landauer(collapse(ψ)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QM_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QM_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QM_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QM_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QM_2</rdfs:label>
    <rdfs:comment>Measurement as site topology change: projective collapse on a SuperposedSiteState is topologically equivalent to applying a ResidueConstraint that pins the collapsed site.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QM_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QM_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QM_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QM_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QM_3</rdfs:label>
    <rdfs:comment>Superposition entropy bound: 0 ≤ S_vN(ψ) ≤ ln 2 for any single-site SuperposedSiteState.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QM_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QM_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QM_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QM_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QM_4</rdfs:label>
    <rdfs:comment>Collapse idempotence: collapse(collapse(ψ)) = collapse(ψ). Measurement on an already-collapsed state is a no-op.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QM_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QM_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QM_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QM_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QM_5</rdfs:label>
    <rdfs:comment>Amplitude normalization (Born rule): the sum of squared amplitudes equals 1 for any well-formed SuperposedSiteState.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QM_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QM_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QM_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/RC_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>RC_6</rdfs:label>
    <rdfs:comment>Amplitude renormalization: a SuperposedSiteState can always be normalized to satisfy QM_5.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_RC_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_RC_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_RC_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/SuperpositionDomain"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_8</rdfs:label>
    <rdfs:comment>Partition exhaustiveness: the four component cardinalities sum to the ring size.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Enumerative"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FPM_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FPM_9</rdfs:label>
    <rdfs:comment>Exterior membership criterion: x is exterior iff x is not in the carrier of T.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_FPM_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_FPM_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_FPM_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MN_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MN_8</rdfs:label>
    <rdfs:comment>Holonomy classification covering: every ConstrainedType with a computed holonomy group is either flat or twisted, not both.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MN_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MN_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MN_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/QL_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>QL_8</rdfs:label>
    <rdfs:comment>Witt level chain inverse: wittLevelPredecessor is the left inverse of nextWittLevel.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_QL_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_QL_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_QL_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_7</rdfs:label>
    <rdfs:comment>Dihedral composition rule: (rᵃ sᵖ)(rᵇ sᵠ) = r^(a + (-1)ᵖ b mod 2ⁿ) s^(p xor q).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Geometric"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SP_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SP_1</rdfs:label>
    <rdfs:comment>Classical embedding: superposition resolution of a classical (non-superposed) datum reduces to classical resolution.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SP_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SP_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SP_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/SuperpositionDomain"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SP_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SP_2</rdfs:label>
    <rdfs:comment>Collapse–resolve commutativity: collapsing then resolving classically equals resolving in superposition then collapsing.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SP_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SP_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SP_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SP_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SP_3</rdfs:label>
    <rdfs:comment>Amplitude preservation: the SuperpositionResolver preserves the normalized amplitude vector during ψ-pipeline traversal.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SP_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SP_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SP_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/SuperpositionDomain"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/SP_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>SP_4</rdfs:label>
    <rdfs:comment>Born rule outcome probability: the probability of collapsing to site k equals the squared amplitude of that site.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_SP_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_SP_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_SP_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_2a">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_2a</rdfs:label>
    <rdfs:comment>Product type partition tensor: the partition of a product type is the tensor product of the component partitions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_2a_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_2a_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_2a_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PT_2b">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PT_2b</rdfs:label>
    <rdfs:comment>Sum type partition coproduct: the partition of a sum type is the coproduct of the variant partitions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PT_2b_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PT_2b_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_PT_2b_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GD_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GD_6</rdfs:label>
    <rdfs:comment>Geodesic predicate decomposition: a trace is geodesic iff it is both AR_1-ordered and DC_10-selected.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GD_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GD_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GD_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_1</rdfs:label>
    <rdfs:comment>LiftChain(Q_j, Q_k) is valid CompleteType tower iff every chainStep WittLift has trivial or resolved LiftObstruction.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_2</rdfs:label>
    <rdfs:comment>Obstruction count bound: the number of non-trivial LiftObstructions in a chain is at most the chain length.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_3</rdfs:label>
    <rdfs:comment>Resolved basis size formula: the basis size at Q_k equals basisSize(Q_j) + chainLength + obstructionResolutionCost.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_4</rdfs:label>
    <rdfs:comment>Flat tower characterization: isFlat(chain) iff obstructionCount = 0 iff HolonomyGroup trivial at every step.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_5</rdfs:label>
    <rdfs:comment>LiftChainCertificate existence: a CompleteType at Q_k satisfies IT_7d with a witness chain.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_6</rdfs:label>
    <rdfs:comment>Single-step reduction: QT_3 with chainLength=1 and cost=0 reduces to QLS_3.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_7</rdfs:label>
    <rdfs:comment>Flat chain basis size: for flat chains, resolvedBasisSize(Q_k) = basisSize(Q_j) + (k - j).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_PINS">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_PINS</rdfs:label>
    <rdfs:comment>Carry-constraint site-pinning map: pinsSites(CarryConstraint(p)) equals the set of bit positions where p has a 1 plus the first-zero stopping position.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_PINS_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_PINS_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_PINS_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CC_COST_SITE">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CC_COST_SITE</rdfs:label>
    <rdfs:comment>Carry-constraint cost-to-site count: the number of sites pinned by a CarryConstraint equals popcount plus one for the stopping position.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CC_COST_SITE_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CC_COST_SITE_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CC_COST_SITE_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Enumerative"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/jsat_RR">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>jsat_RR</rdfs:label>
    <rdfs:comment>CRT joint satisfiability: two ResidueConstraints are jointly satisfiable iff the gcd of their moduli divides the difference of their residues.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_jsat_RR_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_jsat_RR_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_jsat_RR_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/jsat_CR">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>jsat_CR</rdfs:label>
    <rdfs:comment>Carry-residue joint satisfiability: a CarryConstraint and ResidueConstraint are jointly satisfiable iff the carry-pinned sites are compatible with the residue class.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_jsat_CR_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_jsat_CR_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_jsat_CR_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/jsat_CC">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>jsat_CC</rdfs:label>
    <rdfs:comment>Carry-carry joint satisfiability: two CarryConstraints are jointly satisfiable iff their bit-patterns have no conflicting positions.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_jsat_CC_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_jsat_CC_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_jsat_CC_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Enumerative"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_8</rdfs:label>
    <rdfs:comment>Dihedral inverse formula: the inverse of r^a s^p in D_(2^n) is r^(-(−1)^p a mod 2^n) s^p.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/D_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>D_9</rdfs:label>
    <rdfs:comment>Dihedral reflection order: every reflection element r^k s^1 in D_(2^n) has order 2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_D_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_D_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_D_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/EXP_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>EXP_1</rdfs:label>
    <rdfs:comment>Monotone carrier characterization: a ConstrainedType has an upward-closed carrier iff every ResidueConstraint has residue = modulus - 1 and no CarryConstraint or DepthConstraint appears.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_EXP_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_EXP_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_EXP_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/EXP_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>EXP_2</rdfs:label>
    <rdfs:comment>Monotone constraint count: the number of expressible monotone ConstrainedTypes at quantum level Q_n is 2^n, corresponding to the principal filter count.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_EXP_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_EXP_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_EXP_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Enumerative"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/EXP_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>EXP_3</rdfs:label>
    <rdfs:comment>SumType carrier semantics: the carrier of a SumType is the coproduct (disjoint union) of component carriers, not the set-theoretic union.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_EXP_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_EXP_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_EXP_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_3</rdfs:label>
    <rdfs:comment>SumType Euler characteristic additivity: for a SumType with topologically disjoint component nerves, the Euler characteristic is additive.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_4</rdfs:label>
    <rdfs:comment>SumType Betti number additivity: for disjoint component nerves, all Betti numbers are additive.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_5</rdfs:label>
    <rdfs:comment>SumType completeness transfer: a SumType A+B is CompleteType iff both A and B are CompleteType and they have equal quantum levels.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_6</rdfs:label>
    <rdfs:comment>SumType tag site unique existence: every PartitionCoproduct A + B has exactly one tag site, logically distinct from every data site of A and B, carrying the ln 2 entropy quantum of ST_2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_7</rdfs:label>
    <rdfs:comment>SumType variant tagging: the constraints of a PartitionCoproduct decompose into the operands&apos; constraints plus one tag-pinning constraint per variant (tag = 0 for the left variant, tag = 1 for the right).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_8</rdfs:label>
    <rdfs:comment>SumType variant nerve disjointness bridge: a PartitionCoproduct constructed via ST_6 + ST_7 + the foundation layout convention produces topologically disjoint component nerves. Bridges the existing conditional ST_3 and ST_4 to PartitionCoproduct constructions concretely.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_9</rdfs:label>
    <rdfs:comment>SumType Euler corollary for PartitionCoproduct constructions: combining ST_8&apos;s disjointness guarantee with the universal ST_3 yields Euler additivity for any A + B assembled via the PartitionCoproduct construction.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/ST_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>ST_10</rdfs:label>
    <rdfs:comment>SumType Betti corollary for PartitionCoproduct constructions: combining ST_8&apos;s disjointness guarantee with the universal ST_4 yields Betti additivity at every dimension for any A + B assembled via the PartitionCoproduct construction.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_ST_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_ST_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_ST_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_1</rdfs:label>
    <rdfs:comment>Cartesian partition product site additivity: siteBudget(A ⊠ B) = siteBudget(A) + siteBudget(B). UOR sites are bit widths; |A ⊠ B| = 2^{n_A} · 2^{n_B} = 2^{n_A + n_B}, so sites add even though cardinalities multiply.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_2a">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_2a</rdfs:label>
    <rdfs:comment>Cartesian partition product partition map: Π(A ⊠ B) = CartesianPartitionProduct(Π(A), Π(B)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_2a_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_2a_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_2a_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_3</rdfs:label>
    <rdfs:comment>Cartesian partition product Euler multiplicativity: χ(N(C(A ⊠ B))) = χ(N(C(A))) · χ(N(C(B))). Distinguishes CartesianPartitionProduct (multiplicative χ, Künneth) from PartitionProduct (additive χ, site-disjoint union).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_4</rdfs:label>
    <rdfs:comment>Cartesian partition product Künneth formula: Betti numbers compose via the Künneth convolution — β_k(A ⊠ B) = Σ_{i+j=k} β_i(A) · β_j(B). Routed through primitive_cartesian_nerve_betti when a CartesianProductShape marker is declared on the combined shape.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_5</rdfs:label>
    <rdfs:comment>Cartesian partition product entropy additivity: S(A ⊠ B) = S(A) + S(B). Matches PT_4&apos;s additive Shannon convention for independent subsystems and is consistent pointwise with IT_7a/b on the combined system (no cross-factor bilinearity required).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Thermodynamic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CPT_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CPT_6</rdfs:label>
    <rdfs:comment>Cartesian partition product distributes over PartitionCoproduct: A ⊠ (B + C) ≡ (A ⊠ B) + (A ⊠ C) with equality at the siteBudget, SITE_COUNT, Euler, and entropy levels simultaneously. Does NOT extend to PartitionProduct — distributing ⊠ over × fails at the site-budget level because it duplicates the outer factor.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CPT_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CPT_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CPT_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_8</rdfs:label>
    <rdfs:comment>Betti-1 minimum constraint count: the minimum number of constraints needed to achieve first Betti number beta_1 = k in the constraint nerve is 2k + 1.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_9</rdfs:label>
    <rdfs:comment>TypeSynthesisResolver termination: the resolver terminates in at most 2^n steps for any target signature at quantum level Q_n, returning either a ConstrainedType or a ForbiddenSignature certificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/TS_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>TS_10</rdfs:label>
    <rdfs:comment>ForbiddenSignature membership criterion: a topological signature is a ForbiddenSignature iff no ConstrainedType with at most n constraints realises it at quantum level Q_n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_TS_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_TS_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_TS_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_8</rdfs:label>
    <rdfs:comment>ObstructionChain length bound: the length of the ObstructionChain from Q_j to Q_k is at most (k-j) times C(basisSize(Q_j), 3).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WT_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WT_9</rdfs:label>
    <rdfs:comment>TowerCompletenessResolver termination: the resolver terminates for any finite LiftChain within the QT_8 bound, producing a CompleteType certificate or a bounded ObstructionChain.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WT_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WT_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WT_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
