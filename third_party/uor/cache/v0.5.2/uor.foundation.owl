  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OB_M5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OB_M5</rdfs:label>
    <rdfs:comment>Bitwise complement preserves Hamming metric.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OB_M5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OB_M5_rhs"/>
