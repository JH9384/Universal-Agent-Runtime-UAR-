    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MO_2</rdfs:label>
    <rdfs:comment>Associativity: (A⊗B)⊗C ≅ A⊗(B⊗C).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MO_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MO_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MO_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MO_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MO_3</rdfs:label>
    <rdfs:comment>Certificate composition: cert(A⊗B) contains cert(A) and cert(B).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MO_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MO_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MO_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MO_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MO_4</rdfs:label>
    <rdfs:comment>σ(A⊗B) ≥ max(σ(A), σ(B)): sequential composition does not lose saturation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MO_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MO_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MO_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MO_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MO_5</rdfs:label>
    <rdfs:comment>r(A⊗B) ≤ min(r(A), r(B)): residual can only shrink under sequential composition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MO_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MO_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MO_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OP_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OP_1</rdfs:label>
    <rdfs:comment>Site additivity: siteCount(F(G)) = F.sites + Σ_i G_i.sites.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OP_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OP_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OP_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OP_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OP_2</rdfs:label>
    <rdfs:comment>Grounding distributivity: grounding(F(G(x))) = F.ground(G.ground(x)).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OP_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OP_2_rhs"/>
