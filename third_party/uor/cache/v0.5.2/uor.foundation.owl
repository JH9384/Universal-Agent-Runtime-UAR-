    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CF_3</rdfs:label>
    <rdfs:comment>Successor curvature flux: trailing_ones(x) for most x, n−1 at maximum.</rdfs:comment>
