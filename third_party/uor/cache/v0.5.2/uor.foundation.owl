  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PR_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PR_3</rdfs:label>
