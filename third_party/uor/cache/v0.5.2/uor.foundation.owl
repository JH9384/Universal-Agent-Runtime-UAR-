    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_6</rdfs:label>
    <rdfs:comment>Certificate issuance: a MeasurementEvent verifying the von Neumann–Landauer bridge at β* = ln 2 admits a MeasurementCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CIC_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_7</rdfs:label>
    <rdfs:comment>Certificate issuance: a MeasurementEvent verifying P(outcome k) = |α_k|² admits a BornRuleVerification certificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_CIC_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/QuantumThermodynamic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GC_1</rdfs:label>
    <rdfs:comment>Certificate issuance: shared-frame grounding that lands in the type-equivalent neighbourhood admits a GroundingCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_8</rdfs:label>
    <rdfs:comment>Session composition validity: compose(S_A, S_B) is valid at Q_k iff all pinned-site intersections agree at every tower level Q_0 through Q_k.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/ParametricLower"/>
    <uor:op/validKMin rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">0</uor:op/validKMin>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_9</rdfs:label>
    <rdfs:comment>ContextLease disjointness: two distinct leases on the same SharedContext have non-overlapping site sets.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/GR_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>GR_10</rdfs:label>
    <rdfs:comment>ExecutionPolicy confluence: different execution policies on the same pending query set produce the same final resolved state (Church-Rosser for session resolution).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_GR_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_GR_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_GR_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_1</rdfs:label>
    <rdfs:comment>Lease partition conserves total budget: the sum of freeRank over all leases equals the SharedContext freeRank.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_2</rdfs:label>
    <rdfs:comment>Per-lease binding monotonicity: within a leased sub-domain, freeRank decreases monotonically (SR_1 restricted to lease).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_3</rdfs:label>
    <rdfs:comment>General composition freeRank via inclusion-exclusion.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_4</rdfs:label>
    <rdfs:comment>Disjoint-lease composition is additive: the intersection term vanishes when leases are site-disjoint (SR_9).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_5</rdfs:label>
    <rdfs:comment>Policy-invariant final binding set: different execution policies produce identical SiteBinding records.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_6</rdfs:label>
    <rdfs:comment>Full lease coverage implies composed saturation: k sessions on disjoint covering leases, each locally converged, produce a GroundedContext via composition.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_7</rdfs:label>
    <rdfs:comment>Distributed O(1) resolution: a query against a composed GroundedContext resolves in zero steps.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/MC_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>MC_8</rdfs:label>
    <rdfs:comment>Parallelism bound: per-session resolution work is bounded by lease size, not by total site count n.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_MC_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_MC_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_MC_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_1</rdfs:label>
    <rdfs:comment>Witt coordinate identification: the bit coordinates (x_0, …, x_[n−1]) of x ∈ Z/(2ⁿ)Z are exactly its Witt coordinates under the canonical isomorphism W_n(F_2) ≅ Z/(2ⁿ)Z.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_2</rdfs:label>
    <rdfs:comment>Witt sum correction equals carry: the k-th Witt addition polynomial correction term S_k − x_k − y_k (mod 2) is exactly the carry c_k(x,y).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_3</rdfs:label>
    <rdfs:comment>Carry recurrence is the Witt polynomial recurrence: CA_2 implements the ghost equation for S_[k+1] at p=2.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_4</rdfs:label>
    <rdfs:comment>The δ-correction at level k equals the single-level carry c_[k+1](x,y). Each application of δ divides by 2, consuming one unit of 2-adic valuation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_5</rdfs:label>
    <rdfs:comment>LiftObstruction is equivalent to δ-nonvanishing: a nontrivial LiftObstruction at Q_[k+1] means δ_k ≠ 0 for some element pair.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_6</rdfs:label>
    <rdfs:comment>Metric discrepancy equals Witt defect: d_Δ(x,y) &gt; 0 iff the ghost map correction (carry) is nonzero.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Analytical"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_7</rdfs:label>
    <rdfs:comment>D_1 is the Witt truncation order relation: succ^[2ⁿ](x) = x is the group relation r^[2ⁿ] = 1 in the Witt-Burnside ring of D_[2∞].</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_7_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_7_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_8">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_8</rdfs:label>
    <rdfs:comment>D_3 is the Witt-Burnside conjugation relation: neg(succ(neg(x))) = pred(x) is srs = r⁻¹ in the pro-dihedral group.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_8_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_8_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_8_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_9">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_9</rdfs:label>
    <rdfs:comment>D_4 is a Witt-Burnside reflection composition: bnot(neg(x)) = pred(x) is the product of two reflections yielding inverse rotation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_9_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_9_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_9_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_10">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_10</rdfs:label>
    <rdfs:comment>The δ-ring Frobenius lift on W_n(F_2) is the identity map because F_2 is a perfect field of characteristic 2 (a² = a for a ∈ F_2).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_10_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_10_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_10_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_11">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_11</rdfs:label>
    <rdfs:comment>The Verschiebung on W_n(F_2) is multiplication by 2: V(x) = 2x = add(x,x). This is a coordinate shift with zero Witt defect.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_11_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_11_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_11_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/WC_12">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>WC_12</rdfs:label>
    <rdfs:comment>The δ-operator on W_n(F_2) is the squaring defect divided by 2: δ(x) = (x − mul(x,x)) / 2. Expressible entirely in existing op/ primitives (sub, mul, arithmetic right shift).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_WC_12_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_WC_12_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_WC_12_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OA_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OA_1</rdfs:label>
    <rdfs:comment>Ostrowski product formula at p=2: |2|_2 · |2|_∞ = 1. The 2-adic and Archimedean absolute values of 2 are multiplicative inverses.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OA_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OA_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OA_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OA_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OA_2</rdfs:label>
    <rdfs:comment>Crossing cost equals ln 2: the Archimedean image of one unit of 2-adic valuation, under the product formula, is ln 2 nats.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OA_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OA_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OA_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OA_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OA_3</rdfs:label>
    <rdfs:comment>QM_1 grounding: the Landauer cost β* = ln 2 is the crossing cost from OA_2, derived from the prime p=2 that structures the Witt tower.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OA_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OA_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OA_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OA_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OA_4</rdfs:label>
    <rdfs:comment>Born rule bridge (conditional on amplitude rationality): P(outcome k) = |α_k|_∞², where |·|_∞ is the Archimedean image of the 2-adic amplitude via the product formula.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OA_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OA_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OA_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/OA_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>OA_5</rdfs:label>
    <rdfs:comment>Entropy per delta-level equals the crossing cost: each application of the delta-operator (division by 2) costs ln 2 nats in the Archimedean completion, which is the per-bit Landauer cost. v0.2.2 Phase C.4: grounds MultiplicationCertificate.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_OA_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_OA_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_OA_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/ArithmeticValuation"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_1</rdfs:label>
    <rdfs:comment>KanComplex(N(C)) — the constraint nerve satisfies the Kan extension condition for all horns of dimension ≤ d where d is the maximum simplex dimension of N(C).</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_1_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_1_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_2</rdfs:label>
    <rdfs:comment>Path components of nerve recover β₀: π₀(N(C)) ≅ Z^{β₀} counts the connected components of the constraint configuration.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_2_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_2_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_3">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_3</rdfs:label>
    <rdfs:comment>MN_6 monodromy is abelianisation of full π₁: the fundamental group π₁(N(C)) surjects onto the HolonomyGroup D_{2^n} via abelianisation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_3_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_3_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_3_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_4">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_4</rdfs:label>
    <rdfs:comment>Higher homotopy groups vanish above nerve dimension: π_k(N(C)) = 0 for all k &gt; dim(N(C)), because the nerve is a finite CW-complex.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_4_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_4_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_4_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_5">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_5</rdfs:label>
    <rdfs:comment>1-truncation determines flat/twisted classification: τ_{≤1}(N(C)) captures the holonomy action that distinguishes FlatType from TwistedType.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_5_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_5_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_5_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Topological"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_6">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_6</rdfs:label>
    <rdfs:comment>Trivial k-invariants beyond depth d imply spectral collapse: if κ_k is trivial for all k &gt; d then the spectral sequence collapses at E_{d+2}.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_6_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_6_rhs"/>
    <uor:op/forAll rdf:resource="https://uor.foundation/schema/term_HT_6_forAll"/>
    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/IndexTheoretic"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/HT_7">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>HT_7</rdfs:label>
    <rdfs:comment>Non-trivial Whitehead product implies lift obstruction: [α, β] ≠ 0 in π_{p+q−1} implies a non-trivial LiftObstruction that Betti numbers alone cannot detect.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_HT_7_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_HT_7_rhs"/>
