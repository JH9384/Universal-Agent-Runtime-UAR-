  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/FX_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>FX_1</rdfs:label>
    <rdfs:comment>Pinning decrements free count by exactly 1.</rdfs:comment>
