    <rdfs:label>term_FPM_6_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>2^{n−k−1} for 0 &lt; k &lt; n; 1 for k = n</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_FPM_6_forAll">
