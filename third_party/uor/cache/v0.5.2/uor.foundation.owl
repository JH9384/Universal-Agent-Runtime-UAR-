    <uor:proof/impossibilityReason>χ &gt; n violates MS_2: Euler characteristic bounded by quantum level</uor:proof/impossibilityReason>
    <uor:proof/impossibilityDomain rdf:resource="https://uor.foundation/op/Algebraic"/>
    <uor:proof/verified rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:proof/verified>
    <uor:proof/strategy rdf:resource="https://uor.foundation/proof/Contradiction"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/proof/mr_completeness_target">
