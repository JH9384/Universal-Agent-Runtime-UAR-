  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/PR_1">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>PR_1</rdfs:label>
    <rdfs:comment>Every predicate is total: evaluation terminates for all inputs.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_PR_1_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_PR_1_rhs"/>
