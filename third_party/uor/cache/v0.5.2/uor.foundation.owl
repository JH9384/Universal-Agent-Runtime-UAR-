    <uor:op/verificationDomain rdf:resource="https://uor.foundation/op/Pipeline"/>
    <uor:op/universallyValid rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</uor:op/universallyValid>
    <uor:op/validityKind rdf:resource="https://uor.foundation/op/Universal"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/op/CIC_2">
    <rdf:type rdf:resource="https://uor.foundation/op/Identity"/>
    <rdfs:label>CIC_2</rdfs:label>
    <rdfs:comment>Certificate issuance: every metric-preserving Transform admits an IsometryCertificate attesting distance preservation.</rdfs:comment>
    <uor:op/lhs rdf:resource="https://uor.foundation/schema/term_CIC_2_lhs"/>
    <uor:op/rhs rdf:resource="https://uor.foundation/schema/term_CIC_2_rhs"/>
