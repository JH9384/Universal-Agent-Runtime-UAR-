  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_9_rhs">
    <rdf:type rdf:resource="https://uor.foundation/schema/LiteralExpression"/>
    <rdfs:label>term_D_9_rhs</rdfs:label>
    <rdfs:comment></rdfs:comment>
    <uor:schema/literalValue>2</uor:schema/literalValue>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="https://uor.foundation/schema/term_D_9_forAll">
