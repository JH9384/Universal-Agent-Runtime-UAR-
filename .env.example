# UAR Environment Configuration

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1

# Environment
ENVIRONMENT=development
DEBUG=false

# Paths
PROJECT_ROOT=/path/to/project
UAR_LIBRARY_DIR=.uar_library

# Limits
UAR_MAX_UPLOAD_BYTES=52428800

# Security - IMPORTANT: Change this in production!
# Generate a new secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-must-be-changed-in-production

# API Keys (comma-separated, format: key:user:tier,key2:user2:tier2)
API_KEYS=dev_key:dev:admin

# CORS configuration (optional)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080  # Allowed CORS origins
CORS_ALLOW_CREDENTIALS=true          # Allow credentials in CORS requests
CORS_ALLOW_METHODS=*                # Allowed HTTP methods (* for all)
CORS_ALLOW_HEADERS=*                # Allowed HTTP headers (* for all)

# Logging
LOG_LEVEL=info

# Security & Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANONYMOUS=10
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_WINDOW=60

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Storage
RUNS_DIR=runs
MAX_FILE_SIZE=10485760  # 10MB in bytes
MAX_FILES=1000
MAX_REQUEST_SIZE=10485760  # 10MB

# Ollama integration (optional)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=60

# Autonomi decentralized storage (optional)
# WARNING: Autonomi is currently experimental for production use
# - Network stability issues may impact reliability
# - Data permanence not guaranteed until stable Autonomi 2.0 release
# - Python SDK has usability and concurrency issues
# - Consider adding fallback storage options for critical data
# Install: pip install autonomi
AUTONOMI_PRIVATE_KEY=0x...          # EVM wallet private key (hex)
AUTONOMI_NETWORK=testnet            # 'testnet' or 'mainnet'
AUTONOMI_TIMEOUT_SEC=300              # Upload/download timeout

# Atomic Language Model (ALM) Service Configuration
ALM_SERVICE_URL=http://localhost:5001/api/v1
ALM_TIMEOUT_SEC=30

# GraphRAG size limits (optional)
GRAPHRAG_MAX_NODES=10000          # Maximum nodes in knowledge graph
GRAPHRAG_MAX_EDGES=50000          # Maximum edges in knowledge graph
GRAPHRAG_MAX_ENTITY_LIMIT=5000   # Maximum entity extraction limit

# Retry policy (optional)
UAR_MAX_RETRIES=2                 # Default max retries for skill execution

# OpenTelemetry tracing (optional)
# Install: pip install opentelemetry-api opentelemetry-sdk opentelemetry-exporter-otlp
OTEL_ENABLED=false                 # Enable/disable OpenTelemetry tracing
OTEL_SERVICE_NAME=uar-api         # Service name for tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # OTLP exporter endpoint

# Streaming backpressure (optional)
BACKPRESSURE_ENABLED=true          # Enable backpressure handling in streaming
BACKPRESSURE_THRESHOLD=100         # Max buffered events before triggering backpressure
BACKPRESSURE_DELAY=0.1             # Delay in seconds when backpressure triggered

# Monitoring (optional)
METRICS_ENABLED=true
METRICS_PORT=9090

# Future:
# DATABASE_URL=
# REDIS_URL=

# Production Deployment Notes:
# 1. Always set a custom SECRET_KEY in production
# 2. Generate new API_KEYS - never use default/development keys
# 3. Set ENVIRONMENT=production
# 4. Set DEBUG=false
# 5. Configure proper CORS_ORIGINS for your domain
# 6. Consider using Redis for rate limiting in high-traffic scenarios
